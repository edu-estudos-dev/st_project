<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    margin-top: 1.5rem;
    padding: 3.25rem 1rem 2.35rem;
    background:
      radial-gradient(circle at 18% 8%,
        rgba(37, 99, 235, 0.16),
        transparent 28%),
      radial-gradient(circle at 86% 86%,
        rgba(34, 197, 94, 0.1),
        transparent 26%),
      linear-gradient(135deg, #071225 0%, #0d2a56 100%);
    color: #e5edf8;
  }

  .site-footer::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg,
        rgba(255, 255, 255, 0.045) 0%,
        transparent 30%);
  }

  .site-footer::after {
    content: '';
    position: absolute;
    top: 1.35rem;
    left: 50%;
    z-index: 2;
    width: min(1040px, calc(100% - 2rem));
    height: 1px;
    transform: translateX(-50%);
    background: linear-gradient(90deg,
        transparent 0%,
        rgba(148, 163, 184, 0.26) 12%,
        rgba(219, 234, 254, 0.42) 50%,
        rgba(148, 163, 184, 0.26) 88%,
        transparent 100%);
    pointer-events: none;
  }

  .site-footer-inner {
    position: relative;
    z-index: 1;
    width: min(1180px, 100%);
    margin: 0 auto;
  }

  .site-footer-main {
    display: grid;
    grid-template-columns:
      minmax(220px, 0.85fr) minmax(500px, 1.3fr) minmax(240px, 0.85fr);
    gap: 1.75rem;
    align-items: start;
  }

  .site-footer-brand {
    min-width: 0;
    text-align: left;
  }

  .site-footer-links {
    min-width: 0;
    text-align: center;
  }

  .site-footer-contact {
    min-width: 0;
    text-align: right;
  }

  .brand-mark-footer {
    display: inline-flex;
    align-items: baseline;
    justify-content: flex-start;
    color: inherit;
    font-size: 1.7rem;
    font-weight: 950;
    line-height: 1;
    letter-spacing: -0.06em;
    text-decoration: none;
  }

  .brand-mark-primary {
    color: #2563eb;
  }

  .brand-mark-accent {
    color: #22c55e;
  }

  .site-footer .footer-title {
    display: block;
    margin: 0 0 0.82rem;
    color: #f8fafc;
    font-size: 0.98rem;
    font-weight: 950;
    line-height: 1.2;
  }

  .site-footer .footer-small-title {
    margin: 0.9rem 0 0;
    color: #f8fafc;
    font-size: 0.92rem;
    font-weight: 850;
    line-height: 1.45;
  }

  .site-footer .footer-small-text {
    margin: 0.38rem 0 0;
    color: #cbd5e1;
    font-size: 0.88rem;
    font-weight: 650;
    line-height: 1.48;
  }

  .footer-links-list {
    width: 100%;
    max-width: none;
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    gap: 0.95rem;
    list-style: none;
  }

  .footer-links-list li {
    margin: 0;
    padding: 0;
    line-height: 1;
  }

  .site-footer a {
    color: #dbeafe;
    text-decoration: none;
    transition:
      color 220ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 220ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-footer a:hover {
    color: #22c55e;
  }

  .footer-links-list a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #dbeafe;
    font-size: 0.88rem;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  .footer-links-list a:hover {
    transform: translateY(-1px);
    color: #22c55e;
  }

  .footer-email {
    margin-top: 1rem;
  }

  .footer-email-label,
  .footer-phone-label {
    display: block;
    margin: 0 0 0.35rem;
    color: #cbd5e1;
    font-size: 0.84rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .footer-email-link,
  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    color: #c7f9dc !important;
    font-size: 0.95rem;
    font-weight: 900;
    line-height: 1.2;
  }

  .footer-email-link:hover,
  .footer-contact-link:hover {
    color: #22c55e !important;
    transform: translateY(-1px);
  }

  .footer-whatsapp-icon {
    width: 18px;
    height: 18px;
    flex: 0 0 18px;
    color: currentColor;
  }

  .site-footer-divider {
    position: relative;
    z-index: 1;
    width: min(620px, 72%);
    height: 1px;
    margin: 1.85rem auto 0;
    background: linear-gradient(90deg,
        transparent 0%,
        rgba(148, 163, 184, 0.2) 50%,
        transparent 100%);
  }

  @media (max-width: 991.98px) {
    .site-footer {
      padding: 3rem 1rem 2.25rem;
    }

    .site-footer::after {
      top: 1.25rem;
      width: min(720px, calc(100% - 2rem));
    }

    .site-footer-main {
      grid-template-columns: 1fr;
      gap: 1.55rem;
      align-items: center;
    }

    .site-footer-brand,
    .site-footer-links,
    .site-footer-contact {
      text-align: center;
    }

    .brand-mark-footer {
      justify-content: center;
    }

    .footer-links-list {
      max-width: 420px;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.72rem 1rem;
    }

    .footer-email {
      margin-top: 0.95rem;
    }
  }

  @media (max-width: 575.98px) {
    .site-footer {
      margin-top: 1.25rem;
      padding: 2.65rem 0.9rem 2.25rem;
    }

    .site-footer::after {
      top: 0.95rem;
      width: min(320px, calc(100% - 1.5rem));
    }

    .site-footer-main {
      gap: 0.95rem;
    }

    .brand-mark-footer {
      font-size: 1.52rem;
    }

    .site-footer .footer-small-title {
      max-width: 22ch;
      margin: 0.7rem auto 0;
      font-size: 0.9rem;
      line-height: 1.42;
    }

    .site-footer .footer-small-text {
      margin-top: 0.3rem;
      font-size: 0.86rem;
      line-height: 1.42;
    }

    .site-footer .footer-title {
      margin-bottom: 0.58rem;
      font-size: 0.94rem;
    }

    .footer-links-list {
      max-width: 280px;
      display: grid;
      grid-template-columns: repeat(2, minmax(88px, auto));
      justify-content: center;
      gap: 0.54rem 1rem;
    }

    .footer-links-list a {
      font-size: 0.86rem;
    }

    .footer-email {
      margin-top: 0.68rem;
    }

    .footer-email-link,
    .footer-contact-link {
      font-size: 0.9rem;
    }

    .footer-phone-label,
    .footer-email-label {
      margin-bottom: 0.28rem;
      font-size: 0.8rem;
    }

    .site-footer-divider {
      display: none;
    }
  }
</style>

