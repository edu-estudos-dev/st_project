<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    margin-top: 1.5rem;
    padding: 2.75rem 1rem 2.05rem;
    background:
      radial-gradient(circle at 18% 8%,
        rgba(37, 99, 235, 0.16),
        transparent 28%),
      radial-gradient(circle at 86% 86%,
        rgba(34, 197, 94, 0.1),
        transparent 26%),
      linear-gradient(135deg, #071225 0%, #0d2a56 100%);
    color: #e5edf8;
  }

  .site-footer::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg,
        rgba(255, 255, 255, 0.045) 0%,
        transparent 30%);
  }

  .site-footer::after {
    content: '';
    position: absolute;
    top: 1.35rem;
    left: 50%;
    z-index: 2;
    width: min(1080px, calc(100% - 2rem));
    height: 1px;
    transform: translateX(-50%);
    background: linear-gradient(90deg,
        transparent 0%,
        rgba(148, 163, 184, 0.24) 10%,
        rgba(219, 234, 254, 0.58) 50%,
        rgba(148, 163, 184, 0.24) 90%,
        transparent 100%);
    box-shadow: 0 0 18px rgba(96, 165, 250, 0.18);
    pointer-events: none;
  }

  .site-footer-inner {
    position: relative;
    z-index: 1;
    width: min(1180px, 100%);
    margin: 0 auto;
  }

  .site-footer-main {
    display: grid;
    grid-template-columns:
      minmax(240px, 0.95fr) minmax(420px, 1.25fr) minmax(240px, 0.9fr);
    gap: 2rem;
    align-items: start;
  }

  .site-footer-brand,
  .site-footer-links,
  .site-footer-contact {
    min-width: 0;
  }

  .site-footer-brand {
    text-align: left;
  }

  .site-footer-links {
    text-align: center;
  }

  .site-footer-contact {
    text-align: right;
  }

  .brand-mark-footer {
    display: inline-flex;
    align-items: baseline;
    justify-content: flex-start;
    color: inherit;
    font-size: 1.72rem;
    font-weight: 950;
    line-height: 1;
    letter-spacing: -0.06em;
    text-decoration: none;
  }

  .brand-mark-primary {
    color: #60a5fa;
  }

  .brand-mark-accent {
    color: #22c55e;
  }

  .site-footer .footer-title {
    display: block;
    margin: 0 0 0.85rem;
    color: #f8fafc;
    font-size: 0.98rem;
    font-weight: 950;
    line-height: 1.2;
  }

  .site-footer .footer-small-title {
    max-width: 30ch;
    margin: 0.85rem 0 0;
    color: #dbeafe;
    font-size: 0.91rem;
    font-weight: 750;
    line-height: 1.48;
  }

  .site-footer .footer-small-text {
    margin: 0.45rem 0 0;
    color: #cbd5e1;
    font-size: 0.86rem;
    font-weight: 650;
    line-height: 1.48;
  }

  .footer-links-list {
    width: 100%;
    max-width: 540px;
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.7rem 1.05rem;
    list-style: none;
  }

  .footer-links-list li {
    margin: 0;
    padding: 0;
    line-height: 1;
  }

  .site-footer a {
    color: #dbeafe;
    text-decoration: none;
    transition:
      color 220ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 220ms cubic-bezier(0.22, 1, 0.36, 1),
      transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .site-footer a:hover {
    color: #22c55e;
  }

  .footer-links-list a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #dbeafe;
    font-size: 0.88rem;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  .footer-links-list a:hover {
    transform: translateY(-1px);
    color: #22c55e;
  }

  .footer-contact-card {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.45rem;
  }

  .footer-contact-label {
    display: block;
    color: #cbd5e1;
    font-size: 0.84rem;
    font-weight: 800;
    line-height: 1.25;
  }

  .footer-email {
    margin-top: 0.95rem;
  }

  .footer-email-label {
    display: block;
    margin: 0 0 0.32rem;
    color: #cbd5e1;
    font-size: 0.82rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .footer-email-link,
  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    color: #c7f9dc !important;
    font-size: 0.94rem;
    font-weight: 900;
    line-height: 1.2;
  }

  .footer-email-link:hover,
  .footer-contact-link:hover {
    color: #22c55e !important;
    transform: translateY(-1px);
  }

  .footer-whatsapp-icon {
    width: 18px;
    height: 18px;
    flex: 0 0 18px;
    color: currentColor;
  }

  .site-footer-divider {
    position: relative;
    z-index: 1;
    width: min(620px, 72%);
    height: 1px;
    margin: 1.7rem auto 0;
    background: linear-gradient(90deg,
        transparent 0%,
        rgba(148, 163, 184, 0.2) 50%,
        transparent 100%);
  }

  @media (max-width: 991.98px) {
    .site-footer {
      padding: 2.9rem 1rem 2.25rem;
    }

    .site-footer::after {
      top: 1.2rem;
      width: min(720px, calc(100% - 2rem));
    }

    .site-footer-main {
      grid-template-columns: 1fr;
      gap: 1.55rem;
      align-items: center;
    }

    .site-footer-brand,
    .site-footer-links,
    .site-footer-contact {
      text-align: center;
    }

    .brand-mark-footer {
      justify-content: center;
    }

    .site-footer .footer-small-title {
      margin-left: auto;
      margin-right: auto;
    }

    .footer-links-list {
      max-width: 430px;
      justify-content: center;
      gap: 0.72rem 1rem;
    }

    .footer-contact-card {
      align-items: center;
    }

    .footer-email {
      margin-top: 0.9rem;
    }
  }

  @media (max-width: 575.98px) {
  .site-footer {
    margin-top: 1.1rem;
    padding: 2.25rem 0.85rem 1.55rem;
  }

  .site-footer::after {
    top: 0.88rem;
    width: min(300px, calc(100% - 1.5rem));
  }

  .site-footer-inner {
    width: min(100%, 340px);
  }

  .site-footer-main {
    gap: 0.95rem;
  }

  .site-footer-brand,
  .site-footer-links,
  .site-footer-contact {
    width: 100%;
    text-align: center;
  }

  .brand-mark-footer {
    justify-content: center;
    font-size: 1.42rem;
