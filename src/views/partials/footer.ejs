    }

    .brand-mark-footer {
      font-size: 1.55rem;
    }

    .site-footer .footer-small-title {
      max-width: 22ch;
      margin-left: auto;
      margin-right: auto;
      font-size: 0.92rem;
      line-height: 1.45;
    }

    .site-footer .footer-small-text {
      font-size: 0.88rem;
    }

    .site-footer .footer-title {
      margin-bottom: 0.82rem;
      font-size: 0.96rem;
    }

    .footer-links-list {
      max-width: 270px;
      display: grid;
      grid-template-columns: repeat(2, minmax(88px, auto));
      justify-content: center;
      gap: 0.72rem 1.05rem;
    }

    .footer-links-list a {
      font-size: 0.88rem;
    }

    .footer-email {
      margin-top: 1rem;
    }

    .footer-email-link,
    .footer-contact-link {
      font-size: 0.92rem;
    }

    .footer-phone-label,
    .footer-email-label {
      font-size: 0.82rem;
    }

    .site-footer-divider {
      width: min(260px, 72%);
      margin-top: 1.65rem;
    }
  }
</style>

