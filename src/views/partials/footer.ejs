    color: #dbeafe;
    font-size: 0.84rem;
    font-weight: 750;
    line-height: 1.38;
  }

  .site-footer .footer-small-text {
    max-width: 28ch;
    margin: 0.28rem auto 0;
    color: rgba(203, 213, 225, 0.88);
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.36;
  }

  .site-footer .footer-title {
    margin-bottom: 0.58rem;
    color: #f8fafc;
    font-size: 0.92rem;
    font-weight: 950;
    line-height: 1.1;
  }

  .footer-links-list {
    width: 100%;
    max-width: 304px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.42rem;
  }

  .footer-links-list a {
    width: 100%;
    min-height: 34px;
    padding: 0.42rem 0.36rem;
    border-radius: 999px;
    color: #dbeafe;
    background: rgba(255, 255, 255, 0.055);
    border: 1px solid rgba(147, 197, 253, 0.14);
    font-size: 0.78rem;
    font-weight: 850;
    line-height: 1;
    white-space: nowrap;
  }

  .footer-links-list a:hover {
    color: #bbf7d0;
    background: rgba(34, 197, 94, 0.12);
    border-color: rgba(74, 222, 128, 0.26);
    transform: translateY(-1px);
  }

  .footer-email {
    width: min(100%, 304px);
    margin: 0.82rem auto 0;
    padding: 0.78rem 0.86rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.055);
    border: 1px solid rgba(147, 197, 253, 0.14);
  }

  .footer-email-label {
    margin: 0 0 0.28rem;
    color: rgba(203, 213, 225, 0.92);
    font-size: 0.76rem;
    font-weight: 850;
    line-height: 1.15;
  }

  .footer-email-link {
    max-width: 100%;
    color: #bbf7d0 !important;
    font-size: 0.84rem;
    font-weight: 950;
    line-height: 1.18;
    overflow-wrap: anywhere;
  }

  .site-footer-contact {
    width: min(100%, 304px);
    margin: 0 auto;
    padding: 0.78rem 0.86rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.055);
    border: 1px solid rgba(147, 197, 253, 0.14);
  }

  .footer-contact-card {
    width: 100%;
    align-items: center;
    gap: 0.32rem;
  }

  .footer-contact-label {
    color: rgba(203, 213, 225, 0.92);
    font-size: 0.76rem;
    font-weight: 850;
    line-height: 1.15;
  }

  .footer-contact-link {
    gap: 0.38rem;
    color: #bbf7d0 !important;
    font-size: 0.86rem;
    font-weight: 950;
    line-height: 1.18;
  }

  .footer-whatsapp-icon {
    width: 17px;
    height: 17px;
    flex: 0 0 17px;
  }

  .site-footer-divider {
    display: none;
  }
}

@media (max-width: 360px) {
  .footer-links-list {
    max-width: 270px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .footer-links-list a {
    min-height: 33px;
    font-size: 0.78rem;
  }

  .footer-email,
  .site-footer-contact {
    width: min(100%, 270px);
  }
}

</style>

