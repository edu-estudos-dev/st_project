<style>
  .site-footer {
    position: relative;
    overflow: hidden;
    margin-top: 0;
    padding: 2.8rem 1rem 2.5rem;
    background:
      radial-gradient(
        circle at 18% 8%,
        rgba(37, 99, 235, 0.18),
        transparent 28%
      ),
      radial-gradient(
        circle at 86% 86%,
        rgba(34, 197, 94, 0.12),
        transparent 26%
      ),
      linear-gradient(135deg, #071225 0%, #0f2f63 100%);
    color: #e5edf8;
  }

  .site-footer::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.05) 0%,
        transparent 28%
      );
  }

  .site-footer-inner {
    position: relative;
    z-index: 1;
    width: min(1120px, 100%);
    margin: 0 auto;
  }

  .site-footer-main {
    display: grid;
    grid-template-columns: minmax(240px, 0.9fr) minmax(440px, 1.25fr) minmax(240px, 0.9fr);
    gap: 2rem;
    align-items: center;
  }

  .site-footer-brand,
  .site-footer-links,
  .site-footer-contact {
    min-width: 0;
    text-align: center;
  }

  .brand-mark-footer {
    display: inline-flex;
    align-items: baseline;
    justify-content: center;
    color: inherit;
    font-size: 1.72rem;
    font-weight: 950;
    line-height: 1;
    letter-spacing: -0.06em;
    text-decoration: none;
  }

  .brand-mark-primary {
    color: #2563eb;
  }

  .brand-mark-accent {
    color: #22c55e;
  }

  .site-footer .footer-title {
    display: block;
    margin: 0 0 0.9rem;
    color: #f8fafc;
    font-size: 1rem;
    font-weight: 950;
    line-height: 1.2;
  }

  .site-footer .footer-small-title {
    margin: 1rem 0 0;
    color: #f8fafc;
    font-size: 0.95rem;
    font-weight: 850;
    line-height: 1.45;
  }

  .site-footer .footer-small-text {
    margin: 0.45rem 0 0;
    color: #cbd5e1;
    font-size: 0.92rem;
    font-weight: 650;
    line-height: 1.48;
  }

  .footer-links-list {
    width: 100%;
    max-width: none;
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    gap: 1.05rem;
    list-style: none;
  }

  .footer-links-list li {
    margin: 0;
    padding: 0;
    line-height: 1;
  }

  .site-footer a {
    color: #dbeafe;
    text-decoration: none;
    transition:
      color 0.25s ease,
      opacity 0.25s ease,
      transform 0.25s ease;
  }

  .site-footer a:hover {
    color: #22c55e;
  }

  .footer-links-list a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #dbeafe;
    font-size: 0.9rem;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  .footer-links-list a:hover {
    transform: translateY(-1px);
    color: #22c55e;
  }

  .footer-email {
    margin-top: 1.05rem;
  }

  .footer-email-label,
  .footer-phone-label {
    display: block;
    margin: 0 0 0.35rem;
    color: #cbd5e1;
    font-size: 0.86rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .footer-email-link,
  .footer-contact-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    color: #c7f9dc !important;
    font-size: 0.98rem;
    font-weight: 900;
    line-height: 1.2;
  }

  .footer-email-link:hover,
  .footer-contact-link:hover {
    color: #22c55e !important;
  }

  .footer-whatsapp-icon {
    width: 19px;
    height: 19px;
    flex: 0 0 19px;
    color: currentColor;
  }

  .site-footer-divider {
    position: relative;
    z-index: 1;
    width: min(520px, 72%);
    height: 1px;
    margin: 2rem auto 0;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(148, 163, 184, 0.28) 50%,
      transparent 100%
    );
  }

  @media (max-width: 991.98px) {
    .site-footer {
      padding: 2.7rem 1rem 2.4rem;
    }

    .site-footer-main {
      grid-template-columns: 1fr;
      gap: 1.65rem;
    }

    .footer-links-list {
      max-width: 340px;
      display: grid;
      grid-template-columns: repeat(3, auto);
      justify-content: center;
      gap: 0.72rem 1rem;
    }

    .footer-email {
      margin-top: 1rem;
    }
  }

  @media (max-width: 575.98px) {
    .site-footer {
      padding: 2.25rem 0.9rem 5.2rem;
    }

    .site-footer-main {
