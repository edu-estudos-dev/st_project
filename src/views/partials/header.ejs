            max-height: calc(100vh - 7rem);
        }

        .menu-group-label {
            font-size: 0.78rem;
        }

        .menu-link-text {
            font-size: 0.84rem;
        }

        .notification-drawer {
            width: 100vw;
            max-width: 100vw;
        }

        .notification-drawer-header {
            padding: 1rem;
        }

        .notification-drawer-header span {
            font-size: 0.8rem;
        }

        .notification-drawer-header h2 {
            font-size: 1.28rem;
        }

        .notification-drawer-item {
            grid-template-columns: auto minmax(0, 1fr);
            gap: 0.8rem;
            padding: 1rem;
        }

        .notification-drawer-time {
