<style>
    .dropdown-submenu {
        position: relative;
    }

    .dropdown-submenu .dropdown-menu {
        display: none;
        position: absolute;
        left: 100%;
        top: 0;
    }

    .dropdown-submenu.show > .dropdown-menu {
        display: block;
    }

    .dropdown-toggle::after {
        display: inline-block;
        width: 0;
        height: 0;
        margin-left: .255em;
        vertical-align: .255em;
        content: "";
        border-top: .3em solid;
        border-right: .3em solid transparent;
        border-bottom: 0;
        border-left: .3em solid transparent;
    }

    .dropdown-submenu.show > .dropdown-toggle::after {
        border-top: 0;
        border-bottom: .3em solid;
    }

    .menu-active {
        background-color: #dbeafe !important;
        color: #0f172a !important;
    }

    @media (min-width: 992px) {
        .dropdown-submenu:hover > .dropdown-menu {
            display: block;
        }
    }

    @media (max-width: 991.98px) {
        .navbar-toggler {
            border-color: rgba(15, 23, 42, 0.18);
        }

        .navbar-toggler:focus {
            box-shadow: 0 0 0 0.2rem rgba(191, 219, 254, 0.35);
        }

        .app-nav .container-fluid {
            padding: 0.7rem;
        }

        .navbar .dropdown-menu {
            margin-top: 0.35rem;
        }

        .dropdown-submenu .dropdown-menu {
            position: static !important;
            left: auto !important;
            top: auto !important;
            margin-top: 0.45rem;
            box-shadow: none;
            border: 0;
            padding-left: 0.75rem;
            background: transparent;
        }
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var submenuToggles = document.querySelectorAll('.submenu-toggle');

        submenuToggles.forEach(function (toggle) {
            toggle.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();
                var parent = this.closest('.dropdown-submenu');
                parent.classList.toggle('show');
                this.classList.toggle('menu-active');
            });
        });

        document.addEventListener('click', function (e) {
            if (!e.target.closest('.dropdown-submenu')) {
                document.querySelectorAll('.dropdown-submenu.show').forEach(function (submenu) {
                    submenu.classList.remove('show');
                });
                document.querySelectorAll('.submenu-toggle.menu-active').forEach(function (toggle) {
                    toggle.classList.remove('menu-active');
                });
            }
        });
    });
</script>
