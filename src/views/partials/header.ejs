    }

    .notification-drawer-footer {
        display: grid;
        gap: 0.65rem;
        padding: 1rem 1.35rem;
        border-top: 1px solid rgba(148, 163, 184, 0.24);
    }

    .notification-drawer-footer a,
    .notification-drawer-footer button {
        border: 0;
        background: transparent;
        color: #bfdbfe;
        font-weight: 900;
        text-align: center;
        text-decoration: none;
    }

    .notification-drawer-footer button {
