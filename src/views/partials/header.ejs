        .mobile-register-sheet.is-open {
            transform: translateY(0);
        }

        .mobile-register-sheet-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
        }

        .mobile-register-sheet-head span {
            color: #64748b;
            font-size: 0.72rem;
            font-weight: 900;
            letter-spacing: 0.08em;
            text-transform: uppercase;
        }

        .mobile-register-sheet-head h2 {
            margin: 0.1rem 0 0;
            font-size: 1.22rem;
            font-weight: 900;
        }

        .mobile-register-sheet-head button {
            display: inline-grid;
            place-items: center;
            width: 42px;
            height: 42px;
            border: 0;
            border-radius: 14px;
