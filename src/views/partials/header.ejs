        }

        .mobile-register-sheet-body a {
            display: grid;
            grid-template-columns: auto minmax(0, 1fr);
            align-items: center;
            gap: 0.8rem;
            min-height: 62px;
            padding: 0.75rem;
            border: 1px solid #dbe4ef;
