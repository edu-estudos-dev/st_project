        font-weight: 600;
        line-height: 1.35;
        white-space: normal;
    }

    .menu-link-button::after {
        align-self: center;
        margin-left: auto;
    }

    @media (min-width: 992px) {
        .app-nav .container-fluid {
            position: relative;
            gap: 1rem;
        }

        .app-primary-nav {
            position: static;
            flex: 1 1 auto;
            justify-content: center;
            z-index: 2;
            flex-wrap: nowrap;
