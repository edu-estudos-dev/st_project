    @media (max-width: 575.98px) {
        body:not(.dashboard-body) {
            padding-bottom: calc(78px + env(safe-area-inset-bottom, 0px));
        }

        .app-nav .container-fluid {
            gap: 0.45rem;
            padding: 0.62rem;
        }

        .app-nav-actions {
            display: grid;
            grid-template-columns: 1fr auto auto;
            gap: 0.5rem;
            margin-top: 0.62rem;
        }

        .app-nav-search {
            display: none;
        }

        .app-nav-search .form-control {
            min-height: 44px;
