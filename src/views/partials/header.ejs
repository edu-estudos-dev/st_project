        }

        .app-nav .container-fluid {
            padding: 0.7rem;
        }

        .app-nav-actions {
            width: 100%;
            margin-top: 0.75rem;
            margin-left: 0;
            align-items: stretch;
        }

        .app-nav-search {
            min-width: 0;
            flex: 1;
        }

        .app-primary-nav {
            position: static;
            transform: none;
        }

        .nav-account-dropdown {
            right: 0;
        }

        .navbar .dropdown-menu {
            margin-top: 0.35rem;
        }

        .menu-link {
