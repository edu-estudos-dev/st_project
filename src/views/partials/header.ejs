<div class="notification-drawer-backdrop" id="notificationDrawerBackdrop"></div>
<aside class="notification-drawer" id="notificationDrawer" aria-hidden="true">
    <div class="notification-drawer-header">
        <div>
            <span>Central</span>
            <h2>Alertas</h2>
        </div>
        <button type="button" id="notificationDrawerClose" aria-label="Fechar alertas">
            <i class="bi bi-x-lg"></i>
        </button>
    </div>
    <div class="notification-drawer-list">
        <% const notificationItems = [
            ...((financialNotifications?.atrasados || []).map((item) => ({ ...item, tone: 'danger', label: `${Math.abs(item.diffDays || 0)} dia(s) atrasado`, title: 'Vencimento atrasado' }))),
            ...((financialNotifications?.proximos || []).map((item) => ({ ...item, tone: 'warning', label: `${item.diffDays || 0} dia(s)`, title: 'Vencimento próximo' })))
        ]; %>
        <% if (notificationItems.length) { %>
            <% notificationItems.forEach((item) => { %>
                <a class="notification-drawer-item notification-drawer-item-<%= item.tone %>" href="/lancamentos/vencimentos">
                    <span class="notification-drawer-icon"><i class="bi bi-exclamation-circle"></i></span>
                    <span class="notification-drawer-copy">
                        <strong><%= item.title %></strong>
                        <small><%= item.descricao || item.tipo_de_lancamento || 'Lançamento financeiro' %></small>
                    </span>
                    <span class="notification-drawer-time"><%= item.label %></span>
                </a>
            <% }) %>
        <% } else { %>
            <div class="notification-drawer-empty">
                <i class="bi bi-check2-circle"></i>
                <strong>Nenhum alerta ativo</strong>
                <span>Vencimentos e avisos importantes aparecerão aqui.</span>
            </div>
        <% } %>
    </div>
    <a class="notification-drawer-footer" href="/lancamentos/vencimentos">Ver detalhes financeiros</a>
</aside>

