<style>
    .dropdown-submenu {
        position: relative;
    }

    .nav-item.dropdown > .dropdown-menu {
        display: none;
    }

    .nav-item.dropdown.show > .dropdown-menu {
        display: block;
    }

    .dropdown-submenu .dropdown-menu {
        display: none;
        position: absolute;
        left: 100%;
        top: 0;
    }

    .dropdown-submenu.show > .dropdown-menu {
        display: block;
    }

    .dropdown-toggle::after {
        display: inline-block;
        width: 0;
        height: 0;
        margin-left: .255em;
        vertical-align: .255em;
        content: "";
        border-top: .3em solid;
        border-right: .3em solid transparent;
        border-bottom: 0;
        border-left: .3em solid transparent;
    }

    .dropdown-submenu.show > .dropdown-toggle::after {
        border-top: 0;
        border-bottom: .3em solid;
    }

    .menu-active {
        background-color: #dbeafe !important;
        color: #0f172a !important;
    }

    .app-nav button.nav-link,
    .app-nav .submenu-toggle {
        width: 100%;
        background: transparent;
        border: 0;
        text-align: left;
    }

    .menu-group-label {
        padding: 0.45rem 0.9rem 0.3rem;
        font-size: 0.72rem;
        font-weight: 800;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #64748b;
    }

    .menu-link {
        display: flex !important;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.2rem;
        min-width: 260px;
    }

    .menu-link-title {
        font-size: 0.95rem;
        font-weight: 800;
        line-height: 1.2;
    }

    .menu-link-text {
        color: #64748b;
        font-size: 0.78rem;
        font-weight: 600;
        line-height: 1.35;
        white-space: normal;
    }

    .menu-link-button::after {
        align-self: center;
        margin-left: auto;
    }

    @media (min-width: 992px) {
        .dropdown-submenu:hover > .dropdown-menu {
            display: block;
        }
    }

    @media (max-width: 991.98px) {
        .navbar-toggler {
            border-color: rgba(15, 23, 42, 0.18);
        }

        .navbar-toggler:focus {
            box-shadow: 0 0 0 0.2rem rgba(191, 219, 254, 0.35);
        }

        .app-nav .container-fluid {
            padding: 0.7rem;
        }

        .navbar .dropdown-menu {
            margin-top: 0.35rem;
        }

        .menu-link {
            min-width: 100%;
        }

        .dropdown-submenu .dropdown-menu {
            position: static !important;
            left: auto !important;
            top: auto !important;
            margin-top: 0.45rem;
            box-shadow: none;
            border: 0;
            padding-left: 0.75rem;
            background: transparent;
        }
    }
</style>

<script>
    function initHeaderNavigation() {
        if (document.body.dataset.headerNavInitialized === 'true') return;
        document.body.dataset.headerNavInitialized = 'true';

        var topLevelToggles = document.querySelectorAll('.app-nav .nav-item.dropdown > .dropdown-toggle');
        var submenuToggles = document.querySelectorAll('.submenu-toggle');

        function closeNestedSubmenus(container) {
            if (!container) return;

            container.querySelectorAll('.dropdown-submenu.show').forEach(function (submenu) {
                submenu.classList.remove('show');
            });

            container.querySelectorAll('.submenu-toggle.menu-active').forEach(function (toggle) {
                toggle.classList.remove('menu-active');
                toggle.setAttribute('aria-expanded', 'false');
            });
        }

        function closeTopLevelMenus(exceptParent) {
            document.querySelectorAll('.app-nav .nav-item.dropdown.show').forEach(function (dropdown) {
                if (dropdown === exceptParent) return;

                dropdown.classList.remove('show');
                closeNestedSubmenus(dropdown);

                var toggle = dropdown.querySelector(':scope > .dropdown-toggle');
                if (toggle) {
                    toggle.classList.remove('show');
                    toggle.setAttribute('aria-expanded', 'false');
                }
            });
        }

        topLevelToggles.forEach(function (toggle) {
            toggle.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                var parent = this.closest('.nav-item.dropdown');
                var shouldOpen = !parent.classList.contains('show');

                closeTopLevelMenus(parent);

                parent.classList.toggle('show', shouldOpen);
                this.classList.toggle('show', shouldOpen);
                this.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');

                if (!shouldOpen) {
                    closeNestedSubmenus(parent);
                }
            });
        });

        submenuToggles.forEach(function (toggle) {
            toggle.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                var parent = this.closest('.dropdown-submenu');
                var shouldOpen = !parent.classList.contains('show');

                parent.parentElement.querySelectorAll(':scope > .dropdown-submenu.show').forEach(function (submenu) {
                    submenu.classList.remove('show');

                    var siblingToggle = submenu.querySelector(':scope > .submenu-toggle');
                    if (siblingToggle) {
                        siblingToggle.classList.remove('menu-active');
                        siblingToggle.setAttribute('aria-expanded', 'false');
                    }
                });

                parent.classList.toggle('show', shouldOpen);
                this.classList.toggle('menu-active', shouldOpen);
                this.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
            });
        });

        document.addEventListener('click', function (e) {
            if (!e.target.closest('.app-nav')) {
                closeTopLevelMenus();
            }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeTopLevelMenus();
            }
        });
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initHeaderNavigation);
    } else {
        initHeaderNavigation();
    }
</script>
