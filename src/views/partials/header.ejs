</style>

<script nonce="<%= cspNonce || '' %>">
    function initHeaderNavigation() {
        if (document.body.dataset.headerNavInitialized === 'true') return;
        document.body.dataset.headerNavInitialized = 'true';

        var topLevelToggles = document.querySelectorAll('.app-nav .nav-item.dropdown > .dropdown-toggle');
        var submenuToggles = document.querySelectorAll('.submenu-toggle');

        function closeNestedSubmenus(container) {
            if (!container) return;

            container.querySelectorAll('.dropdown-submenu.show').forEach(function (submenu) {
                submenu.classList.remove('show');
            });

            container.querySelectorAll('.submenu-toggle.menu-active').forEach(function (toggle) {
                toggle.classList.remove('menu-active');
                toggle.setAttribute('aria-expanded', 'false');
            });
        }

        function closeTopLevelMenus(exceptParent) {
            document.querySelectorAll('.app-nav .nav-item.dropdown.show').forEach(function (dropdown) {
                if (dropdown === exceptParent) return;

                dropdown.classList.remove('show');
                closeNestedSubmenus(dropdown);

                var toggle = dropdown.querySelector(':scope > .dropdown-toggle');
                if (toggle) {
                    toggle.classList.remove('show');
                    toggle.setAttribute('aria-expanded', 'false');
                }
            });
        }

        topLevelToggles.forEach(function (toggle) {
            toggle.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                var parent = this.closest('.nav-item.dropdown');
                var shouldOpen = !parent.classList.contains('show');

                closeTopLevelMenus(parent);

                parent.classList.toggle('show', shouldOpen);
                this.classList.toggle('show', shouldOpen);
                this.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');

                if (!shouldOpen) {
                    closeNestedSubmenus(parent);
                }
            });
        });

        submenuToggles.forEach(function (toggle) {
            toggle.addEventListener('click', function (e) {
                e.preventDefault();
                e.stopPropagation();

                var parent = this.closest('.dropdown-submenu');
                var shouldOpen = !parent.classList.contains('show');

                parent.parentElement.querySelectorAll(':scope > .dropdown-submenu.show').forEach(function (submenu) {
                    submenu.classList.remove('show');

                    var siblingToggle = submenu.querySelector(':scope > .submenu-toggle');
                    if (siblingToggle) {
                        siblingToggle.classList.remove('menu-active');
                        siblingToggle.setAttribute('aria-expanded', 'false');
                    }
                });

                parent.classList.toggle('show', shouldOpen);
                this.classList.toggle('menu-active', shouldOpen);
                this.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
            });
        });

        document.addEventListener('click', function (e) {
            if (!e.target.closest('.app-nav')) {
                closeTopLevelMenus();
            }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeTopLevelMenus();
                closeAccountMenu();
                closeNotificationDrawer();
                closeMobileRegisterSheet();
            }
        });

        var accountMenu = document.getElementById('accountMenu');
        var accountMenuToggle = document.getElementById('accountMenuToggle');
        var notificationOpen = document.getElementById('notificationDrawerOpen');
        var notificationClose = document.getElementById('notificationDrawerClose');
        var notificationBackdrop = document.getElementById('notificationDrawerBackdrop');
        var notificationDismissToday = document.getElementById('notificationDismissToday');
        var notificationList = document.querySelector('.notification-drawer-list');
        var notificationDismissKey = 'vendmaster-alerts-dismissed-date';
        var todayKey = new Date().toISOString().slice(0, 10);

        function markNotificationsDismissed() {
            window.localStorage.setItem(notificationDismissKey, todayKey);
            document.querySelectorAll('.nav-alert-badge').forEach(function (badge) {
                badge.remove();
            });

            if (notificationList) {
                notificationList.innerHTML = '<div class="notification-drawer-empty"><i class="bi bi-check2-circle"></i><strong>Alertas dispensados hoje</strong><span>Novos avisos voltam a aparecer amanhã.</span></div>';
            }

            closeNotificationDrawer();
        }

        if (window.localStorage.getItem(notificationDismissKey) === todayKey) {
            document.querySelectorAll('.nav-alert-badge').forEach(function (badge) {
                badge.remove();
            });

            if (notificationList) {
                notificationList.innerHTML = '<div class="notification-drawer-empty"><i class="bi bi-check2-circle"></i><strong>Alertas dispensados hoje</strong><span>Novos avisos voltam a aparecer amanhã.</span></div>';
            }
        }

        function closeAccountMenu() {
            var wrapper = accountMenuToggle?.closest('.nav-account-menu');
            if (!wrapper) return;
            wrapper.classList.remove('is-open');
            accountMenuToggle.setAttribute('aria-expanded', 'false');
        }

        function openNotificationDrawer() {
            document.body.classList.add('notification-drawer-open');
            document.getElementById('notificationDrawer')?.setAttribute('aria-hidden', 'false');
            closeAccountMenu();
            closeMobileRegisterSheet();
        }

        function closeNotificationDrawer() {
            document.body.classList.remove('notification-drawer-open');
            document.getElementById('notificationDrawer')?.setAttribute('aria-hidden', 'true');
        }

        var mobileRegisterOpen = document.getElementById('mobileRegisterOpen');
        var mobileRegisterClose = document.getElementById('mobileRegisterClose');
        var mobileRegisterSheet = document.getElementById('mobileRegisterSheet');
        var mobileRegisterBackdrop = document.getElementById('mobileRegisterBackdrop');
        var mobileMoreOpen = document.getElementById('mobileMoreOpen');

        function openMobileRegisterSheet() {
            closeTopLevelMenus();
            closeAccountMenu();
            closeNotificationDrawer();
            if (!mobileRegisterSheet || !mobileRegisterBackdrop) return;
            mobileRegisterBackdrop.hidden = false;
            mobileRegisterSheet.classList.add('is-open');
            mobileRegisterSheet.setAttribute('aria-hidden', 'false');
            mobileRegisterOpen?.setAttribute('aria-expanded', 'true');
        }

        function closeMobileRegisterSheet() {
            if (!mobileRegisterSheet || !mobileRegisterBackdrop) return;
            mobileRegisterSheet.classList.remove('is-open');
            mobileRegisterSheet.setAttribute('aria-hidden', 'true');
            mobileRegisterBackdrop.hidden = true;
            mobileRegisterOpen?.setAttribute('aria-expanded', 'false');
        }

        accountMenuToggle?.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            var wrapper = this.closest('.nav-account-menu');
            var shouldOpen = !wrapper.classList.contains('is-open');
            closeTopLevelMenus();
            closeNotificationDrawer();
            closeMobileRegisterSheet();
            wrapper.classList.toggle('is-open', shouldOpen);
            this.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
        });

        accountMenu?.addEventListener('click', function (e) {
            e.stopPropagation();
        });

        notificationOpen?.addEventListener('click', function (e) {
            e.preventDefault();
            openNotificationDrawer();
        });

        notificationClose?.addEventListener('click', closeNotificationDrawer);
        notificationBackdrop?.addEventListener('click', closeNotificationDrawer);
        notificationDismissToday?.addEventListener('click', markNotificationsDismissed);
        mobileRegisterOpen?.addEventListener('click', function (e) {
            e.preventDefault();
            openMobileRegisterSheet();
        });
        mobileRegisterClose?.addEventListener('click', closeMobileRegisterSheet);
        mobileRegisterBackdrop?.addEventListener('click', closeMobileRegisterSheet);
        mobileMoreOpen?.addEventListener('click', function (e) {
            e.preventDefault();
            accountMenuToggle?.click();
        });

        var currentPath = window.location.pathname;
        document.querySelectorAll('.app-mobile-bottom-nav a').forEach(function (link) {
            var href = link.getAttribute('href') || '';
            var isCurrent =
                (href === '/painel' && currentPath.startsWith('/painel')) ||
                (href === '/estabelecimentos' && currentPath.startsWith('/estabelecimentos')) ||
                (href === '/lancamentos' && (currentPath.startsWith('/lancamentos') || currentPath.startsWith('/fluxo-de-caixa')));

            link.classList.toggle('is-active', isCurrent);
        });

        document.addEventListener('click', closeAccountMenu);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initHeaderNavigation);
    } else {
        initHeaderNavigation();
    }
</script>
