<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken || '' %>">

    <% const pageTitle = typeof title !== 'undefined' && title ? title
        : 'VendMaster | Roteiro Inteligente para Máquinas Recreativas'; %>

    <% const pageDescription = typeof metaDescription !== 'undefined' && metaDescription ? metaDescription
        : 'Pare de improvisar a rota. O VendMaster organiza pontos, sangrias e financeiro para você sair sabendo onde coletar, sem planilha e sem achismo.'; %>

    <% const pageCanonical = typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl
        : 'https://vendmaster.com.br/'; %>

    <% const pageOgImage = typeof ogImage !== 'undefined' && ogImage ? ogImage
        : 'https://vendmaster.com.br/images/brand/og-image.png'; %>

    <!-- SEO PRINCIPAL -->
    <title><%= pageTitle %></title>
    <meta name="description" content="<%= pageDescription %>">
    <link rel="canonical" href="<%= pageCanonical %>">

    <% if (typeof robotsMeta !== 'undefined' && robotsMeta) { %>
        <meta name="robots" content="<%= robotsMeta %>">
    <% } %>

    <!-- PRELOAD DA IMAGEM PRINCIPAL DO LCP -->
    <% if (typeof preloadImage !== 'undefined' && preloadImage) { %>
        <link
            rel="preload"
            as="image"
            href="<%= preloadImage %>"
            fetchpriority="high"
        >
    <% } %>

    <!-- OPEN GRAPH / WHATSAPP / LINKEDIN -->
    <meta property="og:title" content="<%= pageTitle %>">
    <meta property="og:description" content="<%= pageDescription %>">
    <meta property="og:url" content="<%= pageCanonical %>">
    <meta property="og:image" content="<%= pageOgImage %>">
    <meta property="og:type" content="<%= typeof articleJsonLd !== 'undefined' && articleJsonLd ? 'article' : 'website' %>">
    <meta property="og:site_name" content="VendMaster">
    <meta property="og:locale" content="pt_BR">

    <!-- TWITTER -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= pageTitle %>">
    <meta name="twitter:description" content="<%= pageDescription %>">
    <meta name="twitter:image" content="<%= pageOgImage %>">

    <% if (typeof faqJsonLd !== 'undefined' && faqJsonLd) { %>
        <script type="application/ld+json"><%- JSON.stringify(faqJsonLd).replace(/</g, '\\u003c') %></script>
    <% } %>

    <% if (typeof articleJsonLd !== 'undefined' && articleJsonLd) { %>
        <script type="application/ld+json"><%- JSON.stringify(articleJsonLd).replace(/</g, '\\u003c') %></script>
    <% } %>

    <% if (typeof breadcrumbJsonLd !== 'undefined' && breadcrumbJsonLd) { %>
        <script type="application/ld+json"><%- JSON.stringify(breadcrumbJsonLd).replace(/</g, '\\u003c') %></script>
    <% } %>

    <% if (typeof collectionJsonLd !== 'undefined' && collectionJsonLd) { %>
        <script type="application/ld+json"><%- JSON.stringify(collectionJsonLd).replace(/</g, '\\u003c') %></script>
    <% } %>

    <% if (typeof offerCatalogJsonLd !== 'undefined' && offerCatalogJsonLd) { %>
        <script type="application/ld+json"><%- JSON.stringify(offerCatalogJsonLd).replace(/</g, '\\u003c') %></script>
    <% } %>

    <!-- FAVICONS / PWA - VENDMASTER -->
    <link rel="icon" href="/images/system/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/system/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/system/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="48x48" href="/images/system/favicon-48x48.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/images/system/favicon-96x96.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/images/system/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#052e7a">

    <!-- FONTES CRÍTICAS -->
    <link
        rel="preload"
        href="/vendor/fontsource/urbanist/files/urbanist-latin-400-normal.woff2"
        as="font"
        type="font/woff2"
        crossorigin
    >

    <link
        rel="preload"
        href="/vendor/fontsource/urbanist/files/urbanist-latin-700-normal.woff2"
        as="font"
        type="font/woff2"
        crossorigin
    >

    <style>
        @font-face {
            font-family: 'Urbanist';
            font-style: normal;
            font-display: swap;
            font-weight: 400;
            src: url('/vendor/fontsource/urbanist/files/urbanist-latin-400-normal.woff2') format('woff2');
        }

        @font-face {
            font-family: 'Urbanist';
            font-style: normal;
            font-display: swap;
            font-weight: 600;
            src: url('/vendor/fontsource/urbanist/files/urbanist-latin-600-normal.woff2') format('woff2');
        }

        @font-face {
            font-family: 'Urbanist';
            font-style: normal;
            font-display: swap;
            font-weight: 700;
            src: url('/vendor/fontsource/urbanist/files/urbanist-latin-700-normal.woff2') format('woff2');
        }

        @font-face {
            font-family: 'Urbanist';
            font-style: normal;
            font-display: swap;
            font-weight: 800;
            src: url('/vendor/fontsource/urbanist/files/urbanist-latin-800-normal.woff2') format('woff2');
        }
    </style>

    <!-- CSS DA APLICAÇÃO -->
    <% if (typeof disableBootstrap === 'undefined' || !disableBootstrap) { %>
        <link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css">
    <% } %>

    <% if (typeof skipGlobalStyles === 'undefined' || !skipGlobalStyles) { %>
        <link rel="stylesheet" href="<%= typeof assetPath !== 'undefined' ? assetPath('/css/styles.css') : '/css/styles.css' %>">

        <% const globalStyleModules = [
            '/css/lancamentos.css',
            '/css/fluxo-caixa.css',
            '/css/receitas.css',
            '/css/bolinhas.css',
            '/css/pelucias.css',
            '/css/consignados.css',
            '/css/estabelecimentos.css'
        ]; %>

        <% globalStyleModules.forEach((href) => { %>
            <link rel="stylesheet" href="<%= typeof assetPath !== 'undefined' ? assetPath(href) : href %>">
        <% }) %>
    <% } %>

    <% if (typeof extraStyles !== 'undefined' && extraStyles) { %>
        <% extraStyles.forEach((href) => { %>
            <% if (typeof preloadExtraStyles !== 'undefined' && preloadExtraStyles) { %>
                <link
                    rel="preload"
                    href="<%= typeof assetPath !== 'undefined' ? assetPath(href) : href %>"
                    as="style"
                    onload="this.onload=null;this.rel='stylesheet'"
                >

                <noscript>
                    <link rel="stylesheet" href="<%= typeof assetPath !== 'undefined' ? assetPath(href) : href %>">
                </noscript>
            <% } else { %>
                <link rel="stylesheet" href="<%= typeof assetPath !== 'undefined' ? assetPath(href) : href %>">
            <% } %>
        <% }) %>
    <% } %>

    <% if (typeof disableBootstrapIcons === 'undefined' || !disableBootstrapIcons) { %>
        <!-- ÍCONES BOOTSTRAP — CARREGAMENTO NÃO BLOQUEANTE -->
        <link
            rel="preload"
            href="/vendor/bootstrap-icons/bootstrap-icons.min.css"
            as="style"
            onload="this.onload=null;this.rel='stylesheet'"
        >

        <noscript>
            <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.min.css">
        </noscript>
    <% } %>

    <!-- SCRIPTS NÃO BLOQUEANTES -->
    <% if (typeof disableBootstrap === 'undefined' || !disableBootstrap) { %>
        <script defer src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <% } %>
    <% if (typeof disableInteractionScripts === 'undefined' || !disableInteractionScripts) { %>
        <script defer src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
        <script defer src="/js/appAlerts.js"></script>
        <script defer src="/js/csrf.js"></script>
    <% } %>

    <!-- MÁSCARA DE TELEFONE SEM BIBLIOTECA EXTERNA -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const phoneInputs = document.querySelectorAll('[data-phone-mask]');

            phoneInputs.forEach((phoneInput) => {
                phoneInput.setAttribute('inputmode', 'tel');
                phoneInput.setAttribute('autocomplete', 'tel');

                phoneInput.addEventListener('input', () => {
                    let value = phoneInput.value.replace(/\D/g, '').slice(0, 11);

                    if (value.length > 10) {
                        value = value.replace(/^(\d{2})(\d{5})(\d{0,4}).*/, '($1) $2-$3');
                    } else if (value.length > 6) {
                        value = value.replace(/^(\d{2})(\d{4})(\d{0,4}).*/, '($1) $2-$3');
                    } else if (value.length > 2) {
                        value = value.replace(/^(\d{2})(\d{0,5}).*/, '($1) $2');
                    } else if (value.length > 0) {
                        value = value.replace(/^(\d{0,2}).*/, '($1');
                    }

                    phoneInput.value = value;
                });
            });
        });
    </script>

    <!-- INPUT NUMBER CONTROL -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const numericInputs = document.querySelectorAll('.modern-form input[type="number"]:not([readonly]):not(:disabled)');

            numericInputs.forEach((input) => {
                const step = input.getAttribute('step');
                const allowsDecimal = step && step !== '1';

                input.addEventListener('wheel', (event) => {
                    if (document.activeElement === input) {
                        event.preventDefault();
                    }
                }, { passive: false });

                input.addEventListener('keydown', (event) => {
                    const allowedKeys = [
                        'Backspace',
                        'Delete',
                        'Tab',
                        'Escape',
                        'Enter',
                        'ArrowLeft',
                        'ArrowRight',
                        'Home',
                        'End'
                    ];

                    if (allowedKeys.includes(event.key) || event.ctrlKey || event.metaKey) return;
                    if (/^\d$/.test(event.key)) return;

                    if (allowsDecimal && (event.key === '.' || event.key === ',')) {
                        if (input.value.includes('.') || input.value.includes(',')) event.preventDefault();
                        return;
                    }

                    event.preventDefault();
                });

                input.addEventListener('input', () => {
                    let value = input.value;

                    if (allowsDecimal) {
                        value = value.replace(',', '.').replace(/[^\d.]/g, '');
                        const firstDotIndex = value.indexOf('.');

                        if (firstDotIndex !== -1) {
                            value = `${value.slice(0, firstDotIndex + 1)}${value.slice(firstDotIndex + 1).replace(/\./g, '')}`;
                        }
                    } else {
                        value = value.replace(/\D/g, '');
                    }

                    if (input.value !== value) input.value = value;
                });
            });
        });
    </script>

    <!-- MOBILE TABLE LABELS -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.modern-table').forEach((table) => {
                const headers = Array.from(table.querySelectorAll('thead th')).map((header) =>
                    header.textContent.trim()
                );

                if (!headers.length) return;

                table.querySelectorAll('tbody tr').forEach((row) => {
                    Array.from(row.children).forEach((cell, index) => {
                        if (cell.querySelector('.table-actions, .table-actions-launch')) {
                            cell.classList.add('mobile-table-actions-cell');
                        }
                        if (cell.hasAttribute('colspan') || cell.dataset.label) return;
                        cell.dataset.label = headers[index] || '';
                    });
                });
            });
        });
    </script>

    <!-- LOADING GLOBAL VENDMASTER -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.AppLoading) return;

            const ensureLoadingElement = () => {
                let overlay = document.querySelector('[data-vm-loading-overlay]');

                if (overlay) {
                    return overlay;
                }

                overlay = document.createElement('div');
                overlay.className = 'vm-loading-overlay';
                overlay.setAttribute('data-vm-loading-overlay', '');
                overlay.setAttribute('aria-hidden', 'true');
                overlay.setAttribute('data-vm-loading-compact', 'false');

                overlay.innerHTML = `
                    <div class="vm-loading-card" role="status" aria-live="polite" aria-atomic="true">
                        <div class="vm-loading-spinner" aria-hidden="true"></div>
                        <strong class="vm-loading-title" data-vm-loading-title>Carregando...</strong>
                        <span class="vm-loading-detail" data-vm-loading-detail>Aguarde um instante.</span>
                    </div>
                `;

                document.body.appendChild(overlay);

                return overlay;
            };

            window.AppLoading = {
                show(title = 'Carregando...', detail = 'Aguarde um instante.', options = {}) {
                    const overlay = ensureLoadingElement();
                    const titleElement = overlay.querySelector('[data-vm-loading-title]');
                    const detailElement = overlay.querySelector('[data-vm-loading-detail]');
                    const compact = Boolean(options.compact);

                    if (titleElement) {
                        titleElement.textContent = title;
                    }

                    if (detailElement) {
                        detailElement.textContent = detail;
                    }

                    overlay.setAttribute('data-vm-loading-compact', compact ? 'true' : 'false');
                    overlay.classList.add('is-visible');
                    overlay.setAttribute('aria-hidden', 'false');

                    document.documentElement.classList.add('vm-loading-lock');
                },

                hide() {
                    const overlay = document.querySelector('[data-vm-loading-overlay]');

                    if (!overlay) {
                        return;
                    }

                    overlay.classList.remove('is-visible');
                    overlay.setAttribute('aria-hidden', 'true');
                    document.documentElement.classList.remove('vm-loading-lock');
                },

                update(title = 'Carregando...', detail = 'Aguarde um instante.') {
                    const overlay = ensureLoadingElement();
                    const titleElement = overlay.querySelector('[data-vm-loading-title]');
                    const detailElement = overlay.querySelector('[data-vm-loading-detail]');

                    if (titleElement) {
                        titleElement.textContent = title;
                    }

                    if (detailElement) {
                        detailElement.textContent = detail;
                    }
                }
            };
        });
    </script>

    <!-- LOADING AUTOMATICO EM FORMULARIOS -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const getFormLoadingCopy = (form) => {
                const customTitle = form.dataset.loadingTitle;
                const customDetail = form.dataset.loadingDetail;

                if (customTitle || customDetail) {
                    return {
                        title: customTitle || 'Processando...',
                        detail: customDetail || 'Aguarde um instante.'
                    };
                }

                const action = String(form.getAttribute('action') || '').toLowerCase();
                const method = String(form.getAttribute('method') || 'GET').toUpperCase();

                if (action.includes('/login')) {
                    return {
                        title: 'Entrando...',
                        detail: 'Validando seus dados de acesso.'
                    };
                }

                if (action.includes('/logout')) {
                    return {
                        title: 'Saindo...',
                        detail: 'Encerrando sua sessão com segurança.'
                    };
                }

                if (action.includes('/register')) {
                    return {
                        title: 'Criando sua conta...',
                        detail: 'Preparando seu acesso ao VendMaster.'
                    };
                }

                if (action.includes('/recuperar-senha') || action.includes('/forgot-password')) {
                    return {
                        title: 'Enviando solicitação...',
                        detail: 'Verificando os dados para recuperação de senha.'
                    };
                }

                if (action.includes('/redefinir-senha') || action.includes('/reset-password')) {
                    return {
                        title: 'Redefinindo senha...',
                        detail: 'Atualizando sua nova senha com segurança.'
                    };
                }

                if (action.includes('/estabelecimentos')) {
                    return {
                        title: 'Salvando estabelecimento...',
                        detail: 'Registrando os dados do ponto.'
                    };
                }

                if (action.includes('/sangrias')) {
                    return {
                        title: 'Salvando sangria...',
                        detail: 'Registrando a visita e calculando os dados.'
                    };
                }

                if (action.includes('/lancamentos') && action.includes('/pagar')) {
                    return {
                        title: 'Marcando como pago...',
                        detail: 'Atualizando o vencimento financeiro.'
                    };
                }

                if (action.includes('/lancamentos')) {
                    return {
                        title: 'Salvando lançamento...',
                        detail: 'Atualizando os dados financeiros.'
                    };
                }

                if (action.includes('/assinatura/produtos')) {
                    return {
                        title: 'Salvando ferramentas...',
                        detail: 'Atualizando os produtos da sua assinatura.'
                    };
                }

                if (action.includes('/comunidade')) {
                    return {
                        title: 'Enviando publicação...',
                        detail: 'Salvando o conteúdo na Comunidade VendMaster.'
                    };
                }

                if (action.includes('/admin')) {
                    return {
                        title: 'Processando ação...',
                        detail: 'Atualizando os dados administrativos.'
                    };
                }

                if (method === 'GET') {
                    return {
                        title: 'Carregando...',
                        detail: 'Buscando as informações solicitadas.'
                    };
                }

                return {
                    title: 'Salvando...',
                    detail: 'Aguarde enquanto processamos sua solicitação.'
                };
            };

            document.querySelectorAll('form').forEach((form) => {
                if (form.dataset.loadingBound === 'true') return;
                if (form.dataset.noGlobalLoading === 'true') return;

                form.dataset.loadingBound = 'true';

                form.addEventListener('submit', () => {
                    if (form.dataset.noGlobalLoading === 'true') return;

                    const submitter = document.activeElement;

                    if (
                        submitter &&
                        submitter.matches('button, input[type="submit"]') &&
                        submitter.dataset.noGlobalLoading === 'true'
                    ) {
                        return;
                    }

                    window.setTimeout(() => {
                        const hasInvalidField = form.querySelector(':invalid');

                        if (hasInvalidField) {
                            return;
                        }

                        const copy = getFormLoadingCopy(form);
                        window.AppLoading?.show(copy.title, copy.detail);
                    }, 0);
                });
            });
        });
    </script>

        <!-- LOADING AUTOMATICO EM NAVEGACAO INTERNA -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const DEFAULT_NAVIGATION_LOADING_DELAY = 650;
            const HEAVY_NAVIGATION_LOADING_DELAY = 120;
            const NAVIGATION_LOADING_SAFETY_TIMEOUT = 8000;

            let navigationLoadingTimer = null;
            let navigationSafetyTimer = null;

            const clearNavigationLoadingTimers = () => {
                if (navigationLoadingTimer) {
                    window.clearTimeout(navigationLoadingTimer);
                    navigationLoadingTimer = null;
                }

                if (navigationSafetyTimer) {
                    window.clearTimeout(navigationSafetyTimer);
                    navigationSafetyTimer = null;
                }
            };

            const hideNavigationLoading = () => {
                clearNavigationLoadingTimers();
                window.AppLoading?.hide();
            };

            window.addEventListener('load', () => {
                hideNavigationLoading();
            });

            window.addEventListener('pageshow', () => {
                hideNavigationLoading();
            });

            window.addEventListener('pagehide', () => {
                clearNavigationLoadingTimers();
            });

            document.addEventListener('visibilitychange', () => {
                if (document.visibilityState === 'visible') {
                    hideNavigationLoading();
                }
            });

            const shouldIgnoreNavigationLoading = (link) => {
                if (!link) return true;

                const href = link.getAttribute('href');
                const linkText = String(link.textContent || '').trim().toLowerCase();

                if (!href) return true;
                if (href === '#') return true;
                if (href.startsWith('#')) return true;
                if (href.startsWith('javascript:')) return true;
                if (href.startsWith('mailto:')) return true;
                if (href.startsWith('tel:')) return true;
                if (href.startsWith('whatsapp:')) return true;

                if (link.hasAttribute('download')) return true;
                if (link.dataset.noGlobalLoading === 'true') return true;
                if (link.target && link.target !== '_self') return true;

                if (
                    linkText === 'fechar' ||
                    linkText.includes('fechar') ||
                    linkText.includes('agora não')
                ) {
                    return true;
                }

                if (
                    link.closest('footer') ||
                    link.closest('.site-footer')
                ) {
                    return true;
                }

                return false;
            };

            const isSamePageNavigation = (url) => {
                return (
                    url.origin === window.location.origin &&
                    url.pathname === window.location.pathname &&
                    url.search === window.location.search
                );
            };

            const isHeavyNavigation = (url) => {
                const path = `${url.pathname}${url.search}`.toLowerCase();

                return (
                    path.includes('/sangrias/add') ||
                    path.includes('/sangrias/edit') ||
                    path.includes('/rotas') ||
                    path.includes('/assinatura') ||
                    path.includes('/pagamentos') ||
                    path.includes('/estabelecimentos/add') ||
                    (path.includes('/estabelecimentos/') && path.includes('/edit'))
                );
            };

            const getNavigationLoadingDelay = (url) => {
                return isHeavyNavigation(url)
                    ? HEAVY_NAVIGATION_LOADING_DELAY
                    : DEFAULT_NAVIGATION_LOADING_DELAY;
            };

            const getNavigationLoadingCopy = (link, url) => {
                const customTitle = link.dataset.loadingTitle;
                const customDetail = link.dataset.loadingDetail;

                if (customTitle || customDetail) {
                    return {
                        title: customTitle || 'Carregando...',
                        detail: customDetail || 'Aguarde um instante.'
                    };
                }

                const path = `${url.pathname}${url.search}`.toLowerCase();
                const text = String(link.textContent || '').trim().toLowerCase();

                if (path.includes('/bolinhas/sangrias/add')) {
                    return {
                        title: 'Abrindo sangria de bolinhas...',
                        detail: 'Carregando o formulário da visita.'
                    };
                }

                if (path.includes('/consignados/sangrias/add')) {
                    return {
                        title: 'Abrindo sangria de consignados...',
                        detail: 'Carregando o formulário da visita.'
                    };
                }

                if (path.includes('/pelucias/sangrias/add')) {
                    return {
                        title: 'Abrindo sangria de pelúcias...',
                        detail: 'Carregando o formulário da visita.'
                    };
                }

                if (path.includes('/sangrias')) {
                    return {
                        title: 'Abrindo sangria...',
                        detail: 'Carregando os dados da operação.'
                    };
                }

                if (path.includes('/rotas')) {
                    return {
                        title: 'Abrindo rotas...',
                        detail: 'Carregando os pontos e a operação.'
                    };
                }

                if (path.includes('/estabelecimentos')) {
                    return {
                        title: 'Abrindo estabelecimentos...',
                        detail: 'Carregando os dados dos pontos.'
                    };
                }

                if (path.includes('/lancamentos') || path.includes('/fluxo-de-caixa')) {
                    return {
                        title: 'Abrindo financeiro...',
                        detail: 'Carregando os dados financeiros.'
                    };
                }

                if (path.includes('/assinatura') || path.includes('/pagamentos')) {
                    return {
                        title: 'Abrindo assinatura...',
                        detail: 'Carregando os dados da sua conta.'
                    };
                }

                if (path.includes('/comunidade')) {
                    return {
                        title: 'Abrindo comunidade...',
                        detail: 'Carregando os tópicos e respostas.'
                    };
                }

                if (text.includes('voltar') || text.includes('cancelar')) {
                    return {
                        title: 'Voltando...',
                        detail: 'Carregando a tela anterior.'
                    };
                }

                if (text.includes('visualizar')) {
                    return {
                        title: 'Abrindo detalhes...',
                        detail: 'Carregando as informações do registro.'
                    };
                }

                if (text.includes('editar')) {
                    return {
                        title: 'Abrindo edição...',
                        detail: 'Carregando os dados para alteração.'
                    };
                }

                return {
                    title: 'Carregando página...',
                    detail: 'Aguarde enquanto abrimos a próxima tela.'
                };
            };

            document.addEventListener('click', (event) => {
                const link = event.target.closest('a[href]');

                if (shouldIgnoreNavigationLoading(link)) {
                    return;
                }

                let url;

                try {
                    url = new URL(link.getAttribute('href'), window.location.origin);
                } catch (error) {
                    return;
                }

                if (url.origin !== window.location.origin) {
                    return;
                }

                if (isSamePageNavigation(url)) {
                    return;
                }

                clearNavigationLoadingTimers();

                const copy = getNavigationLoadingCopy(link, url);
                const delay = getNavigationLoadingDelay(url);

                navigationLoadingTimer = window.setTimeout(() => {
                    window.AppLoading?.show(copy.title, copy.detail);

                    navigationSafetyTimer = window.setTimeout(() => {
                        window.AppLoading?.hide();
                    }, NAVIGATION_LOADING_SAFETY_TIMEOUT);
                }, delay);
            });
        });
    </script>

    <!-- MODAL GLOBAL DE RECIBO DE SANGRIA -->
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const urlParams = new URLSearchParams(window.location.search);
            const reciboUrl = urlParams.get('recibo_url');

            if (!reciboUrl) return;

            if (window.VendMasterPageHandlesRecibo) return;

            const storageKey = `vendmaster-recibo-modal:${reciboUrl}`;

            if (sessionStorage.getItem(storageKey)) return;

            sessionStorage.setItem(storageKey, 'shown');

            const getReciboFileName = (url) => {
                try {
                    const parsedUrl = new URL(url, window.location.origin);
                    const parts = parsedUrl.pathname.split('/').filter(Boolean);
                    const reciboId = parts[parts.length - 1] || 'recibo';

                    if (parsedUrl.pathname.includes('/consignados/')) {
                        return `recibo-consignados-${reciboId}.pdf`;
                    }

                    if (parsedUrl.pathname.includes('/pelucias/')) {
                        return `recibo-pelucias-${reciboId}.pdf`;
                    }

                    if (parsedUrl.pathname.includes('/bolinhas/')) {
                        return `recibo-bolinhas-${reciboId}.pdf`;
                    }

                    return `recibo-vendmaster-${reciboId}.pdf`;
                } catch (error) {
                    return 'recibo-vendmaster.pdf';
                }
            };

            const shareReciboPdf = async (url) => {
                const absoluteUrl = new URL(url, window.location.origin).href;

                const response = await fetch(absoluteUrl, {
                    credentials: 'same-origin'
                });

                if (!response.ok) {
                    throw new Error('Não foi possível gerar o arquivo do recibo para compartilhamento.');
                }

                const blob = await response.blob();
                const file = new File([blob], getReciboFileName(url), {
                    type: 'application/pdf'
                });

                if (navigator.canShare && navigator.canShare({ files: [file] })) {
                    await navigator.share({
                        title: 'Recibo VendMaster',
                        text: 'Segue o recibo da visita.',
                        files: [file]
                    });

                    return true;
                }

                return false;
            };

            const openReciboUrl = async (url) => {
                const isMobile =
                    window.matchMedia('(max-width: 767.98px)').matches ||
                    /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);

                if (isMobile) {
                    try {
                        window.AppLoading?.show(
                            'Preparando recibo...',
                            'Gerando o PDF para abrir ou compartilhar.'
                        );

                        const shared = await shareReciboPdf(url);

                        window.AppLoading?.hide();

                        if (shared) {
                            return;
                        }
                    } catch (error) {
                        window.AppLoading?.hide();

                        if (error?.name === 'AbortError') {
                            return;
                        }

                        console.error('Erro ao compartilhar recibo:', error);
                        window.AppAlerts?.warning('Não foi possível abrir o compartilhamento automático. O recibo será aberto na tela para você compartilhar manualmente.');
                    }

                    window.AppLoading?.show(
                        'Abrindo recibo...',
                        'Carregando o PDF na tela.'
                    );

                    window.location.href = url;
                    return;
                }

                window.AppLoading?.show(
                    'Abrindo recibo...',
                    'Preparando o PDF em uma nova aba.'
                );

                const openedWindow = window.open(url, '_blank', 'noopener,noreferrer');

                window.setTimeout(() => {
                    window.AppLoading?.hide();

                    if (!openedWindow) {
                        window.AppAlerts?.warning('Não foi possível abrir o recibo em uma nova aba. Verifique se o navegador bloqueou janelas pop-up do VendMaster.');
                    }
                }, 600);
            };

            const abrirRecibo = async () => {
                if (window.AppAlerts?.confirm) {
                    return await window.AppAlerts.confirm({
                        title: 'Gerar recibo em PDF?',
                        text: 'A sangria foi registrada com sucesso. Deseja gerar um recibo em PDF para entregar ao comerciante?',
                        confirmButtonText: 'Gerar recibo',
                        cancelButtonText: 'Agora não'
                    });
                }

                return window.confirm(
                    'A sangria foi registrada com sucesso. Deseja gerar um recibo em PDF para entregar ao comerciante?'
                );
            };

            const confirmed = await abrirRecibo();

            if (confirmed) {
                await openReciboUrl(reciboUrl);
            }
        });
    </script>
</head>
