<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken || '' %>">

    <% const pageTitle = typeof title !== 'undefined' && title ? title
        : 'VendMaster | Roteiro Inteligente para Máquinas Recreativas'; %>

    <% const pageDescription = typeof metaDescription !== 'undefined' && metaDescription ? metaDescription
        : 'Pare de improvisar a rota. O VendMaster organiza pontos, sangrias e financeiro para você sair sabendo onde coletar, sem planilha e sem achismo.'; %>

    <% const pageCanonical = typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl
        : 'https://vendmaster.com.br/'; %>

    <% const pageOgImage = typeof ogImage !== 'undefined' && ogImage ? ogImage
        : 'https://vendmaster.com.br/images/brand/og-image.png'; %>

    <!-- SEO PRINCIPAL -->
    <title><%= pageTitle %></title>
    <meta name="description" content="<%= pageDescription %>">
    <link rel="canonical" href="<%= pageCanonical %>">

    <% if (typeof robotsMeta !== 'undefined' && robotsMeta) { %>
        <meta name="robots" content="<%= robotsMeta %>">
    <% } %>

    <!-- PRELOAD DA IMAGEM PRINCIPAL DO LCP -->
    <% if (typeof preloadImage !== 'undefined' && preloadImage) { %>
        <link
            rel="preload"
            as="image"
            href="<%= preloadImage %>"
            fetchpriority="high"
        >
    <% } %>

    <!-- OPEN GRAPH / WHATSAPP / LINKEDIN -->
    <meta property="og:title" content="<%= pageTitle %>">
    <meta property="og:description" content="<%= pageDescription %>">
    <meta property="og:url" content="<%= pageCanonical %>">
    <meta property="og:image" content="<%= pageOgImage %>">
    <meta property="og:type" content="<%= typeof articleJsonLd !== 'undefined' && articleJsonLd ? 'article' : 'website' %>">
    <meta property="og:site_name" content="VendMaster">
    <meta property="og:locale" content="pt_BR">

    <!-- TWITTER -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= pageTitle %>">
    <meta name="twitter:description" content="<%= pageDescription %>">
    <meta name="twitter:image" content="<%= pageOgImage %>">

    <% if (typeof faqJsonLd !== 'undefined' && faqJsonLd) { %>
        <script type="application/ld+json"><%- JSON.stringify(faqJsonLd).replace(/</g, '\\u003c') %></script>
    <% } %>

    <% if (typeof articleJsonLd !== 'undefined' && articleJsonLd) { %>
        <script type="application/ld+json"><%- JSON.stringify(articleJsonLd).replace(/</g, '\\u003c') %></script>
    <% } %>

    <% if (typeof breadcrumbJsonLd !== 'undefined' && breadcrumbJsonLd) { %>
        <script type="application/ld+json"><%- JSON.stringify(breadcrumbJsonLd).replace(/</g, '\\u003c') %></script>
    <% } %>

    <% if (typeof collectionJsonLd !== 'undefined' && collectionJsonLd) { %>
        <script type="application/ld+json"><%- JSON.stringify(collectionJsonLd).replace(/</g, '\\u003c') %></script>
    <% } %>

    <% if (typeof offerCatalogJsonLd !== 'undefined' && offerCatalogJsonLd) { %>
        <script type="application/ld+json"><%- JSON.stringify(offerCatalogJsonLd).replace(/</g, '\\u003c') %></script>
    <% } %>

    <!-- FAVICONS / PWA - VENDMASTER -->
    <link rel="icon" href="/images/system/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/system/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/images/system/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="48x48" href="/images/system/favicon-48x48.png">
    <link rel="icon" type="image/png" sizes="96x96" href="/images/system/favicon-96x96.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/images/system/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#052e7a">

    <!-- FONTES CRÍTICAS -->
    <link
        rel="preload"
        href="/vendor/fontsource/urbanist/files/urbanist-latin-400-normal.woff2"
        as="font"
        type="font/woff2"
        crossorigin
    >

    <link
        rel="preload"
        href="/vendor/fontsource/urbanist/files/urbanist-latin-700-normal.woff2"
        as="font"
        type="font/woff2"
        crossorigin
    >

    <style>
        @font-face {
            font-family: 'Urbanist';
            font-style: normal;
            font-display: swap;
            font-weight: 400;
            src: url('/vendor/fontsource/urbanist/files/urbanist-latin-400-normal.woff2') format('woff2');
        }

        @font-face {
            font-family: 'Urbanist';
            font-style: normal;
            font-display: swap;
            font-weight: 600;
            src: url('/vendor/fontsource/urbanist/files/urbanist-latin-600-normal.woff2') format('woff2');
        }

        @font-face {
            font-family: 'Urbanist';
            font-style: normal;
            font-display: swap;
            font-weight: 700;
            src: url('/vendor/fontsource/urbanist/files/urbanist-latin-700-normal.woff2') format('woff2');
        }

        @font-face {
            font-family: 'Urbanist';
            font-style: normal;
            font-display: swap;
            font-weight: 800;
            src: url('/vendor/fontsource/urbanist/files/urbanist-latin-800-normal.woff2') format('woff2');
        }
    </style>

    <!-- CSS DA APLICAÇÃO -->
    <% if (typeof disableBootstrap === 'undefined' || !disableBootstrap) { %>
        <link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css">
    <% } %>

    <% if (typeof skipGlobalStyles === 'undefined' || !skipGlobalStyles) { %>
        <link rel="stylesheet" href="<%= typeof assetPath !== 'undefined' ? assetPath('/css/styles.css') : '/css/styles.css' %>">
    <% } %>

    <% if (typeof extraStyles !== 'undefined' && extraStyles) { %>
        <% extraStyles.forEach((href) => { %>
            <% if (typeof preloadExtraStyles !== 'undefined' && preloadExtraStyles) { %>
                <link
                    rel="preload"
                    href="<%= typeof assetPath !== 'undefined' ? assetPath(href) : href %>"
                    as="style"
                    onload="this.onload=null;this.rel='stylesheet'"
                >

                <noscript>
                    <link rel="stylesheet" href="<%= typeof assetPath !== 'undefined' ? assetPath(href) : href %>">
                </noscript>
            <% } else { %>
                <link rel="stylesheet" href="<%= typeof assetPath !== 'undefined' ? assetPath(href) : href %>">
            <% } %>
        <% }) %>
    <% } %>

    <% if (typeof disableBootstrapIcons === 'undefined' || !disableBootstrapIcons) { %>
        <!-- ÍCONES BOOTSTRAP — CARREGAMENTO NÃO BLOQUEANTE -->
        <link
            rel="preload"
            href="/vendor/bootstrap-icons/bootstrap-icons.min.css"
            as="style"
            onload="this.onload=null;this.rel='stylesheet'"
        >

        <noscript>
            <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.min.css">
        </noscript>
    <% } %>

    <!-- SCRIPTS NÃO BLOQUEANTES -->
    <% if (typeof disableBootstrap === 'undefined' || !disableBootstrap) { %>
        <script defer src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <% } %>
    <% if (typeof disableInteractionScripts === 'undefined' || !disableInteractionScripts) { %>
        <script defer src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
        <script defer src="/js/appAlerts.js"></script>
        <script defer src="/js/csrf.js"></script>
    <% } %>

    <!-- MÁSCARA DE TELEFONE SEM BIBLIOTECA EXTERNA -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const phoneInputs = document.querySelectorAll('[data-phone-mask]');

            phoneInputs.forEach((phoneInput) => {
                phoneInput.setAttribute('inputmode', 'tel');
                phoneInput.setAttribute('autocomplete', 'tel');

                phoneInput.addEventListener('input', () => {
                    let value = phoneInput.value.replace(/\D/g, '').slice(0, 11);

                    if (value.length > 10) {
                        value = value.replace(/^(\d{2})(\d{5})(\d{0,4}).*/, '($1) $2-$3');
                    } else if (value.length > 6) {
                        value = value.replace(/^(\d{2})(\d{4})(\d{0,4}).*/, '($1) $2-$3');
                    } else if (value.length > 2) {
                        value = value.replace(/^(\d{2})(\d{0,5}).*/, '($1) $2');
                    } else if (value.length > 0) {
                        value = value.replace(/^(\d{0,2}).*/, '($1');
                    }

                    phoneInput.value = value;
                });
            });
        });
    </script>

    <!-- INPUT NUMBER CONTROL -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const numericInputs = document.querySelectorAll('.modern-form input[type="number"]:not([readonly]):not(:disabled)');

            numericInputs.forEach((input) => {
                const step = input.getAttribute('step');
                const allowsDecimal = step && step !== '1';

                input.addEventListener('wheel', (event) => {
                    if (document.activeElement === input) {
                        event.preventDefault();
                    }
                }, { passive: false });

                input.addEventListener('keydown', (event) => {
                    const allowedKeys = [
                        'Backspace',
                        'Delete',
                        'Tab',
                        'Escape',
                        'Enter',
                        'ArrowLeft',
                        'ArrowRight',
                        'Home',
                        'End'
                    ];

                    if (allowedKeys.includes(event.key) || event.ctrlKey || event.metaKey) return;
                    if (/^\d$/.test(event.key)) return;

                    if (allowsDecimal && (event.key === '.' || event.key === ',')) {
                        if (input.value.includes('.') || input.value.includes(',')) event.preventDefault();
                        return;
                    }

                    event.preventDefault();
                });

                input.addEventListener('input', () => {
                    let value = input.value;

                    if (allowsDecimal) {
                        value = value.replace(',', '.').replace(/[^\d.]/g, '');
                        const firstDotIndex = value.indexOf('.');

                        if (firstDotIndex !== -1) {
                            value = `${value.slice(0, firstDotIndex + 1)}${value.slice(firstDotIndex + 1).replace(/\./g, '')}`;
                        }
                    } else {
                        value = value.replace(/\D/g, '');
                    }

                    if (input.value !== value) input.value = value;
                });
            });
        });
    </script>

    <!-- MOBILE TABLE LABELS -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.modern-table').forEach((table) => {
                const headers = Array.from(table.querySelectorAll('thead th')).map((header) =>
                    header.textContent.trim()
                );

                if (!headers.length) return;

                table.querySelectorAll('tbody tr').forEach((row) => {
                    Array.from(row.children).forEach((cell, index) => {
                        if (cell.querySelector('.table-actions, .table-actions-launch')) {
                            cell.classList.add('mobile-table-actions-cell');
                        }
                        if (cell.hasAttribute('colspan') || cell.dataset.label) return;
                        cell.dataset.label = headers[index] || '';
                    });
                });
            });
        });
    </script>

        <!-- LOADING GLOBAL VENDMASTER -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (window.AppLoading) return;

            const ensureLoadingElement = () => {
                let overlay = document.querySelector('[data-vm-loading-overlay]');

                if (overlay) {
                    return overlay;
                }

                overlay = document.createElement('div');
                overlay.className = 'vm-loading-overlay';
                overlay.setAttribute('data-vm-loading-overlay', '');
                overlay.setAttribute('aria-hidden', 'true');
                overlay.setAttribute('data-vm-loading-compact', 'false');

                overlay.innerHTML = `
                    <div class="vm-loading-card" role="status" aria-live="polite" aria-atomic="true">
                        <div class="vm-loading-spinner" aria-hidden="true"></div>
                        <strong class="vm-loading-title" data-vm-loading-title>Carregando...</strong>
                        <span class="vm-loading-detail" data-vm-loading-detail>Aguarde um instante.</span>
                    </div>
                `;

                document.body.appendChild(overlay);

                return overlay;
            };

            window.AppLoading = {
                show(title = 'Carregando...', detail = 'Aguarde um instante.', options = {}) {
                    const overlay = ensureLoadingElement();
                    const titleElement = overlay.querySelector('[data-vm-loading-title]');
                    const detailElement = overlay.querySelector('[data-vm-loading-detail]');
                    const compact = Boolean(options.compact);

                    if (titleElement) {
                        titleElement.textContent = title;
                    }

                    if (detailElement) {
                        detailElement.textContent = detail;
                    }

                    overlay.setAttribute('data-vm-loading-compact', compact ? 'true' : 'false');
                    overlay.classList.add('is-visible');
                    overlay.setAttribute('aria-hidden', 'false');

                    document.documentElement.classList.add('vm-loading-lock');
                },

                hide() {
                    const overlay = document.querySelector('[data-vm-loading-overlay]');

                    if (!overlay) {
                        return;
                    }

                    overlay.classList.remove('is-visible');
                    overlay.setAttribute('aria-hidden', 'true');
                    document.documentElement.classList.remove('vm-loading-lock');
                },

                update(title = 'Carregando...', detail = 'Aguarde um instante.') {
                    const overlay = ensureLoadingElement();
                    const titleElement = overlay.querySelector('[data-vm-loading-title]');
                    const detailElement = overlay.querySelector('[data-vm-loading-detail]');

                    if (titleElement) {
                        titleElement.textContent = title;
                    }

                    if (detailElement) {
                        detailElement.textContent = detail;
                    }
                }
            };
        });
    </script>

    <!-- MODAL GLOBAL DE RECIBO DE SANGRIA -->
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            const urlParams = new URLSearchParams(window.location.search);
            const reciboUrl = urlParams.get('recibo_url');

            if (!reciboUrl) return;

            if (window.VendMasterPageHandlesRecibo) return;

            const storageKey = `vendmaster-recibo-modal:${reciboUrl}`;

            if (sessionStorage.getItem(storageKey)) return;

            sessionStorage.setItem(storageKey, 'shown');

                const getReciboFileName = (url) => {
                    try {
                        const parsedUrl = new URL(url, window.location.origin);
                        const parts = parsedUrl.pathname.split('/').filter(Boolean);
                        const reciboId = parts[parts.length - 1] || 'recibo';

                        if (parsedUrl.pathname.includes('/consignados/')) {
                            return `recibo-consignados-${reciboId}.pdf`;
                        }

                        if (parsedUrl.pathname.includes('/pelucias/')) {
                            return `recibo-pelucias-${reciboId}.pdf`;
                        }

                        if (parsedUrl.pathname.includes('/bolinhas/')) {
                            return `recibo-bolinhas-${reciboId}.pdf`;
                        }

                        return `recibo-vendmaster-${reciboId}.pdf`;
                    } catch (error) {
                        return 'recibo-vendmaster.pdf';
                }
            };

            const shareReciboPdf = async (url) => {
                const absoluteUrl = new URL(url, window.location.origin).href;

                const response = await fetch(absoluteUrl, {
                    credentials: 'same-origin'
                });

                if (!response.ok) {
                    throw new Error('Não foi possível gerar o arquivo do recibo para compartilhamento.');
                }

                const blob = await response.blob();
                const file = new File([blob], getReciboFileName(url), {
                    type: 'application/pdf'
                });

                if (navigator.canShare && navigator.canShare({ files: [file] })) {
                    await navigator.share({
                        title: 'Recibo VendMaster',
                        text: 'Segue o recibo da visita.',
                        files: [file]
                    });

                    return true;
                }

                return false;
            };

            const openReciboUrl = async (url) => {
                const isMobile =
                    window.matchMedia('(max-width: 767.98px)').matches ||
                    /Android|iPhone|iPad|iPod/i.test(navigator.userAgent);

                if (isMobile) {
                    try {
                        const shared = await shareReciboPdf(url);

                        if (shared) {
                            return;
                        }
                    } catch (error) {
                        if (error?.name === 'AbortError') {
                            return;
                        }

                        console.error('Erro ao compartilhar recibo:', error);
                        window.AppAlerts?.warning('Não foi possível abrir o compartilhamento automático. O recibo será aberto na tela para você compartilhar manualmente.');
                    }

                    window.location.href = url;
                    return;
                }

                window.open(url, '_blank', 'noopener,noreferrer');
            };

            const abrirRecibo = async () => {
                if (window.AppAlerts?.confirm) {
                    return await window.AppAlerts.confirm({
                        title: 'Gerar recibo em PDF?',
                        text: 'A sangria foi registrada com sucesso. Deseja gerar um recibo em PDF para entregar ao comerciante?',
                        confirmButtonText: 'Gerar recibo',
                        cancelButtonText: 'Agora não'
                    });
                }

                return window.confirm(
                    'A sangria foi registrada com sucesso. Deseja gerar um recibo em PDF para entregar ao comerciante?'
                );
            };

            const confirmed = await abrirRecibo();

            if (confirmed) {
                await openReciboUrl(reciboUrl);
            }
        });
    </script>
</head>