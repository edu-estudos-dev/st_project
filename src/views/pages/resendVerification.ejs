<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken || '' %>">

    <title>Reenviar verificacao - VendMaster</title>
    <meta name="description" content="Reenvie o link de verificacao de e-mail da sua conta VendMaster.">
    <link rel="canonical" href="https://vendmaster.com.br/reenviar-verificacao">
    <meta name="robots" content="noindex, follow">

    <link rel="stylesheet" href="<%= typeof assetPath !== 'undefined' ? assetPath('/css/auth.css') : '/css/auth.css' %>">

    <script nonce="<%= cspNonce || '' %>" defer src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script nonce="<%= cspNonce || '' %>" defer src="/js/appAlerts.js"></script>
    <script nonce="<%= cspNonce || '' %>" defer src="/js/csrf.js"></script>
</head>

<body class="auth-body">
    <main class="auth-page">
        <section class="auth-brand-panel">
            <div class="auth-brand-content">
                <a href="/" class="auth-logo-link" aria-label="Voltar para a pagina inicial da VendMaster">
                    <img src="/images/logo.webp" alt="VendMaster" class="auth-logo-img">
                </a>

                <div class="auth-brand-copy">
                    <span class="auth-pill">Confirmacao de e-mail</span>
                    <h1>Reenvie o link de verificacao.</h1>
                    <p>
                        Informe o e-mail usado no cadastro para receber um novo link de confirmacao.
                    </p>
                </div>
            </div>
        </section>

        <section class="auth-form-panel">
            <div class="auth-card">
                <div class="auth-card-header">
                    <span class="auth-card-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 5h18v14H3V5zm2 2v.35l7 4.38 7-4.38V7H5zm14 10V9.7l-7 4.38L5 9.7V17h14z" />
                        </svg>
                    </span>

                    <div>
                        <h2>Reenviar verificacao</h2>
                        <p>O sistema so libera acesso depois que o e-mail for confirmado.</p>
                    </div>
                </div>

                <form action="/reenviar-verificacao" method="POST" class="auth-form" autocomplete="on">
                    <div class="auth-field">
                        <label for="email">E-mail cadastrado</label>

                        <div class="auth-input-wrap">
                            <span class="auth-input-icon">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M3 5h18v14H3V5zm2 2v.35l7 4.38 7-4.38V7H5zm14 10V9.7l-7 4.38L5 9.7V17h14z" />
                                </svg>
                            </span>

                            <input
                                type="email"
                                id="email"
                                name="email"
                                placeholder="Digite seu e-mail"
                                autocomplete="email"
                                value="<%= formData?.email || '' %>"
                                required
                            >
                        </div>
                    </div>

                    <button type="submit" class="auth-submit">
                        <span>Reenviar link</span>
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M13.3 5.3 20 12l-6.7 6.7-1.4-1.4 4.3-4.3H4v-2h12.2l-4.3-4.3 1.4-1.4z" />
                        </svg>
                    </button>
                </form>

                <% if (previewLink) { %>
                    <div class="auth-local-preview">
                        <strong>Ambiente local:</strong>
                        <span>Use este link para confirmar o e-mail.</span>
                        <a href="<%= previewLink %>"><%= previewLink %></a>
                    </div>
                <% } %>

                <p class="auth-register-text">
                    <a href="/login">Voltar para o login</a>
                </p>
            </div>
        </section>
    </main>

    <% if (success) { %>
        <script nonce="<%= cspNonce || '' %>">
            document.addEventListener('DOMContentLoaded', () => {
                window.AppAlerts?.success(<%- JSON.stringify(success) %>);
            });
        </script>
    <% } %>

    <% if (error) { %>
        <script nonce="<%= cspNonce || '' %>">
            document.addEventListener('DOMContentLoaded', () => {
                window.AppAlerts?.error(<%- JSON.stringify(error) %>, 'Falha no reenvio');
            });
        </script>
    <% } %>
</body>

</html>
