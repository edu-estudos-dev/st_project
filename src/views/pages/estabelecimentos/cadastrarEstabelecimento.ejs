<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Cadastrar Estabelecimento' }) %>

<body class="form-page-body">
    <%- include('../../partials/header') %>

    <div class="page-spacer"></div>

    <% const form = typeof formData !== 'undefined' && formData ? formData : {}; %>
    <% const selectedProducts = Array.isArray(form.produto) ? form.produto : (form.produto ? [form.produto] : []); %>

    <div class="form-shell form-shell-modern">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Cadastrar Estabelecimento' }) %>

        <section class="page-titlebar page-titlebar-neutral">
            <div class="page-titlebar-content">
                <span class="form-kicker"><i class="bi bi-shop-window"></i> Administrativo</span>
                <h1>Cadastrar estabelecimento</h1>
                <p>Monte a base operacional com uma tela clara e já deixe o ponto pronto para rota inteligente, visitas e consultas futuras.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="page-titlebar-stat">
                    <strong>Fluxo</strong>
                    <span>Cadastro completo do ponto</span>
                </div>
                <div class="page-titlebar-stat">
                    <strong>Objetivo</strong>
                    <span>Centralizar dados comerciais, operacionais e de localização</span>
                </div>
            </div>
        </section>

        <main class="form-stage">
            <form id="cadastroForm" class="modern-form" action="/estabelecimentos/add" method="POST">

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Operação</span>
                            <h2>Produtos ativos e observações</h2>
                            <p>Marque quais linhas estão ativas no estabelecimento e registre qualquer detalhe útil para visitas, sangrias ou manutenção.</p>
                        </div>
                    </div>

                    <div class="row g-4 align-items-start">
                        <div class="col-12 col-lg-5">
                            <label>Produtos vinculados</label>

                            <div class="modern-checkbox-grid">
                                <% (productOptions || []).forEach((produto, index) => { %>
                                    <label class="modern-checkbox <%= produto.className %>" for="produto<%= index + 1 %>">
                                        <input
                                            class="form-check-input"
                                            type="checkbox"
                                            id="produto<%= index + 1 %>"
                                            name="produto"
                                            value="<%= produto.value %>"
                                            <%= selectedProducts.includes(produto.value) ? 'checked' : '' %>
                                        >
                                        <span><%= produto.label %></span>
                                    </label>
                                <% }) %>

                                <% if (false) { %>
                                    <label class="modern-checkbox modern-checkbox-green" for="produto1">
                                        <input class="form-check-input" type="checkbox" id="produto1" name="produto" value="BOLINHAS" <%= selectedProducts.includes('BOLINHAS') ? 'checked' : '' %>>
                                        <span>Bolinhas</span>
                                    </label>
                                <% } %>

                                <% if (false) { %>
                                    <label class="modern-checkbox modern-checkbox-blue" for="produto2">
                                        <input class="form-check-input" type="checkbox" id="produto2" name="produto" value="FIGURINHAS" <%= selectedProducts.includes('FIGURINHAS') ? 'checked' : '' %>>
                                        <span>Consignados</span>
                                    </label>
                                <% } %>

                                <% if (false) { %>
                                    <label class="modern-checkbox modern-checkbox-violet" for="produto3">
                                        <input class="form-check-input" type="checkbox" id="produto3" name="produto" value="PELUCIAS" <%= selectedProducts.includes('PELUCIAS') ? 'checked' : '' %>>
                                        <span>Pelúcias</span>
                                    </label>
                                <% } %>
                            </div>

                            <small class="modern-note">Selecione pelo menos um produto para liberar os atalhos corretos no restante do sistema.</small>
                        </div>

                        <div class="col-12 col-lg-7">
                            <label for="observacoes">Comentários</label>
                            <textarea
                                class="form-control"
                                id="observacoes"
                                name="observacoes"
                                rows="5"
                                maxlength="255"
                                placeholder="Ex.: melhor horário para visita, pessoa de contato, detalhes do espaço..."
                            ><%= form.observacoes || '' %></textarea>
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Identificação</span>
                            <h2>Dados principais do estabelecimento</h2>
                            <p>Preencha o nome do ponto, o responsável e o telefone para deixar o cadastro pronto para consultas futuras.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-5">
                            <label for="estabelecimento">Nome do estabelecimento</label>
                            <input
                                type="text"
                                class="form-control"
                                id="estabelecimento"
                                name="estabelecimento"
                                placeholder="Ex.: Supermercado Central"
                                value="<%= form.estabelecimento || '' %>"
                                required
                            >
                        </div>

                        <div class="col-12 col-md-6 col-lg-3 centered-field">
                            <label for="responsavel_nome">Responsável</label>
                            <input
                                type="text"
                                class="form-control text-center"
                                id="responsavel_nome"
                                name="responsavel_nome"
                                placeholder="Nome"
                                value="<%= form.responsavel_nome || '' %>"
                                required
                            >
                        </div>

                        <div class="col-12 col-md-6 col-lg-4 centered-field">
                            <label for="telefone_contato">Contato</label>
                            <input
                                type="tel"
                                class="form-control text-center"
                                id="telefone_contato"
                                name="telefone_contato"
                                placeholder="(00) 00000-0000"
                                value="<%= form.telefone_contato || '' %>"
                                required
                            >
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Localização</span>
                            <h2>Endereço e localização do ponto</h2>
                            <p>Informe o endereço do estabelecimento e, se estiver no local, salve a localização exata automaticamente.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-8">
                            <label for="endereco">Endereço</label>
                            <input
                                type="text"
                                class="form-control"
                                id="endereco"
                                name="endereco"
                                placeholder="Rua, número e complemento"
                                value="<%= form.endereco || '' %>"
                                required
                            >
                        </div>

                        <div class="col-12 col-lg-4">
                            <label for="bairro">Bairro</label>
                            <input
                                type="text"
                                class="form-control"
                                id="bairro"
                                name="bairro"
                                placeholder="Bairro"
                                value="<%= form.bairro || '' %>"
                                required
                            >
                        </div>

                        <!-- ===== BLOCO VISUAL DOS CAMPOS OPERACIONAIS POR PRODUTO ===== -->

                        <div class="col-12 d-none" data-operational-field="bolinhas-machine">
                            <div class="product-setup-block theme-green">
                                <div class="product-setup-header">
                                    <div class="product-setup-badges">
                                        <span class="product-badge product-badge-green">
                                            <i class="bi bi-circle-fill"></i>
                                            Bolinhas
                                        </span>
                                    </div>

                                    <h3>Máquina de bolinhas</h3>
                                    <p>Campos opcionais para registrar a chave e o número da máquina de bolinhas instalada neste ponto.</p>
                                </div>

                                <div class="product-divider"></div>

                                <div class="row g-3">
                                    <div class="col-12 col-md-6 compact-field centered-field">
                                        <label for="chave_bolinhas">Chave da máquina de bolinhas <span class="optional-label">opcional</span></label>
                                        <input
                                            type="text"
                                            class="form-control text-center"
                                            id="chave_bolinhas"
                                            name="chave_bolinhas"
                                            placeholder="Código da chave"
                                            value="<%= form.chave_bolinhas || form.chave || '' %>"
                                        >
                                    </div>

                                    <div class="col-12 col-md-6 compact-field centered-field">
                                        <label for="maquina_bolinhas">Número da máquina de bolinhas <span class="optional-label">opcional</span></label>
                                        <input
                                            type="text"
                                            class="form-control text-center"
                                            id="maquina_bolinhas"
                                            name="maquina_bolinhas"
                                            placeholder="Número da máquina"
                                            value="<%= form.maquina_bolinhas || form.maquina || '' %>"
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 d-none" data-operational-field="figurinhas-initial">
                            <div class="product-setup-block theme-blue">
                                <div class="product-setup-header">
                                    <div class="product-setup-badges">
                                        <span class="product-badge product-badge-blue">
                                            <i class="bi bi-circle-fill"></i>
                                            Consignados
                                        </span>
                                    </div>

                                    <h3>Parâmetro inicial de consignados</h3>
                                    <p>Informe a quantidade inicial deixada para iniciar o controle deste produto no estabelecimento.</p>
                                </div>

                                <div class="product-divider"></div>

                                <div class="row g-3">
                                    <div class="col-12 col-md-6 col-lg-4 compact-field centered-field">
                                        <label for="figurinha_quantidade_inicial">
                                            Quantidade inicial deixada <span class="required-label">obrigatório</span>
                                        </label>
                                        <input
                                            type="number"
                                            class="form-control text-center"
                                            id="figurinha_quantidade_inicial"
                                            name="figurinha_quantidade_inicial"
                                            min="0"
                                            value="<%= form.figurinha_quantidade_inicial || '' %>"
                                            placeholder="Ex.: 100"
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 d-none" data-operational-field="pelucias-machine">
                            <div class="product-setup-block theme-violet">
                                <div class="product-setup-header">
                                    <div class="product-setup-badges">
                                        <span class="product-badge product-badge-violet">
                                            <i class="bi bi-circle-fill"></i>
                                            Pelúcias
                                        </span>
                                    </div>

                                    <h3>Máquina de pelúcias</h3>
                                    <p>Campos opcionais para registrar a chave e o número da máquina de pelúcias instalada neste ponto.</p>
                                </div>

                                <div class="product-divider"></div>

                                <div class="row g-3">
                                    <div class="col-12 col-md-6 compact-field centered-field">
                                        <label for="chave_pelucias">Chave da máquina de pelúcias <span class="optional-label">opcional</span></label>
                                        <input
                                            type="text"
                                            class="form-control text-center"
                                            id="chave_pelucias"
                                            name="chave_pelucias"
                                            placeholder="Código da chave"
                                            value="<%= form.chave_pelucias || '' %>"
                                        >
                                    </div>

                                    <div class="col-12 col-md-6 compact-field centered-field">
                                        <label for="maquina_pelucias">Número da máquina de pelúcias <span class="optional-label">opcional</span></label>
                                        <input
                                            type="text"
                                            class="form-control text-center"
                                            id="maquina_pelucias"
                                            name="maquina_pelucias"
                                            placeholder="Número da máquina, Ex. GRUA-001"
                                            value="<%= form.maquina_pelucias || '' %>"
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 d-none" data-operational-field="pelucias-initial">
                            <div class="product-setup-block theme-violet">
                                <div class="product-setup-header">
                                    <div class="product-setup-badges">
                                        <span class="product-badge product-badge-violet">
                                            <i class="bi bi-circle-fill"></i>
                                            Pelúcias
                                        </span>
                                    </div>

                                    <h3>Parâmetros iniciais de pelúcias</h3>
                                    <p>Esses dados são usados pelo sistema para calcular estoque, vendas e próximas sangrias.</p>
                                </div>

                                <div class="product-divider"></div>

                                <div class="row g-3">
                                    <div class="col-12 col-md-6 col-lg-3 compact-field centered-field">
                                        <label for="pelucia_leitura_inicial">
                                            Leitura inicial <span class="required-label">obrigatório</span>
                                        </label>
                                        <input
                                            type="number"
                                            class="form-control text-center"
                                            id="pelucia_leitura_inicial"
                                            name="pelucia_leitura_inicial"
                                            min="0"
                                            value="<%= form.pelucia_leitura_inicial || '' %>"
                                            placeholder="Ex.: 0"
                                        >
                                    </div>

                                    <div class="col-12 col-md-6 col-lg-3 compact-field centered-field">
                                        <label for="pelucia_abastecido_inicial">
                                            Qtde. Inicial <span class="required-label">obrigatório</span>
                                        </label>
                                        <input
                                            type="number"
                                            class="form-control text-center"
                                            id="pelucia_abastecido_inicial"
                                            name="pelucia_abastecido_inicial"
                                            min="0"
                                            value="<%= form.pelucia_abastecido_inicial || '' %>"
                                            placeholder="Ex.: 50"
                                        >
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ===== FIM DO BLOCO VISUAL DOS CAMPOS OPERACIONAIS POR PRODUTO ===== -->

                        <div class="col-12">
                            <div class="route-coordinates-header route-coordinates-private">
                                <div>
                                    <label class="mb-1">Localização exata do ponto</label>
                                    <small class="modern-note">
                                        Se você estiver no estabelecimento, clique no botão para salvar a localização automaticamente.
                                        Esses dados ficam salvos apenas no sistema para melhorar as rotas.
                                    </small>

                                    <small
                                        class="coordinates-capture-status <%= form.latitude && form.longitude ? 'is-success' : '' %>"
                                        id="coordinatesCaptureStatus"
                                    >
                                        <%= form.latitude && form.longitude ? 'Localização já capturada para este ponto.' : 'Localização ainda não capturada.' %>
                                    </small>
                                </div>

                                <button type="button" class="btn-modern-secondary route-coordinate-button" id="captureCoordinatesButton">
                                    <i class="bi bi-crosshair"></i>
                                    <span>Usar minha localização atual</span>
                                </button>
                            </div>

                            <input
                                type="hidden"
                                id="latitude"
                                name="latitude"
                                value="<%= form.latitude || '' %>"
                            >

                            <input
                                type="hidden"
                                id="longitude"
                                name="longitude"
                                value="<%= form.longitude || '' %>"
                            >
                        </div>
                    </div>
                </section>

                <section class="form-actions-bar">
                    <div class="form-actions-copy">
                        <strong>Pronto para salvar</strong>
                        <span>Revise os dados principais e confirme o cadastro do estabelecimento.</span>
                    </div>

                    <div class="form-actions-buttons">
                        <a href="/estabelecimentos" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Cancelar</span>
                        </a>

                        <button type="submit" class="btn-modern">
                            <i class="bi bi-check2-circle"></i>
                            <span>Cadastrar estabelecimento</span>
                        </button>
                    </div>
                </section>
            </form>
        </main>
    </div>

    <style>
        /* =========================================================
           CADASTRO DE ESTABELECIMENTO - BLOCOS VISUAIS POR PRODUTO
           ========================================================= */

        .product-setup-block {
            border: 1px solid #d9e2f1;
            border-radius: 20px;
            padding: 18px 18px 16px;
            background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
            margin-top: 8px;
            box-shadow: 0 14px 34px rgba(15, 23, 42, 0.045);
        }

        .product-setup-header {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        .product-setup-badges {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .product-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            min-height: 30px;
            padding: 0 12px;
            border-radius: 999px;
            font-size: 0.76rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            border: 1px solid transparent;
        }

        .product-badge i {
            font-size: 0.48rem;
        }

        .product-badge-green {
            color: #166534;
            background: rgba(34, 197, 94, 0.12);
            border-color: rgba(34, 197, 94, 0.28);
        }

        .product-badge-blue {
            color: #1d4ed8;
            background: rgba(37, 99, 235, 0.12);
            border-color: rgba(37, 99, 235, 0.24);
        }

        .product-badge-violet {
            color: #6d28d9;
            background: rgba(124, 58, 237, 0.12);
            border-color: rgba(124, 58, 237, 0.24);
        }

        .product-setup-header h3 {
            margin: 0;
            font-size: 1rem;
            font-weight: 900;
            color: #1f2937;
        }

        .product-setup-header p {
            margin: 0;
            font-size: 0.86rem;
            line-height: 1.45;
            color: #64748b;
        }

        .product-divider {
            width: 100%;
            height: 1px;
            margin: 14px 0 16px;
            background: linear-gradient(90deg, rgba(148, 163, 184, 0.45) 0%, rgba(148, 163, 184, 0.12) 100%);
        }

        .theme-green {
            border-color: rgba(34, 197, 94, 0.25);
            background: linear-gradient(180deg, rgba(240, 253, 244, 0.88) 0%, rgba(255, 255, 255, 1) 100%);
        }

        .theme-green .product-setup-header h3,
        .theme-green label {
            color: #166534;
        }

        .theme-green .product-divider {
            background: linear-gradient(90deg, rgba(34, 197, 94, 0.45) 0%, rgba(34, 197, 94, 0.08) 100%);
        }

        .theme-green .form-control:focus {
            border-color: rgba(34, 197, 94, 0.62);
            box-shadow: 0 0 0 0.18rem rgba(34, 197, 94, 0.12);
        }

        .theme-blue {
            border-color: rgba(37, 99, 235, 0.22);
            background: linear-gradient(180deg, rgba(239, 246, 255, 0.92) 0%, rgba(255, 255, 255, 1) 100%);
        }

        .theme-blue .product-setup-header h3,
        .theme-blue label {
            color: #1d4ed8;
        }

        .theme-blue .product-divider {
            background: linear-gradient(90deg, rgba(37, 99, 235, 0.40) 0%, rgba(37, 99, 235, 0.08) 100%);
        }

        .theme-blue .form-control:focus {
            border-color: rgba(37, 99, 235, 0.58);
            box-shadow: 0 0 0 0.18rem rgba(37, 99, 235, 0.12);
        }

        .theme-violet {
            border-color: rgba(124, 58, 237, 0.22);
            background: linear-gradient(180deg, rgba(245, 243, 255, 0.92) 0%, rgba(255, 255, 255, 1) 100%);
        }

        .theme-violet .product-setup-header h3,
        .theme-violet label {
            color: #6d28d9;
        }

        .theme-violet .product-divider {
            background: linear-gradient(90deg, rgba(124, 58, 237, 0.40) 0%, rgba(124, 58, 237, 0.08) 100%);
        }

        .theme-violet .form-control:focus {
            border-color: rgba(124, 58, 237, 0.58);
            box-shadow: 0 0 0 0.18rem rgba(124, 58, 237, 0.12);
        }

        .optional-label,
        .required-label {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: 6px;
            padding: 2px 8px;
            border-radius: 999px;
            font-size: 0.66rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            vertical-align: middle;
        }

        .optional-label {
            color: #475569;
            background: rgba(148, 163, 184, 0.16);
        }

        .required-label {
            color: #b91c1c;
            background: rgba(239, 68, 68, 0.12);
        }

        .route-coordinates-private {
            align-items: flex-start;
        }

        .coordinates-capture-status {
            display: inline-flex;
            align-items: center;
            width: fit-content;
            margin-top: 0.5rem;
            padding: 0.35rem 0.7rem;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 800;
            color: #475569;
            background: rgba(148, 163, 184, 0.14);
            border: 1px solid rgba(148, 163, 184, 0.2);
        }

        .coordinates-capture-status.is-success {
            color: #166534;
            background: rgba(34, 197, 94, 0.12);
            border-color: rgba(34, 197, 94, 0.24);
        }

        @media (max-width: 767.98px) {
            .product-setup-block {
                padding: 16px 14px 14px;
                border-radius: 16px;
            }

            .product-setup-header h3 {
                font-size: 0.95rem;
            }

            .product-setup-header p {
                font-size: 0.82rem;
            }

            .optional-label,
            .required-label {
                margin-left: 0;
                margin-top: 4px;
            }

            .route-coordinates-private {
                gap: 1rem;
            }

            .coordinates-capture-status {
                font-size: 0.74rem;
            }
        }
    </style>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const telefoneInput = document.getElementById('telefone_contato');
            const latitudeInput = document.getElementById('latitude');
            const longitudeInput = document.getElementById('longitude');
            const captureCoordinatesButton = document.getElementById('captureCoordinatesButton');
            const coordinatesCaptureStatus = document.getElementById('coordinatesCaptureStatus');
            const produtoInputs = Array.from(document.querySelectorAll('input[name="produto"]'));

            const bolinhasMachineFields = Array.from(document.querySelectorAll('[data-operational-field="bolinhas-machine"]'));
            const figurinhasInitialFields = Array.from(document.querySelectorAll('[data-operational-field="figurinhas-initial"]'));
            const peluciasMachineFields = Array.from(document.querySelectorAll('[data-operational-field="pelucias-machine"]'));
            const peluciasInitialFields = Array.from(document.querySelectorAll('[data-operational-field="pelucias-initial"]'));

            const chaveBolinhasInput = document.getElementById('chave_bolinhas');
            const maquinaBolinhasInput = document.getElementById('maquina_bolinhas');
            const figurinhaQuantidadeInicialInput = document.getElementById('figurinha_quantidade_inicial');
            const chavePeluciasInput = document.getElementById('chave_pelucias');
            const maquinaPeluciasInput = document.getElementById('maquina_pelucias');
            const peluciaLeituraInicialInput = document.getElementById('pelucia_leitura_inicial');
            const peluciaAbastecidoInicialInput = document.getElementById('pelucia_abastecido_inicial');

            const getSelectedProducts = () => produtoInputs
                .filter((checkbox) => checkbox.checked)
                .map((checkbox) => checkbox.value);

            const setGroupVisibility = (fields, shouldShow) => {
                fields.forEach((field) => field.classList.toggle('d-none', !shouldShow));
            };

            const syncOperationalFields = () => {
                const selectedProducts = getSelectedProducts();

                const hasBolinhas = selectedProducts.includes('BOLINHAS');
                const hasFigurinhas = selectedProducts.includes('FIGURINHAS');
                const hasPelucias = selectedProducts.includes('PELUCIAS');

                setGroupVisibility(bolinhasMachineFields, hasBolinhas);
                setGroupVisibility(figurinhasInitialFields, hasFigurinhas);
                setGroupVisibility(peluciasMachineFields, hasPelucias);
                setGroupVisibility(peluciasInitialFields, hasPelucias);

                if (chaveBolinhasInput) chaveBolinhasInput.required = false;
                if (maquinaBolinhasInput) maquinaBolinhasInput.required = false;
                if (chavePeluciasInput) chavePeluciasInput.required = false;
                if (maquinaPeluciasInput) maquinaPeluciasInput.required = false;

                if (figurinhaQuantidadeInicialInput) figurinhaQuantidadeInicialInput.required = hasFigurinhas;
                if (peluciaLeituraInicialInput) peluciaLeituraInicialInput.required = hasPelucias;
                if (peluciaAbastecidoInicialInput) peluciaAbastecidoInicialInput.required = hasPelucias;

                if (!hasBolinhas) {
                    if (chaveBolinhasInput) chaveBolinhasInput.value = '';
                    if (maquinaBolinhasInput) maquinaBolinhasInput.value = '';
                }

                if (!hasFigurinhas && figurinhaQuantidadeInicialInput) {
                    figurinhaQuantidadeInicialInput.value = '';
                }

                if (!hasPelucias) {
                    if (chavePeluciasInput) chavePeluciasInput.value = '';
                    if (maquinaPeluciasInput) maquinaPeluciasInput.value = '';
                    if (peluciaLeituraInicialInput) peluciaLeituraInicialInput.value = '';
                    if (peluciaAbastecidoInicialInput) peluciaAbastecidoInicialInput.value = '';
                }
            };

            produtoInputs.forEach((input) => input.addEventListener('change', syncOperationalFields));
            syncOperationalFields();

            telefoneInput?.addEventListener('input', (e) => {
                let value = e.target.value.replace(/\D/g, '');

                if (value.length > 11) value = value.slice(0, 11);
                if (value.length > 0) value = `(${value.slice(0, 2)}) ${value.slice(2)}`;
                if (value.length > 3) value = `${value.slice(0, 4)} ${value.slice(4)}`;
                if (value.length > 10) value = `${value.slice(0, 10)}-${value.slice(10)}`;

                e.target.value = value;
            });

            captureCoordinatesButton?.addEventListener('click', () => {
                if (!navigator.geolocation) {
                    window.AppAlerts?.warning('Seu navegador não permite capturar a localização atual.');
                    return;
                }

                captureCoordinatesButton.disabled = true;

                if (coordinatesCaptureStatus) {
                    coordinatesCaptureStatus.textContent = 'Capturando localização...';
                    coordinatesCaptureStatus.classList.remove('is-success');
                }

                navigator.geolocation.getCurrentPosition(
                    (position) => {
                        latitudeInput.value = position.coords.latitude.toFixed(6);
                        longitudeInput.value = position.coords.longitude.toFixed(6);

                        if (coordinatesCaptureStatus) {
                            coordinatesCaptureStatus.textContent = 'Localização capturada com sucesso.';
                            coordinatesCaptureStatus.classList.add('is-success');
                        }

                        captureCoordinatesButton.disabled = false;
                        window.AppAlerts?.success('Localização do ponto salva com sucesso.');
                    },
                    () => {
                        if (coordinatesCaptureStatus) {
                            coordinatesCaptureStatus.textContent = 'Localização ainda não capturada.';
                            coordinatesCaptureStatus.classList.remove('is-success');
                        }

                        captureCoordinatesButton.disabled = false;
                        window.AppAlerts?.error('Não foi possível capturar sua localização. Verifique a permissão do navegador e tente novamente.');
                    },
                    {
                        enableHighAccuracy: true,
                        timeout: 12000,
                        maximumAge: 60000
                    }
                );
            });

            document.getElementById('cadastroForm').addEventListener('submit', (e) => {
                const selectedProducts = getSelectedProducts();

                if (selectedProducts.length === 0) {
                    e.preventDefault();
                    window.AppAlerts?.warning('Por favor, marque pelo menos um produto.');
                    return;
                }

                if (selectedProducts.includes('FIGURINHAS') && !figurinhaQuantidadeInicialInput.value) {
                    e.preventDefault();
                    window.AppAlerts?.warning('Informe a quantidade inicial deixada para consignados.');
                    return;
                }

                if (
                    selectedProducts.includes('PELUCIAS') &&
                    (!peluciaLeituraInicialInput.value || !peluciaAbastecidoInicialInput.value)
                ) {
                    e.preventDefault();
                    window.AppAlerts?.warning('Informe leitura inicial e quantidade inicial para pelúcias.');
                    return;
                }
            });

            <% if (success) { %>
                window.AppAlerts?.success("<%- success.replace(/"/g, '&quot;') %>");
            <% } %>

            <% if (error) { %>
                window.AppAlerts?.error("<%- error.replace(/"/g, '&quot;') %>");
            <% } %>
        });
    </script>
</body>
</html>