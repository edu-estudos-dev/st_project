<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head') %>

<body class="bg-light">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>
    <div class="form-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Cadastrar' }) %>

        <div class="cabecalho-geral">
            <h1 class="mb-0">Cadastrar Estabelecimento</h1>
        </div>

        <main class="mb-5 geral">
            <form id="cadastroForm" class="p-0" action="/estabelecimentos/add" method="POST">
                <div class="row g-3">
                    <div class="col-12 col-lg-8">
                        <label class="mb-1 fw-bold fs-5" for="estabelecimento">Nome do Estabelecimento</label>
                        <input type="text" class="form-control" id="estabelecimento" name="estabelecimento" required>
                    </div>
                    <div class="col-12 col-md-6 col-lg-2">
                        <label class="mb-1 fw-bold fs-5" for="responsavel_nome">Responsavel</label>
                        <input type="text" class="form-control text-center" id="responsavel_nome" name="responsavel_nome" required>
                    </div>
                    <div class="col-12 col-md-6 col-lg-2">
                        <label class="mb-1 fw-bold fs-5" for="telefone_contato">Contato</label>
                        <input type="tel" class="form-control text-center" id="telefone_contato" name="telefone_contato" required>
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-12 col-lg-5">
                        <label class="mb-1 fw-bold fs-5" for="endereco">Endereco</label>
                        <input type="text" class="form-control" id="endereco" name="endereco" required>
                    </div>
                    <div class="col-12 col-md-4 col-lg-3">
                        <label class="mb-1 fw-bold fs-5" for="bairro">Bairro</label>
                        <input type="text" class="form-control text-center" id="bairro" name="bairro" required>
                    </div>
                    <div class="col-6 col-md-4 col-lg-2 compact-field">
                        <label class="mb-1 fw-bold fs-5" for="chave">Chave</label>
                        <input type="text" class="form-control text-center" id="chave" name="chave">
                    </div>
                    <div class="col-6 col-md-4 col-lg-2 compact-field">
                        <label class="mb-1 fw-bold fs-5" for="maquina">Maquina</label>
                        <input type="text" class="form-control text-center" id="maquina" name="maquina">
                    </div>
                </div>
                <div class="row g-3 mt-1">
                    <div class="col-12 col-lg-3">
                        <label class="mb-1 fw-bold fs-5">Produto</label>
                        <div class="form-check"><input class="form-check-input" type="checkbox" id="produto1" name="produto" value="BOLINHAS"><label class="form-check-label ms-2" for="produto1">BOLINHAS</label></div>
                        <div class="form-check"><input class="form-check-input" type="checkbox" id="produto2" name="produto" value="FIGURINHAS"><label class="form-check-label ms-2" for="produto2">FIGURINHAS</label></div>
                        <div class="form-check"><input class="form-check-input" type="checkbox" id="produto3" name="produto" value="PELUCIAS"><label class="form-check-label ms-2" for="produto3">PELUCIAS</label></div>
                    </div>
                    <div class="col-12 col-lg-9">
                        <label class="mb-1 fw-bold fs-5" for="observacoes">Comentarios</label>
                        <textarea class="form-control" id="observacoes" name="observacoes" rows="4" maxlength="255"></textarea>
                    </div>
                </div>
                <div class="action-row my-4">
                    <a href="/estabelecimentos" class="btn btn-warning fs-5">Cancelar</a>
                    <button type="submit" class="btn btn-primary fs-5">Cadastrar</button>
                </div>
            </form>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const telefoneInput = document.getElementById('telefone_contato');
            telefoneInput.addEventListener('input', (e) => {
                let value = e.target.value.replace(/\D/g, '');
                if (value.length > 11) value = value.slice(0, 11);
                if (value.length > 0) value = `(${value.slice(0, 2)}) ${value.slice(2)}`;
                if (value.length > 3) value = `${value.slice(0, 4)} ${value.slice(4)}`;
                if (value.length > 10) value = `${value.slice(0, 10)}-${value.slice(10)}`;
                e.target.value = value;
            });
            document.getElementById('cadastroForm').addEventListener('submit', (e) => {
                const isChecked = Array.from(document.querySelectorAll('input[name="produto"]')).some((checkbox) => checkbox.checked);
                if (!isChecked) {
                    e.preventDefault();
                    window.AppAlerts?.warning('Por favor, marque pelo menos um produto.');
                }
            });
            <% if (success) { %>window.AppAlerts?.success("<%- success.replace(/"/g, '&quot;') %>");<% } %>
            <% if (error) { %>window.AppAlerts?.error("<%- error.replace(/"/g, '&quot;') %>");<% } %>
        });
    </script>
</body>
</html>
