<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Editar Estabelecimento' }) %>

<body class="form-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="form-shell form-shell-modern">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Editar Estabelecimento' }) %>

        <section class="page-titlebar page-titlebar-neutral">
            <div class="page-titlebar-content">
                <span class="form-kicker"><i class="bi bi-pencil-square"></i> Administrativo</span>
                <h1>Editar estabelecimento</h1>
                <p>Atualize os dados do ponto e ajuste as coordenadas para a central de rotas trabalhar com mais precisão.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="page-titlebar-stat">
                    <strong>Registro atual</strong>
                    <span><%= estabelecimento.estabelecimento %></span>
                </div>
                <div class="page-titlebar-stat">
                    <strong>Ação</strong>
                    <span>Revisar e atualizar dados do ponto</span>
                </div>
            </div>
        </section>

        <main class="form-stage">
            <form id="edicaoForm" class="modern-form" action="/estabelecimentos/<%= estabelecimento.id %>?_method=PUT" method="POST">
                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Identificação</span>
                            <h2>Dados principais do estabelecimento</h2>
                            <p>Ajuste o nome do ponto, o responsável e o telefone de contato para manter a base sempre atualizada.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-4">
                            <label for="estabelecimento">Estabelecimento</label>
                            <input type="text" class="form-control" id="estabelecimento" name="estabelecimento" value="<%= estabelecimento.estabelecimento %>">
                        </div>
                        <div class="col-12 col-md-6 col-lg-4 centered-field">
                            <label for="responsavel_nome">Responsável</label>
                            <input type="text" class="form-control text-center" id="responsavel_nome" name="responsavel_nome" value="<%= estabelecimento.responsavel_nome %>">
                        </div>
                        <div class="col-12 col-md-6 col-lg-4 centered-field">
                            <label for="telefone_contato">Contato</label>
                            <input type="text" class="form-control text-center" id="telefone_contato" name="telefone_contato" value="<%= estabelecimento.telefone_contato %>">
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Localização</span>
                            <h2>Endereço, referência e coordenadas</h2>
                            <p>Revise endereço, bairro e coordenadas do ponto para manter a operação alinhada com a realidade da rua.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-5">
                            <label for="endereco">Endereço</label>
                            <input type="text" class="form-control" id="endereco" name="endereco" value="<%= estabelecimento.endereco %>">
                        </div>
                        <div class="col-12 col-md-4 col-lg-2">
                            <label for="bairro">Bairro</label>
                            <input type="text" class="form-control text-center" id="bairro" name="bairro" value="<%= estabelecimento.bairro %>">
                        </div>
                        <div class="col-6 col-md-4 col-lg-2 compact-field centered-field">
                            <label for="chave">Chave</label>
                            <input type="text" class="form-control text-center" id="chave" name="chave" value="<%= estabelecimento.chave %>">
                        </div>
                        <div class="col-6 col-md-4 col-lg-3 compact-field centered-field">
                            <label for="maquina">Máquina</label>
                            <input type="text" class="form-control text-center" id="maquina" name="maquina" value="<%= estabelecimento.maquina %>">
                        </div>
                        <div class="col-12">
                            <div class="route-coordinates-header">
                                <div>
                                    <label class="mb-1" for="latitude">Coordenadas do ponto</label>
                                    <small class="modern-note">Você pode ajustar manualmente ou capturar a posição atual se estiver no local do estabelecimento.</small>
                                </div>
                                <button type="button" class="btn-modern-secondary route-coordinate-button" id="captureCoordinatesButton">
                                    <i class="bi bi-crosshair"></i>
                                    <span>Atualizar com minha localização atual</span>
                                </button>
                            </div>
                        </div>
                        <div class="col-12 col-md-6">
                            <label for="latitude">Latitude</label>
                            <input type="text" class="form-control text-center" id="latitude" name="latitude" value="<%= estabelecimento.latitude ?? '' %>" placeholder="-3.731862">
                        </div>
                        <div class="col-12 col-md-6">
                            <label for="longitude">Longitude</label>
                            <input type="text" class="form-control text-center" id="longitude" name="longitude" value="<%= estabelecimento.longitude ?? '' %>" placeholder="-38.526669">
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Operação</span>
                            <h2>Produtos e observações</h2>
                            <p>Atualize os produtos ativos no ponto e registre comentários úteis para a equipe nas próximas visitas.</p>
                        </div>
                    </div>

                    <div class="row g-4 align-items-start">
                        <div class="col-12 col-lg-5">
                            <label>Produtos vinculados</label>
                            <div class="modern-checkbox-grid">
                                <% (productOptions || []).forEach((produto, index) => { %>
                                    <label class="modern-checkbox <%= produto.className %>" for="produto<%= index + 1 %>">
                                        <input class="form-check-input" type="checkbox" id="produto<%= index + 1 %>" name="produto" value="<%= produto.value %>" <%= hasProduto(estabelecimento.produto, produto.value) ? 'checked' : '' %>>
                                        <span><%= produto.label %></span>
                                    </label>
                                <% }) %>
                                <% if (false) { %><label class="modern-checkbox modern-checkbox-green" for="produto1">
                                    <input class="form-check-input" type="checkbox" id="produto1" name="produto" value="BOLINHAS" <%= hasProduto(estabelecimento.produto, 'BOLINHAS') ? 'checked' : '' %>>
                                    <span>Bolinhas</span>
                                </label><% } %>
                                <% if (false) { %><label class="modern-checkbox modern-checkbox-blue" for="produto2">
                                    <input class="form-check-input" type="checkbox" id="produto2" name="produto" value="FIGURINHAS" <%= hasProduto(estabelecimento.produto, 'FIGURINHAS') ? 'checked' : '' %>>
                                    <span>Consignados</span>
                                </label><% } %>
                                <% if (false) { %><label class="modern-checkbox modern-checkbox-violet" for="produto3">
                                    <input class="form-check-input" type="checkbox" id="produto3" name="produto" value="PELUCIAS" <%= hasProduto(estabelecimento.produto, 'PELUCIAS') ? 'checked' : '' %>>
                                    <span>Pelúcias</span>
                                </label><% } %>
                            </div>
                            <small class="modern-note">Deixe pelo menos um produto marcado para manter os atalhos e relatórios coerentes com o ponto.</small>
                        </div>

                        <div class="col-12 col-lg-7">
                            <label for="observacoes">Comentários</label>
                            <textarea class="form-control" id="observacoes" name="observacoes" rows="5" maxlength="255"><%= estabelecimento.observacoes %></textarea>
                        </div>
                    </div>
                </section>

                <section class="form-actions-bar">
                    <div class="form-actions-copy">
                        <strong>Atualização do cadastro</strong>
                        <span>Revise os dados do estabelecimento antes de confirmar as alterações.</span>
                    </div>

                    <div class="form-actions-buttons">
                        <a href="/estabelecimentos" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Cancelar</span>
                        </a>
                        <button type="submit" class="btn-modern">
                            <i class="bi bi-check2-circle"></i>
                            <span>Atualizar estabelecimento</span>
                        </button>
                    </div>
                </section>
            </form>
        </main>
    </div>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const latitudeInput = document.getElementById('latitude');
            const longitudeInput = document.getElementById('longitude');
            const captureCoordinatesButton = document.getElementById('captureCoordinatesButton');

            captureCoordinatesButton?.addEventListener('click', () => {
                if (!navigator.geolocation) {
                    window.AppAlerts?.warning('Seu navegador não permite capturar a localização atual.');
                    return;
                }

                captureCoordinatesButton.disabled = true;

                navigator.geolocation.getCurrentPosition(
                    (position) => {
                        latitudeInput.value = position.coords.latitude.toFixed(6);
                        longitudeInput.value = position.coords.longitude.toFixed(6);
                        captureCoordinatesButton.disabled = false;
                        window.AppAlerts?.success('Coordenadas atualizadas com a sua localização atual.');
                    },
                    () => {
                        captureCoordinatesButton.disabled = false;
                        window.AppAlerts?.error('Não foi possível ler sua localização atual.');
                    },
                    { enableHighAccuracy: true, timeout: 12000, maximumAge: 60000 }
                );
            });

            document.getElementById('edicaoForm').addEventListener('submit', (e) => {
                const isChecked = Array.from(document.querySelectorAll('input[name="produto"]')).some((checkbox) => checkbox.checked);
                if (!isChecked) {
                    e.preventDefault();
                    window.AppAlerts?.warning('Por favor, marque pelo menos um produto.');
                }
            });

            <% if (success) { %>window.AppAlerts?.success("<%- success.replace(/"/g, '&quot;') %>"); setTimeout(() => { window.location.href = '/estabelecimentos'; }, 1800);<% } %>
            <% if (error) { %>window.AppAlerts?.error("<%- error.replace(/"/g, '&quot;') %>");<% } %>
        });
    </script>
</body>
</html>
