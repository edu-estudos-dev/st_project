<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head') %>

    <body class="bg-light">
        <%- include('../../partials/header') %>

        <div class="container" style="padding-top: 2.9em;"></div>
        <div>&nbsp;</div>

        <!-- breadcrumb -->
        <%- include('../../partials/breadcrumb', { pageTitle: 'Estabelecimentos Cadastrados' }) %>

        <div class="container-fluid px-4">

            <div class="container-fluid px-4">

                <!-- Mensagens de Sucesso/Falha -->
                <div id="alert-container"></div>
                <% if (typeof success !== 'undefined') { %>
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <%= success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>
                <% if (typeof error !== 'undefined') { %>
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <%= error %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                <% } %>

                <main class="mb-5 geral">
                    <div class="row">
                        <div class="col-6">
                            <h1 class="text-dark mb-3 fw-bold">Estabelecimentos Cadastrados</h1>
                        </div>
                        <div class="col-6 d-flex justify-content-end">
                            <a type="button" class="btn mb-3 btn-dark align-self-center" href="/estabelecimentos/add"><i
                                    class="bi bi-person-add"></i> &nbsp;Novo Estabelecimento</a>
                        </div>
                    </div>

                    <div class="table-container">
                
                        <table class="table table-striped table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Estabelecimento</th>
                                    <th>Produto</th>
                                    <th>Chave</th>
                                    <th>Máquina</th>
                                    <th>Endereço</th>
                                    <th>Responsável</th>
                                    <!-- <th>CONTATO</th> -->
                                    <th>Açoes</th>
                                </tr>
                            </thead>
                            <tbody >
                                <% estabelecimentos.forEach((estabelecimento) => { %>
                                    <tr>
                                        <td class="py-0"  ><%= estabelecimento.estabelecimento %></td>
                                        <td class="py-0"  ><%= estabelecimento.produto %></td>
                                        <td class="py-0"  ><%= estabelecimento.chave %></td>
                                        <td class="py-0"  ><%= estabelecimento.maquina %></td>
                                        <td class="py-0"  ><%= estabelecimento.endereco %></td>
                                        <td class="py-0"  ><%= estabelecimento.responsavel_nome %></td>
                                        <td class="py-0">
                                            <a type="button" class=" btn btn-secondary btn-sm view-btn" data-id="<%= estabelecimento.id %>">&nbsp;Visualizar</a>
                                            <a type="button" class=" my-1 btn btn-warning btn-sm edit-btn" data-id="<%= estabelecimento.id %>">&nbsp;Editar</a>
                                            <a type="button" class=" btn btn-danger btn-sm delete-btn" data-id="<%= estabelecimento.id %>">&nbsp;Excluir</a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </main>
            </div>

            <% if (search) { %>
                <div class="d-flex justify-content-center pb-5">
                    <a href="/estabelecimentos" class="btn btn-primary px-5 fs-5">Voltar</a>
                </div>
            <% } %>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>

        <script>
        
            document.addEventListener('DOMContentLoaded', function() {
                const viewButtons = document.querySelectorAll('.view-btn');
                const editButtons = document.querySelectorAll('.edit-btn');
                const deleteButtons = document.querySelectorAll('.delete-btn');

                viewButtons.forEach(button => {
                    button.addEventListener('click', function() {
                        const idEstabelecimento = this.getAttribute('data-id');
                        window.location.href = `/estabelecimentos/${idEstabelecimento}/view`;
                    });
                });

                editButtons.forEach(button => {
                    button.addEventListener('click', function() {
                        const idEstabelecimento = this.getAttribute('data-id');
                        window.location.href = `/estabelecimentos/${idEstabelecimento}/edit`;
                    });
                });

                deleteButtons.forEach(button => {
                    button.addEventListener('click', function() {
                        const idEstabelecimento = this.getAttribute('data-id');
                        if (confirm('Tem certeza que deseja EXCLUIR este Estabelecimento?')) {
                            fetch(`/estabelecimentos/${idEstabelecimento}`, {
                                method: 'DELETE'
                            })
                            .then(response => {
                                if (response.ok) {
                                    const alertContainer = document.getElementById('alert-container');
                                    alertContainer.innerHTML = `
                                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                                            Estabelecimento Exluido com sucesso!
                                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                        </div>
                                    `;
                                    setTimeout(() => {
                                        window.location.reload(); // Recarrega a página após 2 segundos
                                    }, 2000);
                                } else {
                                    alert('Error deleting user');
                                }
                            });
                        }
                    });
                });
            });
        </script>
    </body>

</html>
