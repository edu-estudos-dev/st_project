<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Estabelecimentos Cadastrados' }) %>

<body class="list-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Estabelecimentos Cadastrados' }) %>

        <section class="list-hero list-hero-neutral">
            <div class="list-hero-content">
                <span class="list-kicker"><i class="bi bi-buildings"></i> Administrativo</span>
                <h1>Estabelecimentos cadastrados</h1>
                <p>Uma visão mais limpa da base de pontos para consultar produtos ativos, localizar responsáveis e agir rapidamente em visualizar, editar ou excluir.</p>
            </div>
            <div class="list-hero-side">
                <div class="list-stat">
                    <strong>Total</strong>
                    <span><%= estabelecimentos.length %> registros</span>
                </div>
                <div class="list-stat">
                    <strong>Ação rápida</strong>
                    <span>Cadastrar e gerenciar pontos</span>
                </div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <div class="list-toolbar">
                    <div class="list-toolbar-copy">
                        <h2>Base de estabelecimentos</h2>
                        <p>Consulte os principais dados da operação e use os atalhos para abrir a tela certa sem perder contexto.</p>
                    </div>
                    <a class="list-action" href="/estabelecimentos/add">
                        <i class="bi bi-plus-circle"></i>
                        <span>Novo estabelecimento</span>
                    </a>
                </div>

                <div class="list-summary-grid">
                    <div class="list-summary-card">
                        <strong>Registros</strong>
                        <span><%= estabelecimentos.length %> pontos</span>
                    </div>
                    <div class="list-summary-card">
                        <strong>Fluxo</strong>
                        <span>Consultar, editar e visualizar</span>
                    </div>
                    <div class="list-summary-card">
                        <strong>Contexto</strong>
                        <span>Operação centralizada</span>
                    </div>
                    <div class="list-summary-card">
                        <strong>Visualização</strong>
                        <span id="estabelecimentosModeLabel">Dados comerciais</span>
                    </div>
                </div>

                <div class="table-mode-switch" aria-label="Modo de visualização">
                    <button type="button" class="table-mode-btn is-active" data-mode="commercial">Dados comerciais</button>
                    <button type="button" class="table-mode-btn" data-mode="operational">Operacional</button>
                </div>

                <div class="modern-table-wrap">
                    <div class="modern-table-scroll">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th>Estabelecimento</th>
                                    <th class="mode-all">Produto</th>
                                    <th class="mode-commercial">Endereço</th>
                                    <th class="mode-commercial">Responsável</th>
                                    <th class="mode-commercial">Contato</th>
                                    <th class="mode-operational" style="display:none;">Chave</th>
                                    <th class="mode-operational" style="display:none;">Máquina</th>
                                    <th class="table-actions-heading">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% estabelecimentos.forEach((estabelecimento) => { %>
                                    <% const produtoBase = (estabelecimento.produtoFormatado || estabelecimento.produto || '').toUpperCase(); %>
                                    <% const hasBolinhas = produtoBase.includes('BOLINHAS'); %>
                                    <tr>
                                        <td>
                                            <div class="table-title-cell"><%= estabelecimento.estabelecimento %></div>
                                        </td>
                                        <td class="mode-all"><span class="table-badge table-badge-blue"><%= estabelecimento.produtoFormatado || estabelecimento.produto %></span></td>
                                        <td class="mode-commercial"><span class="table-muted"><%= estabelecimento.endereco %></span></td>
                                        <td class="mode-commercial"><%= estabelecimento.responsavel_nome %></td>
                                        <td class="mode-commercial"><%= estabelecimento.telefone_contato || '-' %></td>
                                        <td class="mode-operational" style="display:none;"><%= hasBolinhas ? (estabelecimento.chave || '-') : '-' %></td>
                                        <td class="mode-operational" style="display:none;"><%= hasBolinhas ? (estabelecimento.maquina || '-') : '-' %></td>
                                        <td class="table-actions-cell">
                                            <div class="table-actions">
                                                <a class="table-btn table-btn-view view-btn" data-id="<%= estabelecimento.id %>">Visualizar</a>
                                                <a class="table-btn table-btn-edit edit-btn" data-id="<%= estabelecimento.id %>">Editar</a>
                                                <a class="table-btn table-btn-delete delete-btn" data-id="<%= estabelecimento.id %>">Excluir</a>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <% if (search) { %>
                <section class="list-panel">
                    <a href="/estabelecimentos" class="list-action">
                        <i class="bi bi-arrow-left"></i>
                        <span>Voltar para a lista completa</span>
                    </a>
                </section>
            <% } %>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modeButtons = document.querySelectorAll('.table-mode-btn');
            const modeLabel = document.getElementById('estabelecimentosModeLabel');

            const applyMode = (mode) => {
                document.querySelectorAll('.mode-commercial').forEach((cell) => {
                    cell.style.display = mode === 'commercial' ? '' : 'none';
                });
                document.querySelectorAll('.mode-operational').forEach((cell) => {
                    cell.style.display = mode === 'operational' ? '' : 'none';
                });

                modeButtons.forEach((button) => {
                    button.classList.toggle('is-active', button.getAttribute('data-mode') === mode);
                });

                modeLabel.textContent = mode === 'commercial' ? 'Dados comerciais' : 'Operacional';
            };

            modeButtons.forEach((button) => {
                button.addEventListener('click', () => applyMode(button.getAttribute('data-mode')));
            });

            applyMode('commercial');

            document.querySelectorAll('.view-btn').forEach((button) => {
                button.addEventListener('click', function () {
                    window.location.href = `/estabelecimentos/${this.getAttribute('data-id')}/view`;
                });
            });

            document.querySelectorAll('.edit-btn').forEach((button) => {
                button.addEventListener('click', function () {
                    window.location.href = `/estabelecimentos/${this.getAttribute('data-id')}/edit`;
                });
            });

            document.querySelectorAll('.delete-btn').forEach((button) => {
                button.addEventListener('click', async function () {
                    const idEstabelecimento = this.getAttribute('data-id');
                    const confirmed = await window.AppAlerts?.confirm({
                        title: 'Excluir estabelecimento',
                        text: 'Tem certeza que deseja excluir este estabelecimento?',
                        confirmButtonText: 'Excluir',
                        cancelButtonText: 'Cancelar'
                    });
                    if (!confirmed) return;

                    try {
                        const response = await fetch(`/estabelecimentos/${idEstabelecimento}`, { method: 'DELETE' });
                        const data = await response.json();
                        if (!response.ok) throw new Error(data.message || 'Erro ao excluir estabelecimento');
                        await window.AppAlerts?.success(data.message || 'Estabelecimento excluído com sucesso');
                        window.location.reload();
                    } catch (error) {
                        window.AppAlerts?.error(error.message || 'Erro ao excluir estabelecimento');
                    }
                });
            });

            <% if (typeof success !== 'undefined') { %>window.AppAlerts?.success("<%- success.replace(/"/g, '&quot;') %>");<% } %>
            <% if (typeof error !== 'undefined') { %>window.AppAlerts?.error("<%- error.replace(/"/g, '&quot;') %>");<% } %>
        });
    </script>
</body>
</html>

