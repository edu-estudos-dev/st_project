<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Estabelecimentos Cadastrados' }) %>

<body class="list-page-body">
    <%- include('../../partials/header') %>
    <% const isReadOnly = Boolean(typeof assinaturaSomenteLeitura !== 'undefined' && assinaturaSomenteLeitura); %>
    <% const navProducts = typeof navigationProducts !== 'undefined' && navigationProducts ? navigationProducts : null; %>
    <% const listaTemBolinhas = estabelecimentos.some((est) => String(est.produtoFormatado || est.produto || '').toUpperCase().includes('BOLINHAS')); %>
    <% const listaTemPelucias = estabelecimentos.some((est) => {
        const produtoBase = String(est.produtoFormatado || est.produto || '').toUpperCase();
        return produtoBase.includes('PELUCIAS') || produtoBase.includes('PELÚCIAS');
    }); %>
    <% const showBolinhasColumn = navProducts ? Boolean(navProducts.bolinhas) : listaTemBolinhas; %>
    <% const showPeluciasColumn = navProducts ? Boolean(navProducts.pelucias) : listaTemPelucias; %>
    <% const activeOperationalProducts = [showBolinhasColumn, showPeluciasColumn].filter(Boolean).length; %>
    <% const hasOperationalColumns = activeOperationalProducts > 0; %>
    <% const operationalColumnCount = activeOperationalProducts * 2; %>
    <% const operationalColumnsClass = operationalColumnCount === 4 ? 'has-4-operational-cols' : operationalColumnCount === 2 ? 'has-2-operational-cols' : 'has-no-operational-cols'; %>
    <% const shouldPrefixOperationalLabel = activeOperationalProducts > 1; %>

    <% const formatPhone = (value) => {
        const rawValue = String(value || '').trim();
        const digits = rawValue.replace(/\D/g, '');

        if (!digits) {
            return '';
        }

        if (digits.length === 11) {
            return `(${digits.slice(0, 2)}) ${digits.slice(2, 7)}-${digits.slice(7)}`;
        }

        if (digits.length === 10) {
            return `(${digits.slice(0, 2)}) ${digits.slice(2, 6)}-${digits.slice(6)}`;
        }

        return rawValue;
    }; %>

    <div class="page-spacer"></div>

    <div class="list-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Estabelecimentos Cadastrados' }) %>

        <section class="page-titlebar page-titlebar-neutral">
            <div class="page-titlebar-content">
                <span class="list-kicker"><i class="bi bi-buildings"></i> Administrativo</span>
                <h1>Estabelecimentos cadastrados</h1>
                <p>Uma visão mais limpa da base de pontos para consultar produtos ativos, localizar responsáveis e agir rapidamente em visualizar, editar ou excluir.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="list-stat">
                    <strong>Total</strong>
                    <span><%= estabelecimentos.length %> registros</span>
                </div>

                <div class="list-stat">
                    <strong>Ação rápida</strong>
                    <span>Cadastrar e gerenciar pontos</span>
                </div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <div class="list-toolbar">
                    <div class="list-toolbar-copy">
                        <h2>Base de estabelecimentos</h2>
                        <p>Consulte os principais dados da operação e use os atalhos para abrir a tela certa sem perder contexto.</p>
                    </div>

                    <% if (!isReadOnly) { %>
                        <a class="list-action" href="/estabelecimentos/add">
                            <i class="bi bi-plus-circle"></i>
                            <span>Novo estabelecimento</span>
                        </a>
                    <% } %>
                </div>

                <div class="list-summary-grid">
                    <div class="list-summary-card">
                        <strong>Registros</strong>
                        <span><%= estabelecimentos.length %> pontos</span>
                    </div>

                    <div class="list-summary-card">
                        <strong>Fluxo</strong>
                        <span>Consultar, editar e visualizar</span>
                    </div>

                    <div class="list-summary-card">
                        <strong>Contexto</strong>
                        <span>Operação centralizada</span>
                    </div>

                    <div class="list-summary-card">
                        <strong>Visualização</strong>
                        <span id="estabelecimentosModeLabel">Dados comerciais</span>
                    </div>
                </div>

                <% if (hasOperationalColumns) { %>
                    <div class="estabelecimentos-view-tabs" role="tablist" aria-label="Modo de visualização da tabela">
                        <button
                            type="button"
                            class="estabelecimentos-view-tab is-active"
                            data-mode="commercial"
                            role="tab"
                            aria-selected="true"
                        >
                            Dados comerciais
                        </button>

                        <button
                            type="button"
                            class="estabelecimentos-view-tab"
                            data-mode="operational"
                            role="tab"
                            aria-selected="false"
                        >
                            Operacional
                        </button>
                    </div>
                <% } %>

                <div class="modern-table-wrap estabelecimentos-table-wrap">
                    <div class="modern-table-scroll estabelecimentos-table-scroll">
                        <table id="estabelecimentosTable" class="modern-table estabelecimentos-table is-commercial-view <%= operationalColumnsClass %>">
                            <thead>
                                <tr>
                                    <th class="est-col-name">Estabelecimento</th>
                                    <th class="mode-all est-col-product">Produto</th>
                                    <th class="mode-commercial est-col-address">Endereço</th>

                                    <% if (showBolinhasColumn) { %>
                                        <th class="mode-operational est-col-operation est-col-operation-key">
                                            <%= shouldPrefixOperationalLabel ? 'Chave bolinhas' : 'Chave' %>
                                        </th>
                                        <th class="mode-operational est-col-operation est-col-operation-machine">
                                            <%= shouldPrefixOperationalLabel ? 'Máquina bolinhas' : 'Máquina' %>
                                        </th>
                                    <% } %>

                                    <% if (showPeluciasColumn) { %>
                                        <th class="mode-operational est-col-operation est-col-operation-key">
                                            <%= shouldPrefixOperationalLabel ? 'Chave pelúcias' : 'Chave' %>
                                        </th>
                                        <th class="mode-operational est-col-operation est-col-operation-machine">
                                            <%= shouldPrefixOperationalLabel ? 'Máquina pelúcias' : 'Máquina' %>
                                        </th>
                                    <% } %>

                                    <th class="table-actions-heading est-actions-sticky">Ações</th>
                                </tr>
                            </thead>

                            <tbody>
                                <% estabelecimentos.forEach((estabelecimento) => { %>
                                    <% const produtoBase = String(estabelecimento.produtoFormatado || estabelecimento.produto || '').toUpperCase(); %>
                                    <% const hasBolinhas = produtoBase.includes('BOLINHAS'); %>
                                    <% const hasPelucias = produtoBase.includes('PELUCIAS') || produtoBase.includes('PELÚCIAS'); %>
                                    <% const enderecoCompleto = [estabelecimento.endereco, estabelecimento.bairro].filter(Boolean).join(', '); %>

                                    <% const chaveBolinhas = estabelecimento.chave_bolinhas || (hasBolinhas ? estabelecimento.chave : ''); %>
                                    <% const maquinaBolinhas = estabelecimento.maquina_bolinhas || (hasBolinhas ? estabelecimento.maquina : ''); %>
                                    <% const chavePelucias = estabelecimento.chave_pelucias || ''; %>
                                    <% const maquinaPelucias = estabelecimento.maquina_pelucias || ''; %>

                                    <tr>
                                        <td class="est-col-name" data-label="Estabelecimento">
                                            <div class="table-title-cell estabelecimento-title">
                                                <%= estabelecimento.estabelecimento %>
                                            </div>

                                            <div class="est-mobile-meta">
                                                <% if (estabelecimento.responsavel_nome) { %>
                                                    <span><i class="bi bi-person"></i> <%= estabelecimento.responsavel_nome %></span>
                                                <% } %>

                                                <% if (estabelecimento.telefone_contato) { %>
                                                    <span><i class="bi bi-telephone"></i> <%= formatPhone(estabelecimento.telefone_contato) %></span>
                                                <% } %>
                                            </div>
                                        </td>

                                        <td class="mode-all est-col-product" data-label="Produto">
                                            <span class="table-badge table-badge-blue estabelecimento-product-badge">
                                                <%= estabelecimento.produtoFormatado || estabelecimento.produto %>
                                            </span>
                                        </td>

                                        <td class="mode-commercial est-col-address" data-label="Endereço">
                                            <% if (enderecoCompleto) { %>
                                                <button
                                                    type="button"
                                                    class="table-address-link route-address-link estabelecimento-address-link"
                                                    data-address="<%= enderecoCompleto %>"
                                                    data-name="<%= estabelecimento.estabelecimento %>"
                                                    data-latitude="<%= estabelecimento.latitude ?? '' %>"
                                                    data-longitude="<%= estabelecimento.longitude ?? '' %>"
                                                >
                                                    <i class="bi bi-geo-alt"></i>
                                                    <span>
                                                        <strong><%= estabelecimento.endereco %></strong>
                                                        <% if (estabelecimento.bairro) { %>
                                                            <small><%= estabelecimento.bairro %></small>
                                                        <% } %>
                                                    </span>
                                                </button>
                                            <% } else { %>
                                                <span class="table-muted">Não informado</span>
                                            <% } %>
                                        </td>

                                        <% if (showBolinhasColumn) { %>
                                            <td
                                                class="mode-operational est-col-operation est-col-operation-key"
                                                data-label="<%= shouldPrefixOperationalLabel ? 'Chave bolinhas' : 'Chave' %>"
                                            >
                                                <% if (hasBolinhas) { %>
                                                    <span class="table-operational-pill table-operational-green <%= chaveBolinhas ? '' : 'is-empty' %>">
                                                        <%= chaveBolinhas || '-' %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="table-muted">-</span>
                                                <% } %>
                                            </td>

                                            <td
                                                class="mode-operational est-col-operation est-col-operation-machine"
                                                data-label="<%= shouldPrefixOperationalLabel ? 'Máquina bolinhas' : 'Máquina' %>"
                                            >
                                                <% if (hasBolinhas) { %>
                                                    <span class="table-operational-pill table-operational-green <%= maquinaBolinhas ? '' : 'is-empty' %>">
                                                        <%= maquinaBolinhas || '-' %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="table-muted">-</span>
                                                <% } %>
                                            </td>
                                        <% } %>

                                        <% if (showPeluciasColumn) { %>
                                            <td
                                                class="mode-operational est-col-operation est-col-operation-key"
                                                data-label="<%= shouldPrefixOperationalLabel ? 'Chave pelúcias' : 'Chave' %>"
                                            >
                                                <% if (hasPelucias) { %>
                                                    <span class="table-operational-pill table-operational-violet <%= chavePelucias ? '' : 'is-empty' %>">
                                                        <%= chavePelucias || '-' %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="table-muted">-</span>
                                                <% } %>
                                            </td>

                                            <td
                                                class="mode-operational est-col-operation est-col-operation-machine"
                                                data-label="<%= shouldPrefixOperationalLabel ? 'Máquina pelúcias' : 'Máquina' %>"
                                            >
                                                <% if (hasPelucias) { %>
                                                    <span class="table-operational-pill table-operational-violet <%= maquinaPelucias ? '' : 'is-empty' %>">
                                                        <%= maquinaPelucias || '-' %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="table-muted">-</span>
                                                <% } %>
                                            </td>
                                        <% } %>

                                        <td class="table-actions-cell est-actions-sticky" data-label="Ações">
                                            <div class="table-actions estabelecimento-actions">
                                                <a class="table-btn table-btn-view view-btn" data-id="<%= estabelecimento.id %>">
                                                    <i class="bi bi-eye"></i>
                                                    <span>Ver</span>
                                                </a>

                                                <% if (!isReadOnly) { %>
                                                    <a class="table-btn table-btn-edit edit-btn" data-id="<%= estabelecimento.id %>">
                                                        <i class="bi bi-pencil-square"></i>
                                                        <span>Editar</span>
                                                    </a>

                                                    <a class="table-btn table-btn-delete delete-btn" data-id="<%= estabelecimento.id %>">
                                                        <i class="bi bi-trash"></i>
                                                        <span>Excluir</span>
                                                    </a>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <% if (search) { %>
                <section class="list-panel">
                    <a href="/estabelecimentos" class="list-action">
                        <i class="bi bi-arrow-left"></i>
                        <span>Voltar para a lista completa</span>
                    </a>
                </section>
            <% } %>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const table = document.getElementById('estabelecimentosTable');
            const modeButtons = document.querySelectorAll('.estabelecimentos-view-tab');
            const modeLabel = document.getElementById('estabelecimentosModeLabel');

            const hasUsableCoordinates = (latitude, longitude) =>
                Number.isFinite(latitude) &&
                Number.isFinite(longitude) &&
                !(latitude === 0 && longitude === 0);

            const applyMode = (mode) => {
                document.querySelectorAll('.mode-commercial').forEach((cell) => {
                    cell.style.display = mode === 'commercial' ? '' : 'none';
                });

                document.querySelectorAll('.mode-operational').forEach((cell) => {
                    cell.style.display = mode === 'operational' ? '' : 'none';
                });

                if (table) {
                    table.classList.toggle('is-commercial-view', mode === 'commercial');
                    table.classList.toggle('is-operational-view', mode === 'operational');
                }

                modeButtons.forEach((button) => {
                    const isActive = button.getAttribute('data-mode') === mode;

                    button.classList.toggle('is-active', isActive);
                    button.setAttribute('aria-selected', String(isActive));
                });

                if (modeLabel) {
                    modeLabel.textContent = mode === 'commercial' ? 'Dados comerciais' : 'Operacional';
                }
            };

            const buildGoogleRouteUrl = (address, coords, destinationCoords) => {
                const destination = destinationCoords
                    ? `${destinationCoords.latitude},${destinationCoords.longitude}`
                    : encodeURIComponent(address);

                if (coords) {
                    return `https://www.google.com/maps/dir/?api=1&origin=${coords.latitude},${coords.longitude}&destination=${destination}&travelmode=driving`;
                }

                return `https://www.google.com/maps/dir/?api=1&destination=${destination}&travelmode=driving`;
            };

            const openRouteToAddress = (address, destinationCoords = null) => {
                if (!navigator.geolocation) {
                    window.open(buildGoogleRouteUrl(address, null, destinationCoords), '_blank', 'noopener');
                    return;
                }

                navigator.geolocation.getCurrentPosition(
                    (position) => {
                        const routeUrl = buildGoogleRouteUrl(address, {
                            latitude: position.coords.latitude,
                            longitude: position.coords.longitude
                        }, destinationCoords);

                        window.open(routeUrl, '_blank', 'noopener');
                    },
                    () => {
                        window.open(buildGoogleRouteUrl(address, null, destinationCoords), '_blank', 'noopener');
                    },
                    { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
                );
            };

            modeButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    const selectedMode = button.getAttribute('data-mode') || 'commercial';
                    localStorage.setItem('estabelecimentosViewMode', selectedMode);
                    applyMode(selectedMode);
                });
            });

            const savedMode = localStorage.getItem('estabelecimentosViewMode');
            const initialMode = savedMode === 'operational' ? 'operational' : 'commercial';

            applyMode(initialMode);

            document.querySelectorAll('.route-address-link').forEach((button) => {
                button.addEventListener('click', async function () {
                    const address = this.getAttribute('data-address');
                    const name = this.getAttribute('data-name');
                    const latitude = Number(this.getAttribute('data-latitude'));
                    const longitude = Number(this.getAttribute('data-longitude'));

                    if (!address) return;

                    const confirmed = await window.AppAlerts?.confirm({
                        title: 'Criar rota para o estabelecimento',
                        text: `Deseja abrir uma rota do seu ponto atual até ${name}?`,
                        confirmButtonText: 'Abrir rota',
                        cancelButtonText: 'Cancelar'
                    });

                    if (!confirmed) return;

                    openRouteToAddress(
                        address,
                        hasUsableCoordinates(latitude, longitude)
                            ? { latitude, longitude }
                            : null
                    );
                });
            });

            document.querySelectorAll('.view-btn').forEach((button) => {
                button.addEventListener('click', function () {
                    window.location.href = `/estabelecimentos/${this.getAttribute('data-id')}/view`;
                });
            });

            document.querySelectorAll('.edit-btn').forEach((button) => {
                button.addEventListener('click', function () {
                    window.location.href = `/estabelecimentos/${this.getAttribute('data-id')}/edit`;
                });
            });

            document.querySelectorAll('.delete-btn').forEach((button) => {
                button.addEventListener('click', async function () {
                    const idEstabelecimento = this.getAttribute('data-id');

                    const confirmed = await window.AppAlerts?.confirm({
                        title: 'Excluir estabelecimento',
                        text: 'Tem certeza que deseja excluir este estabelecimento?',
                        confirmButtonText: 'Excluir',
                        cancelButtonText: 'Cancelar'
                    });

                    if (!confirmed) return;

                    try {
                        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';
                        const response = await fetch(`/estabelecimentos/${idEstabelecimento}`, {
                            method: 'DELETE',
                            credentials: 'same-origin',
                            headers: {
                                'Accept': 'application/json',
                                'X-CSRF-Token': csrfToken
                            }
                        });

                        const contentType = response.headers.get('content-type') || '';
                        const data = contentType.includes('application/json')
                            ? await response.json()
                            : { message: await response.text() };

                        if (!response.ok) {
                            throw new Error(data.message || 'Erro ao excluir estabelecimento');
                        }

                        await window.AppAlerts?.success(data.message || 'Estabelecimento excluído com sucesso');
                        window.location.href = '/estabelecimentos';
                    } catch (error) {
                        window.AppAlerts?.error(error.message || 'Erro ao excluir estabelecimento');
                    }
                });
            });

            <% if (typeof success !== 'undefined' && success) { %>
                window.AppAlerts?.success("<%- success.replace(/"/g, '&quot;') %>");
            <% } %>

            <% if (typeof error !== 'undefined' && error) { %>
                window.AppAlerts?.error("<%- error.replace(/"/g, '&quot;') %>");
            <% } %>
        });
    </script>
</body>
</html>