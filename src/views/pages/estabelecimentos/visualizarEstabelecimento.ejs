<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Visualizar Estabelecimento' }) %>

<body class="view-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="view-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Visualizar Estabelecimento' }) %>

        <section class="view-hero view-hero-neutral">
            <div class="view-hero-content">
                <span class="form-kicker"><i class="bi bi-shop-window"></i> Administrativo</span>
                <h1><%= estabelecimento.estabelecimento %></h1>
                <p>Visualize rapidamente os dados comerciais e operacionais do ponto em um layout mais limpo, com leitura rápida para contato, endereço e produtos vinculados.</p>
            </div>
            <div class="view-hero-side">
                <div class="list-stat">
                    <strong>ID</strong>
                    <span>#<%= estabelecimento.id %></span>
                </div>
                <div class="list-stat">
                    <strong>Status do cadastro</strong>
                    <span><%= estabelecimento.status || 'Ativo' %></span>
                </div>
            </div>
        </section>

        <main class="view-stage">
            <section class="view-panel">
                <div class="view-panel-header">
                    <div>
                        <span class="form-section-tag">Resumo</span>
                        <h2>Dados do estabelecimento</h2>
                        <p>Essas informações concentram o que a equipe precisa para localizar, atender e operar o ponto com segurança.</p>
                    </div>
                </div>

                <div class="view-grid">
                    <div class="view-card">
                        <strong>Produtos vinculados</strong>
                        <span><%= estabelecimento.produtoFormatado || estabelecimento.produto || 'Não informado' %></span>
                    </div>
                    <div class="view-card">
                        <strong>Responsável</strong>
                        <span><%= estabelecimento.responsavel_nome || 'Não informado' %></span>
                    </div>
                    <div class="view-card">
                        <strong>Contato</strong>
                        <span><%= estabelecimento.telefone_contato || 'Não informado' %></span>
                    </div>
                    <div class="view-card">
                        <strong>Bairro</strong>
                        <span><%= estabelecimento.bairro || 'Não informado' %></span>
                    </div>
                    <div class="view-card is-wide">
                        <strong>Endereço</strong>
                        <span><%= estabelecimento.endereco || 'Não informado' %></span>
                    </div>
                    <div class="view-card">
                        <strong>Chave</strong>
                        <span><%= estabelecimento.chave || 'Não informado' %></span>
                    </div>
                    <div class="view-card">
                        <strong>Máquina</strong>
                        <span><%= estabelecimento.maquina || 'Não informado' %></span>
                    </div>
                    <div class="view-card">
                        <strong>Data de cadastro</strong>
                        <span><%= new Date(estabelecimento.data_criacao).toLocaleDateString('pt-BR') %></span>
                    </div>
                    <div class="view-card">
                        <strong>Última edição</strong>
                        <span><%= data_atualizacao ? new Date(data_atualizacao).toLocaleDateString('pt-BR') : 'Não informado' %></span>
                    </div>
                    <div class="view-card is-wide">
                        <strong>Observações</strong>
                        <span><%= estabelecimento.observacoes || 'Sem observações cadastradas.' %></span>
                    </div>
                </div>

                <div class="view-actions">
                    <div class="view-actions-copy">
                        Revise este cadastro antes de editar ou retornar para a listagem geral dos estabelecimentos.
                    </div>
                    <div class="view-actions-buttons">
                        <a href="/estabelecimentos" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Voltar</span>
                        </a>
                        <a href="/estabelecimentos/<%= estabelecimento.id %>/edit" class="btn-modern">
                            <i class="bi bi-pencil-square"></i>
                            <span>Editar cadastro</span>
                        </a>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>

