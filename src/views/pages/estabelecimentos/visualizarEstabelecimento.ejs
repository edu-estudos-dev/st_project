<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Visualizar Estabelecimento' }) %>

<body class="bg-light">
    <%- include('../../partials/header') %>

    <div class="page-spacer"></div>

    <div class="page-shell py-3">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Visualizar Estabelecimento' }) %>

        <div class="cabecalho-geral">
            <h1 class="mb-0">Visualizar Estabelecimento</h1>
            <a href="/estabelecimentos" class="btn btn-voltar">Voltar</a>
        </div>

        <main class="mb-4 geral">
            <div class="card shadow detail-card">
                <div class="card-body">
                    <div class="detail-header">
                        <div class="detail-title">
                            <p class="mb-0">Estabelecimento:</p>
                            <h4 class="mb-0"><strong><%= estabelecimento.estabelecimento.toUpperCase() %></strong></h4>
                        </div>
                        <p class="mb-0"><strong>ID:</strong> <%= estabelecimento.id %></p>
                    </div>

                    <hr>

                    <div class="detail-grid detail-stack">
                        <div>
                            <p>Produtos: <strong><%= (estabelecimento.produtoFormatado || estabelecimento.produto).toUpperCase() %></strong></p>
                            <p>Responsável: <strong><%= estabelecimento.responsavel_nome.toUpperCase() %></strong></p>
                            <p>Endereço: <strong><%= estabelecimento.endereco.toUpperCase() %></strong></p>
                            <p>Bairro: <strong><%= estabelecimento.bairro.toUpperCase() %></strong></p>
                            <p>Observações: <strong><%= estabelecimento.observacoes ? estabelecimento.observacoes.toUpperCase() : 'N/A' %></strong></p>
                        </div>
                        <div>
                            <p>Telefone: <strong><%= estabelecimento.telefone_contato %></strong></p>
                            <p>Chave: <strong><%= estabelecimento.chave ? estabelecimento.chave.toUpperCase() : 'N/A' %></strong></p>
                            <p>Máquina: <strong><%= estabelecimento.maquina ? estabelecimento.maquina.toUpperCase() : 'N/A' %></strong></p>
                            <p>Dia do Cadastro: <strong><%= new Date(estabelecimento.data_criacao).toLocaleDateString('pt-BR') %></strong></p>
                            <p>Última Edição: <strong><%= data_atualizacao ? new Date(data_atualizacao).toLocaleDateString('pt-BR') : 'N/A' %></strong></p>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
