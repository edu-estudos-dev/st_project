<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Visualizar Estabelecimento' }) %>

<body class="view-page-body">
    <%- include('../../partials/header') %>

    <% const isReadOnly = Boolean(typeof assinaturaSomenteLeitura !== 'undefined' && assinaturaSomenteLeitura); %>
    <% const enderecoCompleto = estabelecimento ? [estabelecimento.endereco, estabelecimento.bairro].filter(Boolean).join(', ') : ''; %>

    <% const formatPhone = (value) => {
        const rawValue = String(value || '').trim();
        const digits = rawValue.replace(/\D/g, '');

        if (!digits) {
            return 'Não informado';
        }

        if (digits.length === 11) {
            return `(${digits.slice(0, 2)}) ${digits.slice(2, 7)}-${digits.slice(7)}`;
        }

        if (digits.length === 10) {
            return `(${digits.slice(0, 2)}) ${digits.slice(2, 6)}-${digits.slice(6)}`;
        }

        return rawValue;
    }; %>

    <% const formatOperationalValue = (value) => {
        const rawValue = String(value ?? '').trim();

        if (!rawValue) {
            return 'Não informado';
        }

        return rawValue;
    }; %>

    <% const isFilled = (value) => String(value ?? '').trim().length > 0; %>

    <div class="page-spacer"></div>

    <div class="view-shell estabelecimento-view-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Visualizar Estabelecimento' }) %>

        <section class="page-titlebar page-titlebar-neutral">
            <div class="page-titlebar-content">
                <span class="form-kicker"><i class="bi bi-shop-window"></i> Administrativo</span>
                <h1><%= estabelecimento ? estabelecimento.estabelecimento : 'Estabelecimento não encontrado' %></h1>
                <p>Visualize os dados comerciais e operacionais do ponto em uma leitura simples para consulta ou edição.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="list-stat">
                    <strong>ID</strong>
                    <span><%= estabelecimento ? `#${estabelecimento.id}` : 'N/A' %></span>
                </div>

                <div class="list-stat">
                    <strong>Status do cadastro</strong>
                    <span><%= estabelecimento?.status || 'Ativo' %></span>
                </div>
            </div>
        </section>

        <main class="view-stage">
            <section class="view-panel estabelecimento-view-panel">
                <% if (estabelecimento) { %>
                    <% const produtoBase = String(estabelecimento.produtoFormatado || estabelecimento.produto || '').toUpperCase(); %>
                    <% const produtoNormalizado = produtoBase.normalize('NFD').replace(/[\u0300-\u036f]/g, ''); %>

                    <% const hasBolinhas = produtoNormalizado.includes('BOLINHAS'); %>
                    <% const hasConsignados = produtoNormalizado.includes('CONSIGNADOS') || produtoNormalizado.includes('FIGURINHAS') || produtoNormalizado.includes('FIG'); %>
                    <% const hasPelucias = produtoNormalizado.includes('PELUCIAS'); %>

                    <% const chaveBolinhas = estabelecimento.chave_bolinhas || (hasBolinhas ? estabelecimento.chave : ''); %>
                    <% const maquinaBolinhas = estabelecimento.maquina_bolinhas || (hasBolinhas ? estabelecimento.maquina : ''); %>

                    <% const consignadoQuantidadeInicial = estabelecimento.consignado_quantidade_inicial || estabelecimento.figurinha_quantidade_inicial || ''; %>

                    <% const chavePelucias = estabelecimento.chave_pelucias || ''; %>
                    <% const maquinaPelucias = estabelecimento.maquina_pelucias || ''; %>
                    <% const peluciaLeituraInicial = estabelecimento.pelucia_leitura_inicial || ''; %>
                    <% const peluciaAbastecidoInicial = estabelecimento.pelucia_abastecido_inicial || ''; %>

                    <% const produtoPrincipal = estabelecimento.produtoFormatado || estabelecimento.produto || 'Não informado'; %>
                    <% const hasOperationalData = hasBolinhas || hasConsignados || hasPelucias; %>

                    <div class="view-panel-header">
                        <div>
                            <span class="form-section-tag">Resumo</span>
                            <h2>Dados do estabelecimento</h2>
                            <p>Essas informações ajudam a localizar, atender e operar o ponto com segurança.</p>
                        </div>
                    </div>

                    <div class="view-section-title">
                        <span>Dados comerciais</span>
                        <small>Identificação, contato e endereço do ponto.</small>
                    </div>

                    <div class="view-grid">
                        <div class="view-card">
                            <strong>Produtos vinculados</strong>
                            <span><%= produtoPrincipal %></span>
                        </div>

                        <div class="view-card">
                            <strong>Responsável</strong>
                            <span><%= estabelecimento.responsavel_nome || 'Não informado' %></span>
                        </div>

                        <div class="view-card">
                            <strong>Contato</strong>
                            <span><%= formatPhone(estabelecimento.telefone_contato) %></span>
                        </div>

                        <div class="view-card">
                            <strong>Bairro</strong>
                            <span><%= estabelecimento.bairro || 'Não informado' %></span>
                        </div>

                        <div class="view-card is-wide">
                            <strong>Endereço</strong>
                            <span><%= estabelecimento.endereco || 'Não informado' %></span>
                        </div>
                    </div>

                    <% if (hasOperationalData) { %>
                        <div class="view-section-title view-section-title-spaced">
                            <span>Dados operacionais</span>
                            <small>Informações usadas na operação de campo, estoque e identificação dos produtos ativos.</small>
                        </div>

                        <div class="view-grid view-operational-grid">
                            <% if (hasBolinhas) { %>
                                <div class="view-card view-card-product view-card-product-green">
                                    <strong>
                                        <span class="view-product-tag view-product-tag-green">Bolinhas</span>
                                        Chave da máquina
                                    </strong>
                                    <span class="<%= isFilled(chaveBolinhas) ? '' : 'view-empty-value' %>">
                                        <%= formatOperationalValue(chaveBolinhas) %>
                                    </span>
                                </div>

                                <div class="view-card view-card-product view-card-product-green">
                                    <strong>
                                        <span class="view-product-tag view-product-tag-green">Bolinhas</span>
                                        Número da máquina
                                    </strong>
                                    <span class="<%= isFilled(maquinaBolinhas) ? '' : 'view-empty-value' %>">
                                        <%= formatOperationalValue(maquinaBolinhas) %>
                                    </span>
                                </div>
                            <% } %>

                            <% if (hasConsignados) { %>
                                <div class="view-card view-card-product view-card-product-blue">
                                    <strong>
                                        <span class="view-product-tag view-product-tag-blue">Consignados</span>
                                        Quantidade inicial deixada
                                    </strong>
                                    <span class="<%= isFilled(consignadoQuantidadeInicial) ? '' : 'view-empty-value' %>">
                                        <%= formatOperationalValue(consignadoQuantidadeInicial) %>
                                    </span>
                                </div>
                            <% } %>

                            <% if (hasPelucias) { %>
                                <div class="view-card view-card-product view-card-product-violet">
                                    <strong>
                                        <span class="view-product-tag view-product-tag-violet">Pelúcias</span>
                                        Chave da máquina
                                    </strong>
                                    <span class="<%= isFilled(chavePelucias) ? '' : 'view-empty-value' %>">
                                        <%= formatOperationalValue(chavePelucias) %>
                                    </span>
                                </div>

                                <div class="view-card view-card-product view-card-product-violet">
                                    <strong>
                                        <span class="view-product-tag view-product-tag-violet">Pelúcias</span>
                                        Número da máquina
                                    </strong>
                                    <span class="<%= isFilled(maquinaPelucias) ? '' : 'view-empty-value' %>">
                                        <%= formatOperationalValue(maquinaPelucias) %>
                                    </span>
                                </div>

                                <div class="view-card view-card-product view-card-product-violet">
                                    <strong>
                                        <span class="view-product-tag view-product-tag-violet">Pelúcias</span>
                                        Leitura inicial
                                    </strong>
                                    <span class="<%= isFilled(peluciaLeituraInicial) ? '' : 'view-empty-value' %>">
                                        <%= formatOperationalValue(peluciaLeituraInicial) %>
                                    </span>
                                </div>

                                <div class="view-card view-card-product view-card-product-violet">
                                    <strong>
                                        <span class="view-product-tag view-product-tag-violet">Pelúcias</span>
                                        Quantidade inicial
                                    </strong>
                                    <span class="<%= isFilled(peluciaAbastecidoInicial) ? '' : 'view-empty-value' %>">
                                        <%= formatOperationalValue(peluciaAbastecidoInicial) %>
                                    </span>
                                </div>
                            <% } %>
                        </div>
                    <% } %>

                    <div class="view-section-title view-section-title-spaced">
                        <span>Histórico e observações</span>
                        <small>Datas de cadastro, última atualização e observações internas.</small>
                    </div>

                    <div class="view-grid">
                        <div class="view-card">
                            <strong>Data de cadastro</strong>
                            <span><%= estabelecimento.data_criacao ? new Date(estabelecimento.data_criacao).toLocaleDateString('pt-BR') : 'Não informado' %></span>
                        </div>

                        <div class="view-card">
                            <strong>Última edição</strong>
                            <span class="<%= estabelecimento.data_atualizacao ? '' : 'view-empty-value' %>">
                                <%= estabelecimento.data_atualizacao ? new Date(estabelecimento.data_atualizacao).toLocaleDateString('pt-BR') : 'Não informado' %>
                            </span>
                        </div>

                        <div class="view-card is-wide">
                            <strong>Observações</strong>
                            <span class="<%= estabelecimento.observacoes ? '' : 'view-empty-value' %>">
                                <%= estabelecimento.observacoes || 'Sem observações cadastradas.' %>
                            </span>
                        </div>
                    </div>
                <% } else { %>
                    <p class="mb-0">Estabelecimento não encontrado.</p>
                <% } %>

                <div class="view-actions">
                    <div class="view-actions-copy">
                        <%= estabelecimento
                            ? 'Revise este cadastro antes de editar, gerar uma rota ou retornar para a listagem geral.'
                            : 'Você pode voltar para a listagem geral de estabelecimentos e continuar a navegação normalmente.' %>
                    </div>

                    <div class="view-actions-buttons">
                        <a href="/estabelecimentos" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Voltar</span>
                        </a>

                        <% if (estabelecimento && enderecoCompleto) { %>
                            <button
                                type="button"
                                class="btn-route-secondary"
                                id="openRouteFromViewButton"
                                data-address="<%= enderecoCompleto %>"
                                data-name="<%= estabelecimento.estabelecimento %>"
                                data-latitude="<%= estabelecimento.latitude ?? '' %>"
                                data-longitude="<%= estabelecimento.longitude ?? '' %>"
                            >
                                <i class="bi bi-sign-turn-right"></i>
                                <span>Gerar rota até aqui</span>
                            </button>
                        <% } %>

                        <% if (estabelecimento && !isReadOnly) { %>
                            <a href="/estabelecimentos/<%= estabelecimento.id %>/edit" class="btn-modern">
                                <i class="bi bi-pencil-square"></i>
                                <span>Editar cadastro</span>
                            </a>
                        <% } %>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const routeButton = document.getElementById('openRouteFromViewButton');
            if (!routeButton) return;

            const hasUsableCoordinates = (latitude, longitude) =>
                Number.isFinite(latitude) &&
                Number.isFinite(longitude) &&
                !(latitude === 0 && longitude === 0);

            const buildGoogleRouteUrl = (address, originCoords, destinationCoords) => {
                const destination = destinationCoords
                    ? `${destinationCoords.latitude},${destinationCoords.longitude}`
                    : encodeURIComponent(address);

                if (originCoords) {
                    return `https://www.google.com/maps/dir/?api=1&origin=${originCoords.latitude},${originCoords.longitude}&destination=${destination}&travelmode=driving`;
                }

                return `https://www.google.com/maps/dir/?api=1&destination=${destination}&travelmode=driving`;
            };

            routeButton.addEventListener('click', async () => {
                const address = routeButton.getAttribute('data-address');
                const name = routeButton.getAttribute('data-name');
                const latitude = Number(routeButton.getAttribute('data-latitude'));
                const longitude = Number(routeButton.getAttribute('data-longitude'));

                if (!address) return;

                const confirmed = await window.AppAlerts?.confirm({
                    title: 'Criar rota para o estabelecimento',
                    text: `Deseja abrir uma rota do seu ponto atual até ${name}?`,
                    confirmButtonText: 'Abrir rota',
                    cancelButtonText: 'Cancelar'
                });

                if (!confirmed) return;

                const destinationCoords =
                    hasUsableCoordinates(latitude, longitude)
                        ? { latitude, longitude }
                        : null;

                if (!navigator.geolocation) {
                    window.open(buildGoogleRouteUrl(address, null, destinationCoords), '_blank', 'noopener');
                    return;
                }

                navigator.geolocation.getCurrentPosition(
                    (position) => {
                        window.open(
                            buildGoogleRouteUrl(
                                address,
                                {
                                    latitude: position.coords.latitude,
                                    longitude: position.coords.longitude
                                },
                                destinationCoords
                            ),
                            '_blank',
                            'noopener'
                        );
                    },
                    () => {
                        window.open(buildGoogleRouteUrl(address, null, destinationCoords), '_blank', 'noopener');
                    },
                    { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
                );
            });
        });
    </script>
</body>
</html>