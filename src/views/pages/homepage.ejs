        <script>
          document.addEventListener('DOMContentLoaded', () => {
            const menuToggle = document.querySelector('[data-menu-toggle]');
            const homepageNav = document.querySelector('[data-homepage-nav]');
            const homepageHeader = document.querySelector('[data-homepage-header]');
            const whatsappFloat = document.querySelector('.vm-whatsapp-float');

            if (whatsappFloat) {
              const whatsappLinkSelector = [
                'a[href*="wa.me"]',
                'a[href*="api.whatsapp.com"]',
                'a[href*="whatsapp"]'
              ].join(',');

              const getSectionsToCheck = () => [
                ...document.querySelectorAll('main section'),
                ...document.querySelectorAll('.site-footer')
              ];

              const sectionHasWhatsappButton = (section) => {
                return Boolean(section.querySelector(whatsappLinkSelector));
              };

              const sectionIsInFocus = (section) => {
                const rect = section.getBoundingClientRect();
                const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
                const focusLine = viewportHeight * 0.62;

                return rect.top <= focusLine && rect.bottom >= focusLine;
              };

              const hideWhatsappFloat = () => {
                whatsappFloat.style.setProperty('display', 'none', 'important');
              };

              const showWhatsappFloat = () => {
                whatsappFloat.style.removeProperty('display');
              };

              const toggleWhatsappFloat = () => {
                const isMobile = window.matchMedia('(max-width: 575.98px)').matches;

                if (!isMobile) {
                  showWhatsappFloat();
                  return;
                }

                const focusedSection = getSectionsToCheck().find(sectionIsInFocus);

                if (!focusedSection) {
                  showWhatsappFloat();
                  return;
                }

                const shouldHideFloat = sectionHasWhatsappButton(focusedSection);

                if (shouldHideFloat) {
                  hideWhatsappFloat();
                } else {
                  showWhatsappFloat();
                }
              };

              toggleWhatsappFloat();

              window.addEventListener('scroll', toggleWhatsappFloat, { passive: true });
              window.addEventListener('resize', toggleWhatsappFloat);
              window.addEventListener('orientationchange', toggleWhatsappFloat);
            }

            function closeHomepageMenu() {
              document.body.classList.remove('homepage-menu-open');
              menuToggle?.setAttribute('aria-expanded', 'false');
            }

            if (menuToggle && homepageNav) {
              menuToggle.addEventListener('click', () => {
                const isOpen = document.body.classList.toggle('homepage-menu-open');
                menuToggle.setAttribute('aria-expanded', String(isOpen));
              });

              homepageNav.querySelectorAll('a').forEach((link) => {
                link.addEventListener('click', closeHomepageMenu);
              });

              document.addEventListener('click', (event) => {
                if (!document.body.classList.contains('homepage-menu-open')) return;
                if (homepageHeader?.contains(event.target)) return;
                closeHomepageMenu();
              });

              document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') closeHomepageMenu();
              });
            }

            const dashboardShowcase = document.querySelector('#solucao.vm-dashboard-showcase');

            if (dashboardShowcase) {
              const showDashboardAnimation = () => {
                dashboardShowcase.classList.add('is-dashboard-visible');
              };

              if ('IntersectionObserver' in window) {
                const dashboardObserver = new IntersectionObserver(
                  (entries, observer) => {
                    entries.forEach((entry) => {
                      if (!entry.isIntersecting) return;

                      showDashboardAnimation();
                      observer.unobserve(entry.target);
                    });
                  },
                  {
                    threshold: 0.28,
                    rootMargin: '0px 0px -12% 0px'
                  }
                );

                dashboardObserver.observe(dashboardShowcase);
              } else {
                showDashboardAnimation();
              }
            }

            const founderSection = document.querySelector('.vm-founder-section');

            if (founderSection) {
              const showFounderAnimation = () => {
                founderSection.classList.add('is-founder-visible');
              };

              if ('IntersectionObserver' in window) {
                const founderObserver = new IntersectionObserver(
                  (entries, observer) => {
                    entries.forEach((entry) => {
                      if (!entry.isIntersecting) return;

                      showFounderAnimation();
                      observer.unobserve(entry.target);
                    });
                  },
                  {
                    threshold: 0.26,
                    rootMargin: '0px 0px -10% 0px'
                  }
                );

                founderObserver.observe(founderSection);
              } else {
                showFounderAnimation();
              }
            }

            const proofSection = document.querySelector('.vm-proof-section');

            if (proofSection) {
              const showProofAnimation = () => {
                proofSection.classList.add('is-proof-visible');
              };

              if ('IntersectionObserver' in window) {
                const proofObserver = new IntersectionObserver(
                  (entries, observer) => {
                    entries.forEach((entry) => {
                      if (!entry.isIntersecting) return;

                      showProofAnimation();
                      observer.unobserve(entry.target);
                    });
                  },
                  {
                    threshold: 0.24,
                    rootMargin: '0px 0px -10% 0px'
                  }
                );

                proofObserver.observe(proofSection);
              } else {
                showProofAnimation();
              }
            }

            const guaranteeSection = document.querySelector('.vm-guarantee-section');

            if (guaranteeSection) {
              const showGuaranteeAnimation = () => {
                guaranteeSection.classList.add('is-guarantee-visible');
              };

              if ('IntersectionObserver' in window) {
                const guaranteeObserver = new IntersectionObserver(
                  (entries, observer) => {
                    entries.forEach((entry) => {
                      if (!entry.isIntersecting) return;

                      showGuaranteeAnimation();
                      observer.unobserve(entry.target);
                    });
                  },
                  {
                    threshold: 0.26,
                    rootMargin: '0px 0px -10% 0px'
                  }
                );

                guaranteeObserver.observe(guaranteeSection);
              } else {
                showGuaranteeAnimation();
              }
            }

            const blogPreviewSection = document.querySelector('#blog-preview.vm-blog-preview-section');
            const blogPreviewGrid = blogPreviewSection?.querySelector('.vm-blog-preview-grid');

            if (blogPreviewSection && blogPreviewGrid) {
              const showBlogAnimation = () => {
                blogPreviewSection.classList.add('is-blog-visible');
              };

              if ('IntersectionObserver' in window) {
                const blogObserver = new IntersectionObserver(
                  (entries, observer) => {
                    entries.forEach((entry) => {
                      if (!entry.isIntersecting) return;

                      showBlogAnimation();
                      observer.unobserve(entry.target);
                    });
                  },
                  {
                    threshold: 0.18,
                    rootMargin: '0px 0px -18% 0px'
                  }
                );

                blogObserver.observe(blogPreviewGrid);
              } else {
                showBlogAnimation();
              }
            }

            const faqSection = document.querySelector('#faq.vm-faq-section');
            const faqGrid = faqSection?.querySelector('.vm-faq-grid');

            if (faqSection && faqGrid) {
              const showFaqAnimation = () => {
                faqSection.classList.add('is-faq-visible');
              };

              if ('IntersectionObserver' in window) {
                const faqObserver = new IntersectionObserver(
                  (entries, observer) => {
                    entries.forEach((entry) => {
                      if (!entry.isIntersecting) return;

                      showFaqAnimation();
                      observer.unobserve(entry.target);
                    });
                  },
                  {
                    threshold: 0.18,
                    rootMargin: '0px 0px -14% 0px'
                  }
                );

                faqObserver.observe(faqGrid);
              } else {
                showFaqAnimation();
              }
            }

            const contactSection = document.querySelector('#contato.vm-contact');
            const contactFormBox = contactSection?.querySelector('.vm-contact-form');

            if (contactSection && contactFormBox) {
              const showContactAnimation = () => {
                contactSection.classList.add('is-contact-visible');
              };

              if ('IntersectionObserver' in window) {
                const contactObserver = new IntersectionObserver(
                  (entries, observer) => {
                    entries.forEach((entry) => {
                      if (!entry.isIntersecting) return;

                      showContactAnimation();
                      observer.unobserve(entry.target);
                    });
                  },
                  {
                    threshold: 0.22,
                    rootMargin: '0px 0px -10% 0px'
                  }
                );

                contactObserver.observe(contactFormBox);
              } else {
                showContactAnimation();
              }
            }

            const transformSection = document.querySelector('.vm-transform');
            const transformContent = transformSection?.querySelector('.vm-before-after');

            if (transformSection && transformContent) {
              const showTransformAnimation = () => {
                transformSection.classList.add('is-transform-visible');
              };

              if ('IntersectionObserver' in window) {
                const transformObserver = new IntersectionObserver(
                  (entries, observer) => {
                    entries.forEach((entry) => {
                      if (!entry.isIntersecting) return;

                      showTransformAnimation();
                      observer.unobserve(entry.target);
                    });
                  },
                  {
                    threshold: 0.24,
                    rootMargin: '0px 0px -10% 0px'
                  }
                );

                transformObserver.observe(transformContent);
              } else {
                showTransformAnimation();
              }
            }

            const form = document.getElementById('contactForm');
            const submitButton = form?.querySelector('button[type="submit"]');
            const statusElement = document.getElementById('contactStatus');
            const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';

            if (!form) return;

            form.addEventListener('submit', async (event) => {
              event.preventDefault();

              const formData = new FormData(form);
              const payload = {
                nome: String(formData.get('nome') || '').trim(),
                telefone: String(formData.get('telefone') || '').trim(),
                produtos: formData.getAll('produtos[]'),
                preferenciaContato: String(formData.get('preferenciaContato') || '').trim()
              };

              if (!payload.nome || !payload.telefone) {
                window.AppAlerts?.warning('Preencha nome e WhatsApp para solicitar a demonstração.');
                return;
              }

              submitButton.disabled = true;
              statusElement.textContent = 'Enviando suas informações...';

              try {
                const response = await fetch(form.action, {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/json',
                    Accept: 'application/json',
                    'X-CSRF-Token': csrfToken
                  },
                  body: JSON.stringify(payload)
                });

                const data = await response.json();

                if (!response.ok) {
                  throw new Error(data.message || 'Não foi possível enviar sua solicitação agora.');
                }

                form.reset();
                statusElement.textContent = data.message || 'Solicitação enviada com sucesso.';
                window.AppAlerts?.success(data.message || 'Solicitação enviada com sucesso.');
              } catch (error) {
                statusElement.textContent = error.message;
                window.AppAlerts?.error(error.message || 'Erro ao enviar as informações.');
              } finally {
                submitButton.disabled = false;
              }
            });
          });
        </script>

        <script defer src="/js/homepage.js"></script>
    </body>

  </html>
