      <section class="entrar-em-contato">
         <h2>Gostaria de ter em seu estabelecimento algum dos nossos produtos?</h2>
         <h3>Entre em contato agora mesmo.</h3>
         <form id="contactForm" action="/enviar-contato" method="POST">
            <div class="inputs">
               <div class="box-1 py-3">

                  <label for="nome">Nome:</label>
                  <input type="text" id="nome" name="nome" required>

                  <label class="mt-3" for="telefone">Telefone:</label>
                  <input type="text" id="telefone" name="telefone" required placeholder="Somente Números.">

               </div>
               <div class="box-2 p-5">
                  <p>Quais produtos você tem interesse em colocar em seu estabelecimento?</p>
                  <div class="checkbox-container">
                     <div class="checkbox-item">
                        <input type="checkbox" id="produto1" name="produtos" value="Maquina de Bolinhas">
                        <label class="m-0 me-5" for="produto1">Máquina de Bolinhas</label>
                        <input type="checkbox" id="produto2" name="produtos" value="Figurinhas">
                        <label class="m-0 me-5" for="produto2">Figurinhas</label>
                        <input type="checkbox" id="produto3" name="produtos" value="Maquina de Ursinho">
                        <label class="m-0 me-5" for="produto3">Máquina de Ursinho</label>
                     </div>
                  </div>
                  <div class="d-flex justify-content-center w-100">
                     <button type="submit" class="btn btn-primary w-50">Enviar</button>
                  </div>
               </div>
            </div>
         </form>

         <span class="contact-actions">
            <a href="https://wa.me/5585986992706" target="_blank" class="contact-link">
               <i class="bi bi-whatsapp"></i> (85) 9 8699-2706
            </a> &nbsp; &nbsp;
            <a href="https://wa.me/5585994287650" target="_blank" class="contact-link">
               <i class="bi bi-whatsapp"></i> (85) 9 9428-7650
            </a>
         </span>
      </section>

      <section class="depoimentos">
         <h2 class="titulo-servicos">O que nossos clientes dizem</h2>
         <div class="depoimentos-container">
            <figure class="depoimento">
               <blockquote class="blockquote">
                  <p>"A SuperToys superou todas as minhas expectativas! A festa do meu filho foi incrível, desde a
                     decoração até a animação. As crianças se divertiram muito e os adultos ficaram impressionados.
                     Recomendo de olhos fechados!"</p>
               </blockquote>
               <figcaption class="blockquote-footer">
                  Ana Silva, mãe do Pedro Paulo.
               </figcaption>
            </figure>
            <figure class="depoimento">
               <blockquote class="blockquote">
                  <p>"A SuperToys é a melhor escolha para quem busca um evento personalizado e inesquecível. A equipe é
                     super atenciosa e criativa, transformando cada festa em um momento mágico. Obrigada por tudo!"</p>
               </blockquote>
               <figcaption class="blockquote-footer">
                  Carlos Ubirajara, cliente satisfeito
               </figcaption>
            </figure>
            <figure class="depoimento">
               <blockquote class="blockquote">
                  <p>"A SuperToys me ajudou a realizar o casamento dos meus sonhos. Tudo foi perfeito, desde a
                     organização até a execução. A equipe é profissional e dedicada, e o resultado final foi além do que
                     eu imaginava. Recomendo a todos!"</p>
               </blockquote>
               <figcaption class="blockquote-footer">
                  Julia Oliveira, noiva feliz
               </figcaption>
            </figure>
         </div>
      </section>

      <script>
         document.addEventListener('DOMContentLoaded', () => {
            const telefoneInput = document.getElementById('telefone');

            telefoneInput.addEventListener('input', (e) => {
               let value = e.target.value.replace(/\D/g, '');
               if (value.length > 11) value = value.slice(0, 11);

               if (value.length > 0) value = `(${value.slice(0, 2)}) ${value.slice(2)}`;
               if (value.length > 3) value = `${value.slice(0, 4)} ${value.slice(4)}`;
               if (value.length > 10) value = `${value.slice(0, 10)}-${value.slice(10)}`;

               e.target.value = value;
            });

            const form = document.getElementById('contactForm');
            form.addEventListener('submit', async function (event) {
               event.preventDefault();

               const nome = document.getElementById('nome').value.trim();
               const telefone = telefoneInput.value.replace(/\D/g, ''); // Remove caracteres não numéricos
               const checkboxes = document.querySelectorAll('input[name="produtos"]');
               const isChecked = Array.from(checkboxes).some(checkbox => checkbox.checked);

               if (!nome) {
                  window.AppAlerts.warning('Por favor, insira seu nome.');
                  return;
               }

               if (!telefone || telefone.length !== 11) {
                  window.AppAlerts.warning('Por favor, insira um telefone valido com 11 digitos (DDD + numero).');
                  return;
               }

               if (!isChecked) {
                  window.AppAlerts.warning('Por favor, marque pelo menos um produto.');
                  return;
               }

               const formData = new FormData(this);
               const formDataObj = Object.fromEntries(formData.entries());

               try {
                  const response = await fetch('/enviar-contato', {
                     method: 'POST',
                     headers: {
                        'Content-Type': 'application/json'
                     },
                     body: JSON.stringify(formDataObj)
                  });

                  if (response.ok) {
                     const result = await response.json();
                     window.AppAlerts.success(result.message);
                     this.reset(); // Limpa o formulário após submissão bem-sucedida
                  } else {
                     const result = await response.json();
                     window.AppAlerts.error(result.message);
                  }
               } catch (error) {
                  window.AppAlerts.error('Erro ao enviar as informacoes.');
               }
            });
         });
      </script>




   </body>

   <%- include('../partials/footer') %>

</html>
