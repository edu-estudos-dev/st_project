    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const menuToggle = document.querySelector('[data-menu-toggle]');
        const homepageNav = document.querySelector('[data-homepage-nav]');
        const homepageHeader = document.querySelector('[data-homepage-header]');

        function closeHomepageMenu() {
          document.body.classList.remove('homepage-menu-open');
          menuToggle?.setAttribute('aria-expanded', 'false');
        }

        if (menuToggle && homepageNav) {
          menuToggle.addEventListener('click', () => {
            const isOpen = document.body.classList.toggle('homepage-menu-open');
            menuToggle.setAttribute('aria-expanded', String(isOpen));
          });

          homepageNav.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeHomepageMenu));

          document.addEventListener('click', (event) => {
            if (!document.body.classList.contains('homepage-menu-open')) return;
            if (homepageHeader?.contains(event.target)) return;
            closeHomepageMenu();
          });

          document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') closeHomepageMenu();
          });
        }

        const form = document.getElementById('contactForm');
        const submitButton = form?.querySelector('button[type="submit"]');
        const statusElement = document.getElementById('contactStatus');
        const csrfToken = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') || '';

        if (!form) return;

        form.addEventListener('submit', async (event) => {
          event.preventDefault();

          const formData = new FormData(form);
          const payload = {
            nome: String(formData.get('nome') || '').trim(),
            telefone: String(formData.get('telefone') || '').trim(),
            produtos: formData.getAll('produtos[]'),
            preferenciaContato: String(formData.get('preferenciaContato') || '').trim()
          };

          if (!payload.nome || !payload.telefone) {
            window.AppAlerts?.warning('Preencha nome e WhatsApp para solicitar a demonstração.');
            return;
          }

          submitButton.disabled = true;
          statusElement.textContent = 'Enviando suas informações...';

          try {
            const response = await fetch(form.action, {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json',
                'X-CSRF-Token': csrfToken
              },
              body: JSON.stringify(payload)
            });

            const data = await response.json();

            if (!response.ok) throw new Error(data.message || 'Não foi possível enviar sua solicitação agora.');

            form.reset();
            statusElement.textContent = data.message || 'Solicitação enviada com sucesso.';
            window.AppAlerts?.success(data.message || 'Solicitação enviada com sucesso.');
          } catch (error) {
            statusElement.textContent = error.message;
            window.AppAlerts?.error(error.message || 'Erro ao enviar as informações.');
          } finally {
            submitButton.disabled = false;
          }
        });
      });
    </script>

    <script defer src="/js/homepage.js"></script>
  </body>

</html>