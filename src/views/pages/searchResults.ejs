<!DOCTYPE html>
<html lang="pt-br">
<%- include('../partials/head', { title: 'Resultados da Pesquisa' }) %>

<body class="list-page-body">
    <%- include('../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell">
        <%- include('../partials/breadcrumb', { pageTitle: 'Resultados da Pesquisa' }) %>

        <section class="page-titlebar page-titlebar-blue">
            <div class="page-titlebar-content">
                <span class="list-kicker"><i class="bi bi-search"></i> Pesquisa</span>
                <h1>Resultados da pesquisa</h1>
                <p>Uma visão mais organizada dos itens encontrados no sistema, separando estabelecimentos e lançamentos em blocos claros e consistentes com o novo visual.</p>
            </div>
            <div class="page-titlebar-side">
                <div class="list-stat"><strong>Estabelecimentos</strong><span><%= estabelecimentos.length %> encontrados</span></div>
                <div class="list-stat"><strong>Lançamentos</strong><span><%= lancamentos.length %> encontrados</span></div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <h2 class="table-section-title">Estabelecimentos</h2>
                <% if (estabelecimentos.length > 0) { %>
                    <div class="modern-table-wrap">
                        <div class="modern-table-scroll">
                            <table class="modern-table">
                                <thead>
                                    <tr>
                                        <th>Nome</th>
                                        <th>Responsável</th>
                                        <th>Bairro</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% estabelecimentos.forEach(estabelecimento => { %>
                                        <tr>
                                            <td><div class="table-title-cell"><%= estabelecimento.estabelecimento %></div></td>
                                            <td><%= estabelecimento.responsavel_nome %></td>
                                            <td><span class="table-muted"><%= estabelecimento.bairro %></span></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% } else { %>
                    <div class="list-panel" style="padding:1rem;">Nenhum estabelecimento encontrado.</div>
                <% } %>
            </section>

            <section class="list-panel">
                <h2 class="table-section-title">Lançamentos</h2>
                <% if (lancamentos.length > 0) { %>
                    <div class="modern-table-wrap">
                        <div class="modern-table-scroll">
                            <table class="modern-table">
                                <thead>
                                    <tr>
                                        <th>Tipo</th>
                                        <th class="table-col-description">Descrição</th>
                                        <th>Data</th>
                                        <th>Valor</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% lancamentos.forEach(lancamento => { %>
                                        <tr>
                                            <td><div class="table-title-cell"><%= lancamento.tipo_de_lancamento %></div></td>
                                            <td class="table-cell-description"><span class="table-muted"><%= lancamento.descricao %></span></td>
                                            <td><%= new Date(lancamento.data).toLocaleDateString('pt-BR') %></td>
                                            <td><strong><%= Number(lancamento.valor).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></strong></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% } else { %>
                    <div class="list-panel" style="padding:1rem;">Nenhum lançamento encontrado.</div>
                <% } %>
            </section>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
<%- include('../partials/footer') %>
</html>

