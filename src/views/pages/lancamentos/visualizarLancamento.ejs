<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Visualizar Lancamento' }) %>

<body class="bg-light">
    <%- include('../../partials/header') %>

    <div class="page-spacer"></div>

    <div class="page-shell py-3">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Visualizar Lancamento' }) %>

        <div class="cabecalho-geral">
            <h1 class="mb-0">Visualizar Lancamento</h1>
            <a href="/lancamentos" class="btn btn-voltar">Voltar</a>
        </div>

        <main class="mb-4 geral">
            <div class="card shadow detail-card">
                <div class="card-body">
                    <div class="detail-header">
                        <div class="detail-title">
                            <p class="mb-0">Tipo de Lancamento:</p>
                            <h4 class="mb-0"><strong><%= lancamento.tipo_de_lancamento.toUpperCase().replace('RECEITA_DOSPONTOS', 'RECEITA DOS PONTOS') %></strong></h4>
                        </div>
                        <p class="mb-0"><strong>ID:</strong> <%= lancamento.id %></p>
                    </div>

                    <hr>

                    <div class="detail-grid detail-stack">
                        <div>
                            <p>Entrada/Saida: <strong><%= lancamento.entrada_saida.toUpperCase() %></strong></p>
                            <p>Data do Evento: <strong><%= new Date(lancamento.data).toLocaleDateString('pt-BR') %></strong></p>
                            <p>Valor: <strong>R$ <%= typeof lancamento.valor === 'number' ? lancamento.valor.toFixed(2) : lancamento.valor %></strong></p>
                            <p>Forma de Pagamento: <strong><%= lancamento.forma_de_pagamento.toUpperCase() %></strong></p>
                            <p>Dia do Cadastro: <strong><%= new Date(lancamento.dia_do_cadastro).toLocaleDateString('pt-BR') %></strong></p>
                        </div>
                        <div>
                            <p>Usuario Responsavel: <strong><%= lancamento.usuario.toUpperCase() %></strong></p>
                            <p>Produto: <strong><%= lancamento.produto.toUpperCase() %></strong></p>
                            <p>Quantidade de Parcelas: <strong><%= lancamento.qtde_de_parcelas %></strong></p>
                            <p>Valor das Parcelas: <strong>R$ <%= valor_da_parcela ? valor_da_parcela.toFixed(2) : 'N/A' %></strong></p>
                            <p>Ultima Edicao: <strong><%= ultima_edicao ? new Date(ultima_edicao).toLocaleDateString('pt-BR') : 'N/A' %></strong></p>
                        </div>
                    </div>

                    <hr>

                    <p class="mb-0">Descricao: <strong><%= lancamento.descricao.toUpperCase() %></strong></p>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
