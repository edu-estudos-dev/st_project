<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Visualizar Lançamento' }) %>

    <body class="bg-light">
        <%- include('../../partials/header') %>

        <div style="padding-top: 2.9em;"></div>
        <div>&nbsp;</div>
        
        <div class="container w-75 px-4">
            
            <!-- breadcrumb -->
            <%- include('../../partials/breadcrumb', { pageTitle: 'Visualizar Lançamento' }) %>

            <div class="cabecalho-geral">
                <h1 class="mb-0">Visualizar Lançamentos</h1>

                <a href="/lancamentos" class="btn px-5 align-middle fs-5 btn-voltar"> 
                    <i class="align-middle fs-5 bi bi-caret-left-square"></i>&nbsp; Voltar
                </a>
            </div>

            <main class="mb-5 geral">
                <div class="card shadow">
                    <div class="card-body">
                        <div class="row px-3">

                            <div class="col-md-12 d-flex justify-content-between">
                                <div class="col-md-11 d-flex ">
                                    <p class="mt-1">Tipo de Lançamento:</p>
                                    <h4 class="ms-1"><strong> <%= lancamento.tipo_de_lancamento.toUpperCase().replace('RECEITA_DOSPONTOS', 'RECEITA DOS PONTOS') %> </strong></h4>
                                </div>
                                <div class="col-md-1 mt-1">
                                    <p>ID: <strong> <%= lancamento.id %> </strong></p>
                                </div>
                            </div>

                            <hr>

                            <div class="col-md-6">
                    
                                <p>Entrada/Saída: <strong> <%= lancamento.entrada_saida.toUpperCase() %></strong></p>
                                <p>Data do evento: <strong> <%= new Date(lancamento.data).toLocaleDateString('pt-BR') %></strong></p>
                                <p>Valor: R$ <strong> <%= typeof lancamento.valor === 'number' ? lancamento.valor.toFixed(2) : lancamento.valor %> </strong></p>
                                <p>Forma de Pagamento: <strong> <%= lancamento.forma_de_pagamento.toUpperCase() %>  </strong></p>
                                <p>Dia do Cadastro: <strong> <%= new Date(lancamento.dia_do_cadastro).toLocaleDateString('pt-BR') %></strong></p>
                            </div>
                            
                            <div class="col-md-6">
                                <p>Usuário responsável pelo cadastro:<strong> <%= lancamento.usuario.toUpperCase() %></strong></p>
                                <p>Produto: <strong> <%= lancamento.produto.toUpperCase() %> </strong></p>
                                <p>Quantidade de Parcelas: <strong> <%= lancamento.qtde_de_parcelas %>  </strong></p>
                                <p>Valor das Parcelas: R$ <strong> <%= valor_da_parcela ? valor_da_parcela.toFixed(2) : 'N/A' %> </strong></p>
                                <p>Última Edição: <strong> <%= ultima_edicao ? new Date(ultima_edicao).toLocaleDateString('pt-BR') : 'N/A' %> </strong></p>
                            </div>
                        </div>

                        <div class="row px-3">
                            <p>Descrição: <strong><%= lancamento.descricao.toUpperCase() %> </strong></p>
                        </div>
                    </div>
                </div>
            </main>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>
    </body>
</html>
