<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Adicionar Lançamento' }) %>

<body class="bg-light">
    <%- include('../../partials/header') %>
    <div class="container w-75 mt-5">

        <div>&nbsp;</div>

        <!-- breadcrumb -->
        <%- include('../../partials/breadcrumb', { pageTitle: 'Adicionar Lançamento' }) %>

        <div class="cabecalho-geral">
            <h1 class="mb-0">Adicionar Lançamento</h1>
        </div>

        <!-- Mensagens de Sucesso/Falha -->
        <% if (success) { %>
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <strong>Success!</strong> <%= success %>
                <a href="/lancamentos">
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </a>
            </div>
        <% } %>
        <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <strong>Error!</strong> <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <main class="mb-5 geral">
            <form class="p-0" action="/lancamentos/add" method="POST">
                <div class="row">
                    <div class="col-md-3 text-center">
                        <label class="mb-1 fs-5 fw-bold" for="entrada_saida">Entrada/Saída</label>
                        <select class="form-control text-center" id="entrada_saida" name="entrada_saida" required>
                            <option value="" disabled selected>Selecione um tipo</option>
                            <option value="Entrada">Entrada</option>
                            <option value="Saida">Saída</option>
                        </select>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="mb-1 fs-5 fw-bold" for="data">Data</label>
                        <input type="date" class="form-control text-center mb-2" id="data" name="data" required>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="mb-1 text-center fs-5 fw-bold" for="tipo_de_lancamento">Tipo de Lançamento</label>
                        <select class="form-control text-center" id="tipo_de_lancamento" name="tipo_de_lancamento" required>
                            <option value="" disabled selected>Selecione um tipo</option>
                            <option value="receita_dos_pontos" class="tipo-entrada">Receita dos Pontos</option>
                            <option value="incremento_de_capital" class="tipo-entrada">Incremento de Capital</option>
                            <option value="compra" class="tipo-saida">Compra</option>
                            <option value="extra" class="tipo-saida">Extra</option>
                            <option value="pro-labore" class="tipo-saida">Pro-Labore</option>
                            <option value="gastos_recorrentes" class="tipo-saida">Gastos Recorrentes</option>
                            <option value="bonus" class="tipo-saida">Bônus</option> 
                        </select>
                    </div>
                    <div class="mb-3 col-3 text-center">
                        <label for="valor" class="form-label mb-1 fs-5 fw-bold">Valor</label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input type="number" step="0.01" class="form-control text-center" id="valor" name="valor" required>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-3 text-center">
                        <label class="mb-1 fs-5 fw-bold" for="produto">Produto</label>
                        <select required class="form-control text-center" id="produto" name="produto">
                            <option value="" disabled selected>Selecione um Produto</option>
                            <option value="bolinhas">Bolinhas</option>
                            <option value="figurinhas">Figurinhas</option>
                            <option value="pelucias">Pelúcias</option>
                        </select>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="mb-1 fs-5 fw-bold" for="forma_de_pagamento">Forma de Pagamento</label>
                        <select class="form-control text-center" id="forma_de_pagamento" name="forma_de_pagamento" required>
                            <option value="" disabled selected>Selecione um tipo</option>
                            <option value="boleto">Boleto</option>
                            <option value="credito">Crédito</option>
                            <option value="pix">Pix</option>
                            <option value="especie">Espécie</option>
                        </select>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="mb-1 fs-5 fw-bold" for="qtde_de_parcelas">Qtde. de Parcelas</label>
                        <input type="number" class="form-control text-center mb-2" id="qtde_de_parcelas" name="qtde_de_parcelas" value="1" required>
                    </div>
                    <div class="col-md-3 text-center">
                        <label class="mb-1 fs-5 fw-bold" for="usuario">Usuário</label>
                        <input disabled type="text" class="form-control text-center mb-2" id="usuario" name="usuario" value="<%= usuario.username %>" readonly>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-12">
                        <label class="mb-1 fs-5 fw-bold" for="descricao">Descrição</label>
                        <textarea class="form-control mb-2" id="descricao" name="descricao" rows="3" required></textarea>
                    </div>
                </div>
                <div class="d-flex justify-content-center my-3">
                    <a href="/lancamentos"><button type="button" class="btn btn-warning px-5 me-3 fs-5">Cancelar</button></a>
                    <button type="submit" class="btn btn-primary ms-3 px-5 fs-5">Cadastrar</button>
                </div>
            </form>
            
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const entradaSaidaSelect = document.getElementById('entrada_saida');
            const tipoDeLancamentoSelect = document.getElementById('tipo_de_lancamento');
            const tipoEntradas = document.querySelectorAll('.tipo-entrada');
            const tipoSaidas = document.querySelectorAll('.tipo-saida');

            entradaSaidaSelect.addEventListener('change', function() {
                const selectedValue = this.value;
                if (selectedValue === 'Entrada') {
                    tipoEntradas.forEach(option => option.style.display = 'block');
                    tipoSaidas.forEach(option => option.style.display = 'none');
                } else if (selectedValue === 'Saida') {
                    tipoEntradas.forEach(option => option.style.display = 'none');
                    tipoSaidas.forEach(option => option.style.display = 'block');
                }
            });

            // Trigger the change event on page load to set the initial state
            entradaSaidaSelect.dispatchEvent(new Event('change'));
        });
    </script>
</body>
<!-- <%- include('../../partials/footer') %> -->
</html>
