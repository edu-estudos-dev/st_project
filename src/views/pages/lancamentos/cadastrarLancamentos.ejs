<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Adicionar Lançamento' }) %>

<body class="form-page-body">
    <%- include('../../partials/header') %>
    <% const navProducts = navigationProducts || { bolinhas: false, consignados: false, figurinhas: false, pelucias: false, hasAny: false }; %>
    <% const hasConsignados = Boolean(navProducts.consignados || navProducts.figurinhas); %>
    <div class="page-spacer"></div>

    <div class="form-shell form-shell-modern lancamento-form-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Adicionar Lançamento' }) %>

        <section class="page-titlebar page-titlebar-neutral">
            <div class="page-titlebar-content">
                <span class="form-kicker"><i class="bi bi-cash-coin"></i> Financeiro</span>
                <h1>Novo lançamento</h1>
                <p>Registre entradas e saídas com clareza, informando apenas os campos necessários para cada tipo de movimentação.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="page-titlebar-stat">
                    <strong>Registro</strong>
                    <span>Fluxo financeiro com contexto completo</span>
                </div>
            </div>
        </section>

        <main class="form-stage">
            <form class="modern-form lancamento-form" action="/lancamentos/add" method="POST">
                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Classificação</span>
                            <h2>Tipo e valor do lançamento</h2>
                            <p>Defina se a movimentação é entrada ou saída, escolha a categoria financeira e informe a data com o valor correspondente.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="entrada_saida">Entrada ou saída</label>
                            <select class="form-select text-center" id="entrada_saida" name="entrada_saida" required>
                                <option value="" disabled selected>Selecione um tipo</option>
                                <option value="Entrada">Entrada</option>
                                <option value="Saida">Saída</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="data">Data</label>
                            <input type="date" class="form-control text-center" id="data" name="data" required>
                        </div>
                        <div class="col-12 col-lg-3">
                            <label for="tipo_de_lancamento">Tipo de lançamento</label>
                            <select class="form-select text-center" id="tipo_de_lancamento" name="tipo_de_lancamento" required>
                                <option value="" disabled selected>Selecione um tipo</option>
                                <option value="receita_dos_pontos" class="tipo-entrada">Receita dos pontos</option>
                                <option value="incremento_de_capital" class="tipo-entrada">Incremento de capital</option>
                                <option value="compra" class="tipo-saida">Compra</option>
                                <option value="extra" class="tipo-saida">Extra</option>
                                <option value="pro-labore" class="tipo-saida">Pró-labore</option>
                                <option value="gastos_recorrentes" class="tipo-saida">Gastos recorrentes</option>
                                <option value="bonus" class="tipo-saida">Bônus</option>
                            </select>
                        </div>
                        <div class="col-12 col-lg-3">
                            <label for="valor">Valor</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input type="number" step="0.01" class="form-control text-center" id="valor" name="valor" required>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Pagamento</span>
                            <h2>Origem e forma de pagamento</h2>
                            <p>Para entradas, informe apenas Pix ou Espécie. Para saídas, informe o produto e use parcelas somente em boleto ou crédito.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-3" id="produtoField">
                            <label for="produto">Produto</label>
                            <select class="form-select text-center" id="produto" name="produto">
                                <option value="" disabled selected>Selecione um produto</option>
                                <% if (navProducts.bolinhas) { %><option value="bolinhas">Bolinhas</option><% } %>
                                <% if (hasConsignados) { %><option value="consignados">Consignados</option><% } %>
                                <% if (navProducts.pelucias) { %><option value="pelucias">Pelúcias</option><% } %>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="forma_de_pagamento">Forma de pagamento</label>
                            <select class="form-select text-center" id="forma_de_pagamento" name="forma_de_pagamento" required>
                                <option value="" disabled selected>Selecione um tipo</option>
                                <option value="boleto" class="pagamento-saida">Boleto</option>
                                <option value="credito" class="pagamento-saida">Crédito</option>
                                <option value="pix" class="pagamento-entrada pagamento-saida">Pix</option>
                                <option value="especie" class="pagamento-entrada pagamento-saida">Espécie</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="qtde_de_parcelas">Qtde. de parcelas</label>
                            <input type="number" min="1" class="form-control text-center" id="qtde_de_parcelas" name="qtde_de_parcelas" value="1" required>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3 d-none" id="vencimentoField">
                            <label for="vencimento">1º vencimento</label>
                            <input type="date" class="form-control text-center" id="vencimento" name="vencimento">
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Descrição</span>
                            <h2>Contexto da movimentação</h2>
                            <p>Descreva o motivo do lançamento para facilitar auditoria, consultas e conferências futuras.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label for="descricao">Descrição</label>
                            <textarea class="form-control" id="descricao" name="descricao" rows="5" placeholder="Explique de forma objetiva o motivo desta movimentação." required></textarea>
                        </div>
                    </div>
                </section>

                <section class="form-actions-bar">
                    <div class="form-actions-copy">
                        <strong>Conferência final</strong>
                        <span>Antes de salvar, verifique tipo, data, forma de pagamento e valor do lançamento.</span>
                    </div>

                    <div class="form-actions-buttons">
                        <a href="/lancamentos" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Cancelar</span>
                        </a>
                        <button type="submit" class="btn-modern">
                            <i class="bi bi-journal-check"></i>
                            <span>Cadastrar lançamento</span>
                        </button>
                    </div>
                </section>
            </form>
        </main>
    </div>

    <script nonce="<%= cspNonce || '' %>" src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script nonce="<%= cspNonce || '' %>">
        document.addEventListener('DOMContentLoaded', function () {
            const entradaSaidaSelect = document.getElementById('entrada_saida');
            const formaPagamentoSelect = document.getElementById('forma_de_pagamento');
            const parcelasInput = document.getElementById('qtde_de_parcelas');
            const vencimentoField = document.getElementById('vencimentoField');
            const vencimentoInput = document.getElementById('vencimento');
            const produtoField = document.getElementById('produtoField');
            const produtoSelect = document.getElementById('produto');
            const tipoLancamentoSelect = document.getElementById('tipo_de_lancamento');
            const tipoEntradas = document.querySelectorAll('.tipo-entrada');
            const tipoSaidas = document.querySelectorAll('.tipo-saida');
            const pagamentosEntrada = document.querySelectorAll('.pagamento-entrada');
            const pagamentosSaida = document.querySelectorAll('.pagamento-saida');

            function syncTipoLancamento() {
                const isEntrada = entradaSaidaSelect.value === 'Entrada';
                const isSaida = entradaSaidaSelect.value === 'Saida';

                tipoEntradas.forEach((option) => {
                    option.style.display = isEntrada ? 'block' : 'none';
                    option.disabled = !isEntrada;
                });

                tipoSaidas.forEach((option) => {
                    option.style.display = isSaida ? 'block' : 'none';
                    option.disabled = !isSaida;
                });

                const selectedOption = tipoLancamentoSelect.options[tipoLancamentoSelect.selectedIndex];

                if (selectedOption?.disabled) {
                    tipoLancamentoSelect.value = '';
                }
            }

            function syncProdutoField() {
                const isEntrada = entradaSaidaSelect.value === 'Entrada';

                produtoField.classList.toggle('d-none', isEntrada);
                produtoSelect.required = !isEntrada;
                produtoSelect.disabled = isEntrada;

                if (isEntrada) {
                    produtoSelect.value = '';
                }
            }

            function syncFormaPagamentoOptions() {
                const isEntrada = entradaSaidaSelect.value === 'Entrada';
                const isSaida = entradaSaidaSelect.value === 'Saida';

                pagamentosEntrada.forEach((option) => {
                    option.style.display = isEntrada || isSaida ? 'block' : 'none';
                    option.disabled = !(isEntrada || isSaida);
                });

                pagamentosSaida.forEach((option) => {
                    const permitido = isSaida || option.classList.contains('pagamento-entrada');

                    option.style.display = permitido ? 'block' : 'none';
                    option.disabled = !permitido;
                });

                const selectedOption = formaPagamentoSelect.options[formaPagamentoSelect.selectedIndex];

                if (selectedOption?.disabled) {
                    formaPagamentoSelect.value = '';
                }

                if (isEntrada && !['pix', 'especie'].includes(formaPagamentoSelect.value)) {
                    formaPagamentoSelect.value = '';
                }
            }

            function syncVencimentoField() {
                const formaPagamento = formaPagamentoSelect.value;
                const permiteParcelamento = entradaSaidaSelect.value === 'Saida'
                    && ['boleto', 'credito'].includes(formaPagamento);

                if (!permiteParcelamento) {
                    parcelasInput.value = '1';
                }

                parcelasInput.readOnly = !permiteParcelamento;
                parcelasInput.min = '1';
                parcelasInput.step = '1';

                const precisaVencimento = permiteParcelamento && Number(parcelasInput.value || 0) > 1;

                vencimentoField.classList.toggle('d-none', !precisaVencimento);
                vencimentoInput.required = precisaVencimento;

                if (!precisaVencimento) {
                    vencimentoInput.value = '';
                }
            }

            entradaSaidaSelect.addEventListener('change', function () {
                syncTipoLancamento();
                syncProdutoField();
                syncFormaPagamentoOptions();
                syncVencimentoField();
            });

            formaPagamentoSelect.addEventListener('change', syncVencimentoField);
            parcelasInput.addEventListener('input', syncVencimentoField);

            syncTipoLancamento();
            syncProdutoField();
            syncFormaPagamentoOptions();
            syncVencimentoField();

            <% if (success) { %>window.AppAlerts?.success("<%- success.replace(/"/g, '&quot;') %>");<% } %>
            <% if (error) { %>window.AppAlerts?.error("<%- error.replace(/"/g, '&quot;') %>");<% } %>
        });
    </script>
    <%- include('../../partials/financialNotificationsPopup', { popupMode: 'launch-once' }) %>
</body>
</html>