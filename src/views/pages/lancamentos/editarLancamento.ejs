<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Editar Lancamento' }) %>

<body class="bg-light">
    <%- include('../../partials/header') %>
    <% const navProducts = navigationProducts || { bolinhas: false, figurinhas: false, pelucias: false, hasAny: false }; %>

    <div class="page-spacer"></div>

    <div class="form-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Editar Lancamento' }) %>

        <div class="cabecalho-geral">
            <h1 class="mb-0">Editar Lancamento</h1>
        </div>

        <main class="mb-5 geral">
            <form class="p-0" action="/lancamentos/<%= lancamento.id %>?_method=PUT" method="POST">
                <div class="row g-3">
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="mb-1 fs-5 fw-bold" for="entrada_saida">Entrada/Saida</label>
                        <select class="form-control text-center" id="entrada_saida" name="entrada_saida" required>
                            <option value="Entrada" <%= lancamento.entrada_saida === 'Entrada' ? 'selected' : '' %>>Entrada</option>
                            <option value="Saida" <%= lancamento.entrada_saida === 'SaÃƒÂ­da' ? 'selected' : '' %>>Saida</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="mb-1 fs-5 fw-bold" for="data">Data</label>
                        <input type="date" class="form-control text-center" id="data" name="data" value="<%= new Date(lancamento.data).toISOString().split('T')[0] %>" required>
                    </div>
                    <div class="col-12 col-lg-3">
                        <label class="mb-1 fs-5 fw-bold" for="tipo_de_lancamento">Tipo de Lancamento</label>
                        <select class="form-control text-center" id="tipo_de_lancamento" name="tipo_de_lancamento" required>
                            <option value="receita_dos_pontos" <%= lancamento.tipo_de_lancamento === 'receita_dos_pontos' ? 'selected' : '' %> class="tipo-entrada">Receita dos Pontos</option>
                            <option value="incremento_de_capital" <%= lancamento.tipo_de_lancamento === 'incremento_de_capital' ? 'selected' : '' %> class="tipo-entrada">Incremento de Capital</option>
                            <option value="compra" <%= lancamento.tipo_de_lancamento === 'compra' ? 'selected' : '' %> class="tipo-saida">Compra</option>
                            <option value="extra" <%= lancamento.tipo_de_lancamento === 'extra' ? 'selected' : '' %> class="tipo-saida">Extra</option>
                            <option value="pro-labore" <%= lancamento.tipo_de_lancamento === 'pro-labore' ? 'selected' : '' %> class="tipo-saida">Pro-Labore</option>
                            <option value="gastos_recorrentes" <%= lancamento.tipo_de_lancamento === 'gastos_recorrentes' ? 'selected' : '' %> class="tipo-saida">Gastos Recorrentes</option>
                            <option value="bonus" <%= lancamento.tipo_de_lancamento === 'bonus' ? 'selected' : '' %> class="tipo-saida">Bonus</option>
                        </select>
                    </div>
                    <div class="col-12 col-lg-3">
                        <label class="mb-1 fs-5 fw-bold" for="valor">Valor</label>
                        <input type="number" step="0.01" class="form-control text-center" id="valor" name="valor" value="<%= lancamento.valor %>" required>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="mb-1 fs-5 fw-bold" for="produto">Produto</label>
                        <select class="form-control text-center" id="produto" name="produto" required>
                            <% if (navProducts.bolinhas || lancamento.produto === 'bolinhas') { %><option value="bolinhas" <%= lancamento.produto === 'bolinhas' ? 'selected' : '' %>>Bolinhas</option><% } %>
                            <% if (navProducts.figurinhas || lancamento.produto === 'figurinhas') { %><option value="figurinhas" <%= lancamento.produto === 'figurinhas' ? 'selected' : '' %>>Figurinhas</option><% } %>
                            <% if (navProducts.pelucias || lancamento.produto === 'pelucias') { %><option value="pelucias" <%= lancamento.produto === 'pelucias' ? 'selected' : '' %>>Pelucias</option><% } %>
                        </select>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="mb-1 fs-5 fw-bold" for="forma_de_pagamento">Forma de Pagamento</label>
                        <select class="form-control text-center" id="forma_de_pagamento" name="forma_de_pagamento" required>
                            <option value="boleto" <%= lancamento.forma_de_pagamento === 'boleto' ? 'selected' : '' %>>Boleto</option>
                            <option value="credito" <%= lancamento.forma_de_pagamento === 'credito' ? 'selected' : '' %>>Credito</option>
                            <option value="pix" <%= lancamento.forma_de_pagamento === 'pix' ? 'selected' : '' %>>Pix</option>
                            <option value="especie" <%= lancamento.forma_de_pagamento === 'especie' ? 'selected' : '' %>>Especie</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="mb-1 fs-5 fw-bold" for="qtde_de_parcelas">Qtde. de Parcelas</label>
                        <input type="number" class="form-control text-center" id="qtde_de_parcelas" name="qtde_de_parcelas" value="<%= lancamento.qtde_de_parcelas %>" required>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label class="mb-1 fs-5 fw-bold" for="usuario">Usuario</label>
                        <input disabled type="text" class="form-control text-center" id="usuario" name="usuario" value="<%= lancamento.usuario %>" readonly>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12">
                        <label class="mb-1 fs-5 fw-bold" for="descricao">Descricao</label>
                        <textarea class="form-control" id="descricao" name="descricao" rows="4" required><%= lancamento.descricao %></textarea>
                    </div>
                </div>

                <div class="action-row my-4">
                    <a href="/lancamentos" class="btn btn-warning fs-5">Cancelar</a>
                    <button type="submit" class="btn btn-primary fs-5">Atualizar</button>
                </div>
            </form>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        <% if (success) { %>
        window.AppAlerts?.success("<%- success.replace(/\"/g, '&quot;') %>");
        setTimeout(() => { window.location.href = '/lancamentos'; }, 1800);
        <% } %>
        <% if (error) { %>
        window.AppAlerts?.error("<%- error.replace(/\"/g, '&quot;') %>");
        <% } %>
    });
    </script>
</body>
</html>
