<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Editar Lançamento' }) %>

<body class="bg-light">
    <%- include('../../partials/header') %>
    <div class="container w-75 mt-5">

        <div>&nbsp;</div>

        <!-- breadcrumb -->
        <%- include('../../partials/breadcrumb', { pageTitle: 'Editar Lançamento' }) %>

        <div class="cabecalho-geral">
            <h1 class="mb-0">Editar Lançamento</h1>
        </div>

        <!-- Mensagens de Sucesso/Falha -->
        <% if (success) { %>
            <div class="alert alert-success fade show" role="alert">
                <%= success %>
                <button type="button" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
            <script>
                setTimeout(() => {
                    window.location.href = '/lancamentos';
                }, 3000); // 3 segundos de espera antes de redirecionar
            </script>
        <% } %>
        <% if (error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        <% } %>

        <main class="mb-5 geral">
            <form class="p-0" action="/lancamentos/<%= lancamento.id %>?_method=PUT" method="POST">
                <div class="row">
                    <div class="col-md-3">
                        <label class="mb-1 fs-5 fw-bold" for="entrada_saida">Entrada/Saída</label>
                        <select class="form-control" id="entrada_saida" name="entrada_saida" required>
                            <option value="Entrada" <%= lancamento.entrada_saida === 'Entrada' ? 'selected' : '' %>>Entrada</option>
                            <option value="Saida" <%= lancamento.entrada_saida === 'Saída' ? 'selected' : '' %>>Saída</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="mb-1 fs-5 fw-bold" for="data">Data</label>
                        <input type="date" class="form-control mb-2" id="data" name="data"
                            value="<%= new Date(lancamento.data).toISOString().split('T')[0] %>" required>
                    </div>
                    <div class="col-md-3">
                        <label class="mb-1 fs-5 fw-bold" for="tipo_de_lancamento">Tipo de Lançamento</label>
                        <select class="form-control" id="tipo_de_lancamento" name="tipo_de_lancamento" required>
                            <option value="receita_dos_pontos" <%= lancamento.tipo_de_lancamento === 'receita_dos_pontos' ? 'selected' : '' %> class="tipo-entrada">Receita dos Pontos</option>
                            <option value="incremento_de_capital" <%= lancamento.tipo_de_lancamento === 'incremento_de_capital' ? 'selected' : '' %> class="tipo-entrada">Incremento de Capital</option>
                            <option value="compra" <%= lancamento.tipo_de_lancamento === 'compra' ? 'selected' : '' %> class="tipo-saida">Compra</option>
                            <option value="extra" <%= lancamento.tipo_de_lancamento === 'extra' ? 'selected' : '' %> class="tipo-saida">Extra</option>
                            <option value="pro-labore" <%= lancamento.tipo_de_lancamento === 'pro-labore' ? 'selected' : '' %> class="tipo-saida">Pro-Labore</option>
                            <option value="gastos_recorrentes" <%= lancamento.tipo_de_lancamento === 'gastos_recorrentes' ? 'selected' : '' %> class="tipo-saida">Gastos Recorrentes</option>
                            <option value="bonus" <%= lancamento.tipo_de_lancamento === 'bonus' ? 'selected' : '' %> class="tipo-saida">Bônus</option>
                        </select>
                        
                    </div>
                    <div class="col-md-3">
                        <label class="mb-1 fs-5 fw-bold" for="valor">Valor</label>
                        <input type="number" step="0.01" class="form-control mb-2" id="valor" name="valor" value="<%= lancamento.valor %>" required>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <label class="mb-1 fs-5 fw-bold" for="produto">Produto</label>
                        <select class="form-control" id="produto" name="produto" required>
                            <option value="bolinhas" <%= lancamento.produto === 'bolinhas' ? 'selected' : '' %>>Bolinhas</option>
                            <option value="figurinhas" <%= lancamento.produto === 'figurinhas' ? 'selected' : '' %>>Figurinhas</option>
                            <option value="pelucias" <%= lancamento.produto === 'pelucias' ? 'selected' : '' %>>Pelúcias</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="mb-1 fs-5 fw-bold" for="forma_de_pagamento">Forma de Pagamento</label>
                        <select class="form-control" id="forma_de_pagamento" name="forma_de_pagamento" required>
                            <option value="boleto" <%= lancamento.forma_de_pagamento === 'boleto' ? 'selected' : '' %>>Boleto</option>
                            <option value="credito" <%= lancamento.forma_de_pagamento === 'credito' ? 'selected' : '' %>>Crédito</option>
                            <option value="pix" <%= lancamento.forma_de_pagamento === 'pix' ? 'selected' : '' %>>Pix</option>
                            <option value="especie" <%= lancamento.forma_de_pagamento === 'especie' ? 'selected' : '' %>>Espécie</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="mb-1 fs-5 fw-bold" for="qtde_de_parcelas">Qtde. de Parcelas</label>
                        <input type="number" class="form-control mb-2" id="qtde_de_parcelas" name="qtde_de_parcelas"
                            value="<%= lancamento.qtde_de_parcelas %>" required>
                    </div>
                    <div class="col-md-3">
                        <label class="mb-1 fs-5 fw-bold" for="usuario">Usuário</label>
                        <input disabled type="text" class="form-control mb-2" id="usuario" name="usuario" value="<%= lancamento.usuario %>" readonly>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-12">
                        <label class="mb-1 fs-5 fw-bold" for="descricao">Descrição</label>
                        <textarea class="form-control mb-2" id="descricao" name="descricao" rows="3" required><%= lancamento.descricao %></textarea>
                    </div>
                </div>

                <div class="d-flex justify-content-center my-3">
                    <a href="/lancamentos"><button type="button" class="btn btn-warning px-5 me-3 fs-5">Cancelar</button></a>
                    <button type="submit" class="btn btn-primary ms-3 px-5 fs-5">Atualizar</button>
                </div>
            </form>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>
</body>
<!-- <%- include('../../partials/footer') %> -->
</html>
