<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Editar Lançamento' }) %>

<body class="form-page-body">
    <%- include('../../partials/header') %>
    <% const navProducts = navigationProducts || { bolinhas: false, consignados: false, figurinhas: false, pelucias: false, hasAny: false }; %>
    <% const hasConsignados = Boolean(navProducts.consignados || navProducts.figurinhas); %>

    <%
        const formatTipoLancamento = (value) => {
            const labels = {
                receita_dos_pontos: 'Receita dos pontos',
                incremento_de_capital: 'Incremento de capital',
                compra: 'Compra',
                extra: 'Extra',
                'pro-labore': 'Pró-labore',
                gastos_recorrentes: 'Gastos recorrentes',
                bonus: 'Bônus'
            };

            const rawValue = String(value || '').trim();

            if (!rawValue) {
                return 'Lançamento';
            }

            return labels[rawValue] || rawValue.replace(/_/g, ' ');
        };

        const formatMovimentacao = (value) => {
            if (value === 'Entrada') {
                return 'Entrada';
            }

            if (value === 'Saida') {
                return 'Saída';
            }

            return 'Não informado';
        };

        const formaPagamentoNormalizada = String(lancamento.forma_de_pagamento || '').trim().toLowerCase();
        const quantidadeParcelas = Number(lancamento.qtde_de_parcelas || 1);
        const permiteParcelamentoAtual = lancamento.entrada_saida === 'Saida'
            && ['boleto', 'credito'].includes(formaPagamentoNormalizada);

        const mostrarVencimentoInicial = permiteParcelamentoAtual && quantidadeParcelas > 1;
    %>

    <div class="page-spacer"></div>

    <div class="form-shell form-shell-modern">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Editar Lançamento' }) %>

        <section class="page-titlebar page-titlebar-neutral">
            <div class="page-titlebar-content">
                <span class="form-kicker"><i class="bi bi-pencil-square"></i> Financeiro</span>
                <h1>Editar lançamento</h1>
                <p>Atualize os dados financeiros revisando categoria, pagamento, valor e descrição em uma tela objetiva.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="page-titlebar-stat">
                    <strong>Registro</strong>
                    <span><%= formatTipoLancamento(lancamento.tipo_de_lancamento) %></span>
                </div>
            </div>
        </section>

        <main class="form-stage">
            <form class="modern-form lancamento-form" action="/lancamentos/<%= lancamento.id %>?_method=PUT" method="POST">
                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Classificação</span>
                            <h2>Tipo e valor do lançamento</h2>
                            <p>A movimentação original não pode ser alterada. Revise a categoria financeira, a data e o valor do lançamento.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="entrada_saida_visual">Entrada ou saída</label>
                            <select class="form-select text-center" id="entrada_saida_visual" disabled>
                                <option value="Entrada" <%= lancamento.entrada_saida === 'Entrada' ? 'selected' : '' %>>Entrada</option>
                                <option value="Saida" <%= lancamento.entrada_saida === 'Saida' ? 'selected' : '' %>>Saída</option>
                            </select>
                            <input type="hidden" id="entrada_saida" name="entrada_saida" value="<%= lancamento.entrada_saida %>">
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="data">Data</label>
                            <input type="date" class="form-control text-center" id="data" name="data" value="<%= new Date(lancamento.data).toISOString().split('T')[0] %>" required>
                        </div>

                        <div class="col-12 col-lg-3">
                            <label for="tipo_de_lancamento">Tipo de lançamento</label>
                            <select class="form-select text-center" id="tipo_de_lancamento" name="tipo_de_lancamento" required>
                                <option value="receita_dos_pontos" <%= lancamento.tipo_de_lancamento === 'receita_dos_pontos' ? 'selected' : '' %> class="tipo-entrada">Receita dos pontos</option>
                                <option value="incremento_de_capital" <%= lancamento.tipo_de_lancamento === 'incremento_de_capital' ? 'selected' : '' %> class="tipo-entrada">Incremento de capital</option>
                                <option value="compra" <%= lancamento.tipo_de_lancamento === 'compra' ? 'selected' : '' %> class="tipo-saida">Compra</option>
                                <option value="extra" <%= lancamento.tipo_de_lancamento === 'extra' ? 'selected' : '' %> class="tipo-saida">Extra</option>
                                <option value="pro-labore" <%= lancamento.tipo_de_lancamento === 'pro-labore' ? 'selected' : '' %> class="tipo-saida">Pró-labore</option>
                                <option value="gastos_recorrentes" <%= lancamento.tipo_de_lancamento === 'gastos_recorrentes' ? 'selected' : '' %> class="tipo-saida">Gastos recorrentes</option>
                                <option value="bonus" <%= lancamento.tipo_de_lancamento === 'bonus' ? 'selected' : '' %> class="tipo-saida">Bônus</option>
                            </select>
                        </div>

                        <div class="col-12 col-lg-3">
                            <label for="valor">Valor</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input type="number" step="0.01" class="form-control text-center" id="valor" name="valor" value="<%= lancamento.valor %>" required>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Pagamento</span>
                            <h2>Origem e forma de pagamento</h2>
                            <p>
                                <% if (lancamento.entrada_saida === 'Entrada') { %>
                                    Para entradas, use apenas Pix ou Espécie.
                                <% } else { %>
                                    Para saídas, informe o produto e use parcelas somente em boleto ou crédito.
                                <% } %>
                            </p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-3" id="produtoField">
                            <label for="produto">Produto</label>
                            <select class="form-select text-center" id="produto" name="produto">
                                <% if (navProducts.bolinhas || lancamento.produto === 'bolinhas') { %>
                                    <option value="bolinhas" <%= lancamento.produto === 'bolinhas' ? 'selected' : '' %>>Bolinhas</option>
                                <% } %>

                                <% if (hasConsignados || lancamento.produto === 'consignados') { %>
                                    <option value="consignados" <%= lancamento.produto === 'consignados' ? 'selected' : '' %>>Consignados</option>
                                <% } %>

                                <% if (navProducts.pelucias || lancamento.produto === 'pelucias') { %>
                                    <option value="pelucias" <%= lancamento.produto === 'pelucias' ? 'selected' : '' %>>Pelúcias</option>
                                <% } %>
                            </select>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="forma_de_pagamento">
                                <%= lancamento.entrada_saida === 'Entrada' ? 'Forma de recebimento' : 'Forma de pagamento' %>
                            </label>
                            <select class="form-select text-center" id="forma_de_pagamento" name="forma_de_pagamento" required>
                                <option value="boleto" class="pagamento-saida" <%= lancamento.forma_de_pagamento === 'boleto' ? 'selected' : '' %>>Boleto</option>
                                <option value="credito" class="pagamento-saida" <%= lancamento.forma_de_pagamento === 'credito' ? 'selected' : '' %>>Crédito</option>
                                <option value="pix" class="pagamento-entrada pagamento-saida" <%= lancamento.forma_de_pagamento === 'pix' ? 'selected' : '' %>>Pix</option>
                                <option value="especie" class="pagamento-entrada pagamento-saida" <%= lancamento.forma_de_pagamento === 'especie' ? 'selected' : '' %>>Espécie</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="qtde_de_parcelas">Parcelas</label>
                            <input type="number" min="1" step="1" class="form-control text-center" id="qtde_de_parcelas" name="qtde_de_parcelas" value="<%= quantidadeParcelas %>" required>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3 <%= mostrarVencimentoInicial ? '' : 'd-none' %>" id="vencimentoField">
                            <label for="vencimento">1º vencimento</label>
                            <input type="date" class="form-control text-center" id="vencimento" name="vencimento" value="<%= lancamento.vencimento ? new Date(lancamento.vencimento).toISOString().split('T')[0] : '' %>">
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Descrição</span>
                            <h2>Contexto da movimentação</h2>
                            <p>Ajuste a descrição para facilitar consultas, auditorias e conferências futuras.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label for="descricao">Descrição</label>
                            <textarea class="form-control" id="descricao" name="descricao" rows="5" required><%= lancamento.descricao %></textarea>
                        </div>
                    </div>
                </section>

                <section class="form-actions-bar">
                    <div class="form-actions-copy">
                        <strong>Salvar alterações</strong>
                        <span>Revise os dados antes de atualizar este lançamento.</span>
                    </div>

                    <div class="form-actions-buttons">
                        <a href="/lancamentos" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Cancelar</span>
                        </a>

                        <button type="submit" class="btn-modern">
                            <i class="bi bi-check2-circle"></i>
                            <span>Atualizar lançamento</span>
                        </button>
                    </div>
                </section>
            </form>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const entradaSaidaSelect = document.getElementById('entrada_saida_visual');
        const formaPagamentoSelect = document.getElementById('forma_de_pagamento');
        const parcelasInput = document.getElementById('qtde_de_parcelas');
        const vencimentoField = document.getElementById('vencimentoField');
        const vencimentoInput = document.getElementById('vencimento');
        const produtoField = document.getElementById('produtoField');
        const produtoSelect = document.getElementById('produto');
        const tipoLancamentoSelect = document.getElementById('tipo_de_lancamento');
        const tipoEntradas = document.querySelectorAll('.tipo-entrada');
        const tipoSaidas = document.querySelectorAll('.tipo-saida');
        const pagamentosEntrada = document.querySelectorAll('.pagamento-entrada');
        const pagamentosSaida = document.querySelectorAll('.pagamento-saida');

        const syncTipoLancamento = () => {
            const isEntrada = entradaSaidaSelect.value === 'Entrada';
            const visibleOptions = isEntrada ? tipoEntradas : tipoSaidas;
            const hiddenOptions = isEntrada ? tipoSaidas : tipoEntradas;

            visibleOptions.forEach((option) => {
                option.style.display = 'block';
                option.disabled = false;
            });

            hiddenOptions.forEach((option) => {
                option.style.display = 'none';
                option.disabled = true;
            });

            const selectedOption = tipoLancamentoSelect.options[tipoLancamentoSelect.selectedIndex];

            if (selectedOption?.disabled) {
                tipoLancamentoSelect.value = visibleOptions[0]?.value || '';
            }
        };

        const syncProdutoField = () => {
            const isEntrada = entradaSaidaSelect.value === 'Entrada';

            produtoField.classList.toggle('d-none', isEntrada);
            produtoSelect.required = !isEntrada;
            produtoSelect.disabled = isEntrada;

            if (isEntrada) {
                produtoSelect.value = '';
            }
        };

        const syncFormaPagamentoOptions = () => {
            const isEntrada = entradaSaidaSelect.value === 'Entrada';
            const isSaida = entradaSaidaSelect.value === 'Saida';

            pagamentosEntrada.forEach((option) => {
                option.style.display = isEntrada || isSaida ? 'block' : 'none';
                option.disabled = !(isEntrada || isSaida);
            });

            pagamentosSaida.forEach((option) => {
                const permitido = isSaida || option.classList.contains('pagamento-entrada');

                option.style.display = permitido ? 'block' : 'none';
                option.disabled = !permitido;
            });

            const selectedOption = formaPagamentoSelect.options[formaPagamentoSelect.selectedIndex];

            if (selectedOption?.disabled) {
                formaPagamentoSelect.value = '';
            }

            if (isEntrada && !['pix', 'especie'].includes(formaPagamentoSelect.value)) {
                formaPagamentoSelect.value = '';
            }
        };

        const syncVencimentoField = () => {
            const formaPagamento = formaPagamentoSelect.value;
            const permiteParcelamento = entradaSaidaSelect.value === 'Saida'
                && ['boleto', 'credito'].includes(formaPagamento);

            if (!permiteParcelamento) {
                parcelasInput.value = '1';
            }

            parcelasInput.readOnly = !permiteParcelamento;
            parcelasInput.min = '1';
            parcelasInput.step = '1';

            const precisaVencimento = permiteParcelamento && Number(parcelasInput.value || 0) > 1;

            vencimentoField.classList.toggle('d-none', !precisaVencimento);
            vencimentoInput.required = precisaVencimento;

            if (!precisaVencimento) {
                vencimentoInput.value = '';
            }
        };

        entradaSaidaSelect.addEventListener('change', () => {
            syncTipoLancamento();
            syncProdutoField();
            syncFormaPagamentoOptions();
            syncVencimentoField();
        });

        formaPagamentoSelect.addEventListener('change', syncVencimentoField);
        parcelasInput.addEventListener('input', syncVencimentoField);

        syncTipoLancamento();
        syncProdutoField();
        syncFormaPagamentoOptions();
        syncVencimentoField();

        <% if (success) { %>
            window.AppAlerts?.success("<%- success.replace(/\"/g, '&quot;') %>");
            setTimeout(() => { window.location.href = '/lancamentos'; }, 1800);
        <% } %>

        <% if (error) { %>
            window.AppAlerts?.error("<%- error.replace(/\"/g, '&quot;') %>");
        <% } %>
    });
    </script>
</body>
</html>