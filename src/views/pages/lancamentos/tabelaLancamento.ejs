<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Lançamentos Cadastrados' }) %>
<body class="bg-light">
    <%- include('../../partials/header') %>
    <div class="container" style="padding-top: 2.9em;"></div><div>&nbsp;</div>
    <%- include('../../partials/breadcrumb', { pageTitle: 'Lançamentos Cadastrados' }) %>
    <div class="container-fluid px-4"><main class="mb-5 geral"><div class="table-container"><div class="row"><div class="col-6"><h1 class="text-dark mb-3 fw-bold">Lançamentos Cadastrados</h1></div><div class="col-6 d-flex justify-content-end"><a type="button" class="btn mb-3 btn-dark align-self-center" href="/lancamentos/add"><i class="bi bi-plus-circle"></i>&nbsp;Novo Lançamento</a></div></div><table class="table table-striped table-hover mb-0"><thead><tr><th>ID</th><th>Entrada/Saída</th><th>Data</th><th>Tipo de Lançamento</th><th>Forma de Pagamento</th><th>Valor</th><th>Descrição</th><th>Vencimentos</th><th>Ações</th></tr></thead><tbody class="text-center align-middle"><% lancamentos.reverse().forEach(lancamento => { const vencimentoDate = lancamento.vencimento ? new Date(lancamento.vencimento).toISOString().split('T')[0] : ''; %><tr id="row-<%= lancamento.id %>"><td class="py-0"><%= lancamento.id %></td><td class="py-0"><%= lancamento.entrada_saida.toUpperCase() %></td><td class="py-0"><%= new Date(lancamento.data).toLocaleDateString('pt-BR') %></td><td class="py-0"><%= lancamento.tipo_de_lancamento.replace(/_/g, ' ').toUpperCase() %></td><td class="py-0"><%= lancamento.forma_de_pagamento.toUpperCase() %></td><td class="py-0">R$ <%= typeof lancamento.valor === 'number' ? 'R$ ' + lancamento.valor.toFixed(2) : lancamento.valor.toUpperCase() %></td><td class="py-0"><%= lancamento.descricao.toUpperCase() %></td><td class="py-0"><form action="/lancamentos/<%= lancamento.id %>/updateVencimento" method="POST" class="d-inline"><div class="d-flex align-items-center"><input type="date" class="form-control form-control-sm me-2" name="vencimento" id="vencimento-<%= lancamento.id %>" value="<%= vencimentoDate %>"><button type="submit" class="btn btn-success btn-sm">Salvar</button></div></form></td><td class="py-0"><a href="/lancamentos/<%= lancamento.id %>/view" class="btn btn-secondary btn-sm">Visualizar</a><a href="/lancamentos/<%= lancamento.id %>/edit" class="btn btn-warning btn-sm my-1">Editar</a><form action="/lancamentos/<%= lancamento.id %>?_method=DELETE" method="POST" class="d-inline delete-form"><button type="submit" class="btn btn-danger btn-sm">Deletar</button></form></td></tr><% }) %></tbody></table></div></main></div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const rows = document.querySelectorAll('tr[id^="row-"]'); const today = new Date();
            rows.forEach(row => { const vencimentoInput = row.querySelector('input[type="date"]'); const vencimentoDate = new Date(vencimentoInput.value); const daysDifference = (vencimentoDate - today) / (1000 * 3600 * 24); row.classList.toggle('table-danger', daysDifference <= 10 && daysDifference >= 0); });
            document.querySelectorAll('.delete-form').forEach((form) => { form.addEventListener('submit', async (event) => { event.preventDefault(); const confirmed = await window.AppAlerts?.confirm({ title: 'Excluir lan?amento', text: 'Tem certeza que deseja deletar este lan?amento?', confirmButtonText: 'Excluir', cancelButtonText: 'Cancelar' }); if (confirmed) form.submit(); }); });
            <% if (typeof success !== 'undefined') { %>window.AppAlerts?.success("<%- success.replace(/"/g, '&quot;') %>");<% } %>
            <% if (typeof error !== 'undefined') { %>window.AppAlerts?.error("<%- error.replace(/"/g, '&quot;') %>");<% } %>
        });
    </script>
</body>
</html>
