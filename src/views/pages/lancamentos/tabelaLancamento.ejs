<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Lançamentos Cadastrados' }) %>

<body class="list-page-body">
    <%- include('../../partials/header') %>
    <% const isReadOnly = Boolean(typeof assinaturaSomenteLeitura !== 'undefined' && assinaturaSomenteLeitura); %>
    <div class="page-spacer"></div>
    <% const currentFiltro = typeof tipoFiltro !== 'undefined' ? tipoFiltro : 'todos'; %>

    <div class="list-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Lançamentos Cadastrados' }) %>

        <section class="page-titlebar page-titlebar-neutral">
            <div class="page-titlebar-content">
                <span class="list-kicker"><i class="bi bi-cash-stack"></i> Financeiro</span>
                <h1>Lançamentos cadastrados</h1>
                <p>Consulte entradas e saídas com destaque para parcelas, vencimentos e ações de manutenção do fluxo financeiro.</p>
            </div>
            <div class="page-titlebar-side">
                <div class="list-stat">
                    <strong>Total</strong>
                    <span id="launchCount"><%= lancamentos.length %> lançamentos</span>
                </div>
                <div class="list-stat">
                    <strong>Ação rápida</strong>
                    <span>Novo registro financeiro</span>
                </div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <div class="list-toolbar">
                    <div class="list-toolbar-copy">
                        <h2>Painel de movimentações</h2>
                        <p>Revise parcelas, categorias e datas sem depender de edição manual do vencimento na grade.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="list-action" href="/lancamentos/vencimentos">
                            <i class="bi bi-bell"></i>
                            <span>Vencimentos</span>
                        </a>
                        <% if (!isReadOnly) { %>
                            <a class="list-action" href="/lancamentos/add">
                                <i class="bi bi-plus-circle"></i>
                                <span>Novo lançamento</span>
                            </a>
                        <% } %>
                    </div>
                </div>

                <div class="table-mode-switch" aria-label="Filtro de lançamentos">
                    <a href="/lancamentos?tipo=todos" class="table-mode-btn <%= currentFiltro === 'todos' ? 'is-active' : '' %>">Todos</a>
                    <a href="/lancamentos?tipo=entrada" class="table-mode-btn <%= currentFiltro === 'entrada' ? 'is-active' : '' %>">Entradas</a>
                    <a href="/lancamentos?tipo=saida" class="table-mode-btn <%= currentFiltro === 'saida' ? 'is-active' : '' %>">Saídas</a>
                </div>

                <div class="list-summary-grid">
                    <div class="list-summary-card"><strong>Entradas e saídas</strong><span>Visão consolidada</span></div>
                    <div class="list-summary-card"><strong>Parcelas</strong><span>Destaque visual</span></div>
                    <div class="list-summary-card"><strong>Operação</strong><span>Gestão financeira</span></div>
                    <div class="list-summary-card"><strong>Total</strong><span id="launchSummaryCount"><%= lancamentos.length %> registros</span></div>
                </div>

                <div class="modern-table-wrap">
                    <div class="modern-table-scroll">
                        <table class="modern-table launch-table">
                            <thead>
                                <tr>
                                    <th>Tipo</th>
                                    <th>Data</th>
                                    <th class="table-col-category">Categoria</th>
                                    <th>Pagamento</th>
                                    <th>Valor</th>
                                    <th class="table-col-description">Descrição</th>
                                    <th>Vencimento</th>
                                    <th class="table-actions-heading">Ações</th>
                                </tr>
                            </thead>
                            <tbody id="launchTableBody">
                                <% lancamentos.slice().reverse().forEach((lancamento) => { 
                                    const vencimentoLabel = lancamento.vencimento ? new Date(lancamento.vencimento).toLocaleDateString('pt-BR') : 'Não definido';
                                    const isParcelado = Number(lancamento.qtde_de_parcelas || 0) > 1;
                                    const rowTone = lancamento.entrada_saida === 'Entrada' ? 'table-badge-green' : 'table-badge-danger';
                                %>
                                    <tr id="row-<%= lancamento.id %>" data-vencimento="<%= lancamento.vencimento || '' %>" class="<%= isParcelado ? 'launch-row-parcelado' : '' %>">
                                        <td>
                                            <div class="table-stack-compact">
                                                <span class="table-badge <%= rowTone %>"><%= lancamento.entrada_saida.toUpperCase() %></span>
                                                <% if (isParcelado) { %>
                                                    <span class="table-badge table-badge-amber">PARCELA</span>
                                                <% } %>
                                            </div>
                                        </td>
                                        <td><%= new Date(lancamento.data).toLocaleDateString('pt-BR') %></td>
                                        <td class="table-col-category">
                                            <div class="table-title-cell"><%= lancamento.tipo_de_lancamento.replace(/_/g, ' ').toUpperCase() %></div>
                                        </td>
                                        <td><%= String(lancamento.forma_de_pagamento || '').toUpperCase() %></td>
                                        <td>
                                            <strong><%= Number(lancamento.valor).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></strong>
                                        </td>
                                        <td class="table-cell-description">
                                            <span class="table-muted"><%= String(lancamento.descricao || '').toUpperCase() %></span>
                                        </td>
                                        <td>
                                            <div class="table-vencimento-copy <%= lancamento.vencimento ? '' : 'is-empty' %>">
                                                <strong><%= vencimentoLabel %></strong>
                                                <% if (isParcelado) { %>
                                                    <span>Definido no cadastro</span>
                                                <% } %>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="table-actions table-actions-launch">
                                                <a href="/lancamentos/<%= lancamento.id %>/view" class="table-btn table-btn-view">Visualizar</a>
                                                <% if (!isReadOnly) { %>
                                                    <a href="/lancamentos/<%= lancamento.id %>/edit" class="table-btn table-btn-edit">Editar</a>
                                                    <form action="/lancamentos/<%= lancamento.id %>" method="POST" class="d-inline delete-form" data-row-id="row-<%= lancamento.id %>" data-delete-url="/lancamentos/<%= lancamento.id %>">
                                                        <input type="hidden" name="_method" value="DELETE">
                                                        <button type="submit" class="table-btn table-btn-delete">Deletar</button>
                                                    </form>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const rows = document.querySelectorAll('tr[id^="row-"]');
            const today = new Date();
            const tableBody = document.getElementById('launchTableBody');
            const launchCount = document.getElementById('launchCount');
            const launchSummaryCount = document.getElementById('launchSummaryCount');

            const syncCounters = () => {
                const totalRows = tableBody.querySelectorAll('tr[id^="row-"]').length;
                launchCount.textContent = `${totalRows} lançamentos`;
                launchSummaryCount.textContent = `${totalRows} registros`;
            };

            rows.forEach((row) => {
                const vencimentoValue = row.dataset.vencimento;
                if (!vencimentoValue) return;

                const vencimentoDate = new Date(`${vencimentoValue}T00:00:00`);
                const daysDifference = (vencimentoDate - today) / (1000 * 3600 * 24);

                if (daysDifference <= 10 && daysDifference >= 0) {
                    row.querySelectorAll('td').forEach((cell) => {
                        cell.classList.add('table-cell-highlight');
                    });
                }
            });

            document.querySelectorAll('.delete-form').forEach((form) => {
                form.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    const confirmed = await window.AppAlerts?.confirm({
                        title: 'Excluir lançamento',
                        text: 'Tem certeza que deseja deletar este lançamento?',
                        confirmButtonText: 'Excluir',
                        cancelButtonText: 'Cancelar'
                    });

                    if (!confirmed) return;

                    try {
                        const rowId = form.dataset.rowId || '';
                        const launchId = rowId.replace('row-', '').trim();
                        const actionAttr = form.getAttribute('action') || '';
                        const deleteUrl = form.dataset.deleteUrl
                            || actionAttr.replace(/\?.*$/, '')
                            || (launchId ? `/lancamentos/${launchId}` : '');

                        if (!deleteUrl || !/\/lancamentos\/\d+$/.test(deleteUrl)) {
                            throw new Error('Não foi possível identificar a rota de exclusão deste lançamento.');
                        }

                        const response = await fetch(deleteUrl, {
                            method: 'DELETE',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest',
                                'Accept': 'application/json'
                            }
                        });

                        const contentType = response.headers.get('content-type') || '';
                        const payload = contentType.includes('application/json')
                            ? await response.json()
                            : { success: false, message: 'A exclusão não retornou JSON válido.' };

                        if (!response.ok || !payload.success) {
                            throw new Error(payload.message || 'Erro ao excluir lançamento.');
                        }

                        const row = document.getElementById(rowId);
                        row?.remove();
                        syncCounters();
                        window.AppAlerts?.success(payload.message || 'Lançamento excluído com sucesso.');
                    } catch (error) {
                        window.AppAlerts?.error(error.message || 'Erro ao excluir lançamento.');
                    }
                });
            });

            <% if (typeof success !== 'undefined') { %>window.AppAlerts?.success("<%- success.replace(/\"/g, '&quot;') %>");<% } %>
            <% if (typeof error !== 'undefined') { %>window.AppAlerts?.error("<%- error.replace(/\"/g, '&quot;') %>");<% } %>
        });
    </script>
    <%- include('../../partials/financialNotificationsPopup', { popupMode: 'launch-once' }) %>
</body>
</html>
