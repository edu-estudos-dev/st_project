<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Lançamentos Cadastrados' }) %>

<body class="list-page-body">
    <%- include('../../partials/header') %>
    <% const isReadOnly = Boolean(typeof assinaturaSomenteLeitura !== 'undefined' && assinaturaSomenteLeitura); %>
    <div class="page-spacer"></div>
    <% const currentFiltro = typeof tipoFiltro !== 'undefined' ? tipoFiltro : 'todos'; %>

    <%
        const formatMovimento = (value) => {
            const rawValue = String(value || '').trim().toLowerCase();

            if (rawValue === 'entrada') {
                return 'Entrada';
            }

            if (rawValue === 'saida' || rawValue === 'saída') {
                return 'Saída';
            }

            return value || 'Não informado';
        };

        const formatCategoria = (value) => {
            const labels = {
                receita_dos_pontos: 'Receita dos pontos',
                incremento_de_capital: 'Incremento de capital',
                compra: 'Compra',
                extra: 'Extra',
                'pro-labore': 'Pró-labore',
                gastos_recorrentes: 'Gastos recorrentes',
                bonus: 'Bônus'
            };

            const rawValue = String(value || '').trim();

            if (!rawValue) {
                return 'Não informado';
            }

            return labels[rawValue] || rawValue.replace(/_/g, ' ');
        };

        const formatFormaPagamento = (value) => {
            const labels = {
                boleto: 'Boleto',
                credito: 'Crédito',
                crédito: 'Crédito',
                pix: 'Pix',
                especie: 'Espécie',
                espécie: 'Espécie'
            };

            const rawValue = String(value || '').trim().toLowerCase();

            return labels[rawValue] || value || 'Não informado';
        };

        const formatDate = (value, fallback = '—') => {
            if (!value) {
                return fallback;
            }

            const date = new Date(value);

            if (Number.isNaN(date.getTime())) {
                return fallback;
            }

            return date.toLocaleDateString('pt-BR');
        };

        const formatCurrency = (value) => {
            const numericValue = Number(value);

            if (!Number.isFinite(numericValue)) {
                return 'Não informado';
            }

            return numericValue.toLocaleString('pt-BR', {
                style: 'currency',
                currency: 'BRL'
            });
        };

        const normalizeCategoriaKey = (value) =>
            String(value || '').trim().toLowerCase().replace(/\s+/g, '_');

        const isReceitaConsolidadaSistema = (lancamento) =>
            String(lancamento.usuario || '').trim().toLowerCase() === 'sistema'
            && lancamento.entrada_saida === 'Entrada'
            && normalizeCategoriaKey(lancamento.tipo_de_lancamento) === 'receita_dos_pontos';
    %>

    <div class="list-shell lancamentos-list-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Lançamentos Cadastrados' }) %>

        <section class="page-titlebar page-titlebar-neutral">
            <div class="page-titlebar-content">
                <span class="list-kicker"><i class="bi bi-cash-stack"></i> Financeiro</span>
                <h1>Lançamentos cadastrados</h1>
                <p>Consulte entradas e saídas com destaque para parcelas, vencimentos e ações de manutenção do fluxo financeiro.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="list-stat">
                    <strong>Total</strong>
                    <span id="launchCount"><%= lancamentos.length %> lançamentos</span>
                </div>

                <div class="list-stat">
                    <strong>Gestão</strong>
                    <span>Registros financeiros e vencimentos</span>
                </div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <div class="list-toolbar">
                    <div class="list-toolbar-copy">
                        <h2>Base de lançamentos</h2>
                        <p>Consulte os principais dados financeiros da operação e use os atalhos para acompanhar vencimentos, entradas e saídas.</p>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <a class="list-action" href="/lancamentos/vencimentos">
                            <i class="bi bi-bell"></i>
                            <span>Vencimentos</span>
                        </a>

                        <% if (!isReadOnly) { %>
                            <a class="list-action" href="/lancamentos/add">
                                <i class="bi bi-plus-circle"></i>
                                <span>Novo lançamento</span>
                            </a>
                        <% } %>
                    </div>
                </div>

                <div class="list-summary-grid">
                    <div class="list-summary-card">
                        <strong>Registros</strong>
                        <span id="launchSummaryCount"><%= lancamentos.length %> lançamentos</span>
                    </div>

                    <div class="list-summary-card">
                        <strong>Fluxo</strong>
                        <span>Entradas, saídas e parcelas</span>
                    </div>

                    <div class="list-summary-card">
                        <strong>Contexto</strong>
                        <span>Gestão financeira centralizada</span>
                    </div>

                    <div class="list-summary-card">
                        <strong>Visualização</strong>
                        <span>
                            <% if (currentFiltro === 'entrada') { %>
                                Entradas
                            <% } else if (currentFiltro === 'saida') { %>
                                Saídas
                            <% } else { %>
                                Todos os lançamentos
                            <% } %>
                        </span>
                    </div>
                </div>

                <div class="table-mode-switch" aria-label="Filtro de lançamentos">
                    <a href="/lancamentos?tipo=todos" class="table-mode-btn <%= currentFiltro === 'todos' ? 'is-active' : '' %>">
                        Todos
                    </a>

                    <a href="/lancamentos?tipo=entrada" class="table-mode-btn <%= currentFiltro === 'entrada' ? 'is-active' : '' %>">
                        Entradas
                    </a>

                    <a href="/lancamentos?tipo=saida" class="table-mode-btn <%= currentFiltro === 'saida' ? 'is-active' : '' %>">
                        Saídas
                    </a>
                </div>

                <div class="modern-table-wrap launch-table-wrap">
                    <div class="modern-table-scroll launch-table-scroll">
                        <table class="modern-table launch-table">
                            <thead>
                                <tr>
                                    <th class="launch-col-movement">Movimentação</th>
                                    <th class="launch-col-payment">Pagamento</th>
                                    <th class="launch-col-value">Valor</th>
                                    <th class="launch-col-description">Descrição</th>
                                    <th class="launch-col-actions table-actions-heading">Ações</th>
                                </tr>
                            </thead>

                            <tbody id="launchTableBody">
                                <% if (!lancamentos.length) { %>
                                    <tr>
                                        <td colspan="5" class="table-empty">
                                            Nenhum lançamento encontrado.
                                        </td>
                                    </tr>
                                <% } %>

                                <% lancamentos.slice().reverse().forEach((lancamento) => {
                                    const formaPagamento = String(lancamento.forma_de_pagamento || '').toLowerCase();
                                    const parcelas = Number(lancamento.qtde_de_parcelas || 0);
                                    const isSaida = lancamento.entrada_saida === 'Saida';
                                    const formaParcelavel = ['boleto', 'credito'].includes(formaPagamento);

                                    const temVencimentoAplicavel = isSaida && formaParcelavel && parcelas > 1;
                                    const vencimentoLabel = temVencimentoAplicavel && lancamento.vencimento
                                        ? formatDate(lancamento.vencimento)
                                        : '';

                                    const rowTone = lancamento.entrada_saida === 'Entrada' ? 'table-badge-green' : 'table-badge-danger';
                                    const descricaoFormatada = String(lancamento.descricao || 'Sem descrição informada.');
                                    const categoriaFormatada = formatCategoria(lancamento.tipo_de_lancamento);
                                    const movimentoFormatado = formatMovimento(lancamento.entrada_saida);
                                    const pagamentoFormatado = formatFormaPagamento(lancamento.forma_de_pagamento);
                                    const receitaConsolidadaSistema = isReceitaConsolidadaSistema(lancamento);
                                %>
                                    <tr
                                        id="row-<%= lancamento.id %>"
                                        data-vencimento="<%= temVencimentoAplicavel ? (lancamento.vencimento || '') : '' %>"
                                        class="<%= temVencimentoAplicavel ? 'launch-row-parcelado' : '' %>"
                                    >
                                        <td class="launch-col-movement" data-label="Movimentação">
                                            <div class="launch-movement-cell">
                                                <div class="table-stack-compact">
                                                    <span class="table-badge <%= rowTone %>"><%= movimentoFormatado %></span>

                                                    <% if (temVencimentoAplicavel) { %>
                                                        <span class="table-badge table-badge-amber">Parcela</span>
                                                    <% } %>
                                                </div>

                                                <strong class="launch-main-title"><%= categoriaFormatada %></strong>

                                                <span class="launch-meta">
                                                    <i class="bi bi-calendar3"></i>
                                                    <%= formatDate(lancamento.data) %>
                                                </span>
                                            </div>
                                        </td>

                                        <td class="launch-col-payment" data-label="Pagamento">
                                            <div class="launch-payment-cell">
                                                <strong><%= pagamentoFormatado %></strong>

                                                <% if (temVencimentoAplicavel) { %>
                                                    <span class="launch-meta launch-due-meta">
                                                        <i class="bi bi-calendar-check"></i>
                                                        Venc. <%= vencimentoLabel %>
                                                    </span>
                                                <% } else { %>
                                                    <span class="launch-meta">Sem vencimento</span>
                                                <% } %>
                                            </div>
                                        </td>

                                        <td class="launch-col-value" data-label="Valor">
                                            <strong><%= formatCurrency(lancamento.valor) %></strong>
                                        </td>

                                        <td class="launch-col-description" data-label="Descrição">
                                            <span class="table-muted"><%= descricaoFormatada %></span>
                                        </td>

                                        <td class="launch-col-actions table-actions-cell" data-label="Ações">
                                            <div class="table-actions table-actions-launch">
                                                <a href="/lancamentos/<%= lancamento.id %>/view" class="table-btn table-btn-view">
                                                    <i class="bi bi-eye"></i>
                                                    <span>Ver</span>
                                                </a>

                                                <% if (!isReadOnly && !receitaConsolidadaSistema) { %>
                                                    <a href="/lancamentos/<%= lancamento.id %>/edit" class="table-btn table-btn-edit">
                                                        <i class="bi bi-pencil-square"></i>
                                                        <span>Editar</span>
                                                    </a>

                                                    <form
                                                        action="/lancamentos/<%= lancamento.id %>"
                                                        method="POST"
                                                        class="d-inline delete-form"
                                                        data-row-id="row-<%= lancamento.id %>"
                                                        data-delete-url="/lancamentos/<%= lancamento.id %>"
                                                    >
                                                        <input type="hidden" name="_method" value="DELETE">
                                                        <button type="submit" class="table-btn table-btn-delete">
                                                            <i class="bi bi-trash3"></i>
                                                            <span>Excluir</span>
                                                        </button>
                                                    </form>
                                                <% } else if (receitaConsolidadaSistema) { %>
                                                    <span class="table-muted">Gerado pelas sangrias</span>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
            <%- include('../../partials/pagination', { pagination }) %>
        </main>
    </div>

    <script nonce="<%= cspNonce || '' %>" src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <script nonce="<%= cspNonce || '' %>">
        document.addEventListener('DOMContentLoaded', () => {
            const rows = document.querySelectorAll('tr[id^="row-"]');
            const today = new Date();
            const tableBody = document.getElementById('launchTableBody');
            const launchCount = document.getElementById('launchCount');
            const launchSummaryCount = document.getElementById('launchSummaryCount');

            const syncCounters = () => {
                const totalRows = tableBody.querySelectorAll('tr[id^="row-"]').length;
                launchCount.textContent = `${totalRows} lançamentos`;
                launchSummaryCount.textContent = `${totalRows} lançamentos`;
            };

            rows.forEach((row) => {
                const vencimentoValue = row.dataset.vencimento;
                if (!vencimentoValue) return;

                const vencimentoDate = new Date(`${vencimentoValue}T00:00:00`);
                const daysDifference = (vencimentoDate - today) / (1000 * 3600 * 24);

                if (daysDifference <= 10 && daysDifference >= 0) {
                    row.querySelectorAll('td').forEach((cell) => {
                        cell.classList.add('table-cell-highlight');
                    });
                }
            });

            document.querySelectorAll('.delete-form').forEach((form) => {
                form.addEventListener('submit', async (event) => {
                    event.preventDefault();

                    if (form.dataset.deleting === 'true') {
                        return;
                    }

                    form.dataset.deleting = 'true';

                    const confirmed = await window.AppAlerts?.confirm({
                        title: 'Excluir lançamento',
                        text: 'Tem certeza que deseja excluir este lançamento?',
                        confirmButtonText: 'Excluir',
                        cancelButtonText: 'Cancelar'
                    });

                    if (!confirmed) {
                        delete form.dataset.deleting;
                        return;
                    }

                    try {
                        window.AppLoading?.show(
                            'Excluindo lançamento...',
                            'Removendo o registro financeiro selecionado.'
                        );

                        const rowId = form.dataset.rowId || '';
                        const launchId = rowId.replace('row-', '').trim();
                        const actionAttr = form.getAttribute('action') || '';
                        const deleteUrl = form.dataset.deleteUrl
                            || actionAttr.replace(/\?.*$/, '')
                            || (launchId ? `/lancamentos/${launchId}` : '');

                        if (!deleteUrl || !/\/lancamentos\/\d+$/.test(deleteUrl)) {
                            throw new Error('Não foi possível identificar a rota de exclusão deste lançamento.');
                        }

                        const response = await fetch(deleteUrl, {
                            method: 'DELETE',
                            headers: {
                                'X-Requested-With': 'XMLHttpRequest',
                                'Accept': 'application/json'
                            }
                        });

                        const contentType = response.headers.get('content-type') || '';
                        const payload = contentType.includes('application/json')
                            ? await response.json()
                            : { success: false, message: 'A exclusão não retornou JSON válido.' };

                        if (!response.ok || !payload.success) {
                            throw new Error(payload.message || 'Erro ao excluir lançamento.');
                        }

                        const row = document.getElementById(rowId);
                        row?.remove();
                        syncCounters();
                        window.AppLoading?.hide();
                        window.AppAlerts?.success(payload.message || 'Lançamento excluído com sucesso.');
                    } catch (error) {
                        delete form.dataset.deleting;
                        window.AppLoading?.hide();
                        window.AppAlerts?.error(error.message || 'Erro ao excluir lançamento.');
                    }
                });
            });

            <% if (typeof success !== 'undefined') { %>
                window.AppAlerts?.success("<%- success.replace(/"/g, '&quot;') %>");
            <% } %>

            <% if (typeof error !== 'undefined') { %>
                window.AppAlerts?.error("<%- error.replace(/"/g, '&quot;') %>");
            <% } %>
        });
    </script>

    <%- include('../../partials/financialNotificationsPopup', { popupMode: 'launch-once' }) %>
</body>
</html>
