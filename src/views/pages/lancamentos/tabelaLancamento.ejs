<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Lançamentos Cadastrados' }) %>

<body class="list-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>
    <% const currentFiltro = typeof tipoFiltro !== 'undefined' ? tipoFiltro : 'todos'; %>

    <div class="list-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Lançamentos Cadastrados' }) %>

        <section class="list-hero list-hero-neutral">
            <div class="list-hero-content">
                <span class="list-kicker"><i class="bi bi-cash-stack"></i> Financeiro</span>
                <h1>Lançamentos cadastrados</h1>
                <p>Consulte entradas e saídas em uma tabela mais clara, com destaque para vencimentos, valores e ações de manutenção do fluxo financeiro.</p>
            </div>
            <div class="list-hero-side">
                <div class="list-stat">
                    <strong>Total</strong>
                    <span><%= lancamentos.length %> lançamentos</span>
                </div>
                <div class="list-stat">
                    <strong>Ação rápida</strong>
                    <span>Novo registro financeiro</span>
                </div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <div class="list-toolbar">
                    <div class="list-toolbar-copy">
                        <h2>Painel de movimentações</h2>
                        <p>Atualize vencimentos, revise categorias e navegue pelas ações de visualizar, editar e excluir sem perder legibilidade.</p>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <a class="list-action" href="/lancamentos/vencimentos">
                            <i class="bi bi-bell"></i>
                            <span>Vencimentos</span>
                        </a>
                        <a class="list-action" href="/lancamentos/add">
                            <i class="bi bi-plus-circle"></i>
                            <span>Novo lançamento</span>
                        </a>
                    </div>
                </div>

                <div class="table-mode-switch" aria-label="Filtro de lançamentos">
                    <a href="/lancamentos?tipo=todos" class="table-mode-btn <%= currentFiltro === 'todos' ? 'is-active' : '' %>">Todos</a>
                    <a href="/lancamentos?tipo=entrada" class="table-mode-btn <%= currentFiltro === 'entrada' ? 'is-active' : '' %>">Entradas</a>
                    <a href="/lancamentos?tipo=saida" class="table-mode-btn <%= currentFiltro === 'saida' ? 'is-active' : '' %>">Saídas</a>
                </div>

                <div class="list-summary-grid">
                    <div class="list-summary-card"><strong>Entradas e saídas</strong><span>Visão consolidada</span></div>
                    <div class="list-summary-card"><strong>Vencimentos</strong><span>Edição inline</span></div>
                    <div class="list-summary-card"><strong>Operação</strong><span>Gestão financeira</span></div>
                    <div class="list-summary-card"><strong>Total</strong><span><%= lancamentos.length %> registros</span></div>
                </div>

                <div class="modern-table-wrap">
                    <div class="modern-table-scroll">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Tipo</th>
                                    <th>Data</th>
                                    <th class="table-col-category">Categoria</th>
                                    <th>Pagamento</th>
                                    <th>Valor</th>
                                    <th class="table-col-description">Descrição</th>
                                    <th>Vencimento</th>
                                    <th class="table-actions-heading">Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% lancamentos.slice().reverse().forEach(lancamento => { const vencimentoDate = lancamento.vencimento ? new Date(lancamento.vencimento).toISOString().split('T')[0] : ''; %>
                                    <tr id="row-<%= lancamento.id %>">
                                        <td><span class="table-badge table-badge-neutral">#<%= lancamento.id %></span></td>
                                        <td><span class="table-badge <%= lancamento.entrada_saida === 'Entrada' ? 'table-badge-green' : 'table-badge-danger' %>"><%= lancamento.entrada_saida.toUpperCase() %></span></td>
                                        <td><%= new Date(lancamento.data).toLocaleDateString('pt-BR') %></td>
                                        <td class="table-col-category"><div class="table-title-cell"><%= lancamento.tipo_de_lancamento.replace(/_/g, ' ').toUpperCase() %></div></td>
                                        <td><%= String(lancamento.forma_de_pagamento || '').toUpperCase() %></td>
                                        <td><strong><%= Number(lancamento.valor).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></strong></td>
                                        <td class="table-cell-description"><span class="table-muted"><%= String(lancamento.descricao || '').toUpperCase() %></span></td>
                                        <td>
                                            <form action="/lancamentos/<%= lancamento.id %>/updateVencimento" method="POST" class="table-inline-form">
                                                <input type="date" class="form-control form-control-sm" name="vencimento" id="vencimento-<%= lancamento.id %>" value="<%= vencimentoDate %>">
                                                <button type="submit" class="table-btn table-btn-save">Salvar</button>
                                            </form>
                                        </td>
                                        <td>
                                            <div class="table-actions table-actions-launch">
                                                <a href="/lancamentos/<%= lancamento.id %>/view" class="table-btn table-btn-view">Visualizar</a>
                                                <a href="/lancamentos/<%= lancamento.id %>/edit" class="table-btn table-btn-edit">Editar</a>
                                                <form action="/lancamentos/<%= lancamento.id %>?_method=DELETE" method="POST" class="d-inline delete-form">
                                                    <button type="submit" class="table-btn table-btn-delete">Deletar</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const rows = document.querySelectorAll('tr[id^="row-"]');
            const today = new Date();

            rows.forEach((row) => {
                const vencimentoInput = row.querySelector('input[type="date"]');
                if (!vencimentoInput || !vencimentoInput.value) return;

                const vencimentoDate = new Date(vencimentoInput.value);
                const daysDifference = (vencimentoDate - today) / (1000 * 3600 * 24);

                if (daysDifference <= 10 && daysDifference >= 0) {
                    row.querySelectorAll('td').forEach((cell) => {
                        cell.classList.add('table-cell-highlight');
                    });
                }
            });

            document.querySelectorAll('.delete-form').forEach((form) => {
                form.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    const confirmed = await window.AppAlerts?.confirm({
                        title: 'Excluir lançamento',
                        text: 'Tem certeza que deseja deletar este lançamento?',
                        confirmButtonText: 'Excluir',
                        cancelButtonText: 'Cancelar'
                    });
                    if (confirmed) form.submit();
                });
            });

            <% if (typeof success !== 'undefined') { %>window.AppAlerts?.success("<%- success.replace(/\"/g, '&quot;') %>");<% } %>
            <% if (typeof error !== 'undefined') { %>window.AppAlerts?.error("<%- error.replace(/\"/g, '&quot;') %>");<% } %>
        });
    </script>
</body>
</html>
