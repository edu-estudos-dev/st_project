<!DOCTYPE html>
<html lang="pt-BR">
<%- include('../../partials/head', { title: 'Rotas dos Pontos' }) %>

<body class="list-page-body">
    <% const mapsEmbedApiKey = typeof googleMapsEmbedApiKey !== 'undefined' ? googleMapsEmbedApiKey : ''; %>
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Rotas dos Pontos' }) %>

        <section class="page-titlebar page-titlebar-neutral">
            <div class="page-titlebar-content">
                <span class="list-kicker"><i class="bi bi-sign-turn-right"></i> Operação</span>
                <h1>Central de rotas</h1>
                <p>Selecione um ou mais bairros, organize a sequência de visitas e avance ponto a ponto sem rodar à toa.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="list-stat">
                    <strong>Bairros</strong>
                    <span><%= selectedBairros?.length ? selectedBairros.join(', ') : 'Selecione' %></span>
                </div>

                <div class="list-stat">
                    <strong>Pontos</strong>
                    <span><%= routeSummary.total %> na rota</span>
                </div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <div class="dashboard-panel-header route-planner-header">
                    <div>
                        <span class="dashboard-section-tag">Planejamento</span>
                        <h2>Montar rota do dia</h2>
                    </div>
                </div>

                <form action="/rotas" method="GET" class="modern-form route-planner-form" id="routePlannerForm">
                    <div class="route-planner-grid">
                        <div class="route-planner-field route-planner-field-neighborhood">
                            <div class="route-neighborhood-header">
                                <label>Bairros</label>
                            </div>

                            <div class="route-neighborhood-picker" data-route-neighborhood-picker>
                                <button
                                    type="button"
                                    class="route-neighborhood-trigger"
                                    data-route-neighborhood-trigger
                                    aria-expanded="false"
                                >
                                    <span data-route-neighborhood-summary>Selecione os bairros</span>
                                    <i class="bi bi-geo-alt"></i>
                                </button>
                            </div>

                            <small class="route-neighborhood-count" data-route-neighborhood-count>
                                <%= selectedBairros?.length || 0 %> bairro(s) selecionado(s)
                            </small>
                        </div>

                        <div class="route-planner-field">
                            <label for="produto">Produto</label>
                            <select class="form-select" id="produto" name="produto">
                                <% produtoOptions.forEach((option) => { %>
                                    <option value="<%= option.value %>" <%= selectedProduto === option.value ? 'selected' : '' %>><%= option.label %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="route-planner-footer">
                        <p>O sistema usa os pontos ativos dos bairros escolhidos para montar uma fila de visitas baseada na sua posição atual.</p>

                        <div class="route-planner-actions">
                            <button type="submit" class="btn-modern route-planner-submit-button">
                                <i class="bi bi-search"></i>
                                <span>Gerar rota</span>
                            </button>
                        </div>
                    </div>
                </form>
            </section>

            <section class="dashboard-grid dashboard-grid-bottom">
                <article class="dashboard-panel dashboard-panel-primary">
                    <div class="dashboard-panel-header">
                        <div>
                            <span class="dashboard-section-tag">Execução</span>
                            <h2>Modo de visita</h2>
                        </div>

                        <p>Comece pela sua localização atual, confirme a chegada e deixe o sistema apontar o próximo destino.</p>
                    </div>

                    <section class="route-journey-card">
                        <div class="route-journey-status">
                            <span class="route-journey-pill">Rota assistida</span>

                            <strong id="routeJourneyTitle">
                                <%= routeSummary.total ? 'Pronto para organizar a fila de visitas.' : 'Selecione ao menos um bairro para iniciar a rota.' %>
                            </strong>

                            <p id="routeJourneyText">
                                <%= routeSummary.total ? 'Clique em "Iniciar rota inteligente" para ordenar os pontos a partir da sua localização atual.' : 'Assim que houver pontos na seleção, o sistema libera o modo de visita.' %>
                            </p>

                            <% if (routeSummary.total) { %>
                                <small class="route-journey-note">
                                    <%= routeSummary.coordinatesCoverage %> de <%= routeSummary.total %> ponto(s) já têm latitude e longitude salvas.
                                    Quanto mais coordenadas cadastradas, melhor fica a ordem sugerida.
                                </small>
                            <% } %>
                        </div>

                        <div class="route-journey-actions">
                            <button type="button" class="btn-modern" id="startSmartRouteButton" <%= routeSummary.total ? '' : 'disabled' %>>
                                <i class="bi bi-geo-alt-fill"></i>
                                <span>Iniciar rota inteligente</span>
                            </button>

                            <button type="button" class="btn-route-secondary" id="markVisitedButton" disabled>
                                <i class="bi bi-check2-circle"></i>
                                <span>Cheguei neste ponto</span>
                            </button>

                            <button type="button" class="btn-route-ghost" id="resetRouteButton" disabled>
                                <i class="bi bi-arrow-counterclockwise"></i>
                                <span>Reiniciar rota</span>
                            </button>
                        </div>

                        <div class="route-journey-helper">
                            <i class="bi bi-info-circle"></i>
                            <span id="routeJourneyHelperText">
                                <%= routeSummary.total ? 'O botão "Cheguei neste ponto" fica liberado logo depois que a rota for iniciada.' : 'Selecione ao menos um bairro para liberar a rota assistida.' %>
                            </span>
                        </div>

                        <div class="route-progress-strip" id="routeProgressStrip">
                            <div class="route-progress-pill">
                                <strong id="routeProgressDone">0</strong>
                                <span>concluídos</span>
                            </div>

                            <div class="route-progress-pill">
                                <strong id="routeProgressPending"><%= routeSummary.total %></strong>
                                <span>pendentes</span>
                            </div>

                            <div class="route-progress-pill">
                                <strong id="routeProgressMode">Nova rota</strong>
                                <span>estado atual</span>
                            </div>
                        </div>

                        <div class="route-next-stop" id="routeNextStopCard">
                            <strong>Próximo ponto</strong>
                            <span id="routeNextStopName">Aguardando início da rota</span>
                            <small id="routeNextStopMeta">O sistema vai calcular a melhor próxima visita com base na sua posição atual.</small>

                            <div class="route-next-stop-actions">
                                <a href="#" class="table-btn table-btn-view is-disabled" id="routeOpenGoogleButton" aria-disabled="true">Abrir no Google Maps</a>
                                <a href="#" class="table-btn table-btn-edit is-disabled" id="routeOpenWazeButton" aria-disabled="true">Abrir no Waze</a>
                            </div>
                        </div>

                    </section>
                </article>

                <aside class="dashboard-panel dashboard-panel-primary">
                    <div class="dashboard-panel-header">
                        <div>
                            <span class="dashboard-section-tag">Resumo</span>
                            <h2>Leitura rápida da rota</h2>
                        </div>

                        <p>Conferência rápida antes de sair para a rua.</p>
                    </div>

                    <section class="route-summary-card">
                        <div class="route-summary-top">
                            <strong><%= routeSummary.total %> ponto(s) na seleção</strong>
                            <span><%= selectedBairros?.length ? `Bairros ${selectedBairros.join(', ')}` : 'Escolha ao menos um bairro para montar a rota.' %></span>
                        </div>

                        <div class="route-summary-grid">
                            <article class="route-summary-item">
                                <strong>Filtro atual</strong>
                                <span><%= produtoOptions.find((item) => item.value === selectedProduto)?.label || 'Todos os produtos' %></span>
                                <em>Planejamento</em>
                            </article>

                            <article class="route-summary-item">
                                <strong>Coordenadas salvas</strong>
                                <span><%= routeSummary.coordinatesCoverage %> ponto(s) com latitude e longitude já cadastradas.</span>
                                <em>Precisão</em>
                            </article>
                        </div>
                    </section>

                    <div class="route-circuit-card route-circuit-card-wide" id="routeCircuitCard">
                        <div class="route-circuit-header">
                            <div>
                                <strong>Mapa do percurso</strong>
                                <span id="routeCircuitSummary">Inicie a rota para visualizar o circuito completo.</span>
                            </div>

                            <a href="#" class="table-btn table-btn-view is-disabled" id="routeOpenFullMapButton" aria-disabled="true">
                                Abrir rota completa
                            </a>
                        </div>

                        <div class="route-circuit-map" id="routeCircuitMap" aria-label="Mapa esquemático do circuito da rota">
                            <% if (mapsEmbedApiKey) { %>
                                <iframe
                                    id="routeGoogleMapFrame"
                                    class="route-google-map-frame"
                                    title="Mapa da rota no Google Maps"
                                    loading="lazy"
                                    allowfullscreen
                                    referrerpolicy="no-referrer-when-downgrade"
                                    src=""
                                ></iframe>
                            <% } %>
                            <svg viewBox="0 0 640 300" role="img" aria-hidden="true">
                                <polyline id="routeCircuitLine" points="" fill="none" />
                                <g id="routeCircuitMarkers"></g>
                            </svg>

                            <div class="route-circuit-empty" id="routeCircuitEmpty">
                                O circuito aparece aqui depois que a localização atual for liberada.
                            </div>
                        </div>

                        <div class="route-circuit-stats">
                            <span>
                                <strong id="routeCircuitDistance">-- km</strong>
                                <small>percurso estimado</small>
                            </span>

                            <span>
                                <strong id="routeCircuitStops"><%= routeSummary.total %></strong>
                                <small>paradas</small>
                            </span>

                            <span>
                                <strong id="routeCircuitReturn">Retorno</strong>
                                <small>termina no ponto inicial</small>
                            </span>
                        </div>
                    </div>
                </aside>
            </section>

            <section class="list-panel">
                <div class="dashboard-panel-header route-list-header">
                    <div>
                        <span class="dashboard-section-tag">Fila de visitas</span>
                        <h2>Estabelecimentos da rota</h2>
                    </div>

                    <% if (routeItems?.length) { %>
                        <div class="route-list-header-actions">
                            <p>Imprima a sequência atual da rota ou ajuste a ordem antes de gerar o PDF.</p>

                            <button type="button" class="btn-modern-secondary route-planner-pdf-button" id="routePdfButton">
                                <i class="bi bi-printer"></i>
                                <span>Imprimir rota</span>
                            </button>
                        </div>
                    <% } else { %>
                        <p>Selecione os bairros e gere a rota para imprimir a sequência de visitas.</p>
                    <% } %>
                </div>

                <% if (!selectedBairros?.length) { %>
                    <div class="dashboard-empty-state dashboard-empty-state-light">
                        <h3>Nenhuma rota gerada ainda</h3>
                        <p>Selecione um ou mais bairros acima para listar os pontos ativos e montar o trajeto.</p>
                    </div>
                <% } else if (!routeItems.length) { %>
                    <div class="dashboard-empty-state dashboard-empty-state-light">
                        <h3>Sem pontos para esse filtro</h3>
                        <p>Não há estabelecimentos ativos nos bairros e produto escolhidos.</p>
                    </div>
                <% } else { %>
                    <div class="route-point-list" id="routePointList">
                        <% routeItems.forEach((item, index) => { %>
                            <article
                                class="route-point-card"
                                data-route-index="<%= index %>"
                                data-route-item
                                data-id="<%= item.id %>"
                                data-name="<%= item.estabelecimento %>"
                                data-address="<%= item.enderecoCompleto %>"
                                data-google="<%= item.googleMapsLink || '' %>"
                                data-waze="<%= item.wazeLink || '' %>"
                                data-latitude="<%= item.latitude ?? '' %>"
                                data-longitude="<%= item.longitude ?? '' %>"
                                data-product="<%= item.produtoLabel %>"
                                data-neighborhood="<%= item.bairro || '' %>"
                                data-key-bolinhas="<%= item.chave_bolinhas || item.chave || '-' %>"
                                data-machine-bolinhas="<%= item.maquina_bolinhas || item.maquina || '-' %>"
                                data-key-pelucias="<%= item.chave_pelucias || '-' %>"
                                data-machine-pelucias="<%= item.maquina_pelucias || '-' %>"
                            >
                                <div class="route-point-copy">
                                    <span class="route-point-order" data-route-order><%= item.orderLabel %></span>

                                    <h3><%= item.estabelecimento %></h3>

                                    <p><strong>Produtos:</strong> <%= item.produtoLabel %></p>
                                    <p><strong>Endereço:</strong> <%= item.enderecoCompleto %></p>
                                    <p><strong>Responsável:</strong> <%= item.responsavel_nome || 'Não informado' %> | <strong>Contato:</strong> <%= item.telefone_contato || 'Não informado' %></p>
                                    <p><strong>Coordenadas:</strong> <%= item.hasCoordinates ? `${item.latitude}, ${item.longitude}` : 'Ainda não cadastradas' %></p>

                                    <small class="route-point-status" data-route-status>Aguardando organização da rota</small>
                                </div>

                                <div class="route-point-actions">
                                    <div class="route-point-order-actions" aria-label="Reordenar ponto">
                                        <button type="button" class="route-order-button" data-route-move="up" title="Mover ponto para cima">
                                            <i class="bi bi-arrow-up"></i>
                                            <span>Subir</span>
                                        </button>

                                        <button type="button" class="route-order-button" data-route-move="down" title="Mover ponto para baixo">
                                            <i class="bi bi-arrow-down"></i>
                                            <span>Descer</span>
                                        </button>
                                    </div>

                                    <button type="button" class="table-btn table-btn-danger route-remove-point-button" data-route-remove>
                                        <i class="bi bi-x-circle"></i>
                                        <span>Remover da rota</span>
                                    </button>

                                    <% if (item.googleMapsLink) { %>
                                        <a href="<%= item.googleMapsLink %>" target="_blank" rel="noopener noreferrer" class="table-btn table-btn-view">Google Maps</a>
                                    <% } %>

                                    <% if (item.wazeLink) { %>
                                        <a href="<%= item.wazeLink %>" target="_blank" rel="noopener noreferrer" class="table-btn table-btn-edit">Waze</a>
                                    <% } %>

                                    <a href="/estabelecimentos/<%= item.id %>/view" class="table-btn table-btn-pay">Ver ponto</a>
                                </div>
                            </article>
                        <% }) %>
                    </div>
                <% } %>
            </section>
        </main>
    </div>

    <div class="route-neighborhood-modal-backdrop" data-route-neighborhood-backdrop></div>

    <section class="route-neighborhood-modal" data-route-neighborhood-modal aria-hidden="true">
        <div class="route-neighborhood-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="routeNeighborhoodModalTitle">
            <div class="route-neighborhood-modal-header">
                <div>
                    <span>Planejamento</span>
                    <h2 id="routeNeighborhoodModalTitle">Selecionar bairros</h2>
                </div>

                <button type="button" class="route-neighborhood-modal-close" data-route-neighborhood-close aria-label="Fechar seleção de bairros">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="route-neighborhood-modal-tools">
                <div class="route-neighborhood-search">
                    <i class="bi bi-search"></i>
                    <input type="search" placeholder="Filtrar bairros" data-route-neighborhood-filter aria-label="Filtrar bairros">
                </div>

                <div class="route-neighborhood-actions" aria-label="Acoes de selecao de bairros">
                    <button type="button" data-route-select-all>Todos</button>
                    <button type="button" data-route-clear-selection>Limpar</button>
                </div>
            </div>

            <div class="route-neighborhood-list" data-route-neighborhood-list>
                <% bairros.forEach((item, index) => { %>
                    <% const bairroId = `bairro-${index}`; %>

                    <label class="route-neighborhood-option" for="<%= bairroId %>" data-route-neighborhood-option>
                        <input
                            type="checkbox"
                            id="<%= bairroId %>"
                            name="bairros"
                            value="<%= item.bairro %>"
                            form="routePlannerForm"
                            <%= selectedBairros?.includes(item.bairro) ? 'checked' : '' %>
                        >
                        <span><%= item.bairro %></span>
                    </label>
                <% }) %>
            </div>

            <div class="route-neighborhood-modal-footer">
                <span data-route-neighborhood-modal-count><%= selectedBairros?.length || 0 %> bairro(s) selecionado(s)</span>

                <button type="button" class="btn-route-secondary" data-route-neighborhood-apply>
                    <i class="bi bi-check2"></i>
                    <span>Aplicar seleção</span>
                </button>
            </div>
        </div>
    </section>

    <% if (routeItems?.length) { %>
        <script src="/vendor/jspdf/jspdf.umd.min.js"></script>
        <script src="/vendor/jspdf-autotable/jspdf.plugin.autotable.min.js"></script>
    <% } %>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const plannerForm = document.querySelector('.route-planner-form');
            const picker = document.querySelector('[data-route-neighborhood-picker]');
            const trigger = document.querySelector('[data-route-neighborhood-trigger]');
            const summaryEl = document.querySelector('[data-route-neighborhood-summary]');
            const countEl = document.querySelector('[data-route-neighborhood-count]');
            const modalCountEl = document.querySelector('[data-route-neighborhood-modal-count]');
            const modal = document.querySelector('[data-route-neighborhood-modal]');
            const backdrop = document.querySelector('[data-route-neighborhood-backdrop]');
            const closeButton = document.querySelector('[data-route-neighborhood-close]');
            const applyButton = document.querySelector('[data-route-neighborhood-apply]');
            const filterInput = document.querySelector('[data-route-neighborhood-filter]');
            const optionLabels = Array.from(document.querySelectorAll('[data-route-neighborhood-option]'));
            const selectAllButton = document.querySelector('[data-route-select-all]');
            const clearButton = document.querySelector('[data-route-clear-selection]');
            const checkboxes = Array.from(document.querySelectorAll('input[name="bairros"]'));

            if (!plannerForm || !picker || !trigger || !modal || !backdrop || !checkboxes.length) return;

            const openNeighborhoodModal = () => {
                document.body.classList.add('route-neighborhood-modal-open');
                modal.setAttribute('aria-hidden', 'false');
                picker.classList.remove('route-neighborhood-picker-empty');
                trigger.setAttribute('aria-expanded', 'true');
                setTimeout(() => filterInput?.focus(), 80);
            };

            const closeNeighborhoodModal = () => {
                document.body.classList.remove('route-neighborhood-modal-open');
                modal.setAttribute('aria-hidden', 'true');
                trigger.setAttribute('aria-expanded', 'false');
            };

            const syncNeighborhoodState = () => {
                const selected = checkboxes.filter((checkbox) => checkbox.checked);
                const selectedCount = selected.length;

                if (summaryEl) {
                    if (!selectedCount) {
                        summaryEl.textContent = 'Selecione os bairros';
                    } else if (selectedCount <= 2) {
                        summaryEl.textContent = selected.map((checkbox) => checkbox.value).join(', ');
                    } else {
                        summaryEl.textContent = `${selectedCount} bairros selecionados`;
                    }
                }

                if (countEl) {
                    countEl.textContent = `${selectedCount} bairro(s) selecionado(s)`;
                }

                if (modalCountEl) {
                    modalCountEl.textContent = `${selectedCount} bairro(s) selecionado(s)`;
                }
            };

            trigger.addEventListener('click', openNeighborhoodModal);

            checkboxes.forEach((checkbox) => {
                checkbox.addEventListener('change', syncNeighborhoodState);
            });

            selectAllButton?.addEventListener('click', () => {
                checkboxes.forEach((checkbox) => {
                    checkbox.checked = true;
                });

                syncNeighborhoodState();
            });

            clearButton?.addEventListener('click', () => {
                checkboxes.forEach((checkbox) => {
                    checkbox.checked = false;
                });

                syncNeighborhoodState();
            });

            filterInput?.addEventListener('input', () => {
                const term = filterInput.value.trim().toUpperCase();

                optionLabels.forEach((label) => {
                    const value = label.textContent.trim().toUpperCase();
                    label.hidden = term && !value.includes(term);
                });
            });

            closeButton?.addEventListener('click', closeNeighborhoodModal);
            applyButton?.addEventListener('click', closeNeighborhoodModal);
            backdrop.addEventListener('click', closeNeighborhoodModal);

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    closeNeighborhoodModal();
                }
            });

            plannerForm.addEventListener('submit', (event) => {
                const hasSelectedNeighborhood = checkboxes.some((checkbox) => checkbox.checked);

                if (hasSelectedNeighborhood) return;

                event.preventDefault();
                window.AppAlerts?.error('Selecione ao menos um bairro para gerar a rota.');
                picker.classList.add('route-neighborhood-picker-empty');
                openNeighborhoodModal();
            });

            syncNeighborhoodState();
        });
    </script>

    <% if (routeItems?.length) { %>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                let routeItems = Array.from(document.querySelectorAll('[data-route-item]'));

                const selectedBairrosData = <%- JSON.stringify(selectedBairros || []) %>;
                const selectedProdutoData = <%- JSON.stringify(selectedProduto || 'todos') %>;

                const routePointList = document.getElementById('routePointList');
                const startButton = document.getElementById('startSmartRouteButton');
                const markVisitedButton = document.getElementById('markVisitedButton');
                const resetRouteButton = document.getElementById('resetRouteButton');
                const titleEl = document.getElementById('routeJourneyTitle');
                const textEl = document.getElementById('routeJourneyText');
                const helperTextEl = document.getElementById('routeJourneyHelperText');
                const nextStopNameEl = document.getElementById('routeNextStopName');
                const nextStopMetaEl = document.getElementById('routeNextStopMeta');
                const googleButton = document.getElementById('routeOpenGoogleButton');
                const wazeButton = document.getElementById('routeOpenWazeButton');
                const progressDoneEl = document.getElementById('routeProgressDone');
                const progressPendingEl = document.getElementById('routeProgressPending');
                const progressModeEl = document.getElementById('routeProgressMode');
                const routePdfButton = document.getElementById('routePdfButton');
                const routeCircuitMap = document.getElementById('routeCircuitMap');
                const routeCircuitLine = document.getElementById('routeCircuitLine');
                const routeCircuitMarkers = document.getElementById('routeCircuitMarkers');
                const routeCircuitSummary = document.getElementById('routeCircuitSummary');
                const routeCircuitDistance = document.getElementById('routeCircuitDistance');
                const routeOpenFullMapButton = document.getElementById('routeOpenFullMapButton');
                const routeCircuitStops = document.getElementById('routeCircuitStops');
                const routeGoogleMapFrame = document.getElementById('routeGoogleMapFrame');
                const googleMapsEmbedApiKey = <%- JSON.stringify(mapsEmbedApiKey || '') %>;

                const routeStorageKey = `vendmaster:rota:${JSON.stringify(selectedBairrosData)}:${selectedProdutoData}`;
                const routeUrlParams = new URLSearchParams(window.location.search);
                const rotaPontoFinalizadoId = routeUrlParams.get('rota_ponto_finalizado');

               let routeState = {
                    currentIndex: -1,
                    started: false,
                    rotaId: null,
                    rotaPontos: [],
                    visitedIds: []
                };

                const geocodeAddress = async (address) => {
                    const url = `https://nominatim.openstreetmap.org/search?format=jsonv2&limit=1&q=${encodeURIComponent(address)}`;
                    const response = await fetch(url, {
                        headers: { Accept: 'application/json' }
                    });

                    if (!response.ok) {
                        throw new Error('Falha ao geocodificar endereço.');
                    }

                    const results = await response.json();

                    if (!results.length) return null;

                    return {
                        lat: Number(results[0].lat),
                        lon: Number(results[0].lon)
                    };
                };

                const haversine = (origin, destination) => {
                    const toRad = (value) => (value * Math.PI) / 180;
                    const earthRadiusKm = 6371;
                    const dLat = toRad(destination.lat - origin.lat);
                    const dLon = toRad(destination.lon - origin.lon);
                    const lat1 = toRad(origin.lat);
                    const lat2 = toRad(destination.lat);

                    const a =
                        Math.sin(dLat / 2) ** 2 +
                        Math.cos(lat1) * Math.cos(lat2) * Math.sin(dLon / 2) ** 2;

                    return 2 * earthRadiusKm * Math.asin(Math.sqrt(a));
                };

                const buildGoogleRoute = (address) => `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(address)}&travelmode=driving`;
                const buildWazeRoute = (address) => `https://www.waze.com/ul?q=${encodeURIComponent(address)}&navigate=yes`;

                const setActionLinkState = (anchor, href) => {
                    if (!anchor) return;

                    if (!href) {
                        anchor.href = '#';
                        anchor.classList.add('is-disabled');
                        anchor.setAttribute('aria-disabled', 'true');
                        return;
                    }

                    anchor.href = href;
                    anchor.classList.remove('is-disabled');
                    anchor.setAttribute('aria-disabled', 'false');
                    anchor.setAttribute('target', '_blank');
                    anchor.setAttribute('rel', 'noopener noreferrer');
                };

                const buildFullGoogleRoute = (startPosition, orderedCards) => {
                    const origin = `${startPosition.lat},${startPosition.lon}`;
                    const waypoints = orderedCards
                        .map((card) => card.dataset.address)
                        .filter(Boolean)
                        .map((address) => encodeURIComponent(address));

                    const base = `https://www.google.com/maps/dir/?api=1&travelmode=driving&origin=${origin}&destination=${origin}`;

                    return waypoints.length ? `${base}&waypoints=${waypoints.join('|')}` : base;
                };

                const buildGoogleEmbedRoute = (startPosition, orderedCards) => {
                    if (!googleMapsEmbedApiKey || !orderedCards.length) return null;

                    const origin = `${startPosition.lat},${startPosition.lon}`;
                    const waypoints = orderedCards
                        .map((card) => card.dataset.address)
                        .filter(Boolean)
                        .join('|');

                    const params = new URLSearchParams({
                        key: googleMapsEmbedApiKey,
                        origin,
                        destination: origin,
                        mode: 'driving'
                    });

                    if (waypoints) {
                        params.set('waypoints', waypoints);
                    }

                    return `https://www.google.com/maps/embed/v1/directions?${params.toString()}`;
                };

                const renderCircuitMap = (startPosition, orderedWithCoords, totalDistanceKm) => {
                    if (!routeCircuitMap || !routeCircuitLine || !routeCircuitMarkers) return;

                    const points = [
                        { label: 'I', coords: startPosition, start: true },
                        ...orderedWithCoords.map((item, index) => ({
                            label: String(index + 1),
                            coords: item.coords,
                            start: false
                        })),
                        { label: 'I', coords: startPosition, start: true }
                    ];

                    const lats = points.map((point) => point.coords.lat);
                    const lons = points.map((point) => point.coords.lon);
                    const minLat = Math.min(...lats);
                    const maxLat = Math.max(...lats);
                    const minLon = Math.min(...lons);
                    const maxLon = Math.max(...lons);
                    const latRange = Math.max(maxLat - minLat, 0.001);
                    const lonRange = Math.max(maxLon - minLon, 0.001);
                    const width = 640;
                    const height = 300;
                    const padding = 34;

                    const project = (coords) => ({
                        x: padding + ((coords.lon - minLon) / lonRange) * (width - padding * 2),
                        y: height - padding - ((coords.lat - minLat) / latRange) * (height - padding * 2)
                    });

                    const projected = points.map((point) => ({
                        ...point,
                        ...project(point.coords)
                    }));

                    routeCircuitLine.setAttribute('points', projected.map((point) => `${point.x},${point.y}`).join(' '));

                    routeCircuitMarkers.innerHTML = projected
                        .slice(0, -1)
                        .map((point) => `
                            <g class="route-circuit-marker ${point.start ? 'route-circuit-marker-start' : ''}">
                                <circle cx="${point.x}" cy="${point.y}" r="15"></circle>
                                <text x="${point.x}" y="${point.y + 1}">${point.label}</text>
                            </g>
                        `)
                        .join('');

                    routeCircuitMap.classList.add('has-route');
                    routeCircuitDistance.textContent = `${totalDistanceKm.toFixed(1)} km`;
                    routeCircuitSummary.textContent = `Circuito com saída e retorno ao ponto inicial, passando por ${orderedWithCoords.length} parada(s).`;
                };

                const calculateCircuitDistance = (startPosition, orderedWithCoords) => {
                    if (!orderedWithCoords.length) return 0;

                    let total = haversine(startPosition, orderedWithCoords[0].coords);

                    orderedWithCoords.forEach((item, index) => {
                        const next = orderedWithCoords[index + 1];

                        if (next) {
                            total += haversine(item.coords, next.coords);
                        }
                    });

                    total += haversine(orderedWithCoords[orderedWithCoords.length - 1].coords, startPosition);

                    return total;
                };

                const getCurrentCard = () => {
                    if (!routeState.started || routeState.currentIndex < 0 || routeState.currentIndex >= routeItems.length) {
                        return null;
                    }

                    return routeItems[routeState.currentIndex];
                };

                const getCurrentCardId = () => getCurrentCard()?.dataset.id || null;

                const getRotaPontoForCard = (card) => {
                    if (!card || !Array.isArray(routeState.rotaPontos)) return null;

                    const estabelecimentoId = Number(card.dataset.id);

                    return routeState.rotaPontos.find((ponto) => {
                        return Number(ponto.estabelecimento_id) === estabelecimentoId;
                    }) || null;
                };

                const getCurrentPositionSafe = async () => {
                    return new Promise((resolve) => {
                        if (!navigator.geolocation) {
                            resolve(null);
                            return;
                        }

                        navigator.geolocation.getCurrentPosition(
                            (position) => {
                                resolve({
                                    lat: position.coords.latitude,
                                    lon: position.coords.longitude
                                });
                            },
                            () => resolve(null),
                            {
                                enableHighAccuracy: true,
                                timeout: 8000,
                                maximumAge: 60000
                            }
                        );
                    });
                };

                const iniciarRotaOperacionalNoBanco = async (startPosition, orderedCards) => {
                    const response = await fetch('/rotas/operacional/iniciar', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            Accept: 'application/json'
                        },
                        body: JSON.stringify({
                            bairros: selectedBairrosData,
                            produto: selectedProdutoData,
                            origem_latitude: startPosition?.lat ?? null,
                            origem_longitude: startPosition?.lon ?? null,
                            pontos: orderedCards.map((card, index) => ({
                                estabelecimento_id: Number(card.dataset.id),
                                ordem: index + 1
                            }))
                        })
                    });

                    const data = await response.json().catch(() => null);

                    if (!response.ok || !data?.success) {
                        throw new Error(data?.message || 'Não foi possível salvar a rota operacional.');
                    }

                    return data;
                };

                const registrarChegadaNoBanco = async (rotaPontoId, position = null) => {
                    const response = await fetch(`/rotas/pontos/${rotaPontoId}/chegada`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            Accept: 'application/json'
                        },
                        body: JSON.stringify({
                            latitude_chegada: position?.lat ?? null,
                            longitude_chegada: position?.lon ?? null,
                            retorno_url: `${window.location.pathname}${window.location.search}`
                        })
                    });

                    const data = await response.json().catch(() => null);

                    if (!response.ok || !data?.success) {
                        throw new Error(data?.message || 'Não foi possível registrar a chegada ao ponto.');
                    }

                    return data;
                };

                const updateRouteButtonsState = () => {
                    routeItems.forEach((card, index) => {
                        const upButton = card.querySelector('[data-route-move="up"]');
                        const downButton = card.querySelector('[data-route-move="down"]');
                        const removeButton = card.querySelector('[data-route-remove]');

                        if (upButton) {
                            upButton.disabled = index === 0;
                        }

                        if (downButton) {
                            downButton.disabled = index === routeItems.length - 1;
                        }

                        if (removeButton) {
                            removeButton.disabled = routeItems.length <= 1 && routeState.started;
                        }
                    });

                    if (routePdfButton) {
                        routePdfButton.disabled = routeItems.length === 0;
                    }

                    if (startButton) {
                        startButton.disabled = routeItems.length === 0 || routeState.started;
                    }

                    if (routeCircuitStops) {
                        routeCircuitStops.textContent = routeItems.length;
                    }
                };

                const saveRouteState = () => {
                    if (!routeItems.length) {
                        localStorage.removeItem(routeStorageKey);
                        return;
                    }

                    localStorage.setItem(routeStorageKey, JSON.stringify({
                        currentIndex: routeState.currentIndex,
                        started: routeState.started,
                        rotaId: routeState.rotaId,
                        rotaPontos: routeState.rotaPontos,
                        visitedIds: routeState.visitedIds,
                        orderedIds: routeItems.map((card) => card.dataset.id),
                        savedAt: new Date().toISOString()
                    }));
                };

                const updateProgress = () => {
                    const done = routeState.started
                        ? Math.min(getVisitedIdSet().size, routeItems.length)
                        : 0;

                    const pending = Math.max(routeItems.length - done, 0);

                    progressDoneEl.textContent = done;
                    progressPendingEl.textContent = pending;

                    if (!routeState.started) {
                        progressModeEl.textContent = 'Nova rota';
                    } else if (routeState.currentIndex >= routeItems.length) {
                        progressModeEl.textContent = 'Finalizada';
                    } else {
                        progressModeEl.textContent = 'Em andamento';
                    }
                };

                const getVisitedIdSet = () => {
                    return new Set((routeState.visitedIds || []).map(String));
                };

                const findNextPendingIndex = (startIndex = 0) => {
                    const visitedIds = getVisitedIdSet();

                    for (let offset = 0; offset < routeItems.length; offset += 1) {
                        const index = (startIndex + offset) % routeItems.length;
                        const card = routeItems[index];

                        if (!visitedIds.has(String(card.dataset.id))) {
                            return index;
                        }
                    }

                    return routeItems.length;
                };

                const renderQueue = () => {
                    const visitedIds = getVisitedIdSet();
                    const currentCard = getCurrentCard();
                    const currentCardId = currentCard ? String(currentCard.dataset.id) : null;

                    routeItems.forEach((card, index) => {
                        const orderEl = card.querySelector('[data-route-order]');
                        const statusEl = card.querySelector('[data-route-status]');
                        const cardId = String(card.dataset.id);

                        const isVisited = routeState.started && visitedIds.has(cardId);
                        const isCurrent =
                            routeState.started &&
                            currentCardId === cardId &&
                            !isVisited &&
                            routeState.currentIndex < routeItems.length;

                        const isPending = routeState.started && !isVisited && !isCurrent;

                        card.classList.toggle('route-point-card-current', isCurrent);
                        card.classList.toggle('route-point-card-visited', isVisited);

                        if (orderEl) {
                            orderEl.textContent = `${index + 1}º ponto`;
                        }

                        if (!statusEl) return;

                        if (!routeState.started) {
                            statusEl.textContent = 'Aguardando organização da rota';
                        } else if (isVisited) {
                            statusEl.textContent = 'Visita concluída';
                        } else if (isCurrent) {
                            statusEl.textContent = 'Próximo destino da rota';
                        } else if (isPending) {
                            statusEl.textContent = 'Na fila das próximas visitas';
                        }
                    });

                    updateRouteButtonsState();
                };

                const scrollToCurrentCard = () => {
                    if (!routeState.started || routeState.currentIndex < 0 || routeState.currentIndex >= routeItems.length) {
                        return;
                    }

                    routeItems[routeState.currentIndex].scrollIntoView({
                        behavior: 'smooth',
                        block: 'center'
                    });
                };

                const syncCurrentStop = () => {
                    updateProgress();
                    resetRouteButton.disabled = !routeState.started;

                    if (!routeItems.length) {
                        titleEl.textContent = 'Nenhum ponto na rota';
                        textEl.textContent = 'Todos os pontos foram removidos desta rota.';
                        helperTextEl.textContent = 'Gere uma nova rota para voltar a listar pontos.';
                        nextStopNameEl.textContent = 'Nenhum ponto disponível';
                        nextStopMetaEl.textContent = 'A rota atual ficou vazia.';

                        setActionLinkState(googleButton, null);
                        setActionLinkState(wazeButton, null);
                        setActionLinkState(routeOpenFullMapButton, null);

                        markVisitedButton.disabled = true;
                        resetRouteButton.disabled = true;

                        localStorage.removeItem(routeStorageKey);
                        return;
                    }

                    if (!routeState.started || routeState.currentIndex >= routeItems.length) {
                        titleEl.textContent = routeState.started ? 'Rota finalizada' : 'Pronto para organizar a fila de visitas.';

                        textEl.textContent = routeState.started
                            ? 'Todos os pontos da fila já foram marcados como visitados.'
                            : 'Clique em "Iniciar rota inteligente" para ordenar os pontos a partir da sua localização atual.';

                        helperTextEl.textContent = routeState.started
                            ? 'Você concluiu a rota selecionada. Se quiser, reinicie a rota para montar uma nova ordem.'
                            : 'O botão "Cheguei neste ponto" fica liberado logo depois que a rota for iniciada.';

                        nextStopNameEl.textContent = routeState.started ? 'Nenhum ponto pendente' : 'Aguardando início da rota';

                        nextStopMetaEl.textContent = routeState.started
                            ? 'Você concluiu a rota selecionada.'
                            : 'O sistema vai calcular a melhor próxima visita com base na sua posição atual.';

                        setActionLinkState(googleButton, null);
                        setActionLinkState(wazeButton, null);

                        markVisitedButton.disabled = true;
                        saveRouteState();
                        updateRouteButtonsState();
                        return;
                    }

                    const currentCard = routeItems[routeState.currentIndex];
                    const address = currentCard.dataset.address;
                    const name = currentCard.dataset.name;

                    titleEl.textContent = `Rota em andamento: ${routeState.currentIndex + 1}/${routeItems.length}`;
                    textEl.textContent = 'Quando chegar ao ponto atual, toque em "Cheguei neste ponto" para abrir a visita guiada.';
                    helperTextEl.textContent = routeState.rotaId
                        ? 'A rota operacional já foi salva. Ao chegar, o sistema abre a tela de visita do ponto.'
                        : 'Inicie a rota inteligente para salvar a rota operacional antes da visita.';
                    nextStopNameEl.textContent = name;
                    nextStopMetaEl.textContent = address;

                    setActionLinkState(googleButton, buildGoogleRoute(address));
                    setActionLinkState(wazeButton, buildWazeRoute(address));

                    markVisitedButton.disabled = !routeState.rotaId;
                    saveRouteState();
                    updateRouteButtonsState();
                };

                const reorderCards = () => {
                    routeItems.forEach((card) => routePointList.appendChild(card));
                    renderQueue();
                    syncCurrentStop();
                    updateRouteButtonsState();
                    scrollToCurrentCard();
                };

                const syncNextPendingFromVisualOrder = () => {
                    if (!routeState.started) return;

                    routeState.currentIndex = findNextPendingIndex(0);
                };

                const syncRouteAfterManualChange = () => {
                    if (!routeItems.length) {
                        routeState = {
                            currentIndex: -1,
                            started: false,
                            rotaId: null,
                            rotaPontos: [],
                            visitedIds: []
                        };

                        localStorage.removeItem(routeStorageKey);

                        titleEl.textContent = 'Nenhum ponto na rota';
                        textEl.textContent = 'Todos os pontos foram removidos desta rota.';
                        helperTextEl.textContent = 'Gere uma nova rota para voltar a listar pontos.';
                        nextStopNameEl.textContent = 'Nenhum ponto disponível';
                        nextStopMetaEl.textContent = 'A rota atual ficou vazia.';
                        progressDoneEl.textContent = '0';
                        progressPendingEl.textContent = '0';
                        progressModeEl.textContent = 'Sem pontos';

                        setActionLinkState(googleButton, null);
                        setActionLinkState(wazeButton, null);
                        setActionLinkState(routeOpenFullMapButton, null);

                        markVisitedButton.disabled = true;
                        resetRouteButton.disabled = true;

                        routeCircuitMap?.classList.remove('has-route', 'has-google-map');
                        routeCircuitLine?.setAttribute('points', '');

                        if (routeGoogleMapFrame) {
                            routeGoogleMapFrame.src = '';
                        }

                        if (routeCircuitMarkers) {
                            routeCircuitMarkers.innerHTML = '';
                        }

                        if (routeCircuitDistance) {
                            routeCircuitDistance.textContent = '-- km';
                        }

                        if (routeCircuitSummary) {
                            routeCircuitSummary.textContent = 'Nenhum ponto disponível para montar o circuito.';
                        }

                        updateRouteButtonsState();
                        return;
                    }

                    syncNextPendingFromVisualOrder();
                    renderQueue();
                    syncCurrentStop();
                    updateRouteButtonsState();
                };

                const moveRouteCard = (card, direction) => {
                    const currentIndex = routeItems.indexOf(card);

                    if (currentIndex < 0) return;

                    const targetIndex = direction === 'up' ? currentIndex - 1 : currentIndex + 1;

                    if (targetIndex < 0 || targetIndex >= routeItems.length) return;

                    const [movedCard] = routeItems.splice(currentIndex, 1);

                    routeItems.splice(targetIndex, 0, movedCard);
                    routeItems.forEach((item) => routePointList.appendChild(item));

                    helperTextEl.textContent = routeState.started
                        ? 'Ordem ajustada manualmente. O próximo destino agora segue a nova ordem da fila.'
                        : 'Ordem ajustada manualmente. Você ainda pode iniciar a rota inteligente ou seguir esta ordem.';

                    syncRouteAfterManualChange();
                    saveRouteState();
                };

                const removeRouteCard = async (card) => {
                    const pointName = card.dataset.name || 'este ponto';

                    const confirmed = await window.AppAlerts?.confirm({
                        title: 'Remover ponto da rota',
                        text: `Deseja remover ${pointName} apenas desta rota? O estabelecimento não será excluído do sistema.`,
                        confirmButtonText: 'Remover da rota',
                        cancelButtonText: 'Cancelar'
                    });

                    if (!confirmed) return;

                    const removedIndex = routeItems.indexOf(card);

                    if (removedIndex < 0) return;

                    routeItems.splice(removedIndex, 1);
                    card.remove();

                    helperTextEl.textContent = `${pointName} foi removido apenas desta rota.`;

                    syncRouteAfterManualChange();
                    saveRouteState();
                };

                routePointList?.addEventListener('click', async (event) => {
                    const moveButton = event.target.closest('[data-route-move]');
                    const removeButton = event.target.closest('[data-route-remove]');

                    if (!moveButton && !removeButton) return;

                    const card = event.target.closest('[data-route-item]');

                    if (!card) return;

                    if (moveButton) {
                        moveRouteCard(card, moveButton.dataset.routeMove);
                        return;
                    }

                    if (removeButton) {
                        await removeRouteCard(card);
                    }
                });

                const getCardCoordinates = async (card) => {
                    const latitude = Number(card.dataset.latitude);
                    const longitude = Number(card.dataset.longitude);

                    if (Number.isFinite(latitude) && Number.isFinite(longitude)) {
                        return {
                            lat: latitude,
                            lon: longitude
                        };
                    }

                    return geocodeAddress(card.dataset.address);
                };

                const applySavedOrder = (orderedIds) => {
                    if (!Array.isArray(orderedIds) || !orderedIds.length) return false;

                    const cardById = new Map(routeItems.map((card) => [card.dataset.id, card]));
                    const orderedCards = [];

                    for (const id of orderedIds) {
                        const card = cardById.get(id);

                        if (card) {
                            orderedCards.push(card);
                        }
                    }

                    if (!orderedCards.length) return false;

                    routeItems.forEach((card) => {
                        if (!orderedIds.includes(card.dataset.id)) {
                            orderedCards.push(card);
                        }
                    });

                    routeItems = orderedCards;

                    return true;
                };

                const restoreSavedRoute = () => {
                    try {
                        const raw = localStorage.getItem(routeStorageKey);

                        if (!raw) return false;

                        const saved = JSON.parse(raw);

                        if (!saved || !Array.isArray(saved.orderedIds)) return false;

                        const orderApplied = applySavedOrder(saved.orderedIds);

                        if (!orderApplied) return false;

                       routeState = {
                            currentIndex: typeof saved.currentIndex === 'number' ? saved.currentIndex : -1,
                            started: Boolean(saved.started),
                            rotaId: saved.rotaId || null,
                            rotaPontos: Array.isArray(saved.rotaPontos) ? saved.rotaPontos : [],
                            visitedIds: Array.isArray(saved.visitedIds) ? saved.visitedIds.map(String) : []
                        };

                        if (routeState.currentIndex > routeItems.length) {
                            routeState.currentIndex = routeItems.length;
                        }

                        helperTextEl.textContent = routeState.started
                            ? 'Rota retomada automaticamente a partir do progresso salvo nesta máquina.'
                            : 'Ordem manual retomada automaticamente. Você pode iniciar a rota quando quiser.';

                        reorderCards();
                        return true;
                    } catch (error) {
                        console.error(error);
                        return false;
                    }
                };

                const showRouteCompletedCelebration = () => {

                const celebrationKey = `vendmaster:rota-concluida:${routeState.rotaId || routeStorageKey}`;

                if (sessionStorage.getItem(celebrationKey)) {
                    return;
                }

                sessionStorage.setItem(celebrationKey, 'true');

                const launchConfetti = () => {
                    const confettiLayer = document.createElement('div');

                    confettiLayer.style.position = 'fixed';
                    confettiLayer.style.inset = '0';
                    confettiLayer.style.pointerEvents = 'none';
                    confettiLayer.style.zIndex = '99999';
                    confettiLayer.style.overflow = 'hidden';

                    document.body.appendChild(confettiLayer);

                    const colors = ['#2563eb', '#22c55e', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4'];

                    for (let i = 0; i < 90; i += 1) {
                        const particle = document.createElement('span');
                        const size = Math.floor(Math.random() * 8) + 6;
                        const left = Math.random() * 100;
                        const delay = Math.random() * 0.7;
                        const duration = Math.random() * 1.8 + 2.6;
                        const rotate = Math.random() * 720;

                        particle.style.position = 'absolute';
                        particle.style.top = '-20px';
                        particle.style.left = `${left}%`;
                        particle.style.width = `${size}px`;
                        particle.style.height = `${size * 1.6}px`;
                        particle.style.borderRadius = '3px';
                        particle.style.background = colors[Math.floor(Math.random() * colors.length)];
                        particle.style.opacity = '0.95';
                        particle.style.transform = `rotate(${rotate}deg)`;
                        particle.style.animation = `vendmasterConfettiFall ${duration}s ease-in ${delay}s forwards`;

                        confettiLayer.appendChild(particle);
                    }

                    if (!document.getElementById('vendmasterConfettiStyle')) {
                        const style = document.createElement('style');

                        style.id = 'vendmasterConfettiStyle';
                        style.textContent = `
                            @keyframes vendmasterConfettiFall {
                                0% {
                                    transform: translateY(-30px) rotate(0deg);
                                    opacity: 1;
                                }

                                100% {
                                    transform: translateY(110vh) rotate(900deg);
                                    opacity: 0;
                                }
                            }
                        `;

                        document.head.appendChild(style);
                    }

                    setTimeout(() => {
                        confettiLayer.remove();
                    }, 5200);
                };

                    launchConfetti();

                    if (window.Swal) {
                        window.Swal.fire({
                            icon: 'success',
                            title: 'Rota concluída!',
                            html: `
                                <strong>Parabéns!</strong><br>
                                Todos os pontos desta rota foram visitados com sucesso.
                            `,
                            confirmButtonText: 'Excelente',
                            confirmButtonColor: '#2563eb',
                            timer: 5200,
                            timerProgressBar: true,
                            showClass: {
                                popup: 'animate__animated animate__fadeInDown'
                            },
                            hideClass: {
                                popup: 'animate__animated animate__fadeOutUp'
                            }
                        });

                        return;
                    }

                    window.AppAlerts?.success?.('Rota concluída! Todos os pontos foram visitados com sucesso.');
                };

                const applyFinishedRoutePointFromUrl = () => {
                    if (!rotaPontoFinalizadoId || !routeState.started || !Array.isArray(routeState.rotaPontos)) {
                        return false;
                    }

                    const pontoFinalizado = routeState.rotaPontos.find((ponto) => {
                        return String(ponto.id) === String(rotaPontoFinalizadoId);
                    });

                    if (!pontoFinalizado) {
                        return false;
                    }

                    const finishedCardIndex = routeItems.findIndex((card) => {
                        return String(card.dataset.id) === String(pontoFinalizado.estabelecimento_id);
                    });

                    if (finishedCardIndex < 0) {
                        return false;
                    }

                    const finishedEstabelecimentoId = String(pontoFinalizado.estabelecimento_id);

                    routeState.visitedIds = Array.from(
                        new Set([
                            ...(routeState.visitedIds || []).map(String),
                            finishedEstabelecimentoId
                        ])
                    );

                    routeState.currentIndex = findNextPendingIndex(finishedCardIndex + 1);

                    saveRouteState();
                    renderQueue();
                    syncCurrentStop();

                    if (routeState.currentIndex >= routeItems.length) {
                        showRouteCompletedCelebration();
                    }

                    const cleanUrl = new URL(window.location.href);
                    cleanUrl.searchParams.delete('rota_ponto_finalizado');
                    cleanUrl.searchParams.delete('success');

                    window.history.replaceState(
                        {},
                        document.title,
                        `${cleanUrl.pathname}${cleanUrl.search}${cleanUrl.hash}`
                    );

                    return true;
                };

                const resetRouteState = () => {
                   routeState = {
                    currentIndex: -1,
                    started: false,
                    rotaId: null,
                    rotaPontos: [],
                    visitedIds: []
                };

                    localStorage.removeItem(routeStorageKey);

                    routeItems.sort((left, right) => Number(left.dataset.routeIndex) - Number(right.dataset.routeIndex));

                    routeCircuitMap?.classList.remove('has-route', 'has-google-map');
                    routeCircuitLine?.setAttribute('points', '');

                    if (routeGoogleMapFrame) {
                        routeGoogleMapFrame.src = '';
                    }

                    if (routeCircuitMarkers) {
                        routeCircuitMarkers.innerHTML = '';
                    }

                    if (routeCircuitDistance) {
                        routeCircuitDistance.textContent = '-- km';
                    }

                    if (routeCircuitSummary) {
                        routeCircuitSummary.textContent = 'Inicie a rota para visualizar o circuito completo.';
                    }

                    setActionLinkState(routeOpenFullMapButton, null);

                    reorderCards();
                };

                const sortRouteByNearest = async () => {
                    titleEl.textContent = 'Calculando a rota';
                    textEl.textContent = 'Pegando sua localização e organizando os pontos selecionados para evitar deslocamento desnecessário.';
                    helperTextEl.textContent = 'Se um ponto ainda não tiver coordenadas salvas, o sistema usa o endereço como apoio.';

                    const currentPosition = await new Promise((resolve, reject) => {
                        if (!navigator.geolocation) {
                            reject(new Error('Geolocalização indisponível.'));
                            return;
                        }

                        navigator.geolocation.getCurrentPosition(
                            (position) => {
                                resolve({
                                    lat: position.coords.latitude,
                                    lon: position.coords.longitude
                                });
                            },
                            () => reject(new Error('Não foi possível ler sua localização atual.')),
                            {
                                enableHighAccuracy: true,
                                timeout: 12000,
                                maximumAge: 60000
                            }
                        );
                    });

                    const geocoded = [];

                    for (const card of routeItems) {
                        const coords = await getCardCoordinates(card);

                        geocoded.push({
                            card,
                            coords
                        });
                    }

                    const valid = geocoded.filter((item) => item.coords);
                    const invalid = geocoded.filter((item) => !item.coords);
                    const ordered = [];
                    const orderedWithCoords = [];
                    let origin = currentPosition;
                    const pending = [...valid];

                    while (pending.length) {
                        pending.sort((left, right) => haversine(origin, left.coords) - haversine(origin, right.coords));

                        const next = pending.shift();

                        ordered.push(next.card);
                        orderedWithCoords.push(next);
                        origin = next.coords;
                    }

                    invalid.forEach((item) => ordered.push(item.card));

                    const totalDistanceKm = calculateCircuitDistance(currentPosition, orderedWithCoords);

                    renderCircuitMap(currentPosition, orderedWithCoords, totalDistanceKm);
                    setActionLinkState(routeOpenFullMapButton, buildFullGoogleRoute(currentPosition, ordered));

                    const googleEmbedRouteUrl = buildGoogleEmbedRoute(currentPosition, ordered);

                    if (routeGoogleMapFrame && googleEmbedRouteUrl) {
                        routeGoogleMapFrame.src = googleEmbedRouteUrl;
                        routeCircuitMap?.classList.add('has-google-map');
                    }

                    const rotaOperacional = await iniciarRotaOperacionalNoBanco(currentPosition, ordered);

                    routeState = {
                        currentIndex: 0,
                        started: true,
                        rotaId: rotaOperacional.rota?.id || null,
                        rotaPontos: Array.isArray(rotaOperacional.pontos) ? rotaOperacional.pontos : [],
                        visitedIds: []
                    };

                    ordered.forEach((card, index) => {
                        routeItems[index] = card;
                    });

                    reorderCards();
                    saveRouteState();

                    window.AppAlerts?.success?.('Rota operacional iniciada com sucesso.');
                };

                const generateRoutePdf = () => {
                    const { jsPDF } = window.jspdf || {};

                    if (!jsPDF) return;

                    const doc = new jsPDF();
                    const orderedCards = Array.from(document.querySelectorAll('[data-route-item]'));
                    const bairros = new Set();

                    const data = orderedCards.map((card, index) => {
                        bairros.add(card.dataset.neighborhood || '-');

                        return [
                            `${index + 1}`,
                            card.dataset.name || '-',
                            card.dataset.address || '-',
                            card.dataset.keyBolinhas || '-',
                            card.dataset.machineBolinhas || '-',
                            card.dataset.keyPelucias || '-',
                            card.dataset.machinePelucias || '-',
                            card.dataset.neighborhood || '-',
                            card.dataset.product || '-'
                        ];
                    });

                    doc.setFontSize(14);
                    doc.text(`Rota de visitas: ${Array.from(bairros).join(', ')}`, 14, 18);

                    doc.setFontSize(9);
                    doc.text(`Gerado em ${new Date().toLocaleDateString('pt-BR')}`, 14, 25);

                    doc.autoTable({
                        head: [['#', 'Estabelecimento', 'Endereco', 'Chave Bolinhas', 'Maquina Bolinhas', 'Chave Pelucias', 'Maquina Pelucias', 'Bairro', 'Produto']],
                        body: data,
                        styles: {
                            fontSize: 8,
                            halign: 'center'
                        },
                        columnStyles: {
                            1: {
                                halign: 'left'
                            },
                            2: {
                                halign: 'left'
                            }
                        },
                        margin: {
                            top: 32
                        },
                        headStyles: {
                            fillColor: [37, 99, 235]
                        }
                    });

                    doc.save('Rota_de_Visitas.pdf');
                };

                startButton.addEventListener('click', async () => {
                    try {
                        startButton.disabled = true;
                        await sortRouteByNearest();
                    } catch (error) {
                        console.error(error);
                        window.AppAlerts?.error(error.message || 'Não foi possível iniciar a rota inteligente.');
                        titleEl.textContent = 'Falha ao iniciar a rota';
                        textEl.textContent = 'Permita a localização e tente novamente para organizar os pontos.';
                        helperTextEl.textContent = 'Se preferir, cadastre latitude e longitude nos estabelecimentos para melhorar a precisão.';
                    } finally {
                        updateRouteButtonsState();
                    }
                });

                markVisitedButton.addEventListener('click', async () => {
                    if (!routeState.started) return;

                    const currentCard = routeItems[routeState.currentIndex];
                    const currentName = currentCard?.dataset.name || 'este ponto';
                    const rotaPonto = getRotaPontoForCard(currentCard);

                    if (!rotaPonto?.id) {
                        window.AppAlerts?.error('Não encontrei o vínculo deste ponto com a rota operacional. Reinicie a rota e tente novamente.');
                        return;
                    }

                    const confirmed = await window.AppAlerts?.confirm({
                        title: 'Confirmar chegada',
                        text: `Você chegou em ${currentName}? Vamos abrir a visita guiada deste ponto.`,
                        confirmButtonText: 'Abrir visita',
                        cancelButtonText: 'Cancelar'
                    });

                    if (!confirmed) return;

                    try {
                        markVisitedButton.disabled = true;
                        helperTextEl.textContent = 'Registrando chegada e abrindo a visita guiada...';

                        const position = await getCurrentPositionSafe();

                        const chegada = await registrarChegadaNoBanco(rotaPonto.id, position);

                        saveRouteState();

                        if (chegada.redirectUrl) {
                            window.location.href = chegada.redirectUrl;
                            return;
                        }

                        window.AppAlerts?.error('Chegada registrada, mas a tela de visita não foi retornada.');
                    } catch (error) {
                        console.error(error);
                        window.AppAlerts?.error(error.message || 'Não foi possível abrir a visita guiada.');
                        markVisitedButton.disabled = false;
                        syncCurrentStop();
                    }
                });

                resetRouteButton.addEventListener('click', async () => {
                    const confirmed = await window.AppAlerts?.confirm({
                        title: 'Reiniciar rota',
                        text: 'Deseja apagar o progresso salvo desta rota e começar de novo?',
                        confirmButtonText: 'Reiniciar',
                        cancelButtonText: 'Cancelar'
                    });

                    if (!confirmed) return;

                    resetRouteState();
                });

                routePdfButton?.addEventListener('click', generateRoutePdf);

                renderQueue();
                updateProgress();
                updateRouteButtonsState();

                const restoredRoute = restoreSavedRoute();

                if (restoredRoute) {
                    applyFinishedRoutePointFromUrl();
                } else {
                    syncCurrentStop();
                }
            });
        </script>
    <% } %>
</body>

</html>
