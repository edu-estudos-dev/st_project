<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrfToken || '' %>">

  <title>Dados de cobrança - VendMaster</title>
  <meta name="robots" content="noindex, nofollow">

  <link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
  <link rel="stylesheet" href="<%= typeof assetPath !== 'undefined' ? assetPath('/css/styles.css') : '/css/styles.css' %>">

  <script defer src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script defer src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
  <script defer src="/js/appAlerts.js"></script>
  <script defer src="/js/csrf.js"></script>

  <style>
    .billing-page {
      min-height: 100vh;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.12), transparent 34rem),
        linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
      padding: 2rem 1rem;
    }

    .billing-shell {
      width: min(100%, 980px);
      margin: 0 auto;
    }

    .billing-hero {
      border-radius: 28px;
      padding: clamp(1.35rem, 3vw, 2.25rem);
      background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 52%, #38bdf8 100%);
      color: #fff;
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.18);
      margin-bottom: 1rem;
      overflow: hidden;
      position: relative;
    }

    .billing-hero::after {
      content: "";
      position: absolute;
      width: 18rem;
      height: 18rem;
      right: -6rem;
      top: -7rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
    }

    .billing-hero-content {
      position: relative;
      z-index: 1;
      max-width: 720px;
    }

    .billing-kicker {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.4rem 0.75rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.16);
      color: #fff;
      font-weight: 700;
      font-size: 0.82rem;
      margin-bottom: 0.9rem;
    }

    .billing-hero h1 {
      font-size: clamp(1.65rem, 4vw, 2.45rem);
      line-height: 1.08;
      font-weight: 800;
      margin: 0 0 0.75rem;
    }

    .billing-hero p {
      margin: 0;
      color: rgba(255, 255, 255, 0.86);
      font-size: clamp(0.98rem, 2vw, 1.08rem);
      line-height: 1.6;
    }

    .billing-card {
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
      overflow: hidden;
    }

    .billing-card-header {
      padding: 1.25rem 1.35rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.18);
      background: rgba(248, 250, 252, 0.82);
    }

    .billing-card-header h2 {
      margin: 0 0 0.35rem;
      color: #0f172a;
      font-size: 1.25rem;
      font-weight: 800;
    }

    .billing-card-header p {
      margin: 0;
      color: #64748b;
      line-height: 1.55;
    }

    .billing-card-body {
      padding: 1.35rem;
    }

    .billing-info-box {
      display: flex;
      gap: 0.8rem;
      padding: 1rem;
      border-radius: 18px;
      background: #eff6ff;
      color: #1e3a8a;
      margin-bottom: 1.2rem;
      border: 1px solid rgba(59, 130, 246, 0.18);
    }

    .billing-info-box i {
      font-size: 1.15rem;
      margin-top: 0.15rem;
    }

    .billing-info-box strong {
      display: block;
      margin-bottom: 0.15rem;
    }

    .billing-info-box span {
      display: block;
      color: #334155;
      line-height: 1.5;
    }

    .billing-form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .billing-field-full {
      grid-column: 1 / -1;
    }

    .billing-form label {
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 0.4rem;
    }

    .billing-form .form-control {
      border-radius: 14px;
      border-color: rgba(148, 163, 184, 0.45);
      padding: 0.78rem 0.9rem;
    }

    .billing-form .form-control:focus {
      border-color: #2563eb;
      box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.12);
    }

    .billing-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.25rem;
    }

    .billing-actions .btn {
      border-radius: 999px;
      font-weight: 800;
      padding: 0.78rem 1.15rem;
    }

    .billing-status {
      margin-top: 1rem;
      border-radius: 18px;
      padding: 1rem;
      display: none;
      line-height: 1.55;
    }

    .billing-status.is-visible {
      display: block;
    }

    .billing-status-success {
      background: #ecfdf5;
      border: 1px solid rgba(16, 185, 129, 0.25);
      color: #065f46;
    }

    .billing-status-warning {
      background: #fffbeb;
      border: 1px solid rgba(245, 158, 11, 0.25);
      color: #92400e;
    }

    .billing-status-error {
      background: #fef2f2;
      border: 1px solid rgba(239, 68, 68, 0.25);
      color: #991b1b;
    }

    @media (max-width: 720px) {
      .billing-page {
        padding: 1rem;
      }

      .billing-hero {
        border-radius: 22px;
      }

      .billing-card {
        border-radius: 22px;
      }

      .billing-card-header,
      .billing-card-body {
        padding: 1rem;
      }

      .billing-form-grid {
        grid-template-columns: 1fr;
      }

      .billing-actions {
        flex-direction: column;
      }

      .billing-actions .btn {
        width: 100%;
      }
    }
  </style>
</head>

<body>
  <main class="billing-page">
    <div class="billing-shell">
      <section class="billing-hero">
        <div class="billing-hero-content">
          <span class="billing-kicker">
            <i class="bi bi-credit-card-2-front"></i>
            Assinatura VendMaster
          </span>

          <h1>Dados de cobrança</h1>

          <p>
            Informe os dados que serão usados para preparar o pagamento da assinatura.
            Enquanto o gateway não estiver configurado, o VendMaster apenas valida e salva essas informações.
          </p>
        </div>
      </section>

      <section class="billing-card">
        <div class="billing-card-header">
          <h2>Identificação do pagador</h2>
          <p>
            Estes dados serão usados futuramente para criar o cliente no gateway de pagamento e iniciar a cobrança.
          </p>
        </div>

        <div class="billing-card-body">
          <div class="billing-info-box">
            <i class="bi bi-info-circle"></i>
            <div>
              <strong>Sem cobrança real neste momento.</strong>
              <span>
                Esta tela apenas salva os dados de cobrança no VendMaster. A criação de cobrança ou checkout será feita em uma etapa posterior.
              </span>
            </div>
          </div>

          <form class="billing-form" id="billingForm" autocomplete="on" novalidate>
            <div class="billing-form-grid">
              <div class="billing-field-full">
                <label for="billing_nome">Nome ou razão social</label>
                <input
                  type="text"
                  class="form-control"
                  id="billing_nome"
                  name="billing_nome"
                  autocomplete="name"
                  value="<%= billingData?.billing_nome || '' %>"
                  placeholder="Ex.: Cliente Teste VendMaster"
                  required
                >
              </div>

              <div>
                <label for="billing_cpf_cnpj">CPF ou CNPJ</label>
                <input
                  type="text"
                  class="form-control"
                  id="billing_cpf_cnpj"
                  name="billing_cpf_cnpj"
                  inputmode="numeric"
                  value="<%= billingData?.billing_cpf_cnpj || '' %>"
                  placeholder="Ex.: 111.444.777-35"
                  required
                >
              </div>

              <div>
                <label for="billing_email">E-mail de cobrança</label>
                <input
                  type="email"
                  class="form-control"
                  id="billing_email"
                  name="billing_email"
                  autocomplete="email"
                  value="<%= billingData?.billing_email || '' %>"
                  placeholder="cliente@empresa.com.br"
                >
              </div>

              <div>
                <label for="billing_telefone">Telefone de cobrança</label>
                <input
                  type="tel"
                  class="form-control"
                  id="billing_telefone"
                  name="billing_telefone"
                  autocomplete="tel"
                  value="<%= billingData?.billing_telefone || '' %>"
                  placeholder="(85) 99999-9999"
                >
              </div>

              <div>
                <label>Status do gateway</label>
                <input
                  type="text"
                  class="form-control"
                  value="<%= gatewayConfigured ? 'Configurado' : 'Não configurado' %>"
                  disabled
                >
              </div>
            </div>

            <div class="billing-actions">
              <button type="submit" class="btn btn-primary" id="saveBillingButton">
                <i class="bi bi-check2-circle me-1"></i>
                Salvar dados de cobrança
              </button>

              <button type="button" class="btn btn-outline-primary" id="startPaymentButton">
                <i class="bi bi-arrow-right-circle me-1"></i>
                Testar início do pagamento
              </button>

              <a href="/assinatura" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>
                Voltar para assinatura
              </a>
            </div>
          </form>

          <div class="billing-status" id="billingStatus" role="status" aria-live="polite"></div>
        </div>
      </section>
    </div>
  </main>

  <script>
    const billingForm = document.getElementById('billingForm');
    const saveBillingButton = document.getElementById('saveBillingButton');
    const startPaymentButton = document.getElementById('startPaymentButton');
    const billingStatus = document.getElementById('billingStatus');

    function getCsrfToken() {
      return document.querySelector('meta[name="csrf-token"]')?.content || '';
    }

    function showStatus(type, message) {
      billingStatus.className = `billing-status billing-status-${type} is-visible`;
      billingStatus.textContent = message;
    }

    function getFormPayload() {
      const formData = new FormData(billingForm);

      return {
        billing_nome: String(formData.get('billing_nome') || '').trim(),
        billing_cpf_cnpj: String(formData.get('billing_cpf_cnpj') || '').trim(),
        billing_email: String(formData.get('billing_email') || '').trim(),
        billing_telefone: String(formData.get('billing_telefone') || '').trim()
      };
    }

    async function parseJsonResponse(response) {
      const data = await response.json().catch(() => null);

      if (!data) {
        throw new Error('Resposta inválida do servidor.');
      }

      return data;
    }

    billingForm.addEventListener('submit', async (event) => {
      event.preventDefault();

      saveBillingButton.disabled = true;
      showStatus('warning', 'Salvando dados de cobrança...');

      try {
        const response = await fetch('/pagamentos/dados-cobranca', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'CSRF-Token': getCsrfToken()
          },
          body: JSON.stringify(getFormPayload())
        });

        const data = await parseJsonResponse(response);

        if (!response.ok || !data.success) {
          throw new Error(data.message || 'Não foi possível salvar os dados de cobrança.');
        }

        showStatus('success', data.message || 'Dados de cobrança salvos com sucesso.');
      } catch (error) {
        showStatus('error', error.message || 'Erro ao salvar dados de cobrança.');
      } finally {
        saveBillingButton.disabled = false;
      }
    });

    startPaymentButton.addEventListener('click', async () => {
      startPaymentButton.disabled = true;
      showStatus('warning', 'Validando dados e preparando pagamento...');

      try {
        const response = await fetch('/pagamentos/iniciar', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'CSRF-Token': getCsrfToken()
          },
          body: JSON.stringify({})
        });

        const data = await parseJsonResponse(response);

        if (!response.ok || !data.success) {
          throw new Error(data.message || 'Não foi possível iniciar o pagamento.');
        }

        if (data.needsGatewayConfiguration) {
          showStatus(
            'warning',
            'Dados de cobrança válidos. O gateway ainda não está configurado, então nenhuma cobrança real foi criada.'
          );
          return;
        }

        showStatus(
          'success',
          data.message || 'Pagamento preparado com sucesso.'
        );
      } catch (error) {
        showStatus('error', error.message || 'Erro ao iniciar pagamento.');
      } finally {
        startPaymentButton.disabled = false;
      }
    });
  </script>
</body>

</html>