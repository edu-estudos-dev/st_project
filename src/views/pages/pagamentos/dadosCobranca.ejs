<!DOCTYPE html>
<html lang="pt-br">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= csrfToken || '' %>">

  <title>Dados de cobrança - VendMaster</title>
  <meta name="robots" content="noindex, nofollow">

  <link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css">
  <link rel="stylesheet" href="/vendor/bootstrap-icons/bootstrap-icons.css">
  <link rel="stylesheet" href="<%= typeof assetPath !== 'undefined' ? assetPath('/css/styles.css') : '/css/styles.css' %>">

  <script defer src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script defer src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
  <script defer src="/js/appAlerts.js"></script>
  <script defer src="/js/csrf.js"></script>

  <style>
    .billing-page {
      min-height: 100vh;
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.12), transparent 34rem),
        linear-gradient(180deg, #f8fafc 0%, #eef2ff 100%);
      padding: 2rem 1rem;
    }

    .billing-shell {
      width: min(100%, 980px);
      margin: 0 auto;
    }

    .billing-hero {
      border-radius: 28px;
      padding: clamp(1.35rem, 3vw, 2.25rem);
      background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 52%, #38bdf8 100%);
      color: #fff;
      box-shadow: 0 24px 60px rgba(15, 23, 42, 0.18);
      margin-bottom: 1rem;
      overflow: hidden;
      position: relative;
    }

    .billing-hero::after {
      content: "";
      position: absolute;
      width: 18rem;
      height: 18rem;
      right: -6rem;
      top: -7rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
    }

    .billing-hero-content {
      position: relative;
      z-index: 1;
      max-width: 720px;
    }

    .billing-kicker {
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.4rem 0.75rem;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.16);
      color: #fff;
      font-weight: 700;
      font-size: 0.82rem;
      margin-bottom: 0.9rem;
    }

    .billing-hero h1 {
      font-size: clamp(1.65rem, 4vw, 2.45rem);
      line-height: 1.08;
      font-weight: 800;
      margin: 0 0 0.75rem;
    }

    .billing-hero p {
      margin: 0;
      color: rgba(255, 255, 255, 0.86);
      font-size: clamp(0.98rem, 2vw, 1.08rem);
      line-height: 1.6;
    }

    .billing-card {
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 24px;
      background: rgba(255, 255, 255, 0.94);
      box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
      overflow: hidden;
    }

    .billing-card-header {
      padding: 1.25rem 1.35rem;
      border-bottom: 1px solid rgba(148, 163, 184, 0.18);
      background: rgba(248, 250, 252, 0.82);
    }

    .billing-card-header h2 {
      margin: 0 0 0.35rem;
      color: #0f172a;
      font-size: 1.25rem;
      font-weight: 800;
    }

    .billing-card-header p {
      margin: 0;
      color: #64748b;
      line-height: 1.55;
    }

    .billing-card-body {
      padding: 1.35rem;
    }

    .billing-info-box {
      display: flex;
      gap: 0.8rem;
      padding: 1rem;
      border-radius: 18px;
      background: #eff6ff;
      color: #1e3a8a;
      margin-bottom: 1.2rem;
      border: 1px solid rgba(59, 130, 246, 0.18);
    }

    .billing-info-box i {
      font-size: 1.15rem;
      margin-top: 0.15rem;
    }

    .billing-info-box strong {
      display: block;
      margin-bottom: 0.15rem;
    }

    .billing-info-box span {
      display: block;
      color: #334155;
      line-height: 1.5;
    }

    .billing-form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .billing-field-full {
      grid-column: 1 / -1;
    }

    .billing-form label {
      font-weight: 700;
      color: #1e293b;
      margin-bottom: 0.4rem;
    }

    .billing-form .form-control {
      border-radius: 14px;
      border-color: rgba(148, 163, 184, 0.45);
      padding: 0.78rem 0.9rem;
      transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
    }

    .billing-form .form-control:focus {
      border-color: #2563eb;
      box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.12);
    }

    .billing-form .form-control.is-valid {
      border-color: rgba(16, 185, 129, 0.75);
      background-color: #f0fdf4;
    }

    .billing-form .form-control.is-invalid {
      border-color: rgba(239, 68, 68, 0.8);
      background-color: #fff7f7;
    }

    .billing-help-text {
      display: block;
      margin-top: 0.35rem;
      color: #64748b;
      font-size: 0.86rem;
      line-height: 1.4;
    }

    .billing-field-error {
      display: none;
      margin-top: 0.35rem;
      color: #b91c1c;
      font-size: 0.86rem;
      font-weight: 700;
      line-height: 1.4;
    }

    .billing-field-error.is-visible {
      display: block;
    }

    .billing-gateway-field {
      position: relative;
    }

    .billing-gateway-status {
      display: flex;
      align-items: flex-start;
      gap: 0.7rem;
      min-height: 48px;
      padding: 0.75rem 0.85rem;
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 16px;
      background: #f8fafc;
      color: #0f172a;
      line-height: 1.35;
    }

    .billing-gateway-status i {
      margin-top: 0.1rem;
      color: #2563eb;
    }

    .billing-gateway-status strong {
      display: block;
      color: #0f172a;
      font-size: 0.98rem;
      font-weight: 900;
    }

    .billing-gateway-status span {
      display: block;
      color: #64748b;
      font-size: 0.9rem;
      font-weight: 650;
    }

    .billing-gateway-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      margin-top: 0.45rem;
      padding: 0.42rem 0.7rem;
      border-radius: 999px;
      font-size: 0.82rem;
      font-weight: 800;
    }

    .billing-gateway-badge.is-ready {
      background: #ecfdf5;
      color: #047857;
      border: 1px solid rgba(16, 185, 129, 0.28);
    }

    .billing-gateway-badge.is-pending {
      background: #fffbeb;
      color: #92400e;
      border: 1px solid rgba(245, 158, 11, 0.28);
    }

    .billing-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 1.25rem;
    }

    .billing-actions .btn {
      border-radius: 999px;
      font-weight: 800;
      padding: 0.78rem 1.15rem;
    }

    .billing-status {
      margin-top: 1rem;
      border-radius: 18px;
      padding: 1rem;
      display: none;
      line-height: 1.55;
    }

    .billing-status.is-visible {
      display: flex;
      align-items: flex-start;
      gap: 0.7rem;
    }

    .billing-status i {
      font-size: 1.1rem;
      margin-top: 0.13rem;
    }

    .billing-status strong {
      display: block;
      margin-bottom: 0.15rem;
    }

    .billing-status span {
      display: block;
    }

    .billing-status-success {
      background: #ecfdf5;
      border: 1px solid rgba(16, 185, 129, 0.25);
      color: #065f46;
    }

    .billing-status-warning {
      background: #fffbeb;
      border: 1px solid rgba(245, 158, 11, 0.25);
      color: #92400e;
    }

    .billing-status-error {
      background: #fef2f2;
      border: 1px solid rgba(239, 68, 68, 0.25);
      color: #991b1b;
    }

    @media (max-width: 720px) {
      .billing-page {
        padding: 1rem;
      }

      .billing-hero {
        border-radius: 22px;
      }

      .billing-card {
        border-radius: 22px;
      }

      .billing-card-header,
      .billing-card-body {
        padding: 1rem;
      }

      .billing-form-grid {
        grid-template-columns: 1fr;
      }

      .billing-actions {
        flex-direction: column;
      }

      .billing-actions .btn {
        width: 100%;
      }

      .billing-gateway-status,
      .billing-gateway-badge {
        width: 100%;
      }
    }
  </style>
</head>

<body>
  <main class="billing-page">
    <div class="billing-shell">
      <section class="billing-hero">
        <div class="billing-hero-content">
          <span class="billing-kicker">
            <i class="bi bi-credit-card-2-front"></i>
            Assinatura VendMaster
          </span>

          <h1>Dados de cobrança</h1>

          <p>
            Informe ou revise os dados usados para identificar sua cobrança. Depois de salvar, você será direcionado para Minha assinatura para escolher cartão ou boleto.
          </p>
        </div>
      </section>

      <section class="billing-card">
        <div class="billing-card-header">
          <h2>Identificação do pagador</h2>
          <p>
            Estes dados ajudam o VendMaster a gerar a cobrança correta da sua assinatura.
          </p>
        </div>

        <div class="billing-card-body">
          <div class="billing-info-box">
            <i class="bi bi-info-circle"></i>
            <div>
              <strong>Dados necessários para cobrança.</strong>
              <span>
                Preencha ou revise as informações abaixo. Após salvar, volte para Minha assinatura para preparar o pagamento com segurança.
              </span>
            </div>
          </div>

          <form class="billing-form" id="billingForm" autocomplete="on" novalidate>
            <div class="billing-form-grid">
              <div class="billing-field-full">
                <label for="billing_nome">Nome ou razão social</label>
                <input
                  type="text"
                  class="form-control"
                  id="billing_nome"
                  name="billing_nome"
                  autocomplete="name"
                  value="<%= billingData?.billing_nome || '' %>"
                  placeholder="Ex.: Empresa Exemplo LTDA"
                  required
                >
                <small class="billing-help-text">
                  Use o nome do responsável ou a razão social que será vinculada à cobrança.
                </small>
                <small class="billing-field-error" id="billing_nome_error"></small>
              </div>

              <div>
                <label for="billing_cpf_cnpj">CPF ou CNPJ</label>
                <input
                  type="text"
                  class="form-control"
                  id="billing_cpf_cnpj"
                  name="billing_cpf_cnpj"
                  inputmode="numeric"
                  maxlength="18"
                  value="<%= billingData?.billing_cpf_cnpj || '' %>"
                  placeholder="Ex.: 111.444.777-35"
                  required
                >
                <small class="billing-help-text">
                  Digite somente números; a formatação será aplicada automaticamente.
                </small>
                <small class="billing-field-error" id="billing_cpf_cnpj_error"></small>
              </div>

              <div>
                <label for="billing_email">E-mail de cobrança</label>
                <input
                  type="email"
                  class="form-control"
                  id="billing_email"
                  name="billing_email"
                  autocomplete="email"
                  value="<%= billingData?.billing_email || '' %>"
                  placeholder="cliente@empresa.com.br"
                >
                <small class="billing-help-text">
                  Opcional, mas recomendado para avisos de pagamento.
                </small>
                <small class="billing-field-error" id="billing_email_error"></small>
              </div>

              <div>
                <label for="billing_telefone">Telefone de cobrança</label>
                <input
                  type="tel"
                  class="form-control"
                  id="billing_telefone"
                  name="billing_telefone"
                  autocomplete="tel"
                  inputmode="numeric"
                  maxlength="15"
                  value="<%= billingData?.billing_telefone || '' %>"
                  placeholder="(85) 99999-9999"
                >
                <small class="billing-help-text">
                  Opcional. Informe DDD + número.
                </small>
                <small class="billing-field-error" id="billing_telefone_error"></small>
              </div>

              <div class="billing-gateway-field">
                <label>Status da cobrança</label>
                <div class="billing-gateway-status" role="status" aria-live="polite">
                  <i class="bi <%= gatewayConfigured ? 'bi-shield-check' : 'bi-clock-history' %>"></i>
                  <span>
                    <strong><%= gatewayConfigured ? 'Cobrança disponível' : 'Cobrança pendente' %></strong>
                    <span><%= gatewayConfigured ? 'O pagamento pode ser preparado com segurança.' : 'A preparação será liberada quando o ambiente estiver configurado.' %></span>
                  </span>
                </div>

                <% if (gatewayConfigured) { %>
                  <span class="billing-gateway-badge is-ready">
                    <i class="bi bi-check2-circle"></i>
                    Cobrança disponível
                  </span>
                <% } else { %>
                  <span class="billing-gateway-badge is-pending">
                    <i class="bi bi-exclamation-triangle"></i>
                    Cobrança pendente
                  </span>
                <% } %>
              </div>
            </div>

            <div class="billing-actions">
              <button type="submit" class="btn btn-primary" id="saveBillingButton">
                <i class="bi bi-check2-circle me-1"></i>
                <span>Salvar dados de cobrança</span>
              </button>

              <a href="/assinatura/status" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i>
                <span>Voltar para minha assinatura</span>
              </a>
            </div>
          </form>

          <div class="billing-status" id="billingStatus" role="status" aria-live="polite"></div>
        </div>
      </section>
    </div>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const billingForm = document.getElementById('billingForm');
      const saveBillingButton = document.getElementById('saveBillingButton');
      const billingStatus = document.getElementById('billingStatus');
      const statusUrl = '/assinatura/status';

      const fields = {
        nome: document.getElementById('billing_nome'),
        cpfCnpj: document.getElementById('billing_cpf_cnpj'),
        email: document.getElementById('billing_email'),
        telefone: document.getElementById('billing_telefone')
      };

      function onlyDigits(value) {
        return String(value || '').replace(/\D/g, '');
      }

      function formatCpfCnpj(value) {
        const digits = onlyDigits(value).slice(0, 14);

        if (digits.length <= 11) {
          return digits
            .replace(/^(\d{3})(\d)/, '$1.$2')
            .replace(/^(\d{3})\.(\d{3})(\d)/, '$1.$2.$3')
            .replace(/^(\d{3})\.(\d{3})\.(\d{3})(\d)/, '$1.$2.$3-$4');
        }

        return digits
          .replace(/^(\d{2})(\d)/, '$1.$2')
          .replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3')
          .replace(/^(\d{2})\.(\d{3})\.(\d{3})(\d)/, '$1.$2.$3/$4')
          .replace(/^(\d{2})\.(\d{3})\.(\d{3})\/(\d{4})(\d)/, '$1.$2.$3/$4-$5');
      }

      function formatPhone(value) {
        const digits = onlyDigits(value).slice(0, 11);

        if (digits.length <= 2) {
          return digits;
        }

        if (digits.length <= 6) {
          return digits.replace(/^(\d{2})(\d)/, '($1) $2');
        }

        if (digits.length <= 10) {
          return digits.replace(/^(\d{2})(\d{4})(\d)/, '($1) $2-$3');
        }

        return digits.replace(/^(\d{2})(\d{5})(\d)/, '($1) $2-$3');
      }

      function showStatus(type, title, message) {
        const icons = {
          success: 'bi-check2-circle',
          warning: 'bi-exclamation-triangle',
          error: 'bi-x-circle'
        };

        billingStatus.className = `billing-status billing-status-${type} is-visible`;
        billingStatus.innerHTML = `
          <i class="bi ${icons[type] || icons.warning}"></i>
          <div>
            <strong>${title}</strong>
            <span>${message}</span>
          </div>
        `;

        billingStatus.scrollIntoView({
          behavior: 'smooth',
          block: 'nearest'
        });
      }

      function clearFieldError(input) {
        if (!input) return;

        const errorElement = document.getElementById(`${input.id}_error`);

        input.classList.remove('is-invalid');

        if (errorElement) {
          errorElement.classList.remove('is-visible');
          errorElement.textContent = '';
        }
      }

      function setFieldError(input, message) {
        if (!input) return;

        const errorElement = document.getElementById(`${input.id}_error`);

        input.classList.add('is-invalid');
        input.classList.remove('is-valid');

        if (errorElement) {
          errorElement.textContent = message;
          errorElement.classList.add('is-visible');
        }
      }

      function setFieldValid(input) {
        if (!input) return;

        input.classList.remove('is-invalid');

        if (String(input.value || '').trim()) {
          input.classList.add('is-valid');
        }
      }

      function validateForm() {
        const errors = [];
        const nome = String(fields.nome.value || '').trim();
        const cpfCnpjDigits = onlyDigits(fields.cpfCnpj.value);
        const email = String(fields.email.value || '').trim();
        const telefoneDigits = onlyDigits(fields.telefone.value);

        Object.values(fields).forEach((input) => clearFieldError(input));

        if (!nome || nome.length < 2) {
          errors.push('Informe o nome ou razão social para cobrança.');
          setFieldError(fields.nome, 'Informe o nome ou razão social.');
        } else {
          setFieldValid(fields.nome);
        }

        if (!cpfCnpjDigits) {
          errors.push('Informe o CPF ou CNPJ para cobrança.');
          setFieldError(fields.cpfCnpj, 'Informe o CPF ou CNPJ.');
        } else if (![11, 14].includes(cpfCnpjDigits.length)) {
          errors.push('CPF/CNPJ deve ter 11 ou 14 dígitos.');
          setFieldError(fields.cpfCnpj, 'CPF/CNPJ deve ter 11 ou 14 dígitos.');
        } else {
          setFieldValid(fields.cpfCnpj);
        }

        if (email && !email.includes('@')) {
          errors.push('Informe um e-mail de cobrança válido.');
          setFieldError(fields.email, 'Informe um e-mail válido.');
        } else {
          setFieldValid(fields.email);
        }

        if (telefoneDigits && (telefoneDigits.length < 10 || telefoneDigits.length > 11)) {
          errors.push('Telefone de cobrança deve ter DDD e 10 ou 11 dígitos.');
          setFieldError(fields.telefone, 'Telefone deve ter DDD e 10 ou 11 dígitos.');
        } else {
          setFieldValid(fields.telefone);
        }

        return {
          isValid: errors.length === 0,
          errors
        };
      }

      function getFormPayload() {
        const formData = new FormData(billingForm);

        return {
          billing_nome: String(formData.get('billing_nome') || '').trim(),
          billing_cpf_cnpj: onlyDigits(formData.get('billing_cpf_cnpj')),
          billing_email: String(formData.get('billing_email') || '').trim(),
          billing_telefone: onlyDigits(formData.get('billing_telefone'))
        };
      }

      async function parseJsonResponse(response) {
        const data = await response.json().catch(() => null);

        if (!data) {
          throw new Error('Resposta inválida do servidor.');
        }

        return data;
      }

      function setButtonLoading(button, isLoading, loadingText) {
        if (!button) return;

        if (isLoading) {
          button.dataset.originalHtml = button.innerHTML;
          button.disabled = true;
          button.innerHTML = `
            <i class="bi bi-hourglass-split me-1"></i>
            <span>${loadingText}</span>
          `;
          return;
        }

        button.disabled = false;

        if (button.dataset.originalHtml) {
          button.innerHTML = button.dataset.originalHtml;
          delete button.dataset.originalHtml;
        }
      }

      fields.cpfCnpj.addEventListener('input', () => {
        fields.cpfCnpj.value = formatCpfCnpj(fields.cpfCnpj.value);
        clearFieldError(fields.cpfCnpj);
      });

      fields.telefone.addEventListener('input', () => {
        fields.telefone.value = formatPhone(fields.telefone.value);
        clearFieldError(fields.telefone);
      });

      fields.nome.addEventListener('input', () => clearFieldError(fields.nome));
      fields.email.addEventListener('input', () => clearFieldError(fields.email));

      fields.cpfCnpj.value = formatCpfCnpj(fields.cpfCnpj.value);
      fields.telefone.value = formatPhone(fields.telefone.value);

      billingForm.addEventListener('submit', async (event) => {
        event.preventDefault();

        const validation = validateForm();

        if (!validation.isValid) {
          const message = validation.errors.join(' ');

          showStatus('error', 'Revise os dados informados.', message);
          window.AppAlerts?.warning(message);
          return;
        }

        setButtonLoading(saveBillingButton, true, 'Salvando...');
        showStatus('warning', 'Salvando dados...', 'Aguarde enquanto os dados de cobrança são atualizados.');

        try {
          const response = await fetch('/pagamentos/dados-cobranca', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              Accept: 'application/json'
            },
            body: JSON.stringify(getFormPayload())
          });

          const data = await parseJsonResponse(response);

          if (!response.ok || !data.success) {
            throw new Error(data.message || 'Não foi possível salvar os dados de cobrança.');
          }

          const message = data.message || 'Dados de cobrança salvos com sucesso.';

          showStatus(
            'success',
            'Dados salvos.',
            `${message} Você será direcionado para Minha assinatura para escolher a forma de pagamento.`
          );

          window.AppAlerts?.success(`${message} Redirecionando para Minha assinatura...`);

          window.setTimeout(() => {
            window.location.href = statusUrl;
          }, 1200);
        } catch (error) {
          const message = error.message || 'Erro ao salvar dados de cobrança.';

          showStatus('error', 'Erro ao salvar.', message);
          window.AppAlerts?.error(message);
        } finally {
          setButtonLoading(saveBillingButton, false);
        }
      });
    });
  </script>
</body>

</html>
