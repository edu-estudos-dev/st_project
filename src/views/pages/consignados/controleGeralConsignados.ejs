<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Controle Geral dos Consignados' }) %>

<body class="list-page-body consignados-page consignados-control-page">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell consignados-shell consignados-control-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Controle Geral dos Consignados' }) %>

        <section class="page-titlebar page-titlebar-blue consignados-titlebar consignados-control-titlebar">
            <div class="page-titlebar-content">
                <span class="list-kicker consignados-kicker">
                    <i class="bi bi-diagram-3"></i>
                    Operacional
                </span>

                <h1>Controle geral dos consignados</h1>

                <p>
                    Acompanhe os pontos que precisam de visita e veja rapidamente a quantidade deixada em cada estabelecimento.
                </p>
            </div>

            <div class="page-titlebar-side consignados-titlebar-side">
                <div class="list-stat consignados-hero-stat">
                    <strong>Pontos</strong>
                    <span><%= estabelecimentos.length %> registros</span>
                </div>

                <div class="list-stat consignados-hero-stat">
                    <strong>Produto</strong>
                    <span>Consignados</span>
                </div>
            </div>
        </section>

        <main class="list-stage consignados-control-stage">
            <section class="list-panel consignados-panel consignados-control-panel">
                <div class="list-toolbar roteiro-toolbar consignados-toolbar consignados-control-toolbar">
                    <div class="list-toolbar-copy consignados-toolbar-copy">
                        <span class="form-section-tag consignados-section-tag">Visitas</span>

                        <h2>Pontos pendentes de visita</h2>

                        <p>
                            Use o prazo abaixo para identificar quais pontos já precisam de sangria.
                        </p>
                    </div>

                    <div class="dias-sangria-top consignados-days-filter">
                        <label for="diasSangria" class="form-label fw-bold">Dias para fazer a sangria</label>

                        <input
                            type="number"
                            class="form-control text-center fw-bold"
                            id="diasSangria"
                            name="diasSangria"
                            min="1"
                            required
                        >
                    </div>
                </div>

                <div class="modern-table-wrap consignados-table-wrap consignados-control-table-wrap">
                    <div class="modern-table-scroll consignados-table-scroll consignados-control-table-scroll">
                        <table class="modern-table consignados-table consignados-control-table">
                            <thead>
                                <tr>
                                    <th>Estabelecimento</th>
                                    <th>Endereço</th>
                                    <th>Bairro</th>
                                    <th>Qtde. deixado</th>
                                    <th>Dias passados</th>
                                    <th>Situação</th>
                                </tr>
                            </thead>

                            <tbody id="tabelaEstabelecimentos">
                                <% if (estabelecimentos.length > 0) { %>
                                    <% estabelecimentos.forEach(function(estabelecimento) {
                                        const dataBaseOriginal = estabelecimento.data_sangria
                                            ? new Date(estabelecimento.data_sangria)
                                            : null;

                                        const dataUltimaVisita = dataBaseOriginal && !Number.isNaN(dataBaseOriginal.getTime())
                                            ? new Date(
                                                dataBaseOriginal.getFullYear(),
                                                dataBaseOriginal.getMonth(),
                                                dataBaseOriginal.getDate()
                                            )
                                            : null;

                                        const hojeOriginal = new Date();

                                        const hoje = new Date(
                                            hojeOriginal.getFullYear(),
                                            hojeOriginal.getMonth(),
                                            hojeOriginal.getDate()
                                        );

                                        const dataValida = Boolean(dataUltimaVisita);

                                        const diferencaDias = dataValida
                                            ? Math.max(0, Math.floor((hoje - dataUltimaVisita) / (1000 * 60 * 60 * 24)))
                                            : '';

                                        const endereco = estabelecimento.endereco || '-';
                                        const bairro = estabelecimento.bairro || '-';
                                        const qtdeDeixada = Number(estabelecimento.qtde_deixada || 0);
                                    %>

                                    <tr
                                        class="consignados-control-row"
                                        data-diferenca-dias="<%= diferencaDias %>"
                                        data-sem-visita="<%= dataValida ? 'false' : 'true' %>"
                                    >
                                        <td class="consignados-control-name-cell" data-label="Estabelecimento">
                                            <span class="table-title-cell consignados-point-name consignados-control-name">
                                                <%= estabelecimento.estabelecimento %>
                                            </span>
                                        </td>

                                        <td class="table-cell-wrap consignados-control-address-cell" data-label="Endereço">
                                            <%= endereco %>
                                        </td>

                                        <td class="consignados-control-neighborhood-cell" data-label="Bairro">
                                            <%= bairro %>
                                        </td>

                                        <td class="consignados-control-stock-cell" data-label="Qtde. deixado">
                                            <%= qtdeDeixada %> unidades
                                        </td>

                                        <td class="dias-passados consignados-control-days-cell" data-label="Dias passados">
                                            <%= dataValida ? diferencaDias : 'Sem visita' %>
                                        </td>

                                        <td class="situacao consignados-control-status-cell" data-label="Situação"></td>
                                    </tr>

                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="table-empty consignados-empty">
                                            Nenhum ponto de consignados encontrado.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <script>
    function obterDiasSangria() {
        const input = document.getElementById('diasSangria');
        const valor = input.value.trim();

        if (valor === '') {
            return 7;
        }

        const numero = Number(valor);

        if (Number.isNaN(numero) || numero <= 0) {
            return 7;
        }

        return numero;
    }

    function salvarDiasSangria() {
        const input = document.getElementById('diasSangria');

        localStorage.setItem('diasSangriaConsignados', input.value);
        atualizarSituacao();
    }

    function carregarDiasSangria() {
        const input = document.getElementById('diasSangria');
        const diasSalvos = localStorage.getItem('diasSangriaConsignados');

        if (diasSalvos === null || diasSalvos === '' || Number(diasSalvos) <= 0 || Number.isNaN(Number(diasSalvos))) {
            input.value = '7';
            localStorage.setItem('diasSangriaConsignados', '7');
        } else {
            input.value = diasSalvos;
        }

        atualizarSituacao();
    }

    function atualizarSituacao() {
        const diasSangria = obterDiasSangria();

        document.querySelectorAll('#tabelaEstabelecimentos tr').forEach(linha => {
            const semVisita = linha.getAttribute('data-sem-visita') === 'true';

            let diferencaDias = Number(linha.getAttribute('data-diferenca-dias'));

            if (Number.isNaN(diferencaDias)) {
                diferencaDias = 0;
            }

            const situacaoCelula = linha.querySelector('.situacao');

            linha.classList.remove('table-row-exit-highlight', 'consignados-control-row-alert', 'consignados-row-alert');

            if (semVisita) {
                situacaoCelula.innerHTML = '<span class="table-badge table-badge-danger consignados-status-badge">Sem visita</span>';
                linha.classList.add('table-row-exit-highlight', 'consignados-control-row-alert', 'consignados-row-alert');
                return;
            }

            if (diferencaDias >= diasSangria) {
                situacaoCelula.innerHTML = '<span class="table-badge table-badge-danger consignados-status-badge">Sangria</span>';
                linha.classList.add('table-row-exit-highlight', 'consignados-control-row-alert', 'consignados-row-alert');
                return;
            }

            situacaoCelula.innerHTML = '<span class="table-badge table-badge-green consignados-status-badge">Aguardar</span>';
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        const inputDiasSangria = document.getElementById('diasSangria');

        carregarDiasSangria();

        inputDiasSangria.addEventListener('input', salvarDiasSangria);
        inputDiasSangria.addEventListener('change', salvarDiasSangria);
        inputDiasSangria.addEventListener('keyup', salvarDiasSangria);
    });
    </script>
</body>
</html>