<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Controle Geral dos Consignados' }) %>

<body class="list-page-body consignados-page consignados-control-page">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell consignados-shell consignados-control-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Controle Geral dos Consignados' }) %>

        <section class="page-titlebar page-titlebar-blue consignados-titlebar consignados-control-titlebar">
            <div class="page-titlebar-content">
                <span class="list-kicker consignados-kicker">
                    <i class="bi bi-diagram-3"></i>
                    Operacional
                </span>

                <h1>Controle geral dos consignados</h1>

                <p>
                    Acompanhe os pontos que precisam de visita e veja rapidamente o estoque deixado em cada estabelecimento.
                </p>
            </div>

            <div class="page-titlebar-side consignados-titlebar-side">
                <div class="list-stat consignados-hero-stat">
                    <strong>Pontos</strong>
                    <span><%= estabelecimentos.length %> registros</span>
                </div>

                <div class="list-stat consignados-hero-stat">
                    <strong>Produto</strong>
                    <span>Consignados</span>
                </div>
            </div>
        </section>

        <main class="list-stage consignados-control-stage">
            <section class="list-panel consignados-panel consignados-control-panel">
                <div class="list-toolbar consignados-toolbar consignados-control-toolbar">
                    <div class="list-toolbar-copy consignados-toolbar-copy">
                        <span class="form-section-tag consignados-section-tag">Visitas</span>

                        <h2>Pontos pendentes de visita</h2>

                        <p>
                            Use o prazo abaixo para identificar quais pontos já precisam de sangria.
                        </p>
                    </div>

                    <div class="dias-sangria-top consignados-days-filter">
                        <label for="diasSangria" class="form-label">Dias para fazer a sangria</label>

                        <input
                            type="number"
                            class="form-control text-center"
                            id="diasSangria"
                            name="diasSangria"
                            min="1"
                            required
                        >
                    </div>
                </div>

                <div class="modern-table-wrap consignados-table-wrap consignados-control-table-wrap">
                    <div class="modern-table-scroll consignados-table-scroll consignados-control-table-scroll">
                        <table class="modern-table consignados-table consignados-control-table">
                            <thead>
                                <tr>
                                    <th>Estabelecimento</th>
                                    <th>Endereço</th>
                                    <th>Bairro</th>
                                    <th>Estoque deixado</th>
                                    <th>Dias passados</th>
                                    <th>Situação</th>
                                </tr>
                            </thead>

                            <tbody id="tabelaEstabelecimentos">
                                <% if (estabelecimentos.length > 0) { %>
                                    <% estabelecimentos.forEach(function(estabelecimento) {
                                        const dataBase = estabelecimento.data_sangria ? new Date(estabelecimento.data_sangria) : null;
                                        const dataValida = dataBase && !Number.isNaN(dataBase.getTime());
                                        const hoje = new Date();
                                        const diferencaDias = dataValida ? Math.floor((hoje - dataBase) / (1000 * 60 * 60 * 24)) : 0;
                                        const dataFormatada = dataValida ? dataBase.toLocaleDateString('pt-BR') : 'Sem visita registrada';
                                        const endereco = estabelecimento.endereco || 'Endereço não informado';
                                        const bairro = estabelecimento.bairro || 'Bairro não informado';
                                        const qtdeDeixada = Number(estabelecimento.qtde_deixada || 0);
                                    %>

                                    <tr data-diferenca-dias="<%= diferencaDias %>">
                                        <td data-label="Estabelecimento">
                                            <div class="consignados-card-head consignados-control-card-head">
                                                <span class="table-title-cell consignados-point-name consignados-control-name">
                                                    <%= estabelecimento.estabelecimento %>
                                                </span>

                                                <span class="consignados-mobile-status consignados-control-mobile-status situacao-mobile"></span>
                                            </div>
                                        </td>

                                        <td data-label="Endereço">
                                            <%= endereco %>
                                        </td>

                                        <td data-label="Bairro">
                                            <%= bairro %>
                                        </td>

                                        <td data-label="Estoque deixado">
                                            <%= qtdeDeixada %> unidades
                                        </td>

                                        <td data-label="Dias passados" class="dias-passados">
                                            <span><%= dataValida ? diferencaDias : 'Sem histórico' %></span>
                                            <small><%= dataFormatada %></small>
                                        </td>

                                        <td data-label="Situação" class="situacao"></td>
                                    </tr>

                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="6" class="table-empty consignados-empty">
                                            Nenhum ponto de consignados encontrado.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <script>
    function obterDiasSangria() {
        const input = document.getElementById('diasSangria');
        const valor = input.value.trim();

        if (valor === '') {
            return 7;
        }

        const numero = Number(valor);

        if (Number.isNaN(numero) || numero <= 0) {
            return 7;
        }

        return numero;
    }

    function salvarDiasSangria() {
        const input = document.getElementById('diasSangria');

        localStorage.setItem('diasSangriaConsignados', input.value);
        atualizarSituacao();
    }

    function carregarDiasSangria() {
        const input = document.getElementById('diasSangria');
        const diasSalvos = localStorage.getItem('diasSangriaConsignados');

        input.value = diasSalvos !== null ? diasSalvos : '7';

        atualizarSituacao();
    }

    function criarBadgeSituacao(diferencaDias, diasSangria) {
        if (diferencaDias >= diasSangria) {
            return '<span class="table-badge table-badge-danger consignados-status-badge">Sangria</span>';
        }

        return '<span class="table-badge table-badge-green consignados-status-badge">Aguardar</span>';
    }

    function atualizarSituacao() {
        const diasSangria = obterDiasSangria();

        document.querySelectorAll('#tabelaEstabelecimentos tr').forEach(linha => {
            let diferencaDias = Number(linha.getAttribute('data-diferenca-dias'));

            if (Number.isNaN(diferencaDias)) {
                diferencaDias = 0;
            }

            const situacaoCelula = linha.querySelector('.situacao');
            const situacaoMobile = linha.querySelector('.situacao-mobile');
            const badge = criarBadgeSituacao(diferencaDias, diasSangria);

            if (situacaoCelula) {
                situacaoCelula.innerHTML = badge;
            }

            if (situacaoMobile) {
                situacaoMobile.innerHTML = badge;
            }

            if (diferencaDias >= diasSangria) {
                linha.classList.add('table-row-exit-highlight', 'consignados-row-alert');
                return;
            }

            linha.classList.remove('table-row-exit-highlight', 'consignados-row-alert');
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        const inputDiasSangria = document.getElementById('diasSangria');

        carregarDiasSangria();

        inputDiasSangria.addEventListener('input', salvarDiasSangria);
        inputDiasSangria.addEventListener('change', salvarDiasSangria);
        inputDiasSangria.addEventListener('keyup', salvarDiasSangria);
    });
    </script>
</body>
</html>