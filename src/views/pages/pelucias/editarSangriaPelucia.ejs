<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Editar Sangria de Pelucias' }) %>

<body class="bg-light">
    <%- include('../../partials/header') %>

    <div class="page-spacer"></div>

    <div class="form-shell py-3">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Editar Sangria de Pelucias' }) %>

        <div class="cabecalho-pelucia">
            <h1 class="mb-0">Editar Sangria de Pelucias</h1>
        </div>

        <main class="pelucia">
            <form action="/pelucias/sangrias/edit" method="POST">
                <input type="hidden" name="id" value="<%= sangria.id %>">

                <div class="row g-3">
                    <div class="col-12 col-lg-6">
                        <label for="estabelecimento" class="form-label fw-bold">Estabelecimento</label>
                        <select class="form-select" id="estabelecimento" name="estabelecimento_id" required>
                            <% estabelecimentos.forEach(function(estabelecimento) { %>
                                <option value="<%= estabelecimento.id %>" <%= estabelecimento.id === sangria.estabelecimento_id ? 'selected' : '' %>><%= estabelecimento.estabelecimento %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label for="data_sangria" class="form-label fw-bold">Data da Sangria</label>
                        <input type="date" class="form-control text-center" id="data_sangria" name="data_sangria" value="<%= sangria.data_sangria.toISOString().split('T')[0] %>" required>
                    </div>
                    <div class="col-12 col-md-6 col-lg-3">
                        <label for="tipo_pagamento" class="form-label fw-bold">Tipo de Pagamento</label>
                        <select class="form-select" id="tipo_pagamento" name="tipo_pagamento" required>
                            <option value="especie" <%= sangria.tipo_pagamento === 'especie' ? 'selected' : '' %>>Especie</option>
                            <option value="pix" <%= sangria.tipo_pagamento === 'pix' ? 'selected' : '' %>>PIX</option>
                        </select>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12 col-md-6 col-xl-3">
                        <label for="leitura_atual" class="form-label fw-bold">Leitura Atual</label>
                        <input type="number" class="form-control text-center" id="leitura_atual" name="leitura_atual" value="<%= sangria.leitura_atual %>" required>
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <label for="ultima_leitura" class="form-label fw-bold">Ultima Leitura</label>
                        <input class="form-control readonly-input text-center" id="ultima_leitura" name="ultima_leitura" value="<%= sangria.ultima_leitura %>" disabled readonly>
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <label for="abastecido" class="form-label fw-bold">Abastecido</label>
                        <input type="number" class="form-control text-center" id="abastecido" name="abastecido" value="<%= sangria.abastecido %>">
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <label for="vendido" class="form-label fw-bold">Vendido</label>
                        <input class="form-control text-center readonly-input" id="vendido" name="vendido" value="<%= sangria.vendido %>" disabled readonly>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12 col-md-6 col-xl-3">
                        <label for="valor_apurado" class="form-label fw-bold">Valor Apurado</label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input type="number" step="0.01" class="form-control text-center" id="valor_apurado" name="valor_apurado" value="<%= sangria.valor_apurado %>" required oninput="calculateValues()">
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <label for="comissao" class="form-label fw-bold">Comissao (%)</label>
                        <div class="input-group">
                            <span class="input-group-text">%</span>
                            <input type="number" step="0.01" class="form-control text-center" id="comissao" name="comissao" value="<%= sangria.comissao %>" required oninput="calculateValues()">
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <label for="valor_comerciante" class="form-label fw-bold">Valor do Comerciante</label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input type="number" step="0.01" class="form-control text-center readonly-input" id="valor_comerciante" name="valor_comerciante" value="<%= sangria.valor_comerciante %>" readonly disabled>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 col-xl-3">
                        <label for="valor_liquido" class="form-label fw-bold">Valor Liquido</label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input type="number" step="0.01" class="form-control text-center readonly-input" id="valor_liquido" name="valor_liquido" value="<%= sangria.valor_liquido %>" readonly disabled>
                        </div>
                    </div>
                </div>

                <div class="row g-3 mt-1">
                    <div class="col-12">
                        <label for="observacoes" class="form-label fw-bold">Observacoes</label>
                        <textarea class="form-control" id="observacoes" name="observacoes" rows="3"><%= sangria.observacoes %></textarea>
                    </div>
                </div>

                <div class="action-row mt-4">
                    <a href="/pelucias/sangrias" class="btn btn-warning">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Atualizar</button>
                </div>
            </form>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
    function calculateValues() {
        const valorApurado = parseFloat(document.getElementById('valor_apurado').value) || 0;
        const comissao = parseFloat(document.getElementById('comissao').value) || 0;
        const valorDaComissao = valorApurado * (comissao / 100);
        const valorComerciante = valorDaComissao;
        const valorLiquido = valorApurado - valorComerciante;
        document.getElementById('valor_comerciante').value = valorComerciante.toFixed(2);
        document.getElementById('valor_liquido').value = valorLiquido.toFixed(2);
    }
    </script>
</body>
</html>
