<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Receita de Pelúcias' }) %>

<body class="list-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Receita de Pelúcias' }) %>

        <section class="page-titlebar page-titlebar-violet">
            <div class="page-titlebar-content">
                <span class="list-kicker"><i class="bi bi-graph-up-arrow"></i> Receita</span>
                <h1>Receita consolidada das pelúcias</h1>
                <p>Compare a evolução anual das receitas das pelúcias em uma tabela ampla, moderna e alinhada à nova linguagem visual do sistema.</p>
            </div>
            <div class="page-titlebar-side">
                <div class="list-stat"><strong>Produto</strong><span>Pelúcias</span></div>
                <div class="list-stat"><strong>Faixa</strong><span>2025 a 2035</span></div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <div class="list-toolbar">
                    <div class="list-toolbar-copy">
                        <h2>Painel de receita anual</h2>
                        <p>Visualize mês a mês e compare os totais de cada ano com uma leitura mais harmoniosa.</p>
                    </div>
                </div>

                <div class="modern-table-wrap">
                    <div class="modern-table-scroll">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th>Meses</th>
                                    <% for (let ano = 2025; ano <= 2035; ano++) { %>
                                        <th><span class="revenue-year-chip"><%= ano %></span></th>
                                    <% } %>
                                </tr>
                            </thead>
                            <tbody>
                                <% const meses = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro']; %>
                                <% meses.forEach((mes, index) => { %>
                                    <tr>
                                        <td class="table-title-cell revenue-month-cell"><%= mes %></td>
                                        <% for (let ano = 2025; ano <= 2035; ano++) { %>
                                            <td>
                                                <%
                                                    const receitaMesAno = receita.find(r => Number(r.ano) === ano && Number(r.mes) === index + 1);
                                                    const valor = receitaMesAno ? Number(receitaMesAno.total).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) : 'R$ 0,00';
                                                %>
                                                <strong><%= valor %></strong>
                                            </td>
                                        <% } %>
                                    </tr>
                                <% }) %>
                                <tr class="revenue-total-row">
                                    <td class="table-title-cell revenue-month-cell">Total</td>
                                    <% for (let ano = 2025; ano <= 2035; ano++) { %>
                                        <td>
                                            <%
                                                const totalAno = receita
                                                    .filter(r => Number(r.ano) === ano)
                                                    .reduce((sum, r) => sum + Number(r.total), 0);
                                            %>
                                            <strong><%= totalAno.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></strong>
                                        </td>
                                    <% } %>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>

