<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Visualizar Sangria Pelúcias' }) %>

    <body class="bg-light">
        <%- include('../../partials/header') %>

        <div style="padding-top: 2.9em;"></div>
        <div>&nbsp;</div>
        
        <div class="container w-75 px-4">
            
            <!-- breadcrumb -->
            <%- include('../../partials/breadcrumb', { pageTitle: 'Visualizar Sangria Pelúcias' }) %>

            <div class="cabecalho-pelucia">
                <h1 class="mb-0">Visualizar Sangria das Pelúcias</h1>

                <a href="/pelucias/sangrias" class="btn px-5 align-middle fs-5 btn-voltar"> 
                    <i class="align-middle fs-5 bi bi-caret-left-square"></i>&nbsp; Voltar
                </a>
            </div>

            <main class="mb-5 pelucia">
                <div class="card shadow">
                    <div class="card-body">
                        <% if (sangria) { %>
                            <div class="row px-3">

                                <div class="col-md-12 d-flex justify-content-between">
                                    <div class="col-md-11 d-flex ">
                                        <p class="mt-1">Estabelecimento:</p>
                                        <h4 class="ms-1"><strong> <%= sangria.estabelecimento %> </strong></h4>
                                    </div>
                                    <div class="col-md-1 mt-1">
                                        <p>ID: <strong> <%= sangria.id %> </strong></p>
                                    </div>
                                </div>

                                <hr>

                                <div class="col-md-6">
                                    <p>Data da Sangria:<strong> <%= new Date(sangria.data_sangria).toLocaleDateString('pt-BR') %> </strong></p>
                                    <p>Valor Apurado:<strong> R$ <%= Number(sangria.valor_apurado).toFixed(2) %> </strong></p>
                                    <p>Comissão:<strong> <%= Number(sangria.comissao).toFixed(2) %> % </strong></p>
                                    <p>Valor do Comerciante:<strong> R$ <%= Number(sangria.valor_comerciante).toFixed(2) %> </strong></p>
                                </div>
                                <div class="col-md-6">
                                    <p>Valor Líquido:<strong> R$ <%= Number(sangria.valor_liquido).toFixed(2) %> </strong></p>
                                    <p>Tipo de Pagamento:<strong> <%= sangria.tipo_pagamento === 'pix' ? 'PIX' : 'Espécie' %> </strong></p>                              
                                    <p>Última Edição:<strong> <%= sangria.data_atualizacao ? new Date(sangria.data_atualizacao).toLocaleDateString('pt-BR') : 'N/A' %> </strong></p>
                                    <p>Observações:<strong> <%= sangria.observacoes || 'N/A' %> </strong></p>
                                </div>
                            </div>
                        <% } else { %>
                            <p>Sangria não encontrada.</p>
                        <% } %>
                    </div>
                </div>
            </main>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous">
        </script>
    </body>
</html>
