<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Registrar Sangria de Pelúcias' }) %>

<body class="bg-light">
    <%- include('../../partials/header') %>
    <div class="container w-75 mt-5">
        <div>&nbsp;</div>

        <%- include('../../partials/breadcrumb', { pageTitle: 'Registrar Sangria de Pelúcias' }) %>

        <div class="cabecalho-pelucia">
            <h1 class="mb-0">Registrar Sangria de Pelúcias</h1>
        </div>

        <main class="pelucia">
            <form action="/pelucias/sangrias/add" method="POST">
                <div class="row">
                    <div class="mb-3 col-6">
                        <label for="estabelecimento" class="form-labe mb-1 fs-5 fw-bold">Estabelecimento</label>
                        <select class="form-select" id="estabelecimento" name="estabelecimento_id" required>
                            <option value="" selected disabled hidden>Selecione um estabelecimento</option>
                            <% estabelecimentos.forEach(function(estabelecimento) { %>
                                <option value="<%= estabelecimento.id %>"><%= estabelecimento.estabelecimento %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="mb-3 col-3 text-center">
                        <label for="data_sangria" class="form-label mb-1 fs-5 fw-bold">Data da Sangria</label>
                        <input type="date" class="form-control text-center" id="data_sangria" name="data_sangria" required>
                    </div>
                    <div class="mb-3 col-3 text-center">
                        <label for="tipo_pagamento" class="form-label mb-1 fs-5 fw-bold">Tipo de Pagamento</label>
                        <select class="form-select" id="tipo_pagamento" name="tipo_pagamento" required>
                            <option value="especie">Espécie</option>
                            <option value="pix">PIX</option>
                        </select>
                    </div>
                </div>
                <div class="row">
                    <div class="mb-3 col-3 text-center">
                        <label for="valor_apurado" class="form-label mb-1 fs-5 fw-bold">Valor Apurado</label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input type="number" step="0.01" class="form-control text-center" id="valor_apurado" name="valor_apurado" required>
                        </div>
                    </div>
                    <div class="mb-3 col-3 text-center">
                        <label for="comissao" class="form-label mb-1 fs-5 fw-bold">Comissão (%)</label>
                        <div class="input-group">
                            <span class="input-group-text">%</span>
                            <input type="number" step="0.01" class="form-control text-center" id="comissao" name="comissao" value="15" required>
                        </div>
                    </div>
                    <div class="mb-3 col-3 text-center">
                        <label for="valor_comerciante" class="form-label mb-1 fs-5 fw-bold">Valor do Comerciante</label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input type="number" step="0.01" class="form-control text-center readonly-input" id="valor_comerciante" name="valor_comerciante" readonly disabled>
                        </div>
                    </div>
                    <div class="mb-3 col-3 text-center">
                        <label for="valor_liquido" class="form-label mb-1 fs-5 fw-bold">Valor Líquido</label>
                        <div class="input-group">
                            <span class="input-group-text">R$</span>
                            <input type="number" step="0.01" class="form-control text-center readonly-input" id="valor_liquido" name="valor_liquido" readonly disabled>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="mb-3 col-2 text-center">
                        <label for="leitura_atual" class="form-label mb-1 fs-5 fw-bold">Leitura Atual</label>
                        <input type="number" class="form-control text-center" id="leitura_atual" name="leitura_atual" required>
                    </div>
                    <div class="mb-3 col-2 text-center">
                        <label for="ultima_leitura" class="form-label mb-1 fs-5 fw-bold">Última Leitura</label>
                        <input type="number" class="form-control text-center readonly-input" id="ultima_leitura" name="ultima_leitura" value="<%= ultimaLeitura %>" readonly disabled>
                    </div>
                    <div class="mb-3 col-2 text-center">
                        <label for="abastecido" class="form-label mb-1 fs-5 fw-bold">Abastecido</label>
                        <input type="number" class="form-control text-center" id="abastecido" name="abastecido" required>
                    </div>
                    <div class="mb-3 col-2 text-center">
                        <label for="qtde_vendido" class="form-label mb-1 fs-5 fw-bold">Vendido</label>
                        <input type="number" class="form-control text-center readonly-input" id="qtde_vendido" name="qtde_vendido" readonly disabled>
                    </div>
                    <div class="mb-3 col-2 text-center">
                        <label for="estoque_atual" class="form-label mb-1 fs-5 fw-bold">Estoque Atual</label>
                        <input type="number" class="form-control text-center readonly-input" id="estoque_atual" value="<%= ultimoEstoque %>" readonly disabled>
                    </div>
                    <div class="mb-3 col-2 text-center">
                        <label for="estoque_previsto" class="form-label mb-1 fs-5 fw-bold">Estoque Previsto</label>
                        <input type="number" class="form-control text-center readonly-input" id="estoque_previsto" readonly disabled>
                    </div>
                </div>
                <div class="row">
                    <div class="mb-3 col-12">
                        <label for="observacoes" class="form-label mb-1 fs-5 fw-bold">Observações</label>
                        <textarea class="form-control" id="observacoes" name="observacoes" rows="3"></textarea>
                    </div>
                </div>
                <div class="d-flex justify-content-center my-3">
                    <a href="/pelucias/sangrias"><button type="button" class="btn btn-warning px-5 me-3 fs-5">Cancelar</button></a>
                    <button type="submit" class="btn btn-primary ms-3 px-5 fs-5">Registrar</button>
                </div>
            </form>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>

    <script>
        function calculateValues() {
            const valorApurado = parseFloat(document.getElementById('valor_apurado').value) || 0;
            const comissao = parseFloat(document.getElementById('comissao').value) || 0;
            const valorDaComissao = valorApurado * (comissao / 100);
            const valorComerciante = valorDaComissao;
            const valorLiquido = valorApurado - valorComerciante;

            document.getElementById('valor_comerciante').value = valorComerciante.toFixed(2);
            document.getElementById('valor_liquido').value = valorLiquido.toFixed(2);
        }

        function calculateEstoquePrevisto() {
            const estabelecimentoId = document.getElementById('estabelecimento').value;
            const estoquePrevistoInput = document.getElementById('estoque_previsto');

            if (!estabelecimentoId) {
                estoquePrevistoInput.value = '';
                return;
            }

            const estoqueAtual = parseFloat(document.getElementById('estoque_atual').value) || 0;
            const qtdeVendido = parseFloat(document.getElementById('qtde_vendido').value) || 0;
            const abastecido = parseFloat(document.getElementById('abastecido').value) || 0;
            const estoquePrevisto = estoqueAtual - qtdeVendido + abastecido;

            estoquePrevistoInput.value = estoquePrevisto;
        }

        function calculateVendido() {
            const estabelecimentoId = document.getElementById('estabelecimento').value;
            const qtdeVendidoInput = document.getElementById('qtde_vendido');

            if (!estabelecimentoId) {
                qtdeVendidoInput.value = '';
                calculateEstoquePrevisto();
                return;
            }

            const leituraAtual = parseFloat(document.getElementById('leitura_atual').value) || 0;
            const ultimaLeitura = parseFloat(document.getElementById('ultima_leitura').value) || 0;
            const qtdeVendido = leituraAtual >= ultimaLeitura ? leituraAtual - ultimaLeitura : 0;
            qtdeVendidoInput.value = qtdeVendido;
            calculateEstoquePrevisto();
        }

        async function loadUltimosDados(estabelecimentoId) {
            const ultimaLeituraInput = document.getElementById('ultima_leitura');
            const estoqueAtualInput = document.getElementById('estoque_atual');
            const estoquePrevistoInput = document.getElementById('estoque_previsto');

            if (!estabelecimentoId) {
                ultimaLeituraInput.value = '';
                estoqueAtualInput.value = '';
                estoquePrevistoInput.value = '';
                document.getElementById('leitura_atual').value = '';
                document.getElementById('abastecido').value = '';
                document.getElementById('qtde_vendido').value = '';
                calculateVendido();
                return;
            }

            try {
                const response = await fetch(`/pelucias/sangrias/get-ultimos-dados/${estabelecimentoId}`);
                if (!response.ok) {
                    throw new Error('Falha ao consultar os últimos dados');
                }

                const data = await response.json();
                ultimaLeituraInput.value = Number(data.ultima_leitura || 0);
                estoqueAtualInput.value = Number(data.estoque || 0);
                calculateVendido();
            } catch (error) {
                console.error('Erro ao buscar os últimos dados:', error);
                ultimaLeituraInput.value = '';
                estoqueAtualInput.value = '';
                estoquePrevistoInput.value = '';
                document.getElementById('qtde_vendido').value = '';
                window.AppAlerts?.error('Não foi possível carregar a última leitura e o estoque deste estabelecimento.');
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            const estabelecimentoSelect = document.getElementById('estabelecimento');
            const leituraAtualInput = document.getElementById('leitura_atual');
            const abastecidoInput = document.getElementById('abastecido');
            const valorApuradoInput = document.getElementById('valor_apurado');
            const comissaoInput = document.getElementById('comissao');

            estabelecimentoSelect.addEventListener('change', function () {
                loadUltimosDados(this.value);
            });

            leituraAtualInput.addEventListener('input', calculateVendido);
            abastecidoInput.addEventListener('input', calculateEstoquePrevisto);
            valorApuradoInput.addEventListener('input', calculateValues);
            comissaoInput.addEventListener('input', calculateValues);

            const dataSangriaInput = document.getElementById('data_sangria');
            dataSangriaInput.value = new Date().toISOString().split('T')[0];

            calculateValues();
            calculateEstoquePrevisto();
        });
    </script>
</body>
</html>
