<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Controle Geral das Pelúcias' }) %>

<body class="list-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell pelucias-control-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Controle Geral das Pelúcias' }) %>

        <section class="page-titlebar page-titlebar-violet pelucias-control-titlebar">
            <div class="page-titlebar-content">
                <span class="list-kicker">
                    <i class="bi bi-diagram-3"></i>
                    Operacional
                </span>

                <h1>Controle geral das pelúcias</h1>

                <p>Acompanhe os pontos que precisam de visita e monitore os dados mais importantes da operação.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="list-stat">
                    <strong>Pontos</strong>
                    <span><%= estabelecimentos.length %> registros</span>
                </div>

                <div class="list-stat">
                    <strong>Produto</strong>
                    <span>Pelúcias</span>
                </div>
            </div>
        </section>

        <main class="list-stage pelucias-control-stage">
            <section class="list-panel pelucias-control-panel">

                <div class="list-toolbar roteiro-toolbar pelucias-control-toolbar">
                    <div class="list-toolbar-copy">
                        <span class="form-section-tag">Visitas</span>
                        <h2>Pontos pendentes de visita</h2>
                        <p>Use o prazo abaixo para identificar quais pontos já precisam de sangria.</p>
                    </div>

                    <div class="dias-sangria-top pelucias-control-days">
                        <label for="diasSangria" class="form-label fw-bold">Dias para fazer a sangria</label>
                        <input
                            type="number"
                            class="form-control text-center fw-bold"
                            id="diasSangria"
                            name="diasSangria"
                            min="1"
                            required
                        >
                    </div>
                </div>

                <div class="modern-table-wrap pelucias-control-table-wrap">
                    <div class="modern-table-scroll pelucias-control-table-scroll">
                        <table class="modern-table pelucias-control-table">
                            <thead>
                                <tr>
                                    <th>Estabelecimento</th>
                                    <th>Endereço</th>
                                    <th>Bairro</th>
                                    <th>Chave</th>
                                    <th>Máquina</th>
                                    <th>Dias passados</th>
                                    <th>Situação</th>
                                </tr>
                            </thead>

                            <tbody id="tabelaEstabelecimentos">
                                <% if (estabelecimentos.length > 0) { %>
                                    <% estabelecimentos.forEach(function(estabelecimento) {
                                        const data = estabelecimento.data ? new Date(estabelecimento.data) : null;
                                        const hoje = new Date();
                                        const diferencaDias = data ? Math.floor((hoje - data) / (1000 * 60 * 60 * 24)) : '';
                                    %>

                                    <tr
                                        class="pelucias-control-row"
                                        data-diferenca-dias="<%= diferencaDias %>"
                                        data-sem-visita="<%= data ? 'false' : 'true' %>"
                                    >
                                       <td class="pelucias-control-name-cell" data-label="Estabelecimento">
                                            <span class="table-title-cell pelucias-control-name">
                                                <%= estabelecimento.estabelecimento %>
                                            </span>
                                        </td>

                                        <td class="table-cell-wrap pelucias-control-address-cell" data-label="Endereço">
                                            <%= estabelecimento.endereco || '-' %>
                                        </td>

                                        <td class="pelucias-control-neighborhood-cell" data-label="Bairro">
                                            <%= estabelecimento.bairro || '-' %>
                                        </td>

                                        <td class="pelucias-control-key-cell" data-label="Chave">
                                            <%= estabelecimento.chave_pelucias || estabelecimento.chave || '-' %>
                                        </td>

                                        <td class="pelucias-control-machine-cell" data-label="Máquina">
                                            <%= estabelecimento.maquina_pelucias || estabelecimento.maquina || '-' %>
                                        </td>

                                        <td class="dias-passados pelucias-control-days-cell" data-label="Dias passados">
                                            <%= data ? diferencaDias : 'Sem visita' %>
                                        </td>

                                        <td class="situacao pelucias-control-status-cell" data-label="Situação"></td>
                                    </tr>

                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="table-empty pelucias-empty">
                                            Nenhum ponto de pelúcias encontrado.
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </section>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <script>
        function obterDiasSangria() {
            const input = document.getElementById('diasSangria');
            const valor = input.value.trim();

            if (valor === '') {
                return 7;
            }

            const numero = Number(valor);

            if (Number.isNaN(numero) || numero <= 0) {
                return 7;
            }

            return numero;
        }

        function salvarDiasSangria() {
            const input = document.getElementById('diasSangria');
            localStorage.setItem('diasSangriaPelucias', input.value);
            atualizarSituacao();
        }

        function carregarDiasSangria() {
            const input = document.getElementById('diasSangria');
            const diasSalvos = localStorage.getItem('diasSangriaPelucias');

            if (diasSalvos === null || diasSalvos === '' || Number(diasSalvos) <= 0 || Number.isNaN(Number(diasSalvos))) {
                input.value = '7';
                localStorage.setItem('diasSangriaPelucias', '7');
            } else {
                input.value = diasSalvos;
            }

            atualizarSituacao();
        }

        function atualizarSituacao() {
            const diasSangria = obterDiasSangria();

            document.querySelectorAll('#tabelaEstabelecimentos tr').forEach(linha => {
                const semVisita = linha.getAttribute('data-sem-visita') === 'true';

                let diferencaDias = Number(linha.getAttribute('data-diferenca-dias'));

                if (Number.isNaN(diferencaDias)) {
                    diferencaDias = 0;
                }

                const situacaoCelula = linha.querySelector('.situacao');

                if (!situacaoCelula) {
                    return;
                }

                linha.classList.remove('table-row-exit-highlight', 'pelucias-control-row-alert');

                if (semVisita) {
                    situacaoCelula.innerHTML = '<span class="table-badge table-badge-danger">Sem visita</span>';
                    linha.classList.add('table-row-exit-highlight', 'pelucias-control-row-alert');
                    return;
                }

                if (diferencaDias >= diasSangria) {
                    situacaoCelula.innerHTML = '<span class="table-badge table-badge-danger">Sangria</span>';
                    linha.classList.add('table-row-exit-highlight', 'pelucias-control-row-alert');
                    return;
                }

                situacaoCelula.innerHTML = '<span class="table-badge table-badge-green">Aguardar</span>';
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            const inputDiasSangria = document.getElementById('diasSangria');

            carregarDiasSangria();

            inputDiasSangria.addEventListener('input', salvarDiasSangria);
            inputDiasSangria.addEventListener('change', salvarDiasSangria);
            inputDiasSangria.addEventListener('keyup', salvarDiasSangria);
        });
    </script>
</body>
</html>
