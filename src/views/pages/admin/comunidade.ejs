<!DOCTYPE html>
<html lang="pt-BR">
<%
  const listaTopicos = Array.isArray(topicos) ? topicos : [];
  const totalTopicos = listaTopicos.length;
  const totalAbertos = listaTopicos.filter(topico => topico.status === 'open').length;
  const totalFechados = listaTopicos.filter(topico => topico.status === 'closed').length;
  const totalOcultos = listaTopicos.filter(topico => topico.status === 'hidden').length;
  const totalFixados = listaTopicos.filter(topico => Boolean(topico.is_pinned)).length;
%>
<%- include('../../partials/head', {
  title,
  metaDescription,
  canonicalUrl,
  robotsMeta,
  skipGlobalStyles: true,
  preloadExtraStyles: false
}) %>

<body class="admin-comunidade-page">
  <style>
    html {
      min-height: 100%;
      background: #eef4fb;
    }

    body.admin-comunidade-page {
      min-height: 100vh;
      margin: 0;
      background:
        radial-gradient(circle at 8% 0%, rgba(37, 99, 235, 0.10), transparent 30%),
        radial-gradient(circle at 92% 6%, rgba(34, 197, 94, 0.08), transparent 24%),
        linear-gradient(180deg, #f5f8fc 0%, #edf3fa 100%);
      color: #10233f;
      font-family: 'Urbanist', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    }

    .admin-comunidade-shell {
      width: min(1320px, calc(100% - 36px));
      margin: 0 auto;
      padding: 28px 0 42px;
    }

    .admin-comunidade-topbar {
      display: flex;
      flex-wrap: wrap;
      gap: 16px;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 18px;
    }

    .admin-comunidade-kicker {
      display: inline-flex;
      align-items: center;
      width: fit-content;
      padding: 6px 11px;
      border-radius: 999px;
      background: #dbeafe;
      color: #1d4ed8;
      font-size: 0.74rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .admin-comunidade-heading {
      margin-top: 10px;
    }

    .admin-comunidade-heading h1 {
      margin: 0;
      color: #071b3a;
      font-size: clamp(1.8rem, 3vw, 2.65rem);
      line-height: 1.04;
      letter-spacing: -0.045em;
      font-weight: 950;
    }

    .admin-comunidade-heading p {
      max-width: 760px;
      margin: 8px 0 0;
      color: #53647d;
      font-size: 1rem;
      line-height: 1.55;
      font-weight: 600;
    }

    .admin-comunidade-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
      justify-content: flex-end;
    }

    .admin-btn,
    .admin-btn-outline,
    .admin-btn-soft,
    .admin-btn-warning,
    .admin-btn-danger {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 40px;
      padding: 10px 15px;
      border-radius: 999px;
      border: 0;
      font: inherit;
      font-size: 0.9rem;
      font-weight: 900;
      line-height: 1;
      text-decoration: none;
      cursor: pointer;
      transition:
        transform 180ms ease,
        box-shadow 180ms ease,
        border-color 180ms ease,
        background 180ms ease,
        color 180ms ease;
    }

    .admin-btn:hover,
    .admin-btn-outline:hover,
    .admin-btn-soft:hover,
    .admin-btn-warning:hover,
    .admin-btn-danger:hover {
      transform: translateY(-1px);
    }

    .admin-btn {
      background: #0e4aa6;
      color: #ffffff;
      box-shadow: 0 12px 24px rgba(14, 74, 166, 0.16);
    }

    .admin-btn-outline {
      border: 1px solid rgba(14, 74, 166, 0.18);
      background: #ffffff;
      color: #0e4aa6;
    }

    .admin-btn-soft {
      border: 1px solid rgba(29, 78, 216, 0.14);
      background: #eff6ff;
      color: #1d4ed8;
    }

    .admin-btn-warning {
      border: 1px solid rgba(194, 65, 12, 0.16);
      background: #fff7ed;
      color: #c2410c;
    }

    .admin-btn-danger {
      border: 1px solid rgba(185, 28, 28, 0.16);
      background: #fef2f2;
      color: #b91c1c;
    }

    .admin-comunidade-alert {
      margin: 0 0 16px;
      padding: 14px 16px;
      border-radius: 16px;
      border: 1px solid transparent;
      font-size: 0.95rem;
      font-weight: 800;
      line-height: 1.45;
    }

    .admin-comunidade-alert-success {
      border-color: #bbf7d0;
      background: #f0fdf4;
      color: #166534;
    }

    .admin-comunidade-alert-error {
      border-color: #fecaca;
      background: #fef2f2;
      color: #991b1b;
    }

    .admin-comunidade-panel {
      overflow: hidden;
      border: 1px solid rgba(15, 35, 70, 0.08);
      border-radius: 26px;
      background: rgba(255, 255, 255, 0.78);
      box-shadow: 0 24px 70px rgba(14, 34, 67, 0.10);
      backdrop-filter: blur(12px);
    }

    .admin-comunidade-panel-header {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 18px;
      align-items: center;
      padding: 22px 24px;
      border-bottom: 1px solid rgba(15, 35, 70, 0.08);
      background:
        radial-gradient(circle at top left, rgba(37, 99, 235, 0.10), transparent 34%),
        linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .admin-comunidade-panel-header h2 {
      margin: 0;
      color: #071b3a;
      font-size: 1.3rem;
      line-height: 1.15;
      letter-spacing: -0.025em;
      font-weight: 950;
    }

    .admin-comunidade-panel-header p {
      margin: 6px 0 0;
      color: #64748b;
      font-size: 0.95rem;
      line-height: 1.5;
      font-weight: 650;
    }

    .admin-comunidade-stats {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 1px;
      background: rgba(15, 35, 70, 0.08);
      border-bottom: 1px solid rgba(15, 35, 70, 0.08);
    }

    .admin-stat-card {
      padding: 18px 20px;
      background: #ffffff;
    }

    .admin-stat-label {
      display: block;
      margin-bottom: 8px;
      color: #64748b;
      font-size: 0.72rem;
      font-weight: 950;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .admin-stat-value {
      color: #071b3a;
      font-size: 2rem;
      line-height: 1;
      font-weight: 950;
      letter-spacing: -0.05em;
    }

    .admin-stat-help {
      margin-top: 8px;
      color: #64748b;
      font-size: 0.86rem;
      line-height: 1.35;
      font-weight: 600;
    }

    .admin-comunidade-list {
      display: grid;
      gap: 14px;
      padding: 18px;
    }

    .admin-topic-card {
      border: 1px solid rgba(15, 35, 70, 0.08);
      border-radius: 22px;
      background: #ffffff;
      box-shadow: 0 14px 34px rgba(14, 34, 67, 0.07);
    }

    .admin-topic-card.is-hidden {
      border-color: rgba(185, 28, 28, 0.18);
      background: linear-gradient(180deg, #ffffff 0%, #fff7f7 100%);
    }

    .admin-topic-card.is-closed {
      border-color: rgba(55, 48, 163, 0.16);
      background: linear-gradient(180deg, #ffffff 0%, #f8f9ff 100%);
    }

    .admin-topic-card-inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 20px;
      align-items: start;
      padding: 20px;
    }

    .admin-topic-main {
      min-width: 0;
    }

    .admin-topic-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 10px;
    }

    .admin-chip {
      display: inline-flex;
      align-items: center;
      padding: 5px 9px;
      border-radius: 999px;
      font-size: 0.7rem;
      font-weight: 950;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .admin-chip-open {
      background: #ecfdf5;
      color: #047857;
    }

    .admin-chip-closed {
      background: #eef2ff;
      color: #3730a3;
    }

    .admin-chip-hidden {
      background: #fef2f2;
      color: #b91c1c;
    }

    .admin-chip-pinned {
      background: #fff7ed;
      color: #c2410c;
    }

    .admin-topic-title {
      margin: 0;
      color: #071b3a;
      font-size: 1.18rem;
      line-height: 1.25;
      letter-spacing: -0.025em;
      font-weight: 950;
    }

    .admin-topic-title a {
      color: inherit;
      text-decoration: none;
    }

    .admin-topic-title a:hover {
      color: #0e4aa6;
    }

    .admin-topic-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 14px;
      margin-top: 10px;
      color: #64748b;
      font-size: 0.9rem;
      line-height: 1.45;
      font-weight: 700;
    }

    .admin-topic-meta span {
      display: inline-flex;
      align-items: center;
      gap: 6px;
    }

    .admin-topic-meta strong {
      color: #10233f;
      font-weight: 900;
    }

    .admin-topic-side {
      display: grid;
      gap: 10px;
      justify-items: end;
    }

    .admin-topic-stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(84px, 1fr));
      gap: 8px;
      min-width: 210px;
    }

    .admin-topic-stat {
      padding: 10px 12px;
      border: 1px solid rgba(15, 35, 70, 0.07);
      border-radius: 15px;
      background: #f8fbff;
    }

    .admin-topic-stat span {
      display: block;
      color: #64748b;
      font-size: 0.7rem;
      font-weight: 950;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .admin-topic-stat strong {
      display: block;
      margin-top: 5px;
      color: #071b3a;
      font-size: 1.15rem;
      line-height: 1;
      font-weight: 950;
    }

    .admin-topic-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: flex-end;
      padding: 14px 20px 18px;
      border-top: 1px solid rgba(15, 35, 70, 0.08);
    }

    .admin-topic-actions form {
      margin: 0;
    }

    .admin-empty-state {
      padding: 42px 24px;
      text-align: center;
      background: #ffffff;
    }

    .admin-empty-state h3 {
      margin: 0;
      color: #071b3a;
      font-size: 1.35rem;
      line-height: 1.2;
      font-weight: 950;
      letter-spacing: -0.025em;
    }

    .admin-empty-state p {
      max-width: 560px;
      margin: 10px auto 0;
      color: #64748b;
      line-height: 1.6;
      font-weight: 650;
    }

    @media (max-width: 1100px) {
      .admin-comunidade-stats {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .admin-topic-card-inner {
        grid-template-columns: 1fr;
      }

      .admin-topic-side {
        justify-items: stretch;
      }

      .admin-topic-stats {
        min-width: 0;
      }
    }

    @media (max-width: 767.98px) {
      .admin-comunidade-shell {
        width: min(100% - 22px, 1320px);
        padding: 20px 0 34px;
      }

      .admin-comunidade-topbar,
      .admin-comunidade-panel-header {
        grid-template-columns: 1fr;
      }

      .admin-comunidade-actions {
        justify-content: stretch;
      }

      .admin-comunidade-actions a {
        width: 100%;
      }

      .admin-comunidade-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .admin-topic-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .admin-topic-actions {
        flex-direction: column;
      }

      .admin-topic-actions form,
      .admin-topic-actions button,
      .admin-topic-actions a {
        width: 100%;
      }
    }

    @media (max-width: 520px) {
      .admin-comunidade-stats,
      .admin-topic-stats {
        grid-template-columns: 1fr;
      }

      .admin-topic-card-inner {
        padding: 16px;
      }

      .admin-topic-actions {
        padding: 14px 16px 16px;
      }
    }
  </style>

  <main class="admin-comunidade-shell">
    <header class="admin-comunidade-topbar">
      <div class="admin-comunidade-heading">
        <span class="admin-comunidade-kicker">Admin SaaS · Comunidade</span>
        <h1>Moderação da Comunidade</h1>
        <p>
          Acompanhe os tópicos publicados, destaque discussões importantes e mantenha
          a Comunidade VendMaster útil para operadores.
        </p>
      </div>

      <div class="admin-comunidade-actions">
        <a href="/comunidade" class="admin-btn">
          Ver comunidade
        </a>

        <a href="/painel" class="admin-btn-outline">
          Voltar ao painel
        </a>
      </div>
    </header>

    <% if (successMessage) { %>
      <div class="admin-comunidade-alert admin-comunidade-alert-success">
        <%= successMessage %>
      </div>
    <% } %>

    <% if (errorMessage) { %>
      <div class="admin-comunidade-alert admin-comunidade-alert-error">
        <%= errorMessage %>
      </div>
    <% } %>

    <section class="admin-comunidade-panel">
      <div class="admin-comunidade-panel-header">
        <div>
          <h2>Resumo da comunidade</h2>
          <p>
            Visão rápida dos tópicos e ações principais de moderação.
          </p>
        </div>
      </div>

      <div class="admin-comunidade-stats">
        <article class="admin-stat-card">
          <span class="admin-stat-label">Total</span>
          <div class="admin-stat-value"><%= totalTopicos %></div>
          <div class="admin-stat-help">Tópicos cadastrados.</div>
        </article>

        <article class="admin-stat-card">
          <span class="admin-stat-label">Abertos</span>
          <div class="admin-stat-value"><%= totalAbertos %></div>
          <div class="admin-stat-help">Aceitando respostas.</div>
        </article>

        <article class="admin-stat-card">
          <span class="admin-stat-label">Fechados</span>
          <div class="admin-stat-value"><%= totalFechados %></div>
          <div class="admin-stat-help">Sem novas respostas.</div>
        </article>

        <article class="admin-stat-card">
          <span class="admin-stat-label">Ocultos</span>
          <div class="admin-stat-value"><%= totalOcultos %></div>
          <div class="admin-stat-help">Fora da área pública.</div>
        </article>

        <article class="admin-stat-card">
          <span class="admin-stat-label">Fixados</span>
          <div class="admin-stat-value"><%= totalFixados %></div>
          <div class="admin-stat-help">Em destaque.</div>
        </article>
      </div>

      <% if (listaTopicos.length) { %>
        <div class="admin-comunidade-list">
          <% listaTopicos.forEach((topico) => { %>
            <article class="admin-topic-card <%= topico.status === 'hidden' ? 'is-hidden' : '' %> <%= topico.status === 'closed' ? 'is-closed' : '' %>">
              <div class="admin-topic-card-inner">
                <div class="admin-topic-main">
                  <div class="admin-topic-badges">
                    <% if (topico.status === 'open') { %>
                      <span class="admin-chip admin-chip-open">Aberto</span>
                    <% } else if (topico.status === 'closed') { %>
                      <span class="admin-chip admin-chip-closed">Fechado</span>
                    <% } else if (topico.status === 'hidden') { %>
                      <span class="admin-chip admin-chip-hidden">Oculto</span>
                    <% } %>

                    <% if (topico.is_pinned) { %>
                      <span class="admin-chip admin-chip-pinned">Fixado</span>
                    <% } %>
                  </div>

                  <h3 class="admin-topic-title">
                    <a href="/comunidade/topico/<%= topico.slug %>" target="_blank" rel="noopener">
                      <%= topico.titulo %>
                    </a>
                  </h3>

                  <div class="admin-topic-meta">
                    <span>Categoria: <strong><%= topico.categoria_nome %></strong></span>
                    <span>Autor: <strong><%= topico.autor_nome || 'Autor removido' %></strong></span>
                    <span>Criado em: <strong><%= formatarDataForum(topico.created_at) %></strong></span>
                  </div>
                </div>

                <aside class="admin-topic-side">
                  <a href="/comunidade/topico/<%= topico.slug %>" target="_blank" rel="noopener" class="admin-btn-soft">
                    Abrir tópico
                  </a>

                  <div class="admin-topic-stats">
                    <div class="admin-topic-stat">
                      <span>Respostas</span>
                      <strong><%= topico.reply_count %></strong>
                    </div>

                    <div class="admin-topic-stat">
                      <span>Views</span>
                      <strong><%= topico.view_count %></strong>
                    </div>
                  </div>
                </aside>
              </div>

              <div class="admin-topic-actions">
                <% if (topico.status === 'hidden') { %>
                  <form action="/admin/comunidade/topico/<%= topico.id %>/reexibir" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                    <button type="submit" class="admin-btn-soft">
                      Reexibir
                    </button>
                  </form>
                <% } else { %>
                  <form action="/admin/comunidade/topico/<%= topico.id %>/fixar" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                    <button type="submit" class="admin-btn-warning">
                      <%= topico.is_pinned ? 'Desfixar' : 'Fixar' %>
                    </button>
                  </form>

                  <form action="/admin/comunidade/topico/<%= topico.id %>/fechar" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                    <button type="submit" class="admin-btn-soft">
                      <%= topico.status === 'closed' ? 'Reabrir' : 'Fechar' %>
                    </button>
                  </form>

                  <form action="/admin/comunidade/topico/<%= topico.id %>/ocultar" method="POST">
                    <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                    <button type="submit" class="admin-btn-danger">
                      Ocultar
                    </button>
                  </form>
                <% } %>

                <form
                  action="/admin/comunidade/topico/<%= topico.id %>/excluir"
                  method="POST"
                  onsubmit="return confirm('Excluir este tópico? Essa ação remove o conteúdo da área pública e da moderação principal, mas mantém o registro no banco para segurança.');"
                >
                  <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                  <button type="submit" class="admin-btn-danger">
                    Excluir tópico
                  </button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      <% } else { %>
        <div class="admin-empty-state">
          <h3>Nenhum tópico publicado ainda.</h3>
          <p>
            Quando os usuários criarem discussões na comunidade, elas aparecerão aqui
            para acompanhamento e moderação.
          </p>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>