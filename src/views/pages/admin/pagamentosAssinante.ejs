<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title }) %>

<body class="list-page-body">
  <%- include('../../partials/header') %>
  <div class="page-spacer"></div>

  <%
    const totalEventos = paymentEvents.length;
    const totalProcessados = paymentEvents.filter((event) => Boolean(event.processed_at)).length;
    const totalIgnorados = paymentEvents.filter((event) => Boolean(event.ignored_at)).length;
    const totalApenasRegistrados = paymentEvents.filter((event) => {
      return !event.processed_at && !event.ignored_at;
    }).length;

    const totalConfirmados = paymentEvents.filter((event) => {
      return ['PAYMENT_CONFIRMED', 'PAYMENT_RECEIVED'].includes(event.event_type);
    }).length;

    const currencyFormatter = new Intl.NumberFormat('pt-BR', {
      style: 'currency',
      currency: 'BRL'
    });

    const formatCurrency = (value) => {
      const numericValue = Number(value);

      if (!Number.isFinite(numericValue)) {
        return 'Não informado';
      }

      return currencyFormatter.format(numericValue);
    };

    const getEventLabel = (eventType) => {
      const labels = {
        PAYMENT_CREATED: 'Cobrança criada',
        PAYMENT_CONFIRMED: 'Pagamento confirmado',
        PAYMENT_RECEIVED: 'Pagamento recebido',
        PAYMENT_OVERDUE: 'Pagamento vencido',
        PAYMENT_DELETED: 'Cobrança removida',
        SUBSCRIPTION_DELETED: 'Assinatura removida',
        SUBSCRIPTION_INACTIVATED: 'Assinatura inativada'
      };

      return labels[eventType] || eventType || 'Não informado';
    };

    const getEventClass = (eventType) => {
      if (['PAYMENT_CONFIRMED', 'PAYMENT_RECEIVED'].includes(eventType)) {
        return 'is-success';
      }

      if (['PAYMENT_OVERDUE', 'PAYMENT_DELETED', 'SUBSCRIPTION_DELETED', 'SUBSCRIPTION_INACTIVATED'].includes(eventType)) {
        return 'is-warning';
      }

      if (eventType === 'PAYMENT_CREATED') {
        return 'is-info';
      }

      return 'is-muted';
    };

    const getProcessingReasonLabel = (reason) => {
      const labels = {
        subscription_activated: 'Assinatura ativada/renovada',
        confirmed_payment_already_processed: 'Pagamento já processado anteriormente',
        confirmed_payment_already_processed_by_unique_index: 'Pagamento já processado pelo índice único',
        confirmed_payment_already_processed_by_concurrent_webhook: 'Pagamento já processado por webhook concorrente',
        confirmed_payment_without_gateway_payment_id: 'Confirmação sem ID do pagamento',
        external_reference_mismatch_or_missing: 'Referência externa ausente ou divergente',
        gateway_customer_mismatch: 'Cliente do gateway divergente',
        payment_value_mismatch: 'Valor do pagamento divergente do plano',
        payment_deleted_recorded_without_subscription_status_change: 'Cobrança removida registrada sem alterar assinatura',
        payment_overdue_ignored_for_active_or_trial_subscription: 'Vencimento ignorado para assinatura ativa/trial',
        payment_overdue_not_current_subscription: 'Vencimento de assinatura antiga ignorado',
        subscription_cancelled: 'Assinatura cancelada pelo gateway',
        subscription_cancelled_not_current_subscription: 'Cancelamento de assinatura antiga ignorado',
        subscription_marked_overdue: 'Assinatura marcada como vencida',
        subscription_not_changed: 'Assinatura não alterada',
        assinante_not_found: 'Assinante não localizado',
        event_not_actionable: 'Evento registrado sem ação automática'
      };

      return labels[reason] || reason || 'Sem motivo registrado';
    };

    const getEventState = (event) => {
      if (event.processed_at) {
        return {
          type: 'processed',
          className: 'is-processed',
          icon: 'bi-check-circle',
          label: 'Processado',
          date: event.processed_at
        };
      }

      if (event.ignored_at) {
        return {
          type: 'ignored',
          className: 'is-ignored',
          icon: 'bi-shield-exclamation',
          label: 'Ignorado',
          date: event.ignored_at
        };
      }

      return {
        type: 'registered',
        className: 'is-pending',
        icon: 'bi-dash-circle',
        label: 'Registrado',
        date: null
      };
    };

    const getEventInterpretation = (event) => {
      if (!event.assinante_id) {
        return {
          type: 'warning',
          label: 'Evento sem assinante vinculado. Verifique cliente, assinatura, cobrança e referência externa.'
        };
      }

      if (event.ignored_at) {
        return {
          type: 'warning',
          label: getProcessingReasonLabel(event.processing_reason)
        };
      }

      const eventType = event.event_type;
      const isProcessed = Boolean(event.processed_at);

      if (eventType === 'PAYMENT_CREATED') {
        return {
          type: 'info',
          label: 'Cobrança criada. Registro esperado; não ativa a assinatura.'
        };
      }

      if (['PAYMENT_CONFIRMED', 'PAYMENT_RECEIVED'].includes(eventType)) {
        return {
          type: isProcessed ? 'success' : 'warning',
          label: isProcessed
            ? 'Pagamento confirmado e aplicado à assinatura.'
            : 'Pagamento confirmado, mas ainda sem ação aplicada. Verifique o motivo técnico.'
        };
      }

      if (eventType === 'PAYMENT_OVERDUE') {
        return {
          type: isProcessed ? 'warning' : 'info',
          label: isProcessed
            ? 'Pagamento vencido e aplicado à assinatura quando permitido.'
            : 'Pagamento vencido registrado sem alterar assinatura.'
        };
      }

      if (eventType === 'PAYMENT_DELETED') {
        return {
          type: 'info',
          label: isProcessed
            ? 'Cobrança removida com ação aplicada.'
            : 'Cobrança removida registrada sem alterar assinatura.'
        };
      }

      if (['SUBSCRIPTION_DELETED', 'SUBSCRIPTION_INACTIVATED'].includes(eventType)) {
        return {
          type: isProcessed ? 'warning' : 'info',
          label: isProcessed
            ? 'Assinatura cancelada ou inativada no provedor e aplicada ao assinante.'
            : 'Evento de assinatura registrado sem ação aplicada.'
        };
      }

      return {
        type: isProcessed ? 'success' : 'info',
        label: isProcessed
          ? 'Evento registrado e processado.'
          : 'Evento registrado sem ação automática.'
      };
    };
  %>

  <div class="list-shell">
    <%- include('../../partials/breadcrumb', { pageTitle: 'Eventos de Pagamento' }) %>

    <section class="page-titlebar page-titlebar-neutral">
      <div class="page-titlebar-content">
        <span class="list-kicker">
          <i class="bi bi-receipt"></i>
          Cobrança
        </span>
        <h1>Eventos de pagamento</h1>
        <p>
          <strong><%= assinante.username %></strong>
          · <%= assinante.email %>
        </p>
      </div>

      <div class="page-titlebar-side">
        <div class="list-stat">
          <strong>Status atual</strong>
          <span><%= String(assinante.status_assinatura || '').toUpperCase() %></span>
        </div>
      </div>
    </section>

    <main class="list-stage">
      <section class="admin-payment-summary-grid" aria-label="Resumo dos eventos de pagamento">
        <article class="admin-payment-summary-card">
          <span>Total</span>
          <strong><%= totalEventos %></strong>
          <small>evento(s) registrado(s)</small>
        </article>

        <article class="admin-payment-summary-card is-success">
          <span>Processados</span>
          <strong><%= totalProcessados %></strong>
          <small>com ação aplicada</small>
        </article>

        <article class="admin-payment-summary-card is-warning">
          <span>Ignorados</span>
          <strong><%= totalIgnorados %></strong>
          <small>protegidos por regra de auditoria</small>
        </article>

        <article class="admin-payment-summary-card is-info">
          <span>Apenas registrados</span>
          <strong><%= totalApenasRegistrados %></strong>
          <small>sem ação automática</small>
        </article>
      </section>

      <section class="list-panel">
        <div class="list-toolbar">
          <div class="list-toolbar-copy">
            <h2>Histórico de eventos de cobrança</h2>
            <p>
              Use esta tela para acompanhar pagamentos confirmados, cobranças vencidas,
              cancelamentos e eventos ignorados pelas regras de segurança. Eventos ignorados
              não indicam necessariamente erro: em muitos casos, são proteções contra webhook
              duplicado, evento antigo ou cobrança substituída.
            </p>
          </div>

          <div class="d-flex flex-wrap gap-2">
            <a class="list-action" href="/admin/assinantes/<%= assinante.id %>/edit">
              <i class="bi bi-pencil-square"></i>
              <span>Editar assinante</span>
            </a>

            <a class="list-action" href="/admin/assinantes">
              <i class="bi bi-arrow-left"></i>
              <span>Voltar</span>
            </a>
          </div>
        </div>

        <% if (!paymentEvents.length) { %>
          <div class="modern-note">
            Nenhum evento de pagamento foi registrado para este assinante.
          </div>
        <% } else { %>
          <div class="admin-payment-audit-note">
            <i class="bi bi-shield-check"></i>
            <div>
              <strong>Leitura da auditoria</strong>
              <span>
                “Processado” significa que o evento alterou a assinatura.
                “Ignorado” significa que o evento foi recebido, mas não alterou a assinatura
                por regra de segurança. “Registrado” significa que o evento foi salvo apenas
                para histórico.
              </span>
            </div>
          </div>

          <div class="table-responsive admin-payment-table-wrap">
            <table class="table align-middle admin-payment-events-table">
              <colgroup>
                <col style="width: 150px;">
                <col style="width: 190px;">
                <col style="width: 170px;">
                <col style="width: 130px;">
                <col style="width: 340px;">
                <col style="width: 120px;">
                <col style="width: 130px;">
                <col style="width: 170px;">
                <col style="width: 270px;">
                <col style="width: 320px;">
              </colgroup>

              <thead>
                <tr>
                  <th>Data</th>
                  <th>Evento</th>
                  <th>Estado</th>
                  <th>Status gateway</th>
                  <th>Interpretação</th>
                  <th>Valor</th>
                  <th>Forma</th>
                  <th>Referência</th>
                  <th>IDs técnicos</th>
                  <th>Detalhes</th>
                </tr>
              </thead>

              <tbody>
                <% paymentEvents.forEach((event) => { %>
                  <% const interpretation = getEventInterpretation(event); %>
                  <% const eventState = getEventState(event); %>

                  <tr>
                    <td class="admin-col-date">
                      <strong><%= formatDateTime(event.created_at) %></strong>
                    </td>

                    <td class="admin-col-event">
                      <span class="admin-event-pill <%= getEventClass(event.event_type) %>">
                        <%= getEventLabel(event.event_type) %>
                      </span>
                      <small class="admin-event-code">
                        <%= event.event_type || 'Não informado' %>
                      </small>
                    </td>

                    <td class="admin-col-state">
                      <span class="admin-event-processed <%= eventState.className %>">
                        <i class="bi <%= eventState.icon %>"></i>
                        <%= eventState.label %>
                      </span>

                      <% if (eventState.date) { %>
                        <small class="admin-event-date">
                          <%= formatDateTime(eventState.date) %>
                        </small>
                      <% } %>

                      <% if (event.processing_reason) { %>
                        <small class="admin-event-reason">
                          <%= getProcessingReasonLabel(event.processing_reason) %>
                        </small>
                      <% } %>
                    </td>

                    <td class="admin-col-gateway-status">
                      <span class="admin-event-status">
                        <%= event.status || 'Não informado' %>
                      </span>
                    </td>

                    <td class="admin-col-interpretation">
                      <span class="admin-event-interpretation is-<%= interpretation.type %>">
                        <%= interpretation.label %>
                      </span>
                    </td>

                    <td class="admin-col-value">
                      <strong class="admin-event-money">
                        <%= formatCurrency(event.payment_value) %>
                      </strong>
                    </td>

                    <td class="admin-col-billing-type">
                      <span class="admin-event-status">
                        <%= event.billing_type || 'Não informado' %>
                      </span>
                    </td>

                    <td class="admin-col-reference">
                      <code class="admin-inline-code"><%= event.external_reference || '-' %></code>
                    </td>

                    <td class="admin-col-ids">
                      <div class="admin-event-id-list">
                        <div class="admin-event-id-item">
                          <span>Pagamento</span>
                          <code><%= event.gateway_payment_id || '-' %></code>
                        </div>

                        <div class="admin-event-id-item">
                          <span>Cliente</span>
                          <code><%= event.gateway_customer_id || '-' %></code>
                        </div>

                        <div class="admin-event-id-item">
                          <span>Assinatura</span>
                          <code><%= event.gateway_subscription_id || '-' %></code>
                        </div>

                        <div class="admin-event-id-item">
                          <span>Evento</span>
                          <code><%= event.gateway_event_id || '-' %></code>
                        </div>
                      </div>
                    </td>

                    <td class="admin-col-details">
                      <details class="admin-event-payload">
                        <summary>Ver detalhes técnicos</summary>

                        <div class="admin-event-technical-grid">
                          <div>
                            <span>Motivo</span>
                            <strong><%= getProcessingReasonLabel(event.processing_reason) %></strong>
                          </div>

                          <div>
                            <span>Processado em</span>
                            <strong><%= event.processed_at ? formatDateTime(event.processed_at) : 'Não processado' %></strong>
                          </div>

                          <div>
                            <span>Ignorado em</span>
                            <strong><%= event.ignored_at ? formatDateTime(event.ignored_at) : 'Não ignorado' %></strong>
                          </div>
                        </div>

                        <pre><%= JSON.stringify(event.payload || {}, null, 2) %></pre>
                      </details>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="admin-payment-footer-note">
            <strong>Total de confirmações recebidas:</strong>
            <span><%= totalConfirmados %>. Esse número pode ser maior que os pagamentos realmente aplicados, porque o gateway pode enviar mais de um evento para a mesma cobrança.</span>
          </div>
        <% } %>
      </section>
    </main>
  </div>

  <style>
    .admin-payment-summary-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.8rem;
      margin-bottom: 1rem;
    }

    .admin-payment-summary-card {
      padding: 1rem;
      border: 1px solid rgba(148, 163, 184, 0.22);
      border-radius: 20px;
      background:
        radial-gradient(circle at top right, rgba(37, 99, 235, 0.08), transparent 8rem),
        #fff;
      box-shadow: 0 14px 34px rgba(15, 23, 42, 0.06);
    }

    .admin-payment-summary-card span,
    .admin-payment-summary-card small {
      display: block;
      color: #64748b;
      font-size: 0.82rem;
      font-weight: 750;
    }

    .admin-payment-summary-card strong {
      display: block;
      margin: 0.18rem 0;
      color: #0f172a;
      font-size: 1.45rem;
      font-weight: 950;
      letter-spacing: -0.04em;
    }

    .admin-payment-summary-card.is-success {
      background:
        radial-gradient(circle at top right, rgba(16, 185, 129, 0.12), transparent 8rem),
        #ecfdf5;
      border-color: rgba(16, 185, 129, 0.22);
    }

    .admin-payment-summary-card.is-warning {
      background:
        radial-gradient(circle at top right, rgba(245, 158, 11, 0.12), transparent 8rem),
        #fffbeb;
      border-color: rgba(245, 158, 11, 0.24);
    }

    .admin-payment-summary-card.is-info {
      background:
        radial-gradient(circle at top right, rgba(37, 99, 235, 0.12), transparent 8rem),
        #eff6ff;
      border-color: rgba(37, 99, 235, 0.2);
    }

    .admin-payment-audit-note,
    .admin-payment-footer-note {
      display: flex;
      align-items: flex-start;
      gap: 0.72rem;
      margin: 0 1rem 1rem;
      padding: 0.95rem 1rem;
      border: 1px solid rgba(37, 99, 235, 0.18);
      border-radius: 18px;
      background: #eff6ff;
      color: #1e3a8a;
    }

    .admin-payment-audit-note i {
      margin-top: 0.08rem;
      font-size: 1.08rem;
      color: #1d4ed8;
    }

    .admin-payment-audit-note strong,
    .admin-payment-footer-note strong {
      display: block;
      margin-bottom: 0.18rem;
      font-size: 0.92rem;
      font-weight: 900;
    }

    .admin-payment-audit-note span,
    .admin-payment-footer-note span {
      display: block;
      font-size: 0.86rem;
      line-height: 1.45;
      font-weight: 650;
    }

    .admin-payment-footer-note {
      margin: 1rem;
    }

    .admin-payment-table-wrap {
      padding: 0 1rem 1rem;
    }

    .admin-payment-events-table {
      margin-bottom: 0;
      min-width: 1990px;
      table-layout: fixed;
      border-collapse: separate;
      border-spacing: 0;
    }

    .admin-payment-events-table thead th {
      position: sticky;
      top: 0;
      z-index: 2;
      color: #ffffff;
      background: #1980ff;
      font-size: 0.81rem;
      font-weight: 850;
      white-space: nowrap;
      border-bottom: 0;
      padding: 0.9rem 0.8rem;
    }

    .admin-payment-events-table thead th:first-child {
      border-top-left-radius: 14px;
    }

    .admin-payment-events-table thead th:last-child {
      border-top-right-radius: 14px;
    }

    .admin-payment-events-table tbody tr {
      background: #ffffff;
    }

    .admin-payment-events-table tbody tr:nth-child(even) {
      background: #fbfdff;
    }

    .admin-payment-events-table tbody td {
      color: #0f172a;
      font-size: 0.9rem;
      vertical-align: top;
      padding: 1rem 0.8rem;
      border-bottom: 1px solid rgba(226, 232, 240, 0.9);
    }

    .admin-payment-events-table td.admin-col-date strong {
      display: inline-block;
      line-height: 1.35;
      white-space: nowrap;
    }

    .admin-payment-events-table td.admin-col-value,
    .admin-payment-events-table td.admin-col-billing-type,
    .admin-payment-events-table td.admin-col-gateway-status {
      white-space: nowrap;
    }

    .admin-inline-code,
    .admin-payment-events-table code {
      display: inline-block;
      max-width: 100%;
      color: #1d4ed8;
      font-size: 0.8rem;
      word-break: break-word;
      white-space: normal;
    }

    .admin-event-pill {
      display: inline-flex;
      align-items: center;
      padding: 0.3rem 0.58rem;
      border-radius: 999px;
      background: #eff6ff;
      color: #1d4ed8;
      font-size: 0.78rem;
      font-weight: 850;
      white-space: nowrap;
    }

    .admin-event-pill.is-success {
      background: #ecfdf5;
      color: #047857;
    }

    .admin-event-pill.is-warning {
      background: #fffbeb;
      color: #92400e;
    }

    .admin-event-pill.is-info {
      background: #eff6ff;
      color: #1d4ed8;
    }

    .admin-event-pill.is-muted {
      background: #f1f5f9;
      color: #475569;
    }

    .admin-event-code,
    .admin-event-date,
    .admin-event-reason {
      display: block;
      margin-top: 0.26rem;
      color: #64748b;
      font-size: 0.74rem;
      font-weight: 700;
      line-height: 1.34;
    }

    .admin-event-reason {
      color: #475569;
      max-width: 100%;
    }

    .admin-event-status {
      display: inline-flex;
      align-items: center;
      padding: 0.28rem 0.52rem;
      border-radius: 999px;
      background: #f8fafc;
      color: #334155;
      border: 1px solid rgba(148, 163, 184, 0.2);
      font-size: 0.78rem;
      font-weight: 850;
      white-space: nowrap;
    }

    .admin-event-interpretation {
      display: block;
      max-width: 100%;
      line-height: 1.45;
      font-size: 0.84rem;
      font-weight: 750;
    }

    .admin-event-interpretation.is-success {
      color: #047857;
    }

    .admin-event-interpretation.is-warning {
      color: #92400e;
    }

    .admin-event-interpretation.is-info {
      color: #1d4ed8;
    }

    .admin-event-interpretation.is-muted {
      color: #475569;
    }

    .admin-event-money {
      color: #0f172a;
      font-size: 0.94rem;
      font-weight: 900;
      white-space: nowrap;
    }

    .admin-event-processed {
      display: inline-flex;
      align-items: center;
      gap: 0.32rem;
      width: fit-content;
      padding: 0.28rem 0.54rem;
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 900;
      white-space: nowrap;
    }

    .admin-event-processed.is-processed {
      color: #047857;
      background: #ecfdf5;
      border: 1px solid rgba(16, 185, 129, 0.22);
    }

    .admin-event-processed.is-pending {
      color: #92400e;
      background: #fffbeb;
      border: 1px solid rgba(245, 158, 11, 0.24);
    }

    .admin-event-processed.is-ignored {
      color: #7c2d12;
      background: #fff7ed;
      border: 1px solid rgba(249, 115, 22, 0.24);
    }

    .admin-event-id-list {
      display: grid;
      gap: 0.55rem;
      width: 100%;
    }

    .admin-event-id-item {
      padding: 0.55rem 0.65rem;
      border-radius: 14px;
      background: #f8fafc;
      border: 1px solid rgba(148, 163, 184, 0.18);
    }

    .admin-event-id-item span {
      display: block;
      margin-bottom: 0.2rem;
      color: #64748b;
      font-size: 0.72rem;
      font-weight: 850;
      letter-spacing: 0.01em;
      text-transform: uppercase;
    }

    .admin-event-id-item code {
      display: block;
      color: #1d4ed8;
      font-size: 0.8rem;
      line-height: 1.45;
      word-break: break-word;
      white-space: normal;
    }

    .admin-event-payload {
      width: 100%;
    }

    .admin-event-payload summary {
      cursor: pointer;
      color: #1d4ed8;
      font-weight: 850;
      font-size: 0.84rem;
      line-height: 1.35;
      list-style: none;
    }

    .admin-event-payload summary::-webkit-details-marker {
      display: none;
    }

    .admin-event-payload summary::before {
      content: '▸';
      display: inline-block;
      margin-right: 0.45rem;
      transition: transform 0.2s ease;
    }

    .admin-event-payload[open] summary::before {
      transform: rotate(90deg);
    }

    .admin-event-technical-grid {
      display: grid;
      gap: 0.55rem;
      margin-top: 0.8rem;
      padding: 0.8rem;
      border: 1px solid rgba(148, 163, 184, 0.2);
      border-radius: 14px;
      background: #f8fafc;
    }

    .admin-event-technical-grid span {
      display: block;
      color: #64748b;
      font-size: 0.74rem;
      font-weight: 850;
    }

    .admin-event-technical-grid strong {
      display: block;
      color: #0f172a;
      font-size: 0.82rem;
      line-height: 1.36;
      font-weight: 850;
    }

    .admin-event-payload pre {
      width: 100%;
      max-width: 100%;
      max-height: 300px;
      overflow: auto;
      margin-top: 0.75rem;
      padding: 0.9rem;
      border-radius: 14px;
      background: #0f172a;
      color: #e2e8f0;
      font-size: 0.77rem;
      line-height: 1.5;
      white-space: pre-wrap;
      word-break: break-word;
    }

    @media (max-width: 1000px) {
      .admin-payment-summary-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 768px) {
      .admin-payment-summary-grid {
        grid-template-columns: 1fr;
      }

      .admin-payment-audit-note,
      .admin-payment-footer-note {
        margin-right: 0;
        margin-left: 0;
      }

      .admin-payment-table-wrap {
        padding-right: 0;
        padding-left: 0;
      }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      <% if (typeof success !== 'undefined' && success) { %>
        window.AppAlerts?.success("<%- String(success).replace(/\"/g, '&quot;') %>");
      <% } %>

      <% if (typeof error !== 'undefined' && error) { %>
        window.AppAlerts?.error("<%- String(error).replace(/\"/g, '&quot;') %>");
      <% } %>
    });
  </script>
</body>
</html>