<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken || '' %>">

    <title>Criar conta - VendMaster</title>

    <link rel="stylesheet" href="/css/auth.css">

    <script defer src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script defer src="/js/appAlerts.js"></script>
    <script defer src="/js/csrf.js"></script>
</head>

<body class="auth-body">
    <main class="auth-page auth-page-register">
        <section class="auth-brand-panel">
            <div class="auth-brand-content">
                <a href="/" class="auth-logo-link" aria-label="Voltar para a página inicial da VendMaster">
                    <img src="/images/logo.png" alt="VendMaster" class="auth-logo-img">
                </a>

                <div class="auth-brand-copy">
                    <span class="auth-pill">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2l1.3 4.2L17.5 5 16.3 9.2 20 12l-3.7 2.8L17.5 19l-4.2-1.2L12 22l-1.3-4.2L6.5 19l1.2-4.2L4 12l3.7-2.8L6.5 5l4.2 1.2L12 2z" />
                        </svg>
                        Comece sua operação agora
                    </span>

                    <h1>Crie sua conta e organize sua gestão.</h1>

                    <p>
                        Configure sua operação para controlar pontos, rotas, abastecimentos,
                        leituras, estoque, comissões e financeiro em uma plataforma feita para operadores.
                    </p>
                </div>

                <div class="auth-feature-grid">
                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 2a7 7 0 0 0-7 7c0 5.25 7 13 7 13s7-7.75 7-13a7 7 0 0 0-7-7zm0 9.5A2.5 2.5 0 1 1 12 6a2.5 2.5 0 0 1 0 5.5z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Pontos</strong>
                            <span>Cadastre seus locais</span>
                        </div>
                    </div>

                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M7 4a3 3 0 1 1-2.24 5H4a2 2 0 0 0 0 4h16a4 4 0 0 1 0 8h-1.76a3 3 0 1 1 0-2H20a2 2 0 0 0 0-4H4a4 4 0 0 1 0-8h.76A3 3 0 0 1 7 4zm0 2a1 1 0 1 0 0 2 1 1 0 0 0 0-2zm10 12a1 1 0 1 0 0 2 1 1 0 0 0 0-2z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Rotas</strong>
                            <span>Planeje visitas</span>
                        </div>
                    </div>

                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M21 7.5 12 2 3 7.5v9L12 22l9-5.5v-9zM12 4.35l6.15 3.76L12 11.87 5.85 8.11 12 4.35zM5 9.9l6 3.67v5.65l-6-3.67V9.9zm8 9.32v-5.65l6-3.67v5.65l-6 3.67z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Estoque</strong>
                            <span>Produtos organizados</span>
                        </div>
                    </div>

                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 2a10 10 0 1 0 10 10A10.01 10.01 0 0 0 12 2zm1 15.9V20h-2v-2.08a5.2 5.2 0 0 1-3.12-1.4l1.2-1.6A3.74 3.74 0 0 0 12 16.1c1.15 0 1.9-.47 1.9-1.25 0-.72-.45-1.08-2.27-1.52-2.25-.55-3.35-1.37-3.35-3.05 0-1.56 1.08-2.72 2.72-3.05V5h2v2.24a4.86 4.86 0 0 1 2.65 1.19l-1.12 1.64A3.6 3.6 0 0 0 12 9.05c-1.1 0-1.68.48-1.68 1.12 0 .7.43.98 2.3 1.45 2.38.6 3.32 1.52 3.32 3.13 0 1.65-1.16 2.82-2.94 3.15z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Financeiro</strong>
                            <span>Acompanhe resultados</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="auth-form-panel">
            <div class="auth-card auth-card-register">
                <div class="auth-card-header">
                    <span class="auth-card-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M15 12a5 5 0 1 0-5-5 5 5 0 0 0 5 5zm0-8a3 3 0 1 1-3 3 3 3 0 0 1 3-3zM2 22v-2a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v2h-2v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2H2zm18-10V9h-3V7h3V4h2v3h3v2h-3v3h-2z" />
                        </svg>
                    </span>

                    <div>
                        <h2>Criar conta</h2>
                        <p>Informe seus dados para acessar o sistema.</p>
                    </div>
                </div>

                <form action="/register" method="POST" class="auth-form" id="registerForm" autocomplete="on" novalidate>
                    <div class="auth-field">
                        <label for="user">Nome</label>

                        <div class="auth-input-wrap">
                            <span class="auth-input-icon">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M12 12a5 5 0 1 0-5-5 5 5 0 0 0 5 5zm0-8a3 3 0 1 1-3 3 3 3 0 0 1 3-3zm8 18h-2v-2a4 4 0 0 0-4-4h-4a4 4 0 0 0-4 4v2H4v-2a6 6 0 0 1 6-6h4a6 6 0 0 1 6 6v2z" />
                                </svg>
                            </span>

                            <input
                                type="text"
                                id="user"
                                name="user"
                                placeholder="Seu nome"
                                autocomplete="name"
                                value="<%= formData?.user || '' %>"
                                required
                            >
                        </div>
                    </div>

                    <div class="auth-field">
                        <label for="email">E-mail</label>

                        <div class="auth-input-wrap">
                            <span class="auth-input-icon">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M3 5h18v14H3V5zm2 2v.35l7 4.38 7-4.38V7H5zm14 10V9.7l-7 4.38L5 9.7V17h14z" />
                                </svg>
                            </span>

                            <input
                                type="email"
                                id="email"
                                name="email"
                                placeholder="Seu e-mail"
                                autocomplete="email"
                                value="<%= formData?.email || '' %>"
                                required
                            >
                        </div>
                    </div>

                    <div class="auth-form-row">
                        <div class="auth-field">
                            <label for="senha">Senha</label>

                            <div class="auth-input-wrap">
                                <span class="auth-input-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M17 9V7a5 5 0 0 0-10 0v2H5v13h14V9h-2zM9 7a3 3 0 0 1 6 0v2H9V7zm8 13H7v-9h10v9zm-5-2a1.5 1.5 0 0 0 1-2.62V14a1 1 0 0 0-2 0v1.38A1.5 1.5 0 0 0 12 18z" />
                                    </svg>
                                </span>

                                <input
                                    type="password"
                                    id="senha"
                                    name="senha"
                                    placeholder="Crie sua senha"
                                    autocomplete="new-password"
                                    minlength="3"
                                    required
                                >

                                <button
                                    type="button"
                                    class="auth-password-toggle"
                                    data-toggle-password="senha"
                                    aria-label="Mostrar senha"
                                >
                                    <svg class="icon-eye" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 5c5.5 0 9.4 5.1 9.84 5.7l.16.3-.16.3C21.4 11.9 17.5 17 12 17s-9.4-5.1-9.84-5.7L2 11l.16-.3C2.6 10.1 6.5 5 12 5zm0 2c-3.58 0-6.45 2.7-7.75 4C5.55 12.3 8.42 15 12 15s6.45-2.7 7.75-4C18.45 9.7 15.58 7 12 7zm0 1.5A2.5 2.5 0 1 1 9.5 11 2.5 2.5 0 0 1 12 8.5z" />
                                    </svg>

                                    <svg class="icon-eye-off" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3.28 2 22 20.72 20.72 22l-3.1-3.1A10.68 10.68 0 0 1 12 20C6.5 20 2.6 14.9 2.16 14.3L2 14l.16-.3a17.58 17.58 0 0 1 4.01-4.13L2 5.28 3.28 2zm4.31 8.99A14.25 14.25 0 0 0 4.25 14C5.55 15.3 8.42 18 12 18a8.28 8.28 0 0 0 4.08-1.08l-2.02-2.02A3.5 3.5 0 0 1 7.59 10.99zM12 8a3.5 3.5 0 0 1 3.5 3.5 3.45 3.45 0 0 1-.17 1.08L20.04 17.3A16.4 16.4 0 0 0 21.75 14C20.45 12.7 17.58 10 14 10a8.2 8.2 0 0 0-1.7.18L10.7 8.6A3.4 3.4 0 0 1 12 8z" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="auth-field">
                            <label for="confirmarSenha">Confirmar senha</label>

                            <div class="auth-input-wrap">
                                <span class="auth-input-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 2 4 5.2V11c0 5.05 3.4 9.75 8 11 4.6-1.25 8-5.95 8-11V5.2L12 2zm6 9c0 4-2.45 7.72-6 8.9C8.45 18.72 6 15 6 11V6.55l6-2.4 6 2.4V11zm-7.1 3.35 5.05-5.05 1.4 1.4-6.45 6.45-3.35-3.35 1.4-1.4 1.95 1.95z" />
                                    </svg>
                                </span>

                                <input
                                    type="password"
                                    id="confirmarSenha"
                                    name="confirmarSenha"
                                    placeholder="Repita a senha"
                                    autocomplete="new-password"
                                    minlength="3"
                                    required
                                >

                                <button
                                    type="button"
                                    class="auth-password-toggle"
                                    data-toggle-password="confirmarSenha"
                                    aria-label="Mostrar confirmação de senha"
                                >
                                    <svg class="icon-eye" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 5c5.5 0 9.4 5.1 9.84 5.7l.16.3-.16.3C21.4 11.9 17.5 17 12 17s-9.4-5.1-9.84-5.7L2 11l.16-.3C2.6 10.1 6.5 5 12 5zm0 2c-3.58 0-6.45 2.7-7.75 4C5.55 12.3 8.42 15 12 15s6.45-2.7 7.75-4C18.45 9.7 15.58 7 12 7zm0 1.5A2.5 2.5 0 1 1 9.5 11 2.5 2.5 0 0 1 12 8.5z" />
                                    </svg>

                                    <svg class="icon-eye-off" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3.28 2 22 20.72 20.72 22l-3.1-3.1A10.68 10.68 0 0 1 12 20C6.5 20 2.6 14.9 2.16 14.3L2 14l.16-.3a17.58 17.58 0 0 1 4.01-4.13L2 5.28 3.28 2zm4.31 8.99A14.25 14.25 0 0 0 4.25 14C5.55 15.3 8.42 18 12 18a8.28 8.28 0 0 0 4.08-1.08l-2.02-2.02A3.5 3.5 0 0 1 7.59 10.99zM12 8a3.5 3.5 0 0 1 3.5 3.5 3.45 3.45 0 0 1-.17 1.08L20.04 17.3A16.4 16.4 0 0 0 21.75 14C20.45 12.7 17.58 10 14 10a8.2 8.2 0 0 0-1.7.18L10.7 8.6A3.4 3.4 0 0 1 12 8z" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>

                    <small class="auth-note" id="confirmarSenhaHint">
                        A confirmação precisa ser idêntica à senha informada acima.
                    </small>

                    <div class="auth-field">
                        <div class="auth-section-title">
                            <span>Produtos da operação</span>
                            <small>Escolha pelo menos um</small>
                        </div>

                        <div class="auth-product-grid">
                            <% const selectedProducts = formData?.produtos_habilitados || []; %>

                            <% (productOptions || []).forEach((produto) => { %>
                                <label class="auth-product-option" for="produto_<%= produto.value %>">
                                    <input
                                        type="checkbox"
                                        id="produto_<%= produto.value %>"
                                        name="produtos_habilitados"
                                        value="<%= produto.value %>"
                                        <%= selectedProducts.includes(produto.value) ? 'checked' : '' %>
                                    >

                                    <span class="auth-product-check">
                                        <svg viewBox="0 0 24 24" aria-hidden="true">
                                            <path d="M9.2 16.6 4.95 12.35l1.4-1.4 2.85 2.85 8.45-8.45 1.4 1.4L9.2 16.6z" />
                                        </svg>
                                    </span>

                                    <span class="auth-product-content">
                                        <strong><%= produto.label %></strong>
                                        <small>
                                            <% if (produto.value === 'BOLINHAS') { %>
                                                Máquinas de bolinhas
                                            <% } else if (produto.value === 'PELUCIAS') { %>
                                                Máquinas de pelúcias
                                            <% } else if (produto.value === 'FIGURINHAS') { %>
                                                Consignados
                                            <% } else { %>
                                                Módulo operacional
                                            <% } %>
                                        </small>
                                    </span>
                                </label>
                            <% }) %>
                        </div>

                        <small class="auth-note" id="produtosHint">
                            Essa escolha define quais módulos aparecem no sistema.
                        </small>
                    </div>

                    <button type="submit" class="auth-submit">
                        <span>Criar conta</span>
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M13.3 5.3 20 12l-6.7 6.7-1.4-1.4 4.3-4.3H4v-2h12.2l-4.3-4.3 1.4-1.4z" />
                        </svg>
                    </button>
                </form>

                <p class="auth-register-text">
                    Já tem cadastro?
                    <a href="/login">Voltar para o login</a>
                </p>
            </div>

            <p class="auth-footer-note">
                VendMaster © <%= new Date().getFullYear() %> — Gestão simples para máquinas recreativas.
            </p>
        </section>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('[data-toggle-password]').forEach((button) => {
                button.addEventListener('click', () => {
                    const targetId = button.getAttribute('data-toggle-password');
                    const input = document.getElementById(targetId);

                    if (!input) return;

                    const isHidden = input.type === 'password';

                    input.type = isHidden ? 'text' : 'password';
                    button.classList.toggle('is-visible', isHidden);
                    button.setAttribute('aria-label', isHidden ? 'Ocultar senha' : 'Mostrar senha');
                });
            });

            const form = document.getElementById('registerForm');
            const senhaInput = document.getElementById('senha');
            const confirmarSenhaInput = document.getElementById('confirmarSenha');
            const hint = document.getElementById('confirmarSenhaHint');
            const produtosHint = document.getElementById('produtosHint');

            const syncPasswordValidation = () => {
                const senha = senhaInput.value;
                const confirmarSenha = confirmarSenhaInput.value;

                if (!confirmarSenha) {
                    confirmarSenhaInput.setCustomValidity('');
                    hint.textContent = 'A confirmação precisa ser idêntica à senha informada acima.';
                    hint.classList.remove('is-valid', 'is-invalid');
                    return;
                }

                if (senha !== confirmarSenha) {
                    confirmarSenhaInput.setCustomValidity('As senhas não conferem.');
                    hint.textContent = 'As senhas informadas estão diferentes.';
                    hint.classList.remove('is-valid');
                    hint.classList.add('is-invalid');
                    return;
                }

                confirmarSenhaInput.setCustomValidity('');
                hint.textContent = 'Confirmação de senha válida.';
                hint.classList.remove('is-invalid');
                hint.classList.add('is-valid');
            };

            senhaInput.addEventListener('input', syncPasswordValidation);
            confirmarSenhaInput.addEventListener('input', syncPasswordValidation);

            form.addEventListener('submit', (event) => {
                syncPasswordValidation();

                const hasProduct = Array.from(document.querySelectorAll('input[name="produtos_habilitados"]'))
                    .some((checkbox) => checkbox.checked);

                if (!hasProduct) {
                    event.preventDefault();
                    produtosHint.textContent = 'Selecione pelo menos um produto para criar sua operação.';
                    produtosHint.classList.add('is-invalid');
                    window.AppAlerts?.warning('Selecione pelo menos um produto da sua operação.');
                    return;
                }

                produtosHint.classList.remove('is-invalid');

                if (!form.checkValidity()) {
                    event.preventDefault();
                    form.reportValidity();
                }
            });
        });
    </script>

    <% if (error) { %>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                window.AppAlerts?.error(<%- JSON.stringify(error) %>, 'Falha no cadastro');
            });
        </script>
    <% } %>
</body>

</html>