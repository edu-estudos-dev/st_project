<!DOCTYPE html>
<html lang="pt-BR">
<%- include('../../partials/head', {
    title,
    metaDescription,
    canonicalUrl,
    ogImage,
    articleJsonLd,
    breadcrumbJsonLd,
    extraStyles
}) %>

  <body class="blog-page blog-article-page">
    <%- include('../../partials/blogPublicHeader') %>

      <main class="blog-main blog-article-main">
        <article class="blog-article">
          <section class="blog-article-hero" aria-labelledby="blog-article-title">
            <div class="blog-container blog-article-container">
              <nav class="blog-breadcrumb" aria-label="Breadcrumb">
                <a href="/">Início</a>
                <span aria-hidden="true">/</span>
                <a href="/blog">Blog</a>
                <span aria-hidden="true">/</span>
                <a href="/blog/categoria/<%= normalizarCategoriaParaUrl(post.categoria) %>">
                  <%= post.categoria %>
                </a>
              </nav>

              <div class="blog-article-heading">
                <span class="blog-eyebrow">
                  <%= post.categoria %>
                </span>

                <h1 id="blog-article-title">
                  <%= post.titulo %>
                </h1>

                <% if (post.resumo) { %>
                  <p>
                    <%= post.resumo %>
                  </p>
                <% } %>

                <div class="blog-article-meta">
                  <span class="blog-article-author-name">
                    <%= post.autor || 'VendMaster' %>
                  </span>

                  <% if (post.data_publicacao) { %>
                    <span aria-hidden="true">•</span>
                    <time
                      datetime="<%= post.data_publicacao.toISOString ? post.data_publicacao.toISOString() : post.data_publicacao %>">
                      <%= formatarDataPost(post.data_publicacao) %>
                    </time>
                  <% } %>

                  <span aria-hidden="true">•</span>
                  <span>Leitura estratégica</span>
                </div>

                <div class="blog-article-hero-actions" aria-label="Ações do artigo">
                  <a href="#conteudo-artigo" class="blog-primary-link">
                    Ler artigo
                  </a>

                  <a href="/demonstracao" class="blog-secondary-link">
                    Conhecer o VendMaster
                  </a>
                </div>
              </div>

              <% if (post.imagem_capa) { %>
                <figure class="blog-article-featured-cover" aria-label="<%= post.titulo %>">
                  <img
                    src="<%= post.imagem_capa %>"
                    alt="<%= post.titulo %>"
                    loading="eager"
                    decoding="async"
                    fetchpriority="high"
                  >

                  <figcaption class="blog-article-featured-caption">
                    <span>Conteúdo VendMaster</span>
                    <strong><%= post.categoria %></strong>
                  </figcaption>
                </figure>
              <% } else { %>
                <figure class="blog-article-featured-cover blog-article-featured-placeholder" aria-label="VendMaster">
                  <span>VendMaster</span>

                  <figcaption class="blog-article-featured-caption">
                    <span>Conteúdo VendMaster</span>
                    <strong><%= post.categoria %></strong>
                  </figcaption>
                </figure>
              <% } %>
            </div>
          </section>

          <div class="blog-container blog-article-layout">
            <%
              const vmArticleShareUrl = typeof canonicalUrl !== 'undefined' && canonicalUrl
                ? canonicalUrl
                : `https://vendmaster.com.br/blog/${post.slug}`;
              const vmArticleShareTitle = post.titulo || 'Artigo VendMaster';
              const vmArticleShareText = `${vmArticleShareTitle} | Blog VendMaster`;

              const encodedVmArticleShareUrl = encodeURIComponent(vmArticleShareUrl);
              const encodedVmArticleShareText = encodeURIComponent(vmArticleShareText);
            %>

            <aside class="blog-article-sidebar" aria-label="Navegação lateral do artigo">
              <div class="blog-sidebar-card">
                <h2>Categorias</h2>

                <% if (categorias && categorias.length) { %>
                  <nav class="blog-sidebar-categories">
                    <% categorias.forEach((item)=> { %>
                      <a href="/blog/categoria/<%= normalizarCategoriaParaUrl(item.categoria) %>"
                        class="<%= item.categoria === post.categoria ? 'is-active' : '' %>">
                        <span>
                          <%= item.categoria %>
                        </span>
                        <strong>
                          <%= item.total %>
                        </strong>
                      </a>
                      <% }) %>
                  </nav>
                  <% } else { %>
                    <p>Nenhuma categoria disponível.</p>
                    <% } %>
              </div>

              <div class="blog-sidebar-card blog-sidebar-share" aria-label="Compartilhar artigo">
                <span class="blog-eyebrow">Compartilhe</span>

                <h2>Gostou do artigo?</h2>

                <p>
                  Envie este conteúdo para alguém que também precisa melhorar a operação.
                </p>

                <div class="blog-sidebar-share-links">
                  <a
                    href="https://api.whatsapp.com/send?text=<%= encodedVmArticleShareText %>%20<%= encodedVmArticleShareUrl %>"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Compartilhar no WhatsApp"
                  >
                    <i class="bi bi-whatsapp" aria-hidden="true"></i>
                  </a>

                  <a
                    href="https://www.facebook.com/sharer/sharer.php?u=<%= encodedVmArticleShareUrl %>"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Compartilhar no Facebook"
                  >
                    <i class="bi bi-facebook" aria-hidden="true"></i>
                  </a>

                  <a
                    href="https://twitter.com/intent/tweet?url=<%= encodedVmArticleShareUrl %>&text=<%= encodedVmArticleShareText %>"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Compartilhar no X"
                  >
                    <i class="bi bi-twitter-x" aria-hidden="true"></i>
                  </a>

                  <button
                    type="button"
                    class="blog-sidebar-share-copy"
                    data-share-copy-link="<%= vmArticleShareUrl %>"
                    aria-label="Copiar link do artigo"
                    aria-describedby="blog-share-feedback"
                  >
                    <i class="bi bi-link-45deg" aria-hidden="true"></i>
                  </button>
                </div>

                <p id="blog-share-feedback" class="blog-sidebar-share-feedback" aria-live="polite" hidden>
                  Link copiado.
                </p>
              </div>

              <div class="blog-sidebar-card blog-sidebar-cta">
                <span class="blog-eyebrow">VendMaster</span>

                <h2>Controle sua operação com mais clareza</h2>

                <p>
                  Organize pontos, rotas, sangrias, estoque e financeiro em um só sistema.
                </p>

                <a href="/demonstracao">Conhecer o VendMaster</a>
              </div>
            </aside>

            <section class="blog-article-content" id="conteudo-artigo">
              <aside class="blog-article-reading-card">
                <span>Guia prático</span>
                <strong>Leia com foco em aplicação, não apenas em teoria.</strong>
                <p>
                  Este conteúdo foi pensado para ajudar operadores a transformar controle,
                  rota, sangria e gestão em uma rotina mais clara e profissional.
                </p>
              </aside>

              <%- post.conteudo %>

              <% const articleCommercialLinks = {
                'controle-de-sangria-maquinas-bolinhas': {
                  href: '/controle-sangria-maquinas-bolinhas',
                  label: 'Ver controle de sangria de máquinas de bolinhas',
                  text: 'Se você quer controlar coletas por ponto com mais clareza, conheça a página comercial sobre sangria de bolinhas.'
                },
                'como-organizar-rota-maquinas-recreativas': {
                  href: '/rota-inteligente-maquinas-recreativas',
                  label: 'Ver rota inteligente para máquinas recreativas',
                  text: 'Para transformar esse planejamento em rotina, veja como funciona a rota inteligente do VendMaster.'
                },
                'planilha-maquinas-bolinhas-controle': {
                  href: '/sistema-gestao-maquinas-recreativas',
                  label: 'Conhecer o sistema de gestão para máquinas recreativas',
                  text: 'Quando a planilha começa a limitar a operação, um sistema centralizado ajuda a organizar pontos, rotas, sangrias e financeiro.'
                }
              }; %>

              <% const articleCommercialLink = articleCommercialLinks[post.slug]; %>

              <% if (articleCommercialLink) { %>
                <aside class="blog-article-commercial-link">
                  <span>Próximo passo</span>
                  <p><%= articleCommercialLink.text %></p>
                  <a href="<%= articleCommercialLink.href %>"><%= articleCommercialLink.label %></a>
                </aside>
              <% } %>
            </section>
          </div>
        </article>

        <% if (postsRelacionados && postsRelacionados.length) { %>
          <section class="blog-section blog-related-section">
            <div class="blog-container">
              <div class="blog-section-header">
                <div>
                  <span class="blog-eyebrow">Leia também</span>
                  <h2>Artigos relacionados</h2>
                </div>

                <p>
                  Outros conteúdos sobre <%= post.categoria %> que podem ajudar na sua operação.
                </p>
              </div>

              <div class="blog-grid">
                <% postsRelacionados.forEach((postRelacionado)=> { %>
                  <article class="blog-card">
                    <a href="/blog/<%= postRelacionado.slug %>" class="blog-card-image"
                      aria-label="Ler artigo: <%= postRelacionado.titulo %>">
                      <% if (postRelacionado.imagem_capa) { %>
                        <img src="<%= postRelacionado.imagem_capa %>" alt="<%= postRelacionado.titulo %>"
                          loading="lazy">
                        <% } else { %>
                          <div class="blog-card-image-placeholder">
                            <span>VendMaster</span>
                          </div>
                          <% } %>
                    </a>

                    <div class="blog-card-body">
                      <div class="blog-card-meta">
                        <a href="/blog/categoria/<%= normalizarCategoriaParaUrl(postRelacionado.categoria) %>">
                          <%= postRelacionado.categoria %>
                        </a>

                        <% if (postRelacionado.data_publicacao) { %>
                          <span>
                            <%= formatarDataPost(postRelacionado.data_publicacao) %>
                          </span>
                          <% } %>
                      </div>

                      <h3>
                        <a href="/blog/<%= postRelacionado.slug %>">
                          <%= postRelacionado.titulo %>
                        </a>
                      </h3>

                      <p>
                        <%= postRelacionado.resumo %>
                      </p>

                      <a href="/blog/<%= postRelacionado.slug %>" class="blog-read-more">
                        Ler artigo
                        <span aria-hidden="true">→</span>
                      </a>
                    </div>
                  </article>
                  <% }) %>
              </div>
            </div>
          </section>
          <% } %>

            <section class="blog-cta-section">
              <div class="blog-container">
                <div class="blog-cta-card blog-cta-card-premium">
                  <div>
                    <span class="blog-eyebrow">VendMaster</span>

                    <h2>Pronto para profissionalizar sua operação?</h2>

                    <p>
                      O VendMaster ajuda você a controlar máquinas, pontos, sangrias,
                      estoque, rotas e financeiro com mais organização.
                    </p>
                  </div>

                  <a href="/demonstracao" class="blog-cta-button">
                    Conhecer o VendMaster
                  </a>
                </div>
              </div>
            </section>
      </main>

      <script>
        document.addEventListener('DOMContentLoaded', () => {
          const shareCopyButton = document.querySelector('[data-share-copy-link]');

          if (!shareCopyButton) return;

          const originalLabel = shareCopyButton.getAttribute('aria-label') || 'Copiar link do artigo';
          const feedback = document.getElementById('blog-share-feedback');

          shareCopyButton.addEventListener('click', async () => {
            const link = shareCopyButton.getAttribute('data-share-copy-link');

            if (!link) return;

            try {
              if (navigator.clipboard && window.isSecureContext) {
                await navigator.clipboard.writeText(link);
              } else {
                const temporaryInput = document.createElement('textarea');
                temporaryInput.value = link;
                temporaryInput.setAttribute('readonly', '');
                temporaryInput.style.position = 'fixed';
                temporaryInput.style.top = '-9999px';
                document.body.appendChild(temporaryInput);
                temporaryInput.select();
                document.execCommand('copy');
                document.body.removeChild(temporaryInput);
              }

              shareCopyButton.setAttribute('aria-label', 'Link copiado');

              if (feedback) {
                feedback.hidden = false;
              }

              window.setTimeout(() => {
                shareCopyButton.setAttribute('aria-label', originalLabel);

                if (feedback) {
                  feedback.hidden = true;
                }
              }, 2600);
            } catch (error) {
              shareCopyButton.setAttribute('aria-label', 'Não foi possível copiar o link');

              window.setTimeout(() => {
                shareCopyButton.setAttribute('aria-label', originalLabel);
              }, 2600);
            }
          });
        });
      </script>

      <%- include('../../partials/footer') %>
  </body>

</html>
