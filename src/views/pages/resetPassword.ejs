<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken || '' %>">

    <title>Redefinir senha - VendMaster</title>

    <link rel="stylesheet" href="/css/auth.css">

    <script defer src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script defer src="/js/appAlerts.js"></script>
    <script defer src="/js/csrf.js"></script>
</head>

<body class="auth-body">
    <main class="auth-page">
        <section class="auth-brand-panel">
            <div class="auth-brand-content">
                <a href="/" class="auth-logo-link" aria-label="Voltar para a página inicial da VendMaster">
                    <img src="/images/logo.png" alt="VendMaster" class="auth-logo-img">
                </a>

                <div class="auth-brand-copy">
                    <span class="auth-pill">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2l1.3 4.2L17.5 5 16.3 9.2 20 12l-3.7 2.8L17.5 19l-4.2-1.2L12 22l-1.3-4.2L6.5 19l1.2-4.2L4 12l3.7-2.8L6.5 5l4.2 1.2L12 2z" />
                        </svg>
                        Nova senha de acesso
                    </span>

                    <h1>Crie uma nova senha para sua conta.</h1>

                    <p>
                        Defina uma nova senha para voltar ao VendMaster com segurança
                        e continuar gerenciando sua operação.
                    </p>
                </div>

                <div class="auth-feature-grid">
                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 2 4 5.2V11c0 5.05 3.4 9.75 8 11 4.6-1.25 8-5.95 8-11V5.2L12 2zm6 9c0 4-2.45 7.72-6 8.9C8.45 18.72 6 15 6 11V6.55l6-2.4 6 2.4V11zm-7.1 3.35 5.05-5.05 1.4 1.4-6.45 6.45-3.35-3.35 1.4-1.4 1.95 1.95z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Proteção</strong>
                            <span>Acesso mais seguro</span>
                        </div>
                    </div>

                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M17 9V7a5 5 0 0 0-10 0v2H5v13h14V9h-2zM9 7a3 3 0 0 1 6 0v2H9V7zm8 13H7v-9h10v9zm-5-2a1.5 1.5 0 0 0 1-2.62V14a1 1 0 0 0-2 0v1.38A1.5 1.5 0 0 0 12 18z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Senha nova</strong>
                            <span>Defina seu acesso</span>
                        </div>
                    </div>

                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M9.2 16.6 4.95 12.35l1.4-1.4 2.85 2.85 8.45-8.45 1.4 1.4L9.2 16.6z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Confirmação</strong>
                            <span>Evite erro de digitação</span>
                        </div>
                    </div>

                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M13.3 5.3 20 12l-6.7 6.7-1.4-1.4 4.3-4.3H4v-2h12.2l-4.3-4.3 1.4-1.4z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Acesso</strong>
                            <span>Volte ao sistema</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="auth-form-panel">
            <div class="auth-card">
                <% if (isTokenValid) { %>
                    <div class="auth-card-header">
                        <span class="auth-card-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M17 9V7a5 5 0 0 0-10 0v2H5v13h14V9h-2zM9 7a3 3 0 0 1 6 0v2H9V7zm8 13H7v-9h10v9zm-5-2a1.5 1.5 0 0 0 1-2.62V14a1 1 0 0 0-2 0v1.38A1.5 1.5 0 0 0 12 18z" />
                            </svg>
                        </span>

                        <div>
                            <h2>Redefinir senha</h2>
                            <p>Crie uma nova senha para manter seu acesso protegido.</p>
                        </div>
                    </div>

                    <form action="/redefinir-senha" method="POST" class="auth-form" id="resetPasswordForm" autocomplete="on" novalidate>
                        <input type="hidden" name="token" value="<%= token %>">

                        <div class="auth-field">
                            <label for="senha">Nova senha</label>

                            <div class="auth-input-wrap">
                                <span class="auth-input-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M17 9V7a5 5 0 0 0-10 0v2H5v13h14V9h-2zM9 7a3 3 0 0 1 6 0v2H9V7zm8 13H7v-9h10v9zm-5-2a1.5 1.5 0 0 0 1-2.62V14a1 1 0 0 0-2 0v1.38A1.5 1.5 0 0 0 12 18z" />
                                    </svg>
                                </span>

                                <input
                                    type="password"
                                    id="senha"
                                    name="senha"
                                    placeholder="Digite a nova senha"
                                    autocomplete="new-password"
                                    minlength="3"
                                    required
                                >

                                <button
                                    type="button"
                                    class="auth-password-toggle"
                                    data-toggle-password="senha"
                                    aria-label="Mostrar senha"
                                >
                                    <svg class="icon-eye" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 5c5.5 0 9.4 5.1 9.84 5.7l.16.3-.16.3C21.4 11.9 17.5 17 12 17s-9.4-5.1-9.84-5.7L2 11l.16-.3C2.6 10.1 6.5 5 12 5zm0 2c-3.58 0-6.45 2.7-7.75 4C5.55 12.3 8.42 15 12 15s6.45-2.7 7.75-4C18.45 9.7 15.58 7 12 7zm0 1.5A2.5 2.5 0 1 1 9.5 11 2.5 2.5 0 0 1 12 8.5z" />
                                    </svg>

                                    <svg class="icon-eye-off" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3.28 2 22 20.72 20.72 22l-3.1-3.1A10.68 10.68 0 0 1 12 20C6.5 20 2.6 14.9 2.16 14.3L2 14l.16-.3a17.58 17.58 0 0 1 4.01-4.13L2 5.28 3.28 2zm4.31 8.99A14.25 14.25 0 0 0 4.25 14C5.55 15.3 8.42 18 12 18a8.28 8.28 0 0 0 4.08-1.08l-2.02-2.02A3.5 3.5 0 0 1 7.59 10.99zM12 8a3.5 3.5 0 0 1 3.5 3.5 3.45 3.45 0 0 1-.17 1.08L20.04 17.3A16.4 16.4 0 0 0 21.75 14C20.45 12.7 17.58 10 14 10a8.2 8.2 0 0 0-1.7.18L10.7 8.6A3.4 3.4 0 0 1 12 8z" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <div class="auth-field">
                            <label for="confirmarSenha">Confirmar nova senha</label>

                            <div class="auth-input-wrap">
                                <span class="auth-input-icon">
                                    <svg viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 2 4 5.2V11c0 5.05 3.4 9.75 8 11 4.6-1.25 8-5.95 8-11V5.2L12 2zm6 9c0 4-2.45 7.72-6 8.9C8.45 18.72 6 15 6 11V6.55l6-2.4 6 2.4V11zm-7.1 3.35 5.05-5.05 1.4 1.4-6.45 6.45-3.35-3.35 1.4-1.4 1.95 1.95z" />
                                    </svg>
                                </span>

                                <input
                                    type="password"
                                    id="confirmarSenha"
                                    name="confirmarSenha"
                                    placeholder="Repita a nova senha"
                                    autocomplete="new-password"
                                    minlength="3"
                                    required
                                >

                                <button
                                    type="button"
                                    class="auth-password-toggle"
                                    data-toggle-password="confirmarSenha"
                                    aria-label="Mostrar confirmação de senha"
                                >
                                    <svg class="icon-eye" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M12 5c5.5 0 9.4 5.1 9.84 5.7l.16.3-.16.3C21.4 11.9 17.5 17 12 17s-9.4-5.1-9.84-5.7L2 11l.16-.3C2.6 10.1 6.5 5 12 5zm0 2c-3.58 0-6.45 2.7-7.75 4C5.55 12.3 8.42 15 12 15s6.45-2.7 7.75-4C18.45 9.7 15.58 7 12 7zm0 1.5A2.5 2.5 0 1 1 9.5 11 2.5 2.5 0 0 1 12 8.5z" />
                                    </svg>

                                    <svg class="icon-eye-off" viewBox="0 0 24 24" aria-hidden="true">
                                        <path d="M3.28 2 22 20.72 20.72 22l-3.1-3.1A10.68 10.68 0 0 1 12 20C6.5 20 2.6 14.9 2.16 14.3L2 14l.16-.3a17.58 17.58 0 0 1 4.01-4.13L2 5.28 3.28 2zm4.31 8.99A14.25 14.25 0 0 0 4.25 14C5.55 15.3 8.42 18 12 18a8.28 8.28 0 0 0 4.08-1.08l-2.02-2.02A3.5 3.5 0 0 1 7.59 10.99zM12 8a3.5 3.5 0 0 1 3.5 3.5 3.45 3.45 0 0 1-.17 1.08L20.04 17.3A16.4 16.4 0 0 0 21.75 14C20.45 12.7 17.58 10 14 10a8.2 8.2 0 0 0-1.7.18L10.7 8.6A3.4 3.4 0 0 1 12 8z" />
                                    </svg>
                                </button>
                            </div>
                        </div>

                        <small class="auth-note" id="confirmarSenhaHint">
                            A confirmação precisa ser idêntica à nova senha informada acima.
                        </small>

                        <button type="submit" class="auth-submit">
                            <span>Salvar nova senha</span>
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M13.3 5.3 20 12l-6.7 6.7-1.4-1.4 4.3-4.3H4v-2h12.2l-4.3-4.3 1.4-1.4z" />
                            </svg>
                        </button>
                    </form>
                <% } else { %>
                    <div class="auth-card-header">
                        <span class="auth-card-icon auth-card-icon-danger">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 2a10 10 0 1 0 10 10A10.01 10.01 0 0 0 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z" />
                            </svg>
                        </span>

                        <div>
                            <h2>Link inválido</h2>
                            <p>Este link não é mais válido ou já expirou.</p>
                        </div>
                    </div>

                    <div class="auth-empty-state">
                        <p>
                            Solicite uma nova recuperação de senha para continuar
                            e receber um novo link de redefinição.
                        </p>

                        <a href="/recuperar-senha" class="auth-submit auth-link-button">
                            <span>Solicitar novo link</span>
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M13.3 5.3 20 12l-6.7 6.7-1.4-1.4 4.3-4.3H4v-2h12.2l-4.3-4.3 1.4-1.4z" />
                            </svg>
                        </a>
                    </div>
                <% } %>

                <p class="auth-register-text">
                    <a href="/login">Voltar para o login</a>
                </p>
            </div>

            <p class="auth-footer-note">
                VendMaster © <%= new Date().getFullYear() %> — Gestão simples para máquinas recreativas.
            </p>
        </section>
    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('[data-toggle-password]').forEach((button) => {
                button.addEventListener('click', () => {
                    const targetId = button.getAttribute('data-toggle-password');
                    const input = document.getElementById(targetId);

                    if (!input) return;

                    const isHidden = input.type === 'password';

                    input.type = isHidden ? 'text' : 'password';
                    button.classList.toggle('is-visible', isHidden);
                    button.setAttribute('aria-label', isHidden ? 'Ocultar senha' : 'Mostrar senha');
                });
            });

            const form = document.getElementById('resetPasswordForm');
            const senhaInput = document.getElementById('senha');
            const confirmarSenhaInput = document.getElementById('confirmarSenha');
            const hint = document.getElementById('confirmarSenhaHint');

            if (!form || !senhaInput || !confirmarSenhaInput || !hint) return;

            const syncPasswordValidation = () => {
                const senha = senhaInput.value;
                const confirmarSenha = confirmarSenhaInput.value;

                if (!confirmarSenha) {
                    confirmarSenhaInput.setCustomValidity('');
                    hint.textContent = 'A confirmação precisa ser idêntica à nova senha informada acima.';
                    hint.classList.remove('is-valid', 'is-invalid');
                    return;
                }

                if (senha !== confirmarSenha) {
                    confirmarSenhaInput.setCustomValidity('As senhas não conferem.');
                    hint.textContent = 'As senhas informadas estão diferentes.';
                    hint.classList.remove('is-valid');
                    hint.classList.add('is-invalid');
                    return;
                }

                confirmarSenhaInput.setCustomValidity('');
                hint.textContent = 'Confirmação de senha válida.';
                hint.classList.remove('is-invalid');
                hint.classList.add('is-valid');
            };

            senhaInput.addEventListener('input', syncPasswordValidation);
            confirmarSenhaInput.addEventListener('input', syncPasswordValidation);

            form.addEventListener('submit', (event) => {
                syncPasswordValidation();

                if (!form.checkValidity()) {
                    event.preventDefault();
                    form.reportValidity();
                }
            });
        });
    </script>

    <% if (success) { %>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                window.AppAlerts?.success(<%- JSON.stringify(success) %>);
            });
        </script>
    <% } %>

    <% if (error) { %>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                window.AppAlerts?.error(<%- JSON.stringify(error) %>, 'Redefinição de senha');
            });
        </script>
    <% } %>
</body>

</html>