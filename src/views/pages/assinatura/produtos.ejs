<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title }) %>

<body class="form-page-body">
  <%- include('../../partials/header') %>
  <div class="page-spacer"></div>

  <div class="form-shell form-shell-modern">
    <% const canManageProducts = assinante?.status_assinatura === 'trial'; %>

    <%- include('../../partials/breadcrumb', { pageTitle: 'Ferramentas da Assinatura' }) %>

    <section class="page-titlebar page-titlebar-neutral">
      <div class="page-titlebar-content">
        <span class="form-kicker">
          <i class="bi bi-grid-3x3-gap"></i>
          Assinatura
        </span>

        <h1>Ferramentas da assinatura</h1>

        <p>
          <% if (canManageProducts) { %>
            Durante o trial, escolha quais frentes deseja testar no VendMaster.
          <% } else { %>
            As ferramentas liberadas seguem o plano contratado e só podem ser alteradas mediante ajuste do plano.
          <% } %>
        </p>
      </div>

      <div class="page-titlebar-side">
        <div class="page-titlebar-stat">
          <strong>Ferramentas</strong>
          <span><%= assinante?.produtos_habilitados_lista?.length || 0 %> habilitada(s)</span>
        </div>
      </div>
    </section>

    <main class="form-stage">
      <form action="/assinatura/produtos" method="POST" class="modern-form" id="produtosAssinaturaForm">
        <section class="form-card">
          <div class="form-card-header">
            <div>
              <span class="form-section-tag">Configuração</span>
              <h2>Frentes que você opera</h2>
              <p>
                Essa seleção controla menus, atalhos, receitas por produto e filtros do sistema.
              </p>
            </div>
          </div>

          <div class="modern-checkbox-grid">
            <% const selectedProducts = assinante?.produtos_habilitados_lista || []; %>

            <% productOptions.forEach((produto) => { %>
              <label class="modern-checkbox <%= produto.className || '' %>" for="assinatura_produto_<%= produto.value %>">
                <input
                  class="form-check-input"
                  type="checkbox"
                  id="assinatura_produto_<%= produto.value %>"
                  name="produtos_habilitados"
                  value="<%= produto.value %>"
                  <%= selectedProducts.includes(produto.value) ? 'checked' : '' %>
                  <%= canManageProducts ? '' : 'disabled' %>
                >
                <span><%= produto.label %></span>
              </label>
            <% }) %>
          </div>

          <small class="modern-note">
            <% if (canManageProducts) { %>
              Se adicionar uma frente nova, depois marque essa ferramenta nos estabelecimentos em que ela existe.
            <% } else { %>
              Para incluir ou remover ferramentas, acesse sua assinatura ou fale com o suporte para ajustar o plano.
            <% } %>
          </small>
        </section>

        <section class="form-card assinatura-products-info-card">
          <div class="form-card-header">
            <div>
              <span class="form-section-tag">Plano e cobrança</span>
              <h2>Gerencie sua assinatura em uma tela separada</h2>
              <p>
                O status da assinatura, vencimento, dados de cobrança e opções de pagamento ficam centralizados na tela Minha assinatura.
              </p>
            </div>
          </div>

          <div class="assinatura-products-info-box">
            <i class="bi bi-person-badge"></i>
            <div>
              <strong>Precisa revisar pagamento ou dados de cobrança?</strong>
              <span>
                Acesse a tela de status da assinatura para regularizar pagamentos, revisar dados de cobrança ou acompanhar o plano atual.
              </span>
            </div>
          </div>

          <div class="assinatura-products-info-actions">
            <a href="/assinatura/status" class="btn-modern">
              <i class="bi bi-person-badge"></i>
              <span>Ir para minha assinatura</span>
            </a>
          </div>
        </section>

        <section class="form-actions-bar">
          <div class="form-actions-copy">
            <strong>Salvar configuração</strong>
            <span>
              <% if (canManageProducts) { %>
                Os menus serão atualizados a partir da próxima navegação.
              <% } else { %>
                As ferramentas atuais seguem o plano contratado.
              <% } %>
            </span>
          </div>

          <div class="form-actions-buttons">
            <a href="/painel" class="btn-modern-secondary">
              <i class="bi bi-arrow-left"></i>
              <span>Voltar</span>
            </a>

            <% if (canManageProducts) { %>
              <button type="submit" class="btn-modern">
                <i class="bi bi-check2-circle"></i>
                <span>Salvar ferramentas</span>
              </button>
            <% } %>
          </div>
        </section>
      </form>
    </main>
  </div>

  <style>
    .assinatura-products-info-card {
      overflow: hidden;
    }

    .assinatura-products-info-box {
      display: flex;
      align-items: flex-start;
      gap: 0.85rem;
      margin: 1rem 1.15rem 0;
      padding: 1rem;
      border: 1px solid rgba(37, 99, 235, 0.18);
      border-radius: 20px;
      background: #eff6ff;
      color: #1e3a8a;
    }

    .assinatura-products-info-box i {
      margin-top: 0.1rem;
      font-size: 1.2rem;
      color: #1d4ed8;
    }

    .assinatura-products-info-box strong {
      display: block;
      margin-bottom: 0.2rem;
      color: #1e3a8a;
      font-size: 0.98rem;
      font-weight: 900;
    }

    .assinatura-products-info-box span {
      display: block;
      color: #334155;
      font-size: 0.94rem;
      line-height: 1.5;
    }

    .assinatura-products-info-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      padding: 1rem 1.15rem 1.15rem;
    }

    @media (max-width: 640px) {
      .assinatura-products-info-box {
        margin: 1rem 1rem 0;
      }

      .assinatura-products-info-actions {
        padding: 1rem;
      }

      .assinatura-products-info-actions .btn-modern {
        width: 100%;
        justify-content: center;
      }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const produtosAssinaturaForm = document.getElementById('produtosAssinaturaForm');

      if (produtosAssinaturaForm) {
        produtosAssinaturaForm.addEventListener('submit', (event) => {
          const hasProduct = Array.from(document.querySelectorAll('input[name="produtos_habilitados"]'))
            .some((checkbox) => checkbox.checked);

          if (!hasProduct) {
            event.preventDefault();
            window.AppAlerts?.warning('Selecione pelo menos uma ferramenta para sua operação.');
          }
        });
      }

      <% if (success) { %>
        window.AppAlerts?.success("<%- String(success).replace(/"/g, '&quot;') %>");
      <% } %>

      <% if (error) { %>
        window.AppAlerts?.error("<%- String(error).replace(/"/g, '&quot;') %>");
      <% } %>
    });
  </script>
</body>
</html>