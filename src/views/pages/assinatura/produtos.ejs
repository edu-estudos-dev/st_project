<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title }) %>

<body class="form-page-body">
  <%- include('../../partials/header') %>
  <div class="page-spacer"></div>

  <div class="form-shell form-shell-modern">
    <% const canManageProducts = assinante?.status_assinatura === 'trial'; %>
    <% const hasBillingData = Boolean(assinante?.billing_nome && assinante?.billing_cpf_cnpj); %>

    <%- include('../../partials/breadcrumb', { pageTitle: 'Produtos da Operação' }) %>

    <section class="page-titlebar page-titlebar-neutral">
      <div class="page-titlebar-content">
        <span class="form-kicker"><i class="bi bi-grid-3x3-gap"></i> Assinatura</span>
        <h1>Produtos da operação</h1>
        <p>
          <% if (canManageProducts) { %>
            Durante o trial, ajuste quais frentes deseja testar no sistema.
          <% } else { %>
            As ferramentas liberadas seguem o plano contratado e são alteradas pelo administrador.
          <% } %>
        </p>
      </div>

      <div class="page-titlebar-side">
        <div class="page-titlebar-stat">
          <strong>Produtos</strong>
          <span><%= assinante?.produtos_habilitados_lista?.length || 0 %> habilitado(s)</span>
        </div>
      </div>
    </section>

    <main class="form-stage">
      <form action="/assinatura/produtos" method="POST" class="modern-form" id="produtosAssinaturaForm">
        <section class="form-card">
          <div class="form-card-header">
            <div>
              <span class="form-section-tag">Configuração</span>
              <h2>Frentes que você opera</h2>
              <p>Essa seleção controla menus, atalhos, receitas por produto e filtros do sistema.</p>
            </div>
          </div>

          <div class="modern-checkbox-grid">
            <% const selectedProducts = assinante?.produtos_habilitados_lista || []; %>
            <% productOptions.forEach((produto) => { %>
              <label class="modern-checkbox <%= produto.className || '' %>" for="assinatura_produto_<%= produto.value %>">
                <input
                  class="form-check-input"
                  type="checkbox"
                  id="assinatura_produto_<%= produto.value %>"
                  name="produtos_habilitados"
                  value="<%= produto.value %>"
                  <%= selectedProducts.includes(produto.value) ? 'checked' : '' %>
                  <%= canManageProducts ? '' : 'disabled' %>
                >
                <span><%= produto.label %></span>
              </label>
            <% }) %>
          </div>

          <small class="modern-note">
            <% if (canManageProducts) { %>
              Se adicionar uma frente nova, depois marque esse produto nos estabelecimentos em que ele existe.
            <% } else { %>
              Para incluir ou remover ferramentas, fale com o suporte para ajustar seu plano.
            <% } %>
          </small>
        </section>

        <section class="form-card">
          <div class="form-card-header">
            <div>
              <span class="form-section-tag">Cobrança</span>
              <h2>Dados de cobrança</h2>
              <p>
                Informe ou revise os dados que serão usados para preparar o pagamento da assinatura.
                Nenhuma cobrança real será criada enquanto o gateway não estiver configurado.
              </p>
            </div>
          </div>

          <div class="modern-note" id="billingStatusBox" style="display: block; margin-bottom: 1rem;">
            <strong>Status atual:</strong>
            <% if (hasBillingData) { %>
              dados de cobrança cadastrados.
            <% } else { %>
              dados de cobrança ainda pendentes.
            <% } %>
          </div>

          <div
            id="paymentPreparationResult"
            class="modern-note"
            style="display: none; margin-bottom: 1rem;"
          ></div>

          <div class="form-actions-buttons" style="justify-content: flex-start; gap: 0.75rem; flex-wrap: wrap;">
            <a href="/pagamentos/dados-cobranca/formulario" class="btn-modern">
              <i class="bi bi-credit-card-2-front"></i>
              <span>Preencher dados de cobrança</span>
            </a>

            <button
              type="button"
              class="btn-modern"
              id="prepararPagamentoBtn"
            >
              <i class="bi bi-shield-check"></i>
              <span>Preparar pagamento</span>
            </button>

            <a href="/assinatura/status" class="btn-modern-secondary assinatura-products-light-button">
              <i class="bi bi-person-badge"></i>
              <span>Status da assinatura</span>
            </a>
          </div>
        </section>

        <section class="form-actions-bar">
          <div class="form-actions-copy">
            <strong>Salvar configuração</strong>
            <span>Os menus serão atualizados a partir da próxima navegação.</span>
          </div>

          <div class="form-actions-buttons">
            <a href="/painel" class="btn-modern-secondary">
              <i class="bi bi-arrow-left"></i>
              <span>Voltar</span>
            </a>

            <% if (canManageProducts) { %>
              <button type="submit" class="btn-modern">
                <i class="bi bi-check2-circle"></i>
                <span>Salvar produtos</span>
              </button>
            <% } %>
          </div>
        </section>
      </form>
    </main>
  </div>

  <style>
    .assinatura-products-light-button {
      background: #fff;
      color: #1d4ed8;
      border: 1px solid rgba(37, 99, 235, 0.2);
    }

    @media (max-width: 640px) {
      .form-actions-buttons .assinatura-products-light-button {
        width: 100%;
        justify-content: center;
      }
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const produtosAssinaturaForm = document.getElementById('produtosAssinaturaForm');
      const prepararPagamentoBtn = document.getElementById('prepararPagamentoBtn');
      const paymentPreparationResult = document.getElementById('paymentPreparationResult');

      function setPaymentResult(message, type = 'info') {
        if (!paymentPreparationResult) return;

        const icons = {
          success: 'bi-check2-circle',
          warning: 'bi-exclamation-triangle',
          error: 'bi-x-circle',
          info: 'bi-info-circle'
        };

        paymentPreparationResult.style.display = 'block';
        paymentPreparationResult.innerHTML = `
          <strong>
            <i class="bi ${icons[type] || icons.info}"></i>
            Pagamento:
          </strong>
          ${message}
        `;
      }

      if (produtosAssinaturaForm) {
        produtosAssinaturaForm.addEventListener('submit', (event) => {
          const hasProduct = Array.from(document.querySelectorAll('input[name="produtos_habilitados"]'))
            .some((checkbox) => checkbox.checked);

          if (!hasProduct) {
            event.preventDefault();
            window.AppAlerts?.warning('Selecione pelo menos um produto para sua operação.');
          }
        });
      }

      if (prepararPagamentoBtn) {
        prepararPagamentoBtn.addEventListener('click', async () => {
          const originalButtonContent = prepararPagamentoBtn.innerHTML;

          prepararPagamentoBtn.disabled = true;
          prepararPagamentoBtn.innerHTML = `
            <i class="bi bi-hourglass-split"></i>
            <span>Preparando...</span>
          `;

          try {
            const response = await fetch('/pagamentos/iniciar', {
              method: 'POST',
              headers: {
                Accept: 'application/json'
              }
            });

            const data = await response.json().catch(() => ({
              success: false,
              message: 'Não foi possível interpretar a resposta do servidor.'
            }));

            if (!response.ok || !data.success) {
              const message = data.message || 'Não foi possível preparar o pagamento.';

              if (data.needsBillingData) {
                setPaymentResult(`${message} Clique em "Preencher dados de cobrança" antes de continuar.`, 'warning');
                window.AppAlerts?.warning(message);
                return;
              }

              setPaymentResult(message, 'error');
              window.AppAlerts?.error(message);
              return;
            }

            if (data.needsGatewayConfiguration) {
              const message = 'Dados de cobrança válidos. O gateway ainda não está configurado, então nenhuma cobrança real foi criada.';

              setPaymentResult(message, 'warning');
              window.AppAlerts?.warning(message);
              return;
            }

            const successMessage = data.message || 'Pagamento preparado com sucesso.';

            setPaymentResult(successMessage, 'success');
            window.AppAlerts?.success(successMessage);
          } catch (error) {
            console.error('Erro ao preparar pagamento:', error);

            const message = 'Erro ao preparar pagamento. Tente novamente em alguns instantes.';

            setPaymentResult(message, 'error');
            window.AppAlerts?.error(message);
          } finally {
            prepararPagamentoBtn.disabled = false;
            prepararPagamentoBtn.innerHTML = originalButtonContent;
          }
        });
      }

      <% if (success) { %>window.AppAlerts?.success("<%- String(success).replace(/"/g, '&quot;') %>");<% } %>
      <% if (error) { %>window.AppAlerts?.error("<%- String(error).replace(/"/g, '&quot;') %>");<% } %>
    });
  </script>
</body>
</html>