<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="csrf-token" content="<%= csrfToken || '' %>">

    <title>Recuperar senha - VendMaster</title>
    <meta name="description" content="Recupere o acesso à sua conta VendMaster com segurança para voltar a gerenciar sua operação.">
    <link rel="canonical" href="https://vendmaster.com.br/recuperar-senha">

    <link rel="stylesheet" href="/css/auth.css">

    <script defer src="/vendor/sweetalert2/sweetalert2.all.min.js"></script>
    <script defer src="/js/appAlerts.js"></script>
    <script defer src="/js/csrf.js"></script>
</head>

<body class="auth-body">
    <main class="auth-page">
        <section class="auth-brand-panel">
            <div class="auth-brand-content">
                <a href="/" class="auth-logo-link" aria-label="Voltar para a página inicial da VendMaster">
                    <img src="/images/logo.webp" alt="VendMaster" class="auth-logo-img">
                </a>

                <div class="auth-brand-copy">
                    <span class="auth-pill">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2l1.3 4.2L17.5 5 16.3 9.2 20 12l-3.7 2.8L17.5 19l-4.2-1.2L12 22l-1.3-4.2L6.5 19l1.2-4.2L4 12l3.7-2.8L6.5 5l4.2 1.2L12 2z" />
                        </svg>
                        Recuperação segura de acesso
                    </span>

                    <h1>Recupere sua senha com segurança.</h1>

                    <p>
                        Informe o e-mail cadastrado para receber o link de redefinição
                        e voltar a acessar sua operação no VendMaster.
                    </p>
                </div>

                <div class="auth-feature-grid">
                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M12 2 4 5.2V11c0 5.05 3.4 9.75 8 11 4.6-1.25 8-5.95 8-11V5.2L12 2zm6 9c0 4-2.45 7.72-6 8.9C8.45 18.72 6 15 6 11V6.55l6-2.4 6 2.4V11zm-7.1 3.35 5.05-5.05 1.4 1.4-6.45 6.45-3.35-3.35 1.4-1.4 1.95 1.95z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Segurança</strong>
                            <span>Redefinição protegida</span>
                        </div>
                    </div>

                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M3 5h18v14H3V5zm2 2v.35l7 4.38 7-4.38V7H5zm14 10V9.7l-7 4.38L5 9.7V17h14z" />
                            </svg>
                        </span>
                        <div>
                            <strong>E-mail</strong>
                            <span>Link enviado para você</span>
                        </div>
                    </div>

                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M17 9V7a5 5 0 0 0-10 0v2H5v13h14V9h-2zM9 7a3 3 0 0 1 6 0v2H9V7zm8 13H7v-9h10v9zm-5-2a1.5 1.5 0 0 0 1-2.62V14a1 1 0 0 0-2 0v1.38A1.5 1.5 0 0 0 12 18z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Nova senha</strong>
                            <span>Crie um novo acesso</span>
                        </div>
                    </div>

                    <div class="auth-feature-card">
                        <span class="auth-feature-icon">
                            <svg viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M13.3 5.3 20 12l-6.7 6.7-1.4-1.4 4.3-4.3H4v-2h12.2l-4.3-4.3 1.4-1.4z" />
                            </svg>
                        </span>
                        <div>
                            <strong>Acesso</strong>
                            <span>Volte para sua conta</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="auth-form-panel">
            <div class="auth-card">
                <div class="auth-card-header">
                    <span class="auth-card-icon">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2a7 7 0 0 0-7 7h2a5 5 0 1 1 1.46 3.54L6.9 11H11V9H3v8h2v-4.6l2.05 2.05A7 7 0 1 0 12 2zm1 7h-2v4.4l3.3 3.3 1.4-1.4-2.7-2.7V9z" />
                        </svg>
                    </span>

                    <div>
                        <h2>Recuperar senha</h2>
                        <p>Digite o e-mail cadastrado para receber o link de redefinição.</p>
                    </div>
                </div>

                <form action="/recuperar-senha" method="POST" class="auth-form" autocomplete="on">
                    <div class="auth-field">
                        <label for="email">E-mail cadastrado</label>

                        <div class="auth-input-wrap">
                            <span class="auth-input-icon">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M3 5h18v14H3V5zm2 2v.35l7 4.38 7-4.38V7H5zm14 10V9.7l-7 4.38L5 9.7V17h14z" />
                                </svg>
                            </span>

                            <input
                                type="email"
                                id="email"
                                name="email"
                                placeholder="Digite seu e-mail"
                                autocomplete="email"
                                value="<%= formData?.email || '' %>"
                                required
                            >
                        </div>

                        <small class="auth-note">
                            Enviaremos um link para você criar uma nova senha com segurança.
                        </small>
                    </div>

                    <button type="submit" class="auth-submit">
                        <span>Enviar link de redefinição</span>
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M13.3 5.3 20 12l-6.7 6.7-1.4-1.4 4.3-4.3H4v-2h12.2l-4.3-4.3 1.4-1.4z" />
                        </svg>
                    </button>
                </form>

                <% if (previewLink) { %>
                    <div class="auth-local-preview">
                        <strong>Ambiente local:</strong>
                        <span>Use este link para continuar a redefinição.</span>
                        <a href="<%= previewLink %>"><%= previewLink %></a>
                    </div>
                <% } %>

                <p class="auth-register-text">
                    Lembrou sua senha?
                    <a href="/login">Voltar para o login</a>
                </p>
            </div>

            <p class="auth-footer-note">
                VendMaster © <%= new Date().getFullYear() %> — Gestão simples para máquinas recreativas.
            </p>
        </section>
    </main>

    <% if (success) { %>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                window.AppAlerts?.success(<%- JSON.stringify(success) %>);
            });
        </script>
    <% } %>

    <% if (error) { %>
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                window.AppAlerts?.error(<%- JSON.stringify(error) %>, 'Falha na recuperação');
            });
        </script>
    <% } %>
</body>

</html>
