<!DOCTYPE html>
<html lang="pt-br">
<%- include('../partials/head', { title: 'Fluxo de Caixa' }) %>

<body class="list-page-body">
    <%- include('../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell">
        <%- include('../partials/breadcrumb', { pageTitle: 'Fluxo de Caixa' }) %>

        <section class="list-hero list-hero-neutral">
            <div class="list-hero-content">
                <span class="list-kicker"><i class="bi bi-graph-up-arrow"></i> Financeiro</span>
                <h1>Fluxo de caixa anual</h1>
                <p>Uma visao mais organizada do desempenho mensal, com resultados, entradas e saidas em uma tabela ampla, moderna e facil de ler.</p>
            </div>
            <div class="list-hero-side">
                <div class="list-stat"><strong>Ano</strong><span><%= year %></span></div>
                <div class="list-stat"><strong>Visao</strong><span>Consolidado mensal do negocio</span></div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <div class="list-toolbar">
                    <div class="list-toolbar-copy">
                        <h2>Resumo financeiro de <%= year %></h2>
                        <p>Altere o ano para comparar rapidamente a evolucao mensal de entradas, saidas e resultado acumulado.</p>
                    </div>
                    <div style="min-width:220px;">
                        <label for="anoInput" class="form-label">Ano para a pesquisa</label>
                        <input type="number" id="anoInput" class="form-control text-center" value="<%= year %>" onchange="atualizarAno()">
                    </div>
                </div>

                <div class="modern-table-wrap">
                    <div class="modern-table-scroll">
                        <table id="fluxoDeCaixaTable" class="modern-table">
                            <thead>
                                <tr>
                                    <th>Resultado atual</th>
                                    <th>Janeiro</th>
                                    <th>Fevereiro</th>
                                    <th>Marco</th>
                                    <th>Abril</th>
                                    <th>Maio</th>
                                    <th>Junho</th>
                                    <th>Julho</th>
                                    <th>Agosto</th>
                                    <th>Setembro</th>
                                    <th>Outubro</th>
                                    <th>Novembro</th>
                                    <th>Dezembro</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <%
                                    const currentMonth = new Date().getMonth();
                                    let somaTotalAnualCorrente = 0;
                                    for (let i = 0; i <= currentMonth; i++) {
                                        somaTotalAnualCorrente += somaMensal[i] || 0;
                                    }
                                    %>
                                    <td><span class="table-badge <%= somaTotalAnualCorrente >= 0 ? 'table-badge-green' : 'table-badge-danger' %>"><%= somaTotalAnualCorrente.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></span></td>
                                    <% somaMensal.forEach(function(total) { %>
                                        <td><strong style="color:<%= total > 0 ? '#15803d' : (total < 0 ? '#b91c1c' : '#0f172a') %>;"><%= total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></strong></td>
                                    <% }) %>
                                </tr>

                                <tr>
                                    <td class="table-title-cell">Total entradas</td>
                                    <% totaisEntradas.forEach(function(total) { %>
                                        <td><strong style="color:#15803d;"><%= total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></strong></td>
                                    <% }) %>
                                </tr>
                                <% for (let tipo in dadosEntradas) { %>
                                    <tr>
                                        <td><span class="table-muted"><%= tipo %></span></td>
                                        <% for (let i = 0; i < 12; i++) { %>
                                            <td style="color:#16a34a;"><%= dadosEntradas[tipo][i].toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></td>
                                        <% } %>
                                    </tr>
                                <% } %>

                                <tr>
                                    <td class="table-title-cell">Total saidas</td>
                                    <% totaisSaidas.forEach(function(total) { %>
                                        <td><strong style="color:#dc2626;"><%= total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></strong></td>
                                    <% }) %>
                                </tr>
                                <% for (let tipo in dadosSaidas) { %>
                                    <tr>
                                        <td><span class="table-muted"><%= tipo %></span></td>
                                        <% for (let i = 0; i < 12; i++) { %>
                                            <td style="color:#dc2626;"><%= dadosSaidas[tipo][i].toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></td>
                                        <% } %>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
    function atualizarAno() {
        const ano = document.getElementById('anoInput').value;
        window.location.href = `/fluxo-de-caixa?year=${ano}`;
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('anoInput').addEventListener('change', atualizarAno);
    });
    </script>
</body>
</html>
