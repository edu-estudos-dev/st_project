<!DOCTYPE html>
<html lang="pt-br">
<%- include('../partials/head', { title: 'Fluxo de Caixa' }) %>

<body class="list-page-body">
    <%- include('../partials/header') %>
    <div class="page-spacer"></div>

    <%
    const mesesFluxoCaixa = [
        { nome: 'Janeiro', curto: 'Jan', semestre: 1 },
        { nome: 'Fevereiro', curto: 'Fev', semestre: 1 },
        { nome: 'Março', curto: 'Mar', semestre: 1 },
        { nome: 'Abril', curto: 'Abr', semestre: 1 },
        { nome: 'Maio', curto: 'Mai', semestre: 1 },
        { nome: 'Junho', curto: 'Jun', semestre: 1 },
        { nome: 'Julho', curto: 'Jul', semestre: 2 },
        { nome: 'Agosto', curto: 'Ago', semestre: 2 },
        { nome: 'Setembro', curto: 'Set', semestre: 2 },
        { nome: 'Outubro', curto: 'Out', semestre: 2 },
        { nome: 'Novembro', curto: 'Nov', semestre: 2 },
        { nome: 'Dezembro', curto: 'Dez', semestre: 2 }
    ];

    const currentMonth = typeof resultadoAteMesIndex !== 'undefined' ? resultadoAteMesIndex : new Date().getMonth();

    let somaTotalAnualCorrente = 0;
    for (let i = 0; i <= currentMonth; i++) {
        somaTotalAnualCorrente += somaMensal[i] || 0;
    }

    const totalEntradasAno = totaisEntradas.reduce((acc, valor) => acc + (Number(valor) || 0), 0);
    const totalSaidasAno = totaisSaidas.reduce((acc, valor) => acc + (Number(valor) || 0), 0);
    const resultadoAno = totalEntradasAno - totalSaidasAno;

    const formatarMoeda = (valor) => {
        return (Number(valor) || 0).toLocaleString('pt-BR', {
            style: 'currency',
            currency: 'BRL'
        });
    };

    const classeValor = (valor) => {
        if ((Number(valor) || 0) > 0) return 'is-positive';
        if ((Number(valor) || 0) < 0) return 'is-negative';
        return 'is-neutral';
    };
    %>

    <div class="list-shell fluxo-caixa-shell" data-semestre="1">
        <%- include('../partials/breadcrumb', { pageTitle: 'Fluxo de Caixa' }) %>

        <section class="page-titlebar page-titlebar-neutral fluxo-caixa-titlebar">
            <div class="page-titlebar-content">
                <span class="list-kicker"><i class="bi bi-graph-up-arrow"></i> Financeiro</span>
                <h1>Fluxo de caixa anual</h1>
                <p>Confira entradas, saídas e resultado mensal em uma visão separada por semestre, sem precisar arrastar a tabela para o lado.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="list-stat">
                    <strong>Ano</strong>
                    <span><%= year %></span>
                </div>

                <div class="list-stat">
                    <strong>Resultado atual</strong>
                    <span class="<%= classeValor(somaTotalAnualCorrente) %>"><%= formatarMoeda(somaTotalAnualCorrente) %></span>
                </div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel fluxo-caixa-panel">
                <div class="fluxo-caixa-summary-grid">
                    <article class="fluxo-caixa-summary-card fluxo-caixa-summary-card-positive">
                        <span>Total de entradas</span>
                        <strong><%= formatarMoeda(totalEntradasAno) %></strong>
                        <small>Soma das receitas registradas no ano.</small>
                    </article>

                    <article class="fluxo-caixa-summary-card fluxo-caixa-summary-card-negative">
                        <span>Total de saídas</span>
                        <strong><%= formatarMoeda(totalSaidasAno) %></strong>
                        <small>Soma das despesas registradas no ano.</small>
                    </article>

                    <article class="fluxo-caixa-summary-card <%= resultadoAno >= 0 ? 'fluxo-caixa-summary-card-result-positive' : 'fluxo-caixa-summary-card-result-negative' %>">
                        <span>Resultado anual</span>
                        <strong><%= formatarMoeda(resultadoAno) %></strong>
                        <small>Entradas menos saídas no período.</small>
                    </article>
                </div>

                <div class="fluxo-caixa-toolbar">
                    <div class="fluxo-caixa-toolbar-copy">
                        <span class="form-section-tag">Resumo mensal</span>
                        <h2>Fluxo financeiro de <%= year %></h2>
                        <p>Use o seletor para alternar entre o primeiro e o segundo semestre mantendo a leitura limpa e sem rolagem lateral.</p>
                    </div>

                    <div class="fluxo-caixa-toolbar-actions">
                        <div class="fluxo-caixa-year-field">
                            <label for="anoInput" class="form-label">Ano da consulta</label>
                            <input type="number" id="anoInput" class="form-control text-center" value="<%= year %>">
                        </div>

                        <div class="fluxo-caixa-mode-switch" role="group" aria-label="Selecionar semestre">
                            <button type="button" class="fluxo-caixa-mode-btn is-active" data-semestre-target="1">
                                1º semestre
                            </button>
                            <button type="button" class="fluxo-caixa-mode-btn" data-semestre-target="2">
                                2º semestre
                            </button>
                        </div>
                    </div>
                </div>

                <div class="fluxo-caixa-table-wrap">
                    <div class="fluxo-caixa-table-scroll">
                        <table id="fluxoDeCaixaTable" class="modern-table fluxo-caixa-table">
                            <thead>
                                <tr>
                                    <th class="fluxo-caixa-col-category">Indicador</th>
                                    <% mesesFluxoCaixa.forEach(function(mes) { %>
                                        <th class="fluxo-caixa-col-month fc-semestre-<%= mes.semestre %>"><%= mes.nome %></th>
                                    <% }) %>
                                </tr>
                            </thead>

                            <tbody>
                                <tr class="fluxo-caixa-row fluxo-caixa-row-balance">
                                    <td data-label="Indicador" class="fluxo-caixa-category-cell">
                                        <span class="fluxo-caixa-row-kicker">Resultado</span>
                                        <strong>Resultado mensal</strong>
                                    </td>

                                    <% somaMensal.forEach(function(total, index) { 
                                        const mes = mesesFluxoCaixa[index];
                                    %>
                                        <td data-label="<%= mes.curto %>" class="fluxo-caixa-value-cell fc-semestre-<%= mes.semestre %>">
                                            <span class="fluxo-caixa-value <%= classeValor(total) %>">
                                                <%= formatarMoeda(total) %>
                                            </span>
                                        </td>
                                    <% }) %>
                                </tr>

                                <tr class="fluxo-caixa-row fluxo-caixa-row-entry-total">
                                    <td data-label="Indicador" class="fluxo-caixa-category-cell">
                                        <span class="fluxo-caixa-row-kicker">Entradas</span>
                                        <strong>Total entradas</strong>
                                    </td>

                                    <% totaisEntradas.forEach(function(total, index) { 
                                        const mes = mesesFluxoCaixa[index];
                                    %>
                                        <td data-label="<%= mes.curto %>" class="fluxo-caixa-value-cell fc-semestre-<%= mes.semestre %>">
                                            <span class="fluxo-caixa-value is-positive">
                                                <%= formatarMoeda(total) %>
                                            </span>
                                        </td>
                                    <% }) %>
                                </tr>

                                <% for (let tipo in dadosEntradas) { %>
                                    <tr class="fluxo-caixa-row fluxo-caixa-row-entry-detail">
                                        <td data-label="Indicador" class="fluxo-caixa-category-cell fluxo-caixa-category-muted">
                                            <strong><%= tipo %></strong>
                                        </td>

                                        <% for (let i = 0; i < 12; i++) { 
                                            const mes = mesesFluxoCaixa[i];
                                        %>
                                            <td data-label="<%= mes.curto %>" class="fluxo-caixa-value-cell fc-semestre-<%= mes.semestre %>">
                                                <span class="fluxo-caixa-value is-positive-soft">
                                                    <%= formatarMoeda(dadosEntradas[tipo][i]) %>
                                                </span>
                                            </td>
                                        <% } %>
                                    </tr>
                                <% } %>

                                <tr class="fluxo-caixa-row fluxo-caixa-row-exit-total">
                                    <td data-label="Indicador" class="fluxo-caixa-category-cell">
                                        <span class="fluxo-caixa-row-kicker">Saídas</span>
                                        <strong>Total saídas</strong>
                                    </td>

                                    <% totaisSaidas.forEach(function(total, index) { 
                                        const mes = mesesFluxoCaixa[index];
                                    %>
                                        <td data-label="<%= mes.curto %>" class="fluxo-caixa-value-cell fc-semestre-<%= mes.semestre %>">
                                            <span class="fluxo-caixa-value is-negative">
                                                <%= formatarMoeda(total) %>
                                            </span>
                                        </td>
                                    <% }) %>
                                </tr>

                                <% for (let tipo in dadosSaidas) { %>
                                    <tr class="fluxo-caixa-row fluxo-caixa-row-exit-detail">
                                        <td data-label="Indicador" class="fluxo-caixa-category-cell fluxo-caixa-category-muted">
                                            <strong><%= tipo %></strong>
                                        </td>

                                        <% for (let i = 0; i < 12; i++) { 
                                            const mes = mesesFluxoCaixa[i];
                                        %>
                                            <td data-label="<%= mes.curto %>" class="fluxo-caixa-value-cell fc-semestre-<%= mes.semestre %>">
                                                <span class="fluxo-caixa-value is-negative-soft">
                                                    <%= formatarMoeda(dadosSaidas[tipo][i]) %>
                                                </span>
                                            </td>
                                        <% } %>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script nonce="<%= cspNonce || '' %>" src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script nonce="<%= cspNonce || '' %>">
    function atualizarAno() {
        const anoInput = document.getElementById('anoInput');
        const ano = anoInput.value;

        if (!ano) {
            return;
        }

        window.location.href = `/fluxo-de-caixa?year=${ano}`;
    }

    document.addEventListener('DOMContentLoaded', () => {
        const shell = document.querySelector('.fluxo-caixa-shell');
        const anoInput = document.getElementById('anoInput');
        const semestreButtons = document.querySelectorAll('[data-semestre-target]');

        anoInput?.addEventListener('change', atualizarAno);

        semestreButtons.forEach((button) => {
            button.addEventListener('click', () => {
                const semestre = button.dataset.semestreTarget;

                shell.dataset.semestre = semestre;

                semestreButtons.forEach((item) => {
                    item.classList.toggle('is-active', item === button);
                });
            });
        });
    });
    </script>
</body>
</html>