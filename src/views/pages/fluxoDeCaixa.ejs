<!DOCTYPE html>
<html lang="pt-br">
<%- include('../partials/head', { title: 'Fluxo de Caixa' }) %>

<body class="bg-light">
    <%- include('../partials/header') %>

    <div class="page-spacer"></div>

    <div class="page-shell py-3">
        <%- include('../partials/breadcrumb', { pageTitle: 'Fluxo de Caixa' }) %>

        <main class="geral">
            <div class="filter-toolbar mb-3">
                <div>
                    <h1 class="mb-0 fw-bold">Fluxo de Caixa Anual - <%= year %></h1>
                </div>
                <div>
                    <label for="anoInput" class="form-label">Ano para a pesquisa</label>
                    <input type="number" id="anoInput" class="form-control text-center" value="<%= year %>" onchange="atualizarAno()">
                </div>
            </div>

            <div class="table-container">
                <table id="fluxoDeCaixaTable" class="table table-bordered table-hover m-0 align-middle">
                    <thead>
                        <tr>
                            <th>RESULTADO ATUAL</th>
                            <th>Janeiro</th>
                            <th>Fevereiro</th>
                            <th>Marco</th>
                            <th>Abril</th>
                            <th>Maio</th>
                            <th>Junho</th>
                            <th>Julho</th>
                            <th>Agosto</th>
                            <th>Setembro</th>
                            <th>Outubro</th>
                            <th>Novembro</th>
                            <th>Dezembro</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <%
                            const currentMonth = new Date().getMonth();
                            let somaTotalAnualCorrente = 0;
                            for (let i = 0; i <= currentMonth; i++) {
                                somaTotalAnualCorrente += somaMensal[i] || 0;
                            }
                            let className = somaTotalAnualCorrente >= 0 ? 'highlight-positive' : 'highlight-negative';
                            %>
                            <td class="currency <%= className %>"><%= somaTotalAnualCorrente.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></td>
                            <% somaMensal.forEach(function(total) { %>
                                <td class="currency <%= total > 0 ? 'text-success bold' : (total < 0 ? 'text-danger bold' : 'text-black') %>"><%= total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></td>
                            <% }) %>
                        </tr>

                        <tr class="table-success total-entradas">
                            <td class="fw-bold">TOTAL ENTRADAS</td>
                            <% totaisEntradas.forEach(function(total) { %>
                                <td class="currency text-success bold"><%= total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></td>
                            <% }) %>
                        </tr>
                        <% for (let tipo in dadosEntradas) { %>
                            <tr>
                                <td><%= tipo %></td>
                                <% for (let i = 0; i < 12; i++) { %>
                                    <td class="currency text-success"><%= dadosEntradas[tipo][i].toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></td>
                                <% } %>
                            </tr>
                        <% } %>

                        <tr class="table-danger total-saidas">
                            <td class="fw-bold">TOTAL SAIDAS</td>
                            <% totaisSaidas.forEach(function(total) { %>
                                <td class="currency text-danger bold"><%= total.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></td>
                            <% }) %>
                        </tr>
                        <% for (let tipo in dadosSaidas) { %>
                            <tr>
                                <td><%= tipo %></td>
                                <% for (let i = 0; i < 12; i++) { %>
                                    <td class="currency text-danger"><%= dadosSaidas[tipo][i].toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></td>
                                <% } %>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
    function atualizarAno() {
        const ano = document.getElementById('anoInput').value;
        window.location.href = `/fluxo-de-caixa?year=${ano}`;
    }

    document.addEventListener('DOMContentLoaded', () => {
        document.getElementById('anoInput').addEventListener('change', atualizarAno);
    });
    </script>
</body>
</html>
