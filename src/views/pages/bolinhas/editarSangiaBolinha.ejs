<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Editar Sangria de Bolinhas' }) %>

<body class="form-page-body">
    <%- include('../../partials/header') %>

    <div class="page-spacer"></div>

    <div class="form-shell form-shell-modern bolinhas-form-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Editar Sangria de Bolinhas' }) %>

        <section class="page-titlebar page-titlebar-green bolinhas-titlebar">
            <div class="page-titlebar-content">
                <span class="form-kicker">
                    <i class="bi bi-pencil-square"></i>
                    Operacional
                </span>
                <h1>Editar sangria de bolinhas</h1>
                <p>Revise os dados da coleta, atualize os valores e confirme as informações antes de salvar.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="page-titlebar-stat">
                    <strong>Produto</strong>
                    <span>Bolinhas</span>
                </div>
                <div class="page-titlebar-stat">
                    <strong>Registro</strong>
                    <span>ID <%= sangria.id %></span>
                </div>
            </div>
        </section>

        <main class="form-stage">
            <form action="/bolinhas/sangrias/edit" method="POST" class="modern-form bolinhas-form">
                <input type="hidden" name="id" value="<%= sangria.id %>">

                <section class="form-card bolinhas-visit-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Visita</span>
                            <h2>Informações da coleta</h2>
                            <p>Atualize o estabelecimento, a data e a forma de pagamento vinculados a esta sangria.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <label for="estabelecimento">Estabelecimento</label>
                            <select class="form-select" id="estabelecimento" name="estabelecimento_id" required>
                                <% estabelecimentos.forEach(function(estabelecimento) { %>
                                    <option value="<%= estabelecimento.id %>" <%= estabelecimento.id === sangria.estabelecimento_id ? 'selected' : '' %>>
                                        <%= estabelecimento.estabelecimento %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="data_sangria">Data da sangria</label>
                            <input type="date" class="form-control text-center" id="data_sangria" name="data_sangria" value="<%= new Date(sangria.data_sangria).toISOString().substring(0, 10) %>" required>
                        </div>

                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="tipo_pagamento">Tipo de pagamento</label>
                            <select class="form-select" id="tipo_pagamento" name="tipo_pagamento" required>
                                <option value="especie" <%= sangria.tipo_pagamento === 'especie' ? 'selected' : '' %>>Espécie</option>
                                <option value="pix" <%= sangria.tipo_pagamento === 'pix' ? 'selected' : '' %>>PIX</option>
                            </select>
                        </div>
                    </div>
                </section>

                <section class="form-card bolinhas-values-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Financeiro</span>
                            <h2>Valores da sangria</h2>
                            <p>Ao editar valor apurado e comissão, os valores do comerciante e líquido são recalculados automaticamente.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-xl-3">
                            <label for="valor_apurado">Valor apurado</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input type="number" step="0.01" min="0" class="form-control text-center" id="valor_apurado" name="valor_apurado" value="<%= sangria.valor_apurado %>" required>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <label for="comissao">Comissão (%)</label>
                            <div class="input-group">
                                <span class="input-group-text">%</span>
                                <input type="number" step="0.01" min="0" max="100" class="form-control text-center" id="comissao" name="comissao" value="<%= sangria.comissao %>" required>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <label for="valor_comerciante">Valor do comerciante</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input type="number" step="0.01" class="form-control text-center readonly-input" id="valor_comerciante" name="valor_comerciante" value="<%= sangria.valor_comerciante %>" readonly disabled>
                            </div>
                        </div>

                        <div class="col-12 col-md-6 col-xl-3">
                            <label for="valor_liquido">Valor líquido</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input type="number" step="0.01" class="form-control text-center readonly-input" id="valor_liquido" name="valor_liquido" value="<%= sangria.valor_liquido %>" readonly disabled>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Observações</span>
                            <h2>Anotações da visita</h2>
                            <p>Atualize as observações se precisar deixar mais contexto sobre o atendimento ou a coleta.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label for="observacoes">Observações</label>
                            <textarea class="form-control" id="observacoes" name="observacoes" rows="5"><%= sangria.observacoes %></textarea>
                        </div>
                    </div>
                </section>

                <section class="form-actions-bar bolinhas-actions-bar">
                    <div class="form-actions-copy">
                        <strong>Conferência final</strong>
                        <span>Revise os valores e confirme a atualização desta sangria de bolinhas.</span>
                    </div>

                    <div class="form-actions-buttons">
                        <a href="/bolinhas/sangrias" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Cancelar</span>
                        </a>
                        <button type="submit" class="btn-modern">
                            <i class="bi bi-check2-circle"></i>
                            <span>Atualizar sangria</span>
                        </button>
                    </div>
                </section>
            </form>
        </main>
    </div>

    <script nonce="<%= cspNonce || '' %>" src="/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script nonce="<%= cspNonce || '' %>">
        function calculateValues() {
            const valorApurado = parseFloat(document.getElementById('valor_apurado').value) || 0;
            const comissao = parseFloat(document.getElementById('comissao').value) || 0;
            const valorDaComissao = valorApurado * (comissao / 100);
            const valorComerciante = valorDaComissao;
            const valorLiquido = valorApurado - valorComerciante;

            document.getElementById('valor_comerciante').value = valorComerciante.toFixed(2);
            document.getElementById('valor_liquido').value = valorLiquido.toFixed(2);
        }

        function validarSangriaBolinhas(event) {
            const valorApurado = Number(document.getElementById('valor_apurado').value);
            const comissao = Number(document.getElementById('comissao').value);

            if (!Number.isFinite(valorApurado) || valorApurado < 0) {
                event.preventDefault();
                window.AppAlerts?.error('Valor apurado deve ser um número válido e não negativo.');
                return false;
            }

            if (!Number.isFinite(comissao) || comissao < 0 || comissao > 100) {
                event.preventDefault();
                window.AppAlerts?.error('Comissão deve estar entre 0 e 100%.');
                return false;
            }

            return true;
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.querySelector('.bolinhas-form')?.addEventListener('submit', validarSangriaBolinhas);

            ['valor_apurado', 'comissao'].forEach((fieldId) => {
                document.getElementById(fieldId)?.addEventListener('input', calculateValues);
            });

            calculateValues();
        });
    </script>
</body>
</html>
