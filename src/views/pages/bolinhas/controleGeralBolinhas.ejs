<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Controle Geral Bolinhas' }) %>

<body class="bg-light">
    <%- include('../../partials/header') %>

    <div class="page-spacer"></div>

    <div class="page-shell py-3">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Controle Geral Bolinhas', usuario: usuario }) %>

        <div class="cabecalho-bolinha">
            <h1 class="mb-0">Controle Geral Bolinhas</h1>
        </div>

        <main class="bolinha">
            <form id="controleGeralForm" class="mb-4">
                <div class="filter-toolbar">
                    <div>
                        <label for="bairroSelect" class="form-label fw-bold">Bairro</label>
                        <select class="form-select text-center fw-bold" id="bairroSelect" name="bairro" required onchange="filtrarPorBairro()">
                            <option value="" selected disabled hidden>Selecione um bairro para criar a rota</option>
                            <option value="mostrar_todos">Mostrar todos a sangrar</option>
                            <%
                            const diasSangria = 7;
                            const bairrosSangria = new Set();
                            estabelecimentos.forEach(function(estabelecimento) {
                                const data = new Date(estabelecimento.data);
                                const hoje = new Date();
                                const diferencaDias = Math.floor((hoje - data) / (1000 * 60 * 60 * 24));
                                if (diferencaDias > diasSangria) {
                                    bairrosSangria.add(estabelecimento.bairro);
                                }
                            });
                            bairrosSangria.forEach(function(bairro) {
                            %>
                                <option value="<%= bairro %>"><%= bairro %></option>
                            <% }); %>
                        </select>
                    </div>

                    <div>
                        <label for="diasSangria" class="form-label fw-bold">Dias para fazer a sangria</label>
                        <input type="number" class="form-control text-center fw-bold" id="diasSangria" name="diasSangria" required oninput="salvarDiasSangria()">
                    </div>

                    <div class="toolbar-actions">
                        <button type="button" class="btn btn-secondary" onclick="mostrarTodos()">Mostrar Todos</button>
                        <button type="button" class="btn btn-warning" onclick="gerarPDF()">Gerar PDF</button>
                    </div>
                </div>
            </form>

            <div class="table-container">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead>
                        <tr>
                            <th><input type="checkbox" id="selectAll" onclick="selecionarTodos(this)"></th>
                            <th>ID</th>
                            <th>Estabelecimento</th>
                            <th>Chave</th>
                            <th>Maquina</th>
                            <th>Endereco</th>
                            <th>Bairro</th>
                            <th>Data</th>
                            <th>Dias Passados</th>
                            <th>Situacao</th>
                            <th>Telefone de Contato</th>
                        </tr>
                    </thead>
                    <tbody id="tabelaEstabelecimentos">
                        <% estabelecimentos.forEach(function(estabelecimento) {
                            const data = new Date(estabelecimento.data);
                            const hoje = new Date();
                            const diferencaDias = Math.floor((hoje - data) / (1000 * 60 * 60 * 24));
                        %>
                        <tr data-diferenca-dias="<%= diferencaDias %>" data-bairro="<%= estabelecimento.bairro %>">
                            <td><input type="checkbox" class="checkbox-selecao" id="checkbox_<%= estabelecimento.id %>"></td>
                            <td><%= estabelecimento.id %></td>
                            <td><label for="checkbox_<%= estabelecimento.id %>"><%= estabelecimento.estabelecimento %></label></td>
                            <td><%= estabelecimento.chave %></td>
                            <td><%= estabelecimento.maquina %></td>
                            <td><%= estabelecimento.endereco %></td>
                            <td><%= estabelecimento.bairro %></td>
                            <td><%= data.toLocaleDateString() %></td>
                            <td class="dias-passados"><%= diferencaDias %></td>
                            <td class="situacao"></td>
                            <td><%= estabelecimento.telefone_contato %></td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.4.0/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.23/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>

    <script>
    function salvarDiasSangria() {
        const diasSangria = document.getElementById('diasSangria').value;
        localStorage.setItem('diasSangria', diasSangria);
        atualizarSituacao();
    }

    function carregarDiasSangria() {
        const diasSangria = localStorage.getItem('diasSangria');
        if (diasSangria !== null) {
            document.getElementById('diasSangria').value = diasSangria;
        }
        atualizarSituacao();
    }

    function atualizarSituacao() {
        const diasSangria = parseInt(document.getElementById('diasSangria').value, 10) || 0;
        const linhas = document.querySelectorAll('#tabelaEstabelecimentos tr');
        linhas.forEach(linha => {
            const diferencaDias = parseInt(linha.getAttribute('data-diferenca-dias'), 10);
            const situacaoCelula = linha.querySelector('.situacao');
            if (diferencaDias > diasSangria) {
                situacaoCelula.textContent = 'SANGRIA';
                linha.classList.add('table-danger');
            } else {
                situacaoCelula.textContent = 'AGUARDAR';
                linha.classList.remove('table-danger');
            }
        });
    }

    function filtrarPorBairro() {
        const select = document.getElementById('bairroSelect');
        const bairroSelecionado = select.value;
        const linhas = document.querySelectorAll('#tabelaEstabelecimentos tr');

        linhas.forEach(linha => {
            const bairro = linha.getAttribute('data-bairro');
            const situacaoCelula = linha.querySelector('.situacao').textContent;
            if (bairroSelecionado === 'mostrar_todos' && situacaoCelula === 'SANGRIA') {
                linha.style.display = '';
            } else if (bairroSelecionado !== 'mostrar_todos' && bairro === bairroSelecionado && situacaoCelula === 'SANGRIA') {
                linha.style.display = '';
            } else {
                linha.style.display = 'none';
            }
        });
    }

    function mostrarTodos() {
        const linhas = document.querySelectorAll('#tabelaEstabelecimentos tr');
        linhas.forEach(linha => {
            linha.style.display = '';
        });
    }

    function selecionarTodos(selectAllCheckbox) {
        const checkboxes = document.querySelectorAll('.checkbox-selecao');
        checkboxes.forEach(checkbox => {
            checkbox.checked = selectAllCheckbox.checked;
        });
    }

    function gerarPDF() {
        const { jsPDF } = window.jspdf;
        if (!jsPDF) {
            return;
        }

        const doc = new jsPDF();
        const tabela = document.getElementById('tabelaEstabelecimentos');
        if (!tabela) {
            return;
        }

        const linhas = tabela.querySelectorAll('tr');
        const data = [];
        const bairros = new Set();
        let algumMarcado = false;

        linhas.forEach(linha => {
            if (linha.style.display !== 'none' && linha.querySelector('.checkbox-selecao').checked) {
                const cells = Array.from(linha.children);
                data.push([
                    cells[2].innerText,
                    cells[5].innerText,
                    cells[3].innerText,
                    cells[4].innerText,
                    cells[6].innerText,
                    cells[10].innerText
                ]);
                bairros.add(cells[6].innerText);
                algumMarcado = true;
            }
        });

        if (!algumMarcado) {
            alert('Por favor, selecione pelo menos um estabelecimento para gerar o PDF.');
            return;
        }

        const bairrosSelecionados = Array.from(bairros).join(', ');
        doc.setFontSize(14);
        doc.text(`Rota de Sangria para os bairros: ${bairrosSelecionados}`, 20, 20);
        doc.autoTable({
            head: [['Estabelecimento', 'Endereco', 'Chave', 'Maquina', 'Bairro', 'Telefone de Contato']],
            body: data,
            styles: { fontSize: 8, halign: 'center' },
            margin: { top: 30 },
            headStyles: { fillColor: [41, 128, 185] },
            footStyles: { fillColor: [41, 128, 185] }
        });
        doc.save('Tabela_Estabelecimentos.pdf');

        document.querySelectorAll('.checkbox-selecao').forEach(checkbox => {
            checkbox.checked = false;
        });
    }

    document.addEventListener('DOMContentLoaded', carregarDiasSangria);

    document.querySelectorAll('#tabelaEstabelecimentos tr').forEach(row => {
        row.addEventListener('click', function(event) {
            if (event.target.tagName.toLowerCase() !== 'input') {
                const checkbox = this.querySelector('.checkbox-selecao');
                checkbox.checked = !checkbox.checked;
            }
        });
    });
    </script>
</body>
</html>
