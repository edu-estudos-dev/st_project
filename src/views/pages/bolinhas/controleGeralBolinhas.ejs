<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Controle Geral das Bolinhas' }) %>

<body class="list-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Controle Geral das Bolinhas' }) %>

        <section class="list-hero list-hero-green">
            <div class="list-hero-content">
                <span class="list-kicker"><i class="bi bi-diagram-3"></i> Operacional</span>
                <h1>Controle geral das bolinhas</h1>
                <p>Acompanhe os pontos que precisam de visita e monitore os dados mais importantes da operação.</p>
            </div>

            <div class="list-hero-side">
                <div class="list-stat"><strong>Pontos</strong><span><%= estabelecimentos.length %> registros</span></div>
                <div class="list-stat"><strong>Produto</strong><span>Bolinhas</span></div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">

                <div class="list-toolbar roteiro-toolbar">
                    <div class="list-toolbar-copy">
                        <h2>Pontos pendentes de visita</h2>
                    </div>

                    <div class="dias-sangria-top">
                        <label for="diasSangria" class="form-label fw-bold">Dias para fazer a sangria</label>
                        <input
                            type="number"
                            class="form-control text-center fw-bold"
                            id="diasSangria"
                            name="diasSangria"
                            min="1"
                            required
                        >
                    </div>
                </div>

                <div class="modern-table-wrap">
                    <div class="modern-table-scroll">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th>Estabelecimento</th>
                                    <th>Chave</th>
                                    <th>Máquina</th>
                                    <th>Endereço</th>
                                    <th>Bairro</th>
                                    <th>Dias passados</th>
                                    <th>Situação</th>
                                </tr>
                            </thead>

                            <tbody id="tabelaEstabelecimentos">
                                <% estabelecimentos.forEach(function(estabelecimento) {
                                    const data = estabelecimento.data ? new Date(estabelecimento.data) : null;
                                    const hoje = new Date();
                                    const diferencaDias = data ? Math.floor((hoje - data) / (1000 * 60 * 60 * 24)) : '';
                                %>

                                <tr
                                    data-diferenca-dias="<%= diferencaDias %>"
                                    data-sem-visita="<%= data ? 'false' : 'true' %>"
                                >
                                    <td>
                                        <span class="table-title-cell">
                                            <%= estabelecimento.estabelecimento %>
                                        </span>
                                    </td>

                                    <td><%= estabelecimento.chave || '-' %></td>
                                    <td><%= estabelecimento.maquina || '-' %></td>
                                    <td class="table-cell-wrap"><%= estabelecimento.endereco || '-' %></td>
                                    <td><%= estabelecimento.bairro || '-' %></td>
                                    <td class="dias-passados"><%= data ? diferencaDias : 'Sem visita' %></td>
                                    <td class="situacao"></td>
                                </tr>

                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </section>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <script>
    function obterDiasSangria() {
        const input = document.getElementById('diasSangria');
        const valor = input.value.trim();

        if (valor === '') {
            return 30;
        }

        const numero = Number(valor);

        if (Number.isNaN(numero) || numero <= 0) {
            return 30;
        }

        return numero;
    }

    function salvarDiasSangria() {
        const input = document.getElementById('diasSangria');
        localStorage.setItem('diasSangriaBolinhas', input.value);
        atualizarSituacao();
    }

    function carregarDiasSangria() {
        const input = document.getElementById('diasSangria');
        const diasSalvos = localStorage.getItem('diasSangriaBolinhas');

        if (diasSalvos === null || diasSalvos === '' || Number(diasSalvos) <= 0 || Number.isNaN(Number(diasSalvos))) {
            input.value = '30';
            localStorage.setItem('diasSangriaBolinhas', '30');
        } else {
            input.value = diasSalvos;
        }

        atualizarSituacao();
    }

    function atualizarSituacao() {
        const diasSangria = obterDiasSangria();

        document.querySelectorAll('#tabelaEstabelecimentos tr').forEach(linha => {
            const semVisita = linha.getAttribute('data-sem-visita') === 'true';

            let diferencaDias = Number(linha.getAttribute('data-diferenca-dias'));

            if (Number.isNaN(diferencaDias)) {
                diferencaDias = 0;
            }

            const situacaoCelula = linha.querySelector('.situacao');

            if (semVisita) {
                situacaoCelula.innerHTML = '<span class="table-badge table-badge-danger">Sem visita</span>';
                linha.classList.add('table-row-exit-highlight');
                return;
            }

            if (diferencaDias >= diasSangria) {
                situacaoCelula.innerHTML = '<span class="table-badge table-badge-danger">Sangria</span>';
                linha.classList.add('table-row-exit-highlight');
                return;
            }

            situacaoCelula.innerHTML = '<span class="table-badge table-badge-green">Aguardar</span>';
            linha.classList.remove('table-row-exit-highlight');
        });
    }

    document.addEventListener('DOMContentLoaded', () => {
        const inputDiasSangria = document.getElementById('diasSangria');

        carregarDiasSangria();

        inputDiasSangria.addEventListener('input', salvarDiasSangria);
        inputDiasSangria.addEventListener('change', salvarDiasSangria);
        inputDiasSangria.addEventListener('keyup', salvarDiasSangria);
    });
    </script>
</body>
</html>