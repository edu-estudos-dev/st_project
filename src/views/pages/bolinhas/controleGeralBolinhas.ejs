<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Controle Geral das Bolinhas' }) %>

<body class="list-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Controle Geral das Bolinhas' }) %>

        <section class="list-hero list-hero-green">
            <div class="list-hero-content">
                <span class="list-kicker"><i class="bi bi-diagram-3"></i> Operacional</span>
                <h1>Controle geral das bolinhas</h1>
                <p>Filtre bairros, destaque pontos que precisam de sangria e gere a rota em PDF dentro do mesmo padrão moderno do restante do sistema.</p>
            </div>
            <div class="list-hero-side">
                <div class="list-stat"><strong>Pontos</strong><span><%= estabelecimentos.length %> registros</span></div>
                <div class="list-stat"><strong>Produto</strong><span>Bolinhas</span></div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <div class="list-toolbar">
                    <div class="list-toolbar-copy">
                        <h2>Roteiro operacional</h2>
                        <p>Selecione os pontos que precisam de visita, filtre por bairro e gere rapidamente o PDF da rota.</p>
                    </div>
                </div>

                <form id="controleGeralForm" class="mb-4">
                    <div class="filter-toolbar">
                        <div>
                            <label for="bairroSelect" class="form-label fw-bold">Bairro</label>
                            <select class="form-select text-center fw-bold" id="bairroSelect" name="bairro" required onchange="filtrarPorBairro()">
                                <option value="" selected disabled hidden>Selecione um bairro para criar a rota</option>
                                <option value="mostrar_todos">Mostrar todos a sangrar</option>
                                <%
                                const diasSangria = 7;
                                const bairrosSangria = new Set();
                                estabelecimentos.forEach(function(estabelecimento) {
                                    const data = new Date(estabelecimento.data);
                                    const hoje = new Date();
                                    const diferencaDias = Math.floor((hoje - data) / (1000 * 60 * 60 * 24));
                                    if (diferencaDias > diasSangria) {
                                        bairrosSangria.add(estabelecimento.bairro);
                                    }
                                });
                                bairrosSangria.forEach(function(bairro) {
                                %>
                                    <option value="<%= bairro %>"><%= bairro %></option>
                                <% }); %>
                            </select>
                        </div>

                        <div>
                            <label for="diasSangria" class="form-label fw-bold">Dias para fazer a sangria</label>
                            <input type="number" class="form-control text-center fw-bold" id="diasSangria" name="diasSangria" required oninput="salvarDiasSangria()">
                        </div>

                        <div class="toolbar-actions">
                            <button type="button" class="btn-modern-secondary" onclick="mostrarTodos()">Mostrar todos</button>
                            <button type="button" class="btn-modern" onclick="gerarPDF()">Gerar PDF</button>
                        </div>
                    </div>
                </form>

                <div class="modern-table-wrap">
                    <div class="modern-table-scroll">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th><input type="checkbox" id="selectAll" onclick="selecionarTodos(this)"></th>
                                    <th>ID</th>
                                    <th>Estabelecimento</th>
                                    <th>Chave</th>
                                    <th>Máquina</th>
                                    <th>Endereço</th>
                                    <th>Bairro</th>
                                    <th>Data</th>
                                    <th>Dias passados</th>
                                    <th>Situação</th>
                                    <th>Contato</th>
                                </tr>
                            </thead>
                            <tbody id="tabelaEstabelecimentos">
                                <% estabelecimentos.forEach(function(estabelecimento) {
                                    const data = new Date(estabelecimento.data);
                                    const hoje = new Date();
                                    const diferencaDias = Math.floor((hoje - data) / (1000 * 60 * 60 * 24));
                                %>
                                <tr data-diferenca-dias="<%= diferencaDias %>" data-bairro="<%= estabelecimento.bairro %>">
                                    <td><input type="checkbox" class="checkbox-selecao" id="checkbox_<%= estabelecimento.id %>"></td>
                                    <td><span class="table-badge table-badge-neutral">#<%= estabelecimento.id %></span></td>
                                    <td><label for="checkbox_<%= estabelecimento.id %>" class="table-title-cell"><%= estabelecimento.estabelecimento %></label></td>
                                    <td><%= estabelecimento.chave %></td>
                                    <td><%= estabelecimento.maquina %></td>
                                    <td class="table-cell-wrap"><%= estabelecimento.endereco %></td>
                                    <td><%= estabelecimento.bairro %></td>
                                    <td><%= data.toLocaleDateString('pt-BR') %></td>
                                    <td class="dias-passados"><%= diferencaDias %></td>
                                    <td class="situacao"></td>
                                    <td><%= estabelecimento.telefone_contato %></td>
                                </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.4.0/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.23/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>

    <script>
    function salvarDiasSangria() {
        const diasSangria = document.getElementById('diasSangria').value;
        localStorage.setItem('diasSangria', diasSangria);
        atualizarSituacao();
    }
    function carregarDiasSangria() {
        const diasSangria = localStorage.getItem('diasSangria');
        if (diasSangria !== null) document.getElementById('diasSangria').value = diasSangria;
        atualizarSituacao();
    }
    function atualizarSituacao() {
        const diasSangria = parseInt(document.getElementById('diasSangria').value, 10) || 0;
        document.querySelectorAll('#tabelaEstabelecimentos tr').forEach(linha => {
            const diferencaDias = parseInt(linha.getAttribute('data-diferenca-dias'), 10);
            const situacaoCelula = linha.querySelector('.situacao');
            if (diferencaDias > diasSangria) {
                situacaoCelula.innerHTML = '<span class="table-badge table-badge-danger">Sangria</span>';
                linha.classList.add('table-row-exit-highlight');
            } else {
                situacaoCelula.innerHTML = '<span class="table-badge table-badge-green">Aguardar</span>';
                linha.classList.remove('table-row-exit-highlight');
            }
        });
    }
    function filtrarPorBairro() {
        const bairroSelecionado = document.getElementById('bairroSelect').value;
        document.querySelectorAll('#tabelaEstabelecimentos tr').forEach(linha => {
            const bairro = linha.getAttribute('data-bairro');
            const situacaoCelula = linha.querySelector('.situacao').textContent;
            if (bairroSelecionado === 'mostrar_todos' && situacaoCelula.includes('Sangria')) linha.style.display = '';
            else if (bairroSelecionado !== 'mostrar_todos' && bairro === bairroSelecionado && situacaoCelula.includes('Sangria')) linha.style.display = '';
            else linha.style.display = 'none';
        });
    }
    function mostrarTodos() { document.querySelectorAll('#tabelaEstabelecimentos tr').forEach(linha => { linha.style.display = ''; }); }
    function selecionarTodos(selectAllCheckbox) { document.querySelectorAll('.checkbox-selecao').forEach(checkbox => { checkbox.checked = selectAllCheckbox.checked; }); }
    function gerarPDF() {
        const { jsPDF } = window.jspdf;
        if (!jsPDF) return;
        const doc = new jsPDF();
        const linhas = document.querySelectorAll('#tabelaEstabelecimentos tr');
        const data = [];
        const bairros = new Set();
        let algumMarcado = false;
        linhas.forEach(linha => {
            if (linha.style.display !== 'none' && linha.querySelector('.checkbox-selecao').checked) {
                const cells = Array.from(linha.children);
                data.push([cells[2].innerText, cells[5].innerText, cells[3].innerText, cells[4].innerText, cells[6].innerText, cells[10].innerText]);
                bairros.add(cells[6].innerText);
                algumMarcado = true;
            }
        });
        if (!algumMarcado) { alert('Por favor, selecione pelo menos um estabelecimento para gerar o PDF.'); return; }
        doc.setFontSize(14);
        doc.text(`Rota de Sangria para os bairros: ${Array.from(bairros).join(', ')}`, 20, 20);
        doc.autoTable({ head: [['Estabelecimento', 'Endereço', 'Chave', 'Máquina', 'Bairro', 'Telefone de Contato']], body: data, styles: { fontSize: 8, halign: 'center' }, margin: { top: 30 }, headStyles: { fillColor: [41, 128, 185] } });
        doc.save('Tabela_Estabelecimentos.pdf');
        document.querySelectorAll('.checkbox-selecao').forEach(checkbox => { checkbox.checked = false; });
    }
    document.addEventListener('DOMContentLoaded', carregarDiasSangria);
    document.querySelectorAll('#tabelaEstabelecimentos tr').forEach(row => {
        row.addEventListener('click', function(event) {
            if (event.target.tagName.toLowerCase() !== 'input') this.querySelector('.checkbox-selecao').checked = !this.querySelector('.checkbox-selecao').checked;
        });
    });
    </script>
</body>
</html>
