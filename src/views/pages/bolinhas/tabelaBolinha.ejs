<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Lista de Sangrias de Bolinhas' }) %>
<body class="bg-light">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>
    <%- include('../../partials/breadcrumb', { pageTitle: 'Lista de Sangrias de Bolinhas' }) %>
    <div class="container-fluid px-4"><main class="bolinha"><div class="table-container"><div class="row mobile-stack-actions align-items-center"><div class="col-12 col-md-6"><h1 class="text-success mb-3 fw-bold">Registro Financeiro das Bolinhas</h1></div><div class="col-12 col-md-6 d-flex justify-content-md-end"><a type="button" class="btn mb-3 btn-success align-self-center w-100 w-md-auto" href="/bolinhas/sangrias/add"><i class="bi bi-plus-circle"></i>&nbsp;Novo Registro</a></div></div><table class="table table-striped table-hover mb-0"><thead><tr><th>ID</th><th>Estabelecimento</th><th>Data da Sangria</th><th>Valor Apurado</th><th>Comissao</th><th>Valor do Comerciante</th><th>Valor Liquido</th><th>Tipo de Pagamento</th><th>Pix Confirmado</th><th>Acoes</th></tr></thead><tbody><% if (sangrias.length > 0) { %><% sangrias.forEach(function(sangria) { %><tr><td class="py-1"><%= sangria.id %></td><td class="py-1"><%= sangria.estabelecimento %></td><td class="py-1"><%= new Date(sangria.data_sangria).toLocaleDateString('pt-BR') %></td><td class="py-1">R$ <%= Number(sangria.valor_apurado).toFixed(2) %></td><td class="py-1"><%= Number(sangria.comissao).toFixed(2) %> %</td><td class="py-1">R$ <%= Number(sangria.valor_comerciante).toFixed(2) %></td><td class="py-1">R$ <%= Number(sangria.valor_liquido).toFixed(2) %></td><td class="py-1"><%= sangria.tipo_pagamento === 'pix' ? 'PIX' : 'Especie' %></td><td class="py-1"><select name="pix_confirmado" id="pix_confirmado_<%= sangria.id %>" class="form-select color-select"><option value="" selected disabled>Selecione</option><option value="SIM" class="option-sim">SIM</option><option value="NAO" class="option-nao">NAO</option></select></td><td class="py-1"><a href="/bolinhas/sangrias/view/<%= sangria.id %>" class="btn btn-secondary btn-sm">Visualizar</a><a href="/bolinhas/sangrias/edit/<%= sangria.id %>" class="btn btn-warning btn-sm mx-1">Editar</a><button type="button" class="btn btn-danger btn-sm delete-btn" data-id="<%= sangria.id %>">Deletar</button></td></tr><% }); %><% } else { %><tr><td colspan="12" class="text-center">Nenhuma sangria encontrada</td></tr><% } %></tbody></table></div></main></div>
    <script>
        function saveSelectValue(selectElement) { localStorage.setItem(selectElement.id, selectElement.value); }
        function loadSelectValue(selectElement) { const savedValue = localStorage.getItem(selectElement.id); if (savedValue) { selectElement.value = savedValue; updateSelectColor(selectElement); } }
        function updateSelectColor(selectElement) { selectElement.classList.remove('select-sim', 'select-nao'); if (selectElement.value === 'SIM') selectElement.classList.add('select-sim'); else if (selectElement.value === 'NAO') selectElement.classList.add('select-nao'); }
        document.querySelectorAll('.form-select.color-select').forEach(select => { loadSelectValue(select); select.addEventListener('change', () => { updateSelectColor(select); saveSelectValue(select); }); });
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.delete-btn').forEach((button) => {
                button.addEventListener('click', async function() {
                    const idSangria = this.getAttribute('data-id');
                    const confirmed = await window.AppAlerts?.confirm({ title: 'Excluir sangria', text: 'Tem certeza que deseja excluir este registro de sangria?', confirmButtonText: 'Excluir', cancelButtonText: 'Cancelar' });
                    if (!confirmed) return;
                    try {
                        const response = await fetch(`/bolinhas/sangrias/delete/${idSangria}`, { method: 'POST' });
                        const data = await response.json();
                        if (!response.ok || !data.success) throw new Error(data.message || 'Erro ao excluir sangria');
                        await window.AppAlerts?.success(data.message || 'Sangria excluida com sucesso');
                        window.history.replaceState({}, document.title, window.location.pathname);
                        window.location.reload();
                    } catch (error) {
                        window.AppAlerts?.error(error.message || 'Erro ao excluir sangria');
                    }
                });
            });
            const urlParams = new URLSearchParams(window.location.search);
            const successMessage = urlParams.get('success'); const errorMessage = urlParams.get('error');
            if (successMessage) window.AppAlerts?.success(successMessage);
            if (errorMessage) window.AppAlerts?.error(errorMessage);
            if (successMessage || errorMessage) window.history.replaceState({}, document.title, window.location.pathname);
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>
