<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Lista de Sangrias de Bolinhas' }) %>

<body class="list-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="list-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Lista de Sangrias de Bolinhas' }) %>

        <section class="list-hero list-hero-green">
            <div class="list-hero-content">
                <span class="list-kicker"><i class="bi bi-circle-square"></i> Operacional</span>
                <h1>Registro financeiro das bolinhas</h1>
                <p>Uma leitura mais agradável dos registros de sangria, com foco no essencial da operação e acesso rápido aos detalhes completos no card de visualização.</p>
            </div>
            <div class="list-hero-side">
                <div class="list-stat"><strong>Total</strong><span><%= sangrias.length %> registros</span></div>
                <div class="list-stat"><strong>Fluxo</strong><span>Controle diário das coletas</span></div>
            </div>
        </section>

        <main class="list-stage">
            <section class="list-panel">
                <div class="list-toolbar">
                    <div class="list-toolbar-copy">
                        <h2>Sangrias de bolinhas</h2>
                        <p>Consulte os registros com uma visão mais objetiva, atualize o status de PIX e abra os detalhes completos quando precisar aprofundar.</p>
                    </div>
                    <a class="list-action" href="/bolinhas/sangrias/add">
                        <i class="bi bi-plus-circle"></i>
                        <span>Novo registro</span>
                    </a>
                </div>

                <div class="modern-table-wrap">
                    <div class="modern-table-scroll">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Estabelecimento</th>
                                    <th>Data</th>
                                    <th>Líquido</th>
                                    <th>Pagamento</th>
                                    <th>PIX confirmado</th>
                                    <th>Ações</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (sangrias.length > 0) { %>
                                    <% sangrias.forEach(function(sangria) { %>
                                        <tr>
                                            <td><span class="table-badge table-badge-neutral">#<%= sangria.id %></span></td>
                                            <td><div class="table-title-cell"><%= sangria.estabelecimento %></div></td>
                                            <td><%= new Date(sangria.data_sangria).toLocaleDateString('pt-BR') %></td>
                                            <td><strong>R$ <%= Number(sangria.valor_liquido).toFixed(2) %></strong></td>
                                            <td><span class="table-badge <%= sangria.tipo_pagamento === 'pix' ? 'table-badge-blue' : 'table-badge-amber' %>"><%= sangria.tipo_pagamento === 'pix' ? 'PIX' : 'Espécie' %></span></td>
                                            <td>
                                                <select name="pix_confirmado" id="pix_confirmado_<%= sangria.id %>" class="form-select color-select">
                                                    <option value="" selected disabled>Selecione</option>
                                                    <option value="SIM" class="option-sim">SIM</option>
                                                    <option value="NAO" class="option-nao">NAO</option>
                                                </select>
                                            </td>
                                            <td>
                                                <div class="table-actions">
                                                    <a href="/bolinhas/sangrias/view/<%= sangria.id %>" class="table-btn table-btn-view">Visualizar</a>
                                                    <a href="/bolinhas/sangrias/edit/<%= sangria.id %>" class="table-btn table-btn-edit">Editar</a>
                                                    <button type="button" class="table-btn table-btn-delete delete-btn" data-id="<%= sangria.id %>">Deletar</button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="7" class="table-empty">Nenhuma sangria encontrada</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script>
        function saveSelectValue(selectElement) { localStorage.setItem(selectElement.id, selectElement.value); }
        function loadSelectValue(selectElement) { const savedValue = localStorage.getItem(selectElement.id); if (savedValue) { selectElement.value = savedValue; updateSelectColor(selectElement); } }
        function updateSelectColor(selectElement) { selectElement.classList.remove('select-sim', 'select-nao'); if (selectElement.value === 'SIM') selectElement.classList.add('select-sim'); else if (selectElement.value === 'NAO') selectElement.classList.add('select-nao'); }
        document.querySelectorAll('.form-select.color-select').forEach(select => { loadSelectValue(select); select.addEventListener('change', () => { updateSelectColor(select); saveSelectValue(select); }); });
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.delete-btn').forEach((button) => {
                button.addEventListener('click', async function() {
                    const idSangria = this.getAttribute('data-id');
                    const confirmed = await window.AppAlerts?.confirm({ title: 'Excluir sangria', text: 'Tem certeza que deseja excluir este registro de sangria?', confirmButtonText: 'Excluir', cancelButtonText: 'Cancelar' });
                    if (!confirmed) return;
                    try {
                        const response = await fetch(`/bolinhas/sangrias/delete/${idSangria}`, { method: 'POST' });
                        const data = await response.json();
                        if (!response.ok || !data.success) throw new Error(data.message || 'Erro ao excluir sangria');
                        await window.AppAlerts?.success(data.message || 'Sangria excluída com sucesso');
                        window.history.replaceState({}, document.title, window.location.pathname);
                        window.location.reload();
                    } catch (error) {
                        window.AppAlerts?.error(error.message || 'Erro ao excluir sangria');
                    }
                });
            });
            const urlParams = new URLSearchParams(window.location.search);
            const successMessage = urlParams.get('success'); const errorMessage = urlParams.get('error');
            if (successMessage) window.AppAlerts?.success(successMessage);
            if (errorMessage) window.AppAlerts?.error(errorMessage);
            if (successMessage || errorMessage) window.history.replaceState({}, document.title, window.location.pathname);
        });
    </script>
    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>

