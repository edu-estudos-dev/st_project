<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Registrar Sangria de Figurinhas' }) %>

<body class="bg-light">
    <%- include('../../partials/header') %>
    <div class="container w-75 mt-5">
        <div>&nbsp;</div>

        <!-- breadcrumb -->
        <%- include('../../partials/breadcrumb', { pageTitle: 'Registrar Sangria de Figurinhas' }) %>

        <div class="cabecalho-figurinhas">
            <h1 class="mb-0">Registrar Sangria de Figurinhas</h1>
        </div>
        
        <main class="figurinhas">
            <form action="/figurinhas/sangrias/add" method="POST">
                <div class="row">
                    <div class="mb-3 col-6">
                        <label for="estabelecimento" class="form-labe mb-1 fs-5 fw-bold">Estabelecimento</label>
                        <select class="form-select" id="estabelecimento" name="estabelecimento_id" required>
                            <option value="" selected disabled hidden>Selecione um Estabelecimento</option>
                            <% estabelecimentos.forEach(function(estabelecimento) { %>
                                <option value="<%= estabelecimento.id %>"><%= estabelecimento.estabelecimento %></option>
                            <% }); %>
                        </select>
                    </div>
                    <div class="mb-3 col-3 text-center">
                        <label for="data_sangria" class="form-label mb-1 fs-5 fw-bold">Data da Visita</label>
                        <input type="date" class="form-control text-center" id="data_sangria" name="data_sangria" required>
                    </div>
                    <div class="mb-3 col-3 text-center">
                        <label for="ultima_visita" class="form-label mb-1 fs-5 fw-bold">Última Visita</label>
                        <input type="date" class="form-control text-center" id="ultima_visita" name="ultima_visita" readonly disabled>
                    </div>
             
                </div>
                <div class="row">
                    <div class="mb-3 col-3 text-center">
                        <label for="qtde_vendido" class="form-label mb-1 fs-5 fw-bold">Qtde. Vendida</label>
                        <div class="input-group">
                            <input type="number" class="form-control text-center" id="qtde_vendido" name="qtde_vendido" value="" required>
                        </div>
                    </div>

                    <div class="mb-3 col-3 text-center">
                        <label for="abastecido" class="form-label mb-1 fs-5 fw-bold">Abastecido</label>
                        <input type="number" class="form-control text-center" id="abastecido" name="abastecido" required>
                    </div>

                    <div class="mb-3 col-3 text-center">
                        <label for="qtde_deixada" class="form-label mb-1 fs-5 fw-bold">Quantidade Deixada</label>
                        <input type="number" class="form-control text-center" id="qtde_deixada" name="qtde_deixada" readonly>
                    </div>
                  
             
                    <div class="mb-3 col-3 text-center">
                        <label for="tipo_pagamento" class="form-label mb-1 fs-5 fw-bold">Tipo de Pagamento</label>
                        <select class="form-select" id="tipo_pagamento" name="tipo_pagamento" required>
                            <option value="especie">Espécie</option>
                            <option value="pix">PIX</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="mb-3 col-12">
                        <label for="observacoes" class="form-label mb-1 fs-5 fw-bold">Observações</label>
                        <textarea class="form-control" id="observacoes" name="observacoes" rows="3"></textarea>
                    </div>
                </div>
                <div class="d-flex justify-content-center my-3">
                    <a href="/figurinhas/sangrias"><button type="button" class="btn btn-warning px-5 me-3 fs-5">Cancelar</button></a>
                    <button type="submit" class="btn btn-primary ms-3 px-5 fs-5">Registrar</button>
                </div>
            </form>
        </main>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
    integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
    crossorigin="anonymous">
    </script>

    <script>

        function calculateQuantidadeDeixada() {
            const abastecido = parseFloat(document.getElementById('abastecido').value) || 0;
            const estoque = parseFloat(document.getElementById('estoque').value) || 0;
            const qtdeDeixada = abastecido + estoque;
            document.getElementById('qtde_deixada').value = qtdeDeixada;
        }

        document.getElementById('abastecido').addEventListener('input', calculateQuantidadeDeixada);
        document.getElementById('estoque').addEventListener('input', calculateQuantidadeDeixada);
        document.getElementById('valor_apurado').addEventListener('input', calculateValues);
        document.getElementById('comissao').addEventListener('input', calculateValues);
    </script>
</body>
</html>
