<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Registrar Sangria de Consignados' }) %>

<body class="form-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <%
        const selectedId = typeof selectedEstabelecimentoId !== 'undefined' ? selectedEstabelecimentoId : '';
        const currentVisitaId = typeof visitaId !== 'undefined' ? visitaId : '';
        const currentRotaId = typeof rotaId !== 'undefined' ? rotaId : '';
        const currentRotaPontoId = typeof rotaPontoId !== 'undefined' ? rotaPontoId : '';
        const currentOrigem = typeof origem !== 'undefined' ? origem : '';
        const currentRetornoUrl = typeof retornoUrl !== 'undefined' && retornoUrl ? retornoUrl : '/rotas';
        const currentRotaRetornoUrl = typeof rotaRetornoUrl !== 'undefined' && rotaRetornoUrl ? rotaRetornoUrl : currentRetornoUrl;
        const cancelarUrl = currentOrigem === 'rota' ? currentRetornoUrl : '/figurinhas/sangrias';
    %>

    <div class="form-shell form-shell-modern">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Registrar Sangria de Consignados' }) %>

        <section class="page-titlebar page-titlebar-blue">
            <div class="page-titlebar-content">
                <span class="form-kicker"><i class="bi bi-stickies"></i> Operacional</span>
                <h1>Registrar sangria de consignados</h1>
                <p>Organize a visita do ponto com mais contexto visual, enxergando venda, abastecimento e estoque deixado de forma mais fluida durante o preenchimento.</p>
            </div>

            <div class="page-titlebar-side">
                <div class="page-titlebar-stat">
                    <strong>Produto</strong>
                    <span>Consignados</span>
                </div>
                <div class="page-titlebar-stat">
                    <strong>Destaque</strong>
                    <span>Última visita e quantidade deixada calculadas na tela</span>
                </div>
            </div>
        </section>

        <main class="form-stage">
            <form action="/figurinhas/sangrias/add" method="POST" class="modern-form" id="figurinhaForm">
                <input type="hidden" name="visita_id" value="<%= currentVisitaId || '' %>">
                <input type="hidden" name="rota_id" value="<%= currentRotaId || '' %>">
                <input type="hidden" name="rota_ponto_id" value="<%= currentRotaPontoId || '' %>">
                <input type="hidden" name="origem" value="<%= currentOrigem || '' %>">
                <input type="hidden" name="retorno_url" value="<%= currentRetornoUrl || '/rotas' %>">
                <input type="hidden" name="rota_retorno_url" value="<%= currentRotaRetornoUrl || currentRetornoUrl || '/rotas' %>">

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Visita</span>
                            <h2>Dados do atendimento</h2>
                            <p>Selecione o estabelecimento, informe a data e deixe o sistema recuperar automaticamente a última visita desse ponto.</p>
                        </div>

                        <% if (currentOrigem !== 'rota') { %>
                            <button type="button" class="form-inline-action form-inline-action-warning" id="toggleAberturaInicial">
                                <i class="bi bi-plus-circle"></i>
                                <span>Criar novo</span>
                            </button>
                        <% } %>
                    </div>

                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-lg-8">
                            <label for="estabelecimento">Estabelecimento</label>

                            <select class="form-select" id="estabelecimento" name="estabelecimento_id" required>
                                <option value="" <%= selectedId ? '' : 'selected' %> disabled hidden>Selecione um estabelecimento</option>

                                <% estabelecimentos.forEach(function(estabelecimento) { %>
                                    <option
                                        value="<%= estabelecimento.id %>"
                                        <%= String(estabelecimento.id) === String(selectedId || '') ? 'selected' : '' %>
                                    >
                                        <%= estabelecimento.estabelecimento %>
                                    </option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="col-12 col-lg-4">
                            <label for="data_sangria" id="dataSangriaLabel">Data da sangria</label>
                            <input type="date" class="form-control text-center" id="data_sangria" name="data_sangria" required>
                        </div>
                    </div>

                    <input class="form-check-input d-none" type="checkbox" id="abertura_inicial" name="abertura_inicial">

                    <div class="row g-3 mt-1">
                        <div class="col-12">
                            <small class="modern-note" id="modoRegistroHint">Use "Criar novo" para cadastrar a abertura inicial de um ponto sem histórico anterior.</small>
                        </div>
                    </div>

                    <div id="aberturaInicialBox" class="row g-3 mt-1 d-none">
                        <div class="col-12 col-lg-4">
                            <label for="quantidade_inicial">Quantidade inicial deixada</label>
                            <input type="number" class="form-control text-center" id="quantidade_inicial" name="quantidade_inicial" min="0">
                        </div>
                    </div>

                    <div class="form-summary-grid mt-4">
                        <div class="form-summary-card">
                            <strong>Última visita</strong>
                            <span id="ultimaVisitaResumo">Aguardando seleção</span>
                        </div>

                        <div class="form-summary-card">
                            <strong>Estoque anterior</strong>
                            <span id="estoqueAnteriorResumo">0 unidades</span>
                        </div>

                        <div class="form-summary-card">
                            <strong>Resultado</strong>
                            <span id="qtdeDeixadaResumo">0 unidades</span>
                        </div>

                        <div class="form-summary-card">
                            <strong>Pagamento</strong>
                            <span id="pagamentoResumo">Espécie ou PIX</span>
                        </div>
                    </div>
                </section>

                <section class="form-card" id="movimentacaoCard">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Movimentação</span>
                            <h2>Venda, abastecimento e saldo</h2>
                            <p>Preencha os números da visita e acompanhe a quantidade deixada e a última visita sem precisar sair da página.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="valor_apurado">Valor apurado</label>
                            <input type="number" step="0.01" class="form-control text-center" id="valor_apurado" name="valor_apurado" required>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="qtde_vendido">Qtde. vendida</label>
                            <input type="number" class="form-control text-center" id="qtde_vendido" name="qtde_vendido" required oninput="calculateQuantidadeDeixada()">
                        </div>

                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="abastecido">Abastecido</label>
                            <input type="number" class="form-control text-center" id="abastecido" name="abastecido" required oninput="calculateQuantidadeDeixada()">
                        </div>

                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="qtde_deixada">Quantidade deixada</label>
                            <input type="number" class="form-control text-center readonly-input" id="qtde_deixada" readonly disabled>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4" id="tipoPagamentoField">
                            <label for="tipo_pagamento">Tipo de pagamento</label>
                            <select class="form-select" id="tipo_pagamento" name="tipo_pagamento" required>
                                <option value="especie">Espécie</option>
                                <option value="pix">PIX</option>
                            </select>
                        </div>

                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="ultima_visita">Última visita</label>
                            <input type="date" class="form-control text-center readonly-input" id="ultima_visita" readonly disabled>
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Observações</span>
                            <h2>Anotações sobre o ponto</h2>
                            <p>Deixe observações complementares para orientar a próxima visita e facilitar o acompanhamento da operação.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label for="observacoes">Observações</label>
                            <textarea class="form-control" id="observacoes" name="observacoes" rows="5" placeholder="Ex.: ponto vendeu bem, precisou de reposição extra, comerciante pediu novo horário..."></textarea>
                        </div>
                    </div>
                </section>

                <section class="form-actions-bar">
                    <div class="form-actions-copy">
                        <strong>Revisão final</strong>
                        <span>Confira data, quantidades e valor apurado antes de concluir o registro da visita.</span>
                    </div>

                    <div class="form-actions-buttons">
                        <a href="<%= cancelarUrl %>" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Cancelar</span>
                        </a>

                        <button type="submit" class="btn-modern">
                            <i class="bi bi-save2"></i>
                            <span id="figurinhaSubmitLabel">Registrar sangria</span>
                        </button>
                    </div>
                </section>
            </form>
        </main>
    </div>

    <script>
        window.estoqueAnterior = 0;
        window.figurinhaHasHistorico = false;

        const estabelecimentoSelect = document.getElementById('estabelecimento');
        const aberturaInicialInput = document.getElementById('abertura_inicial');
        const toggleAberturaInicialButton = document.getElementById('toggleAberturaInicial');
        const quantidadeInicialInput = document.getElementById('quantidade_inicial');
        const isRouteFlow = '<%= currentOrigem %>' === 'rota';

        function formatDateToBrazilian(dateString) {
            if (!dateString) return '';

            const parts = dateString.split('-');

            if (parts.length !== 3) return dateString;

            return `${parts[2]}/${parts[1]}/${parts[0]}`;
        }

        function updateResumoUltimaVisita(data, estoque) {
            document.getElementById('ultimaVisitaResumo').textContent = data
                ? formatDateToBrazilian(data)
                : 'Sem histórico';

            document.getElementById('estoqueAnteriorResumo').textContent = `${estoque || 0} unidades`;
        }

        function updateResumoQuantidade(resultado) {
            document.getElementById('qtde_deixada').value = resultado;
            document.getElementById('qtdeDeixadaResumo').textContent = `${resultado} unidades`;
        }

        function calculateQuantidadeDeixada() {
            const abastecido = parseFloat(document.getElementById('abastecido').value) || 0;
            const vendido = parseFloat(document.getElementById('qtde_vendido').value) || 0;
            const resultado = window.estoqueAnterior - vendido + abastecido;

            updateResumoQuantidade(resultado);
        }

        function syncModoAberturaInicial() {
            const isAbertura = aberturaInicialInput.checked;
            const hasSelectedEstabelecimento = Boolean(estabelecimentoSelect.value);
            const hasHistorico = window.figurinhaHasHistorico === true;
            const aberturaBox = document.getElementById('aberturaInicialBox');
            const submitLabel = document.getElementById('figurinhaSubmitLabel');
            const hint = document.getElementById('modoRegistroHint');
            const dataSangriaLabel = document.getElementById('dataSangriaLabel');
            const tipoPagamentoField = document.getElementById('tipoPagamentoField');
            const camposNormais = ['valor_apurado', 'qtde_vendido', 'abastecido', 'tipo_pagamento'];

            aberturaBox.classList.toggle('d-none', !isAbertura);
            tipoPagamentoField.classList.toggle('d-none', isAbertura);
            dataSangriaLabel.textContent = isAbertura ? 'Data de registro' : 'Data da sangria';
            quantidadeInicialInput.required = isAbertura;
            toggleAberturaInicialButton?.classList.toggle('is-active', isAbertura);

            camposNormais.forEach((id) => {
                const field = document.getElementById(id);

                field.required = !isAbertura;

                if (isAbertura && field.tagName === 'INPUT') {
                    field.value = '';
                }
            });

            document.getElementById('movimentacaoCard').classList.toggle('opacity-50', isAbertura);
            document.getElementById('movimentacaoCard').style.pointerEvents = isAbertura ? 'none' : 'auto';
            document.getElementById('pagamentoResumo').textContent = isAbertura ? 'Abertura inicial' : 'Espécie ou PIX';
            submitLabel.textContent = isAbertura && !hasHistorico ? 'Registrar' : 'Registrar sangria';

            if (hasSelectedEstabelecimento && !hasHistorico) {
                aberturaInicialInput.checked = true;

                if (toggleAberturaInicialButton) {
                    toggleAberturaInicialButton.disabled = true;
                }

                hint.textContent = isRouteFlow
                    ? 'Este ponto ainda não tem histórico inicial de consignados. Cadastre a abertura inicial fora da rota antes de registrar a visita guiada.'
                    : 'Este ponto ainda não tem histórico. O primeiro cadastro precisa ser o registro inicial.';
            } else {
                if (toggleAberturaInicialButton) {
                    toggleAberturaInicialButton.disabled = false;
                }

                hint.textContent = isRouteFlow
                    ? 'Visita guiada em andamento. Registre apenas a sangria do ponto já inicializado.'
                    : 'Use "Criar novo" para cadastrar a abertura inicial de um ponto sem histórico anterior.';
            }

            if (isAbertura) {
                const qtdInicial = parseFloat(quantidadeInicialInput.value) || 0;
                updateResumoQuantidade(qtdInicial);
            } else {
                calculateQuantidadeDeixada();
            }
        }

        async function loadUltimaSangriaFigurinha(estabelecimentoId) {
            if (!estabelecimentoId) {
                window.figurinhaHasHistorico = false;
                window.estoqueAnterior = 0;
                document.getElementById('ultima_visita').value = '';
                updateResumoUltimaVisita('', 0);
                syncModoAberturaInicial();
                return;
            }

            try {
                const response = await fetch(`/figurinhas/sangrias/ultima-sangria/${estabelecimentoId}`);
                const data = await response.json();

                if (data.data) {
                    const formattedDate = data.data.split('T')[0];
                    document.getElementById('ultima_visita').value = formattedDate;
                    updateResumoUltimaVisita(formattedDate, data.estoque || 0);
                } else {
                    document.getElementById('ultima_visita').value = '';
                    updateResumoUltimaVisita('', data.estoque || 0);
                }

                window.figurinhaHasHistorico = Boolean(data.hasHistorico);

                if (window.figurinhaHasHistorico) {
                    aberturaInicialInput.checked = false;
                    quantidadeInicialInput.value = '';
                }

                window.estoqueAnterior = data.estoque || 0;

                syncModoAberturaInicial();
            } catch (error) {
                console.error(error);

                window.figurinhaHasHistorico = false;
                window.estoqueAnterior = 0;
                updateResumoUltimaVisita('', 0);
                syncModoAberturaInicial();
            }
        }

        estabelecimentoSelect.addEventListener('change', function () {
            loadUltimaSangriaFigurinha(this.value);
        });

        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('data_sangria').value = new Date().toISOString().split('T')[0];
            updateResumoUltimaVisita('', 0);

            aberturaInicialInput.addEventListener('change', syncModoAberturaInicial);

            toggleAberturaInicialButton?.addEventListener('click', function () {
                if (aberturaInicialInput.disabled) return;

                aberturaInicialInput.checked = !aberturaInicialInput.checked;
                syncModoAberturaInicial();
            });

            quantidadeInicialInput.addEventListener('input', syncModoAberturaInicial);

            document.getElementById('figurinhaForm').addEventListener('submit', (event) => {
                const isAbertura = aberturaInicialInput.checked;
                const hasHistorico = window.figurinhaHasHistorico === true;
                const quantidadeInicial = quantidadeInicialInput.value;

                if (!estabelecimentoSelect.value) {
                    event.preventDefault();
                    window.AppAlerts?.warning('Selecione um estabelecimento antes de salvar.');
                    return;
                }

                if (isRouteFlow && !hasHistorico) {
                    event.preventDefault();
                    window.AppAlerts?.warning('Este ponto ainda não tem registro inicial de consignados. Cadastre a abertura inicial fora da rota antes de usar a visita guiada.');
                    return;
                }

                if (!hasHistorico && !isAbertura) {
                    event.preventDefault();
                    window.AppAlerts?.warning('Este ponto ainda não tem registro inicial. Clique em "Criar novo" e informe a quantidade inicial.');
                    return;
                }

                if (isAbertura && !quantidadeInicial) {
                    event.preventDefault();
                    window.AppAlerts?.warning('Informe a quantidade inicial antes de salvar a abertura de consignados.');
                }
            });

            if (estabelecimentoSelect.value) {
                loadUltimaSangriaFigurinha(estabelecimentoSelect.value);
            } else {
                syncModoAberturaInicial();
            }
        });
    </script>
</body>
</html>
