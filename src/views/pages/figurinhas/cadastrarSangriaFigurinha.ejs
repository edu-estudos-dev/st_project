<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Registrar Sangria de Figurinhas' }) %>

    <body class="bg-light">
        <%- include('../../partials/header') %>

            <div class="container w-75 mt-5">
                <div>&nbsp;</div>

                <%- include('../../partials/breadcrumb', { pageTitle: 'Registrar Sangria de Figurinhas' }) %>

                    <div class="cabecalho-figurinhas">
                        <h1 class="mb-0">Registrar Sangria de Figurinhas</h1>
                    </div>

                    <main class="figurinhas">
                        <form action="/figurinhas/sangrias/add" method="POST">

                            <div class="row">
                                <div class="mb-3 col-9">
                                    <label class="form-label fs-5 fw-bold">Estabelecimento</label>
                                    <select class="form-select" id="estabelecimento" name="estabelecimento_id" required>
                                        <option value="" selected disabled hidden>Selecione um Estabelecimento</option>
                                        <% estabelecimentos.forEach(function(estabelecimento) { %>
                                            <option value="<%= estabelecimento.id %>">
                                                <%= estabelecimento.estabelecimento %>
                                            </option>
                                            <% }); %>
                                    </select>
                                </div>

                                <div class="mb-3 col-3 text-center">
                                    <label class="form-label fs-5 fw-bold">Data da Visita</label>
                                    <input type="date" class="form-control text-center" id="data_sangria"
                                        name="data_sangria" required>
                                </div>

                            </div>

                            <div class="row">

                                  <div class="mb-3 col-4">
                                    <label class="form-label fs-5 fw-bold">Valor Apurado</label>
                                    <input type="number" step="0.01" class="form-control" name="valor_apurado" required>
                                </div>
                                <div class="mb-3 col-4 text-center">
                                    <label class="form-label fs-5 fw-bold">Qtde. Vendido</label>
                                    <input type="number" class="form-control text-center" id="qtde_vendido"
                                        name="qtde_vendido" required oninput="calculateQuantidadeDeixada()">
                                </div>

                                <div class="mb-3 col-4 text-center">
                                    <label class="form-label fs-5 fw-bold">Abastecido</label>
                                    <input type="number" class="form-control text-center" id="abastecido"
                                        name="abastecido" required oninput="calculateQuantidadeDeixada()">
                                </div>

                                    <div class="mb-3 col-4 text-center">
                                    <label class="form-label fs-5 fw-bold">Quantidade Deixada</label>
                                    <input type="number" class="form-control text-center" id="qtde_deixada" readonly
                                        disabled>
                                </div>

                                <div class="mb-3 col-4 text-center">
                                    <label class="form-label fs-5 fw-bold">Tipo de Pagamento</label>
                                    <select class="form-select" name="tipo_pagamento" required>
                                        <option value="especie">Espécie</option>
                                        <option value="pix">PIX</option>
                                    </select>
                                </div>

                                  <div class="mb-3 col-4 text-center">
                                    <label class="form-label fs-5 fw-bold">Última Visita</label>
                                    <input type="date" class="form-control text-center" id="ultima_visita" readonly
                                        disabled>
                                </div>
                            </div>

                            <div class="row">

                            </div>

                            <div class="row">
                                <div class="mb-3 col-12">
                                    <label class="form-label fs-5 fw-bold">Observações</label>
                                    <textarea class="form-control" name="observacoes"></textarea>
                                </div>
                            </div>

                            <div class="d-flex justify-content-center my-3">
                                <a href="/figurinhas/sangrias">
                                    <button type="button" class="btn btn-warning px-5 me-3 fs-5">Cancelar</button>
                                </a>
                                <button type="submit" class="btn btn-primary ms-3 px-5 fs-5">Registrar</button>
                            </div>

                        </form>
                    </main>
            </div>

            <script>
                window.estoqueAnterior = 0;

                document.getElementById('estabelecimento').addEventListener('change', async function () {
                    const id = this.value;

                    try {
                        const response = await fetch(`/figurinhas/sangrias/ultima-sangria/${id}`);
                        const data = await response.json();

                        if (data.data) {
                            document.getElementById('ultima_visita').value = data.data.split('T')[0];
                        } else {
                            document.getElementById('ultima_visita').value = '';
                        }

                        window.estoqueAnterior = data.estoque || 0;

                        calculateQuantidadeDeixada();

                    } catch (error) {
                        console.error(error);
                    }
                });

                function calculateQuantidadeDeixada() {
                    const abastecido = parseFloat(document.getElementById('abastecido').value) || 0;
                    const vendido = parseFloat(document.getElementById('qtde_vendido').value) || 0;

                    const resultado = window.estoqueAnterior - vendido + abastecido;

                    document.getElementById('qtde_deixada').value = resultado;
                }

                document.addEventListener('DOMContentLoaded', function () {
                    document.getElementById('data_sangria').value =
                        new Date().toISOString().split('T')[0];
                });
            </script>

    </body>

</html>