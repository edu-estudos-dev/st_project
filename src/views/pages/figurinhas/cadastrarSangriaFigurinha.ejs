<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Registrar Sangria de Figurinhas' }) %>

<body class="form-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="form-shell form-shell-modern">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Registrar Sangria de Figurinhas' }) %>

        <section class="form-hero form-hero-blue">
            <div class="form-hero-content">
                <span class="form-kicker"><i class="bi bi-stickies"></i> Operacional</span>
                <h1>Registrar sangria de figurinhas</h1>
                <p>Organize a visita do ponto com mais contexto visual, enxergando venda, abastecimento e estoque deixado de forma mais fluida durante o preenchimento.</p>
            </div>

            <div class="form-hero-side">
                <div class="form-hero-stat">
                    <strong>Produto</strong>
                    <span>Figurinhas</span>
                </div>
                <div class="form-hero-stat">
                    <strong>Destaque</strong>
                    <span>Ultima visita e quantidade deixada calculadas na tela</span>
                </div>
            </div>
        </section>

        <main class="form-stage">
            <form action="/figurinhas/sangrias/add" method="POST" class="modern-form">
                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Visita</span>
                            <h2>Dados do atendimento</h2>
                            <p>Selecione o estabelecimento, informe a data e deixe o sistema recuperar automaticamente a ultima visita desse ponto.</p>
                        </div>
                    </div>

                    <div class="row g-3 align-items-end">
                        <div class="col-12 col-lg-8">
                            <label for="estabelecimento">Estabelecimento</label>
                            <select class="form-select" id="estabelecimento" name="estabelecimento_id" required>
                                <option value="" selected disabled hidden>Selecione um estabelecimento</option>
                                <% estabelecimentos.forEach(function(estabelecimento) { %>
                                    <option value="<%= estabelecimento.id %>"><%= estabelecimento.estabelecimento %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="col-12 col-lg-4">
                            <label for="data_sangria">Data da visita</label>
                            <input type="date" class="form-control text-center" id="data_sangria" name="data_sangria" required>
                        </div>
                    </div>

                    <div class="form-summary-grid mt-4">
                        <div class="form-summary-card">
                            <strong>Ultima visita</strong>
                            <span id="ultimaVisitaResumo">Aguardando selecao</span>
                        </div>
                        <div class="form-summary-card">
                            <strong>Estoque anterior</strong>
                            <span id="estoqueAnteriorResumo">0 unidades</span>
                        </div>
                        <div class="form-summary-card">
                            <strong>Resultado</strong>
                            <span id="qtdeDeixadaResumo">0 unidades</span>
                        </div>
                        <div class="form-summary-card">
                            <strong>Pagamento</strong>
                            <span>Especie ou PIX</span>
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Movimentacao</span>
                            <h2>Venda, abastecimento e saldo</h2>
                            <p>Preencha os numeros da visita e acompanhe a quantidade deixada e a ultima visita sem precisar sair da pagina.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="valor_apurado">Valor apurado</label>
                            <input type="number" step="0.01" class="form-control text-center" id="valor_apurado" name="valor_apurado" required>
                        </div>
                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="qtde_vendido">Qtde. vendido</label>
                            <input type="number" class="form-control text-center" id="qtde_vendido" name="qtde_vendido" required oninput="calculateQuantidadeDeixada()">
                        </div>
                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="abastecido">Abastecido</label>
                            <input type="number" class="form-control text-center" id="abastecido" name="abastecido" required oninput="calculateQuantidadeDeixada()">
                        </div>
                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="qtde_deixada">Quantidade deixada</label>
                            <input type="number" class="form-control text-center readonly-input" id="qtde_deixada" readonly disabled>
                        </div>
                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="tipo_pagamento">Tipo de pagamento</label>
                            <select class="form-select" id="tipo_pagamento" name="tipo_pagamento" required>
                                <option value="especie">Especie</option>
                                <option value="pix">PIX</option>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-lg-4">
                            <label for="ultima_visita">Ultima visita</label>
                            <input type="date" class="form-control text-center readonly-input" id="ultima_visita" readonly disabled>
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Observacoes</span>
                            <h2>Anotacoes sobre o ponto</h2>
                            <p>Deixe observacoes complementares para orientar a proxima visita e facilitar o acompanhamento da operacao.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label for="observacoes">Observacoes</label>
                            <textarea class="form-control" id="observacoes" name="observacoes" rows="5" placeholder="Ex.: ponto vendeu bem, precisou de reposicao extra, comerciante pediu novo horario..."></textarea>
                        </div>
                    </div>
                </section>

                <section class="form-actions-bar">
                    <div class="form-actions-copy">
                        <strong>Revisao final</strong>
                        <span>Confira data, quantidades e valor apurado antes de concluir o registro da visita.</span>
                    </div>

                    <div class="form-actions-buttons">
                        <a href="/figurinhas/sangrias" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Cancelar</span>
                        </a>
                        <button type="submit" class="btn-modern">
                            <i class="bi bi-save2"></i>
                            <span>Registrar sangria</span>
                        </button>
                    </div>
                </section>
            </form>
        </main>
    </div>

    <script>
        window.estoqueAnterior = 0;

        function formatDateToBrazilian(dateString) {
            if (!dateString) return '';

            const parts = dateString.split('-');
            if (parts.length !== 3) return dateString;

            return `${parts[2]}/${parts[1]}/${parts[0]}`;
        }

        function updateResumoUltimaVisita(data, estoque) {
            document.getElementById('ultimaVisitaResumo').textContent = data ? formatDateToBrazilian(data) : 'Sem historico';
            document.getElementById('estoqueAnteriorResumo').textContent = `${estoque || 0} unidades`;
        }

        function updateResumoQuantidade(resultado) {
            document.getElementById('qtde_deixada').value = resultado;
            document.getElementById('qtdeDeixadaResumo').textContent = `${resultado} unidades`;
        }

        document.getElementById('estabelecimento').addEventListener('change', async function () {
            const id = this.value;

            try {
                const response = await fetch(`/figurinhas/sangrias/ultima-sangria/${id}`);
                const data = await response.json();

                if (data.data) {
                    const formattedDate = data.data.split('T')[0];
                    document.getElementById('ultima_visita').value = formattedDate;
                    updateResumoUltimaVisita(formattedDate, data.estoque || 0);
                } else {
                    document.getElementById('ultima_visita').value = '';
                    updateResumoUltimaVisita('', data.estoque || 0);
                }

                window.estoqueAnterior = data.estoque || 0;
                calculateQuantidadeDeixada();
            } catch (error) {
                console.error(error);
                updateResumoUltimaVisita('', 0);
            }
        });

        function calculateQuantidadeDeixada() {
            const abastecido = parseFloat(document.getElementById('abastecido').value) || 0;
            const vendido = parseFloat(document.getElementById('qtde_vendido').value) || 0;
            const resultado = window.estoqueAnterior - vendido + abastecido;

            updateResumoQuantidade(resultado);
        }

        document.addEventListener('DOMContentLoaded', function () {
            document.getElementById('data_sangria').value = new Date().toISOString().split('T')[0];
            updateResumoUltimaVisita('', 0);
        });
    </script>
</body>
</html>
