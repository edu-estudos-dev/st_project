<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Editar Sangria de Figurinhas' }) %>

<body class="form-page-body">
    <%- include('../../partials/header') %>

    <div class="page-spacer"></div>

    <div class="form-shell form-shell-modern">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Editar Sangria de Figurinhas' }) %>

        <section class="form-hero form-hero-blue">
            <div class="form-hero-content">
                <span class="form-kicker"><i class="bi bi-pencil-square"></i> Operacional</span>
                <h1>Editar sangria de figurinhas</h1>
                <p>Deixei a edição com o mesmo padrão visual do cadastro para facilitar a revisão de quantidades, data da visita e observações.</p>
            </div>

            <div class="form-hero-side">
                <div class="form-hero-stat">
                    <strong>Produto</strong>
                    <span>Figurinhas</span>
                </div>
                <div class="form-hero-stat">
                    <strong>Registro</strong>
                    <span>ID <%= sangria.id %></span>
                </div>
            </div>
        </section>

        <main class="form-stage">
            <form action="/figurinhas/sangrias/edit" method="POST" class="modern-form">
                <input type="hidden" name="id" value="<%= sangria.id %>">

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Visita</span>
                            <h2>Dados do atendimento</h2>
                            <p>Atualize estabelecimento, data e tipo de pagamento vinculados ao registro desta visita.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-lg-6">
                            <label for="estabelecimento">Estabelecimento</label>
                            <select class="form-select" id="estabelecimento" name="estabelecimento_id" required>
                                <% estabelecimentos.forEach(function(estabelecimento) { %>
                                    <option value="<%= estabelecimento.id %>" <%= estabelecimento.id === sangria.estabelecimento_id ? 'selected' : '' %>><%= estabelecimento.estabelecimento %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="data_sangria">Data da sangria</label>
                            <input type="date" class="form-control text-center" id="data_sangria" name="data_sangria" value="<%= sangria.data_sangria.toISOString().split('T')[0] %>" required>
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <label for="tipo_pagamento">Tipo de pagamento</label>
                            <select class="form-select" id="tipo_pagamento" name="tipo_pagamento" required>
                                <option value="especie" <%= sangria.tipo_pagamento === 'especie' ? 'selected' : '' %>>Espécie</option>
                                <option value="pix" <%= sangria.tipo_pagamento === 'pix' ? 'selected' : '' %>>PIX</option>
                            </select>
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Movimentação</span>
                            <h2>Venda, abastecimento e saldo</h2>
                            <p>Ao ajustar as quantidades, a quantidade deixada continua sendo recalculada automaticamente.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-xl-3">
                            <label for="valor_apurado">Valor apurado</label>
                            <div class="input-group">
                                <span class="input-group-text">R$</span>
                                <input type="number" step="0.01" class="form-control text-center" id="valor_apurado" name="valor_apurado" value="<%= sangria.valor_apurado %>" required>
                            </div>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label for="qtde_vendido">Vendido</label>
                            <input type="number" class="form-control text-center" id="qtde_vendido" name="qtde_vendido" value="<%= sangria.qtde_vendido %>" required>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label for="abastecido">Abastecido</label>
                            <input type="number" class="form-control text-center" id="abastecido" name="abastecido" value="<%= sangria.abastecido %>" required>
                        </div>
                        <div class="col-12 col-md-6 col-xl-3">
                            <label for="qtde_deixada">Quantidade deixada</label>
                            <input type="number" class="form-control text-center readonly-input" id="qtde_deixada" name="qtde_deixada" value="<%= sangria.qtde_deixada %>" readonly disabled>
                        </div>
                    </div>
                </section>

                <section class="form-card">
                    <div class="form-card-header">
                        <div>
                            <span class="form-section-tag">Observações</span>
                            <h2>Anotações sobre o ponto</h2>
                            <p>Atualize as observações para refletir o contexto real da visita ou da alteração feita neste registro.</p>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-12">
                            <label for="observacoes">Observações</label>
                            <textarea class="form-control" id="observacoes" name="observacoes" rows="5"><%= sangria.observacoes %></textarea>
                        </div>
                    </div>
                </section>

                <section class="form-actions-bar">
                    <div class="form-actions-copy">
                        <strong>Atualizar visita</strong>
                        <span>Revise as quantidades e confirme a atualização desta sangria de figurinhas.</span>
                    </div>

                    <div class="form-actions-buttons">
                        <a href="/figurinhas/sangrias" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Cancelar</span>
                        </a>
                        <button type="submit" class="btn-modern">
                            <i class="bi bi-check2-circle"></i>
                            <span>Atualizar sangria</span>
                        </button>
                    </div>
                </section>
            </form>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
    function calculateQuantidadeDeixada() {
        const qtdeVendido = parseFloat(document.getElementById('qtde_vendido').value) || 0;
        const abastecido = parseFloat(document.getElementById('abastecido').value) || 0;
        const qtdeDeixada = abastecido - qtdeVendido;
        document.getElementById('qtde_deixada').value = qtdeDeixada;
    }

    document.getElementById('abastecido').addEventListener('input', calculateQuantidadeDeixada);
    document.getElementById('qtde_vendido').addEventListener('input', calculateQuantidadeDeixada);
    </script>
</body>
</html>
