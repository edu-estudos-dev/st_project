<!DOCTYPE html>
    <html lang="pt-br">
    <%- include('../../partials/head', { title: 'Lista de Sangrias de Figurinhas' }) %>

    <body class="bg-light">
        <%- include('../../partials/header') %>

        <div style="padding-top: 2.9em;"></div>
        <div>&nbsp;</div>

        <!-- breadcrumb -->
        <%- include('../../partials/breadcrumb', { pageTitle: 'Lista de Sangrias de Figurinhas' }) %>

        <div class="container-fluid px-4">
            <!-- Contêiner de Mensagens de Sucesso/Falha -->
            <div id="alert-container"></div>

            <main class="figurinhas">
                <div class="table-container">
                    <div class="row">
                        <div class="col-6">
                            <h1 class="text-dark-blue mb-3 fw-bold">Registro Financeiro das Figurinhas</h1>
                        </div>
                        <div class="col-6 d-flex justify-content-end">
                            <a type="button" class="btn mb-3 btn-dark-blue align-self-center" href="/figurinhas/sangrias/add">
                                <i class="bi bi-plus-circle"></i>
                                &nbsp;Novo Registro
                            </a>
                        </div>
                    </div>

                    <table class="table table-striped table-hover mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Estabelecimento</th>
                                <th>Data da Sangria</th>
                                <th>Valor Apurado</th>
                                <th>Comissão</th>
                                <th>Valor do Comerciante</th>
                                <th>Valor Líquido</th>
                                <th>Tipo de Pagamento</th>
                                <th>Pix Confirmado</th>
                                <th>Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (sangrias.length > 0) { %>
                                <% sangrias.forEach(function(sangria) { %>
                                    <tr>
                                        <td class="py-1"><%= sangria.id %></td>
                                        <td class="py-1"><%= sangria.estabelecimento %></td>
                                        <td class="py-1"><%= new Date(sangria.data_sangria).toLocaleDateString('pt-BR') %></td>
                                        <td class="py-1">R$ <%= Number(sangria.valor_apurado).toFixed(2) %></td>
                                        <td class="py-1"><%= Number(sangria.comissao).toFixed(2) %> %</td>
                                        <td class="py-1">R$ <%= Number(sangria.valor_comerciante).toFixed(2) %></td>
                                        <td class="py-1">R$ <%= Number(sangria.valor_liquido).toFixed(2) %></td>
                                        <td class="py-1"><%= sangria.tipo_pagamento === 'pix' ? 'PIX' : 'Espécie' %></td>
                                        <td class="py-1">
                                            <select name="pix_confirmado" id="pix_confirmado_<%= sangria.id %>" class="form-select color-select" onchange="updateSelectColor(this)">
                                                <option value="" selected disabled>Selecione</option>
                                                <option value="SIM" class="option-sim">SIM</option>
                                                <option value="NÃO" class="option-nao">NÃO</option>
                                            </select>
                                        </td>
                                        <td class="py-1">
                                            <a href="/figurinhas/sangrias/view/<%= sangria.id %>" class="btn btn-secondary btn-sm">Visualizar</a>
                                            <a href="/figurinhas/sangrias/edit/<%= sangria.id %>" class="btn btn-warning btn-sm">Editar</a>
                                            <button type="button" class="btn btn-danger btn-sm delete-btn" data-id="<%= sangria.id %>">Deletar</button>
                                        </td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="9" class="text-center">Nenhuma sangria encontrada</td> 
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </main>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous">
        </script>

        <script>
            // Função para salvar o valor do select no localStorage
            function saveSelectValue(selectElement) {
                const selectId = selectElement.id;
                const selectedValue = selectElement.value;
                localStorage.setItem(selectId, selectedValue);
            }

            // Função para carregar o valor do select do localStorage
            function loadSelectValue(selectElement) {
                const selectId = selectElement.id;
                const savedValue = localStorage.getItem(selectId);
                if (savedValue) {
                    selectElement.value = savedValue;
                    updateSelectColor(selectElement);
                }
            }

            // Atualiza a cor do select com base no valor selecionado
            function updateSelectColor(selectElement) {
                // Remove classes anteriores
                selectElement.classList.remove('select-sim', 'select-nao');
                
                // Adiciona nova classe baseada no valor selecionado
                if (selectElement.value === 'SIM') {
                    selectElement.classList.add('select-sim');
                } else if (selectElement.value === 'NÃO') {
                    selectElement.classList.add('select-nao');
                }
            }

            // Inicializa os valores e cores corretas ao carregar a página
            document.querySelectorAll('.form-select.color-select').forEach(select => {
                loadSelectValue(select);
                select.addEventListener('change', () => {
                    updateSelectColor(select);
                    saveSelectValue(select);
                });
            });

            // Script para gerenciamento das ações de excluir
            document.addEventListener('DOMContentLoaded', function() {
                const deleteButtons = document.querySelectorAll('.delete-btn');

                deleteButtons.forEach(button => {
                    button.addEventListener('click', function() {
                        const idSangria = this.getAttribute('data-id');
                        if (confirm('Tem certeza que deseja EXCLUIR este registro de sangria?')) {
                            fetch(`/figurinhas/sangrias/delete/${idSangria}`, {
                                method: 'POST'
                            })
                            .then(response => response.json())
                            .then(data => {
                                console.log('Response data:', data);
                                const alertContainer = document.getElementById('alert-container');
                                if (data.success) {
                                    alertContainer.innerHTML = `
                                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                                            ${data.message}
                                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                        </div>
                                    `;
                                } else {
                                    alertContainer.innerHTML = `
                                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                            ${data.message}
                                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                        </div>
                                    `;
                                }
                                setTimeout(() => {
                                    alertContainer.innerHTML = ''; // Limpa a mensagem após 2 segundos
                                    window.history.replaceState({}, document.title, window.location.pathname);
                                    window.location.reload(); // Recarrega a página após 2 segundos
                                }, 2000);
                            })
                            .catch(error => {
                                console.error('Erro ao excluir sangria:', error);
                                const alertContainer = document.getElementById('alert-container');
                                alertContainer.innerHTML = `
                                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                        Erro ao excluir sangria
                                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                    </div>
                                `;
                                setTimeout(() => {
                                    alertContainer.innerHTML = ''; // Limpa a mensagem após 2 segundos
                                }, 2000);
                            });
                        }
                    });
                });

                // Função para lidar com mensagens de sucesso/erro ao carregar a página
                const urlParams = new URLSearchParams(window.location.search);
                const successMessage = urlParams.get('success');
                const errorMessage = urlParams.get('error');

                if (successMessage || errorMessage) {
                    const alertContainer = document.getElementById('alert-container');
                    if (successMessage) {
                        alertContainer.innerHTML = `
                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                ${successMessage}
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        `;
                    }
                    if (errorMessage) {
                        alertContainer.innerHTML = `
                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                ${errorMessage}
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        `;
                    }
                    setTimeout(() => {
                        alertContainer.innerHTML = ''; // Limpa a mensagem após 2 segundos
                    }, 2000);
                    window.history.replaceState({}, document.title, window.location.pathname);
                }
            });
        </script>
    </body>
</html>
