<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Visualizar Sangria Figurinhas' }) %>

<body class="bg-light">
    <%- include('../../partials/header') %>

    <div class="page-spacer"></div>

    <div class="page-shell py-3">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Visualizar Sangria Figurinhas' }) %>

        <div class="cabecalho-figurinhas">
            <h1 class="mb-0">Visualizar Sangria das Figurinhas</h1>
            <a href="/figurinhas/sangrias" class="btn btn-voltar">Voltar</a>
        </div>

        <main class="mb-4 figurinhas">
            <div class="card shadow detail-card">
                <div class="card-body">
                    <% if (sangria) { %>
                        <div class="detail-header">
                            <div class="detail-title">
                                <p class="mb-0">Estabelecimento:</p>
                                <h4 class="mb-0"><strong><%= sangria.estabelecimento %></strong></h4>
                            </div>
                            <p class="mb-0"><strong>ID:</strong> <%= sangria.id %></p>
                        </div>

                        <hr>

                        <div class="detail-grid detail-stack">
                            <div>
                                <p>Data da Sangria: <strong><%= new Date(sangria.data_sangria).toLocaleDateString('pt-BR') %></strong></p>
                                <p>Valor Apurado: <strong>R$ <%= Number(sangria.valor_apurado).toFixed(2) %></strong></p>
                                <p>Tipo de Pagamento: <strong><%= sangria.tipo_pagamento === 'pix' ? 'PIX' : 'Especie' %></strong></p>
                                <p>Ultima Edicao: <strong><%= sangria.data_atualizacao ? new Date(sangria.data_atualizacao).toLocaleDateString('pt-BR') : 'N/A' %></strong></p>
                            </div>
                            <div>
                                <p>Ultima Sangria Anterior: <strong><%= sangria.data_sangria_anterior ? new Date(sangria.data_sangria_anterior).toLocaleDateString('pt-BR') : 'N/A' %></strong></p>
                                <p>Quantidade Anterior: <strong><%= sangria.qtde_anterior ?? 'N/A' %></strong></p>
                                <p>Nova Quantidade Deixada: <strong><%= sangria.qtde_deixada ?? 'N/A' %></strong></p>
                                <p>Observacoes: <strong><%= sangria.observacoes || 'N/A' %></strong></p>
                            </div>
                        </div>
                    <% } else { %>
                        <p class="mb-0">Sangria nao encontrada.</p>
                    <% } %>
                </div>
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
</body>
</html>
