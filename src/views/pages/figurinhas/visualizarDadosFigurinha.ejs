<!DOCTYPE html>
<html lang="pt-br">
<%- include('../../partials/head', { title: 'Visualizar Sangria de Figurinhas' }) %>

<body class="view-page-body">
    <%- include('../../partials/header') %>
    <div class="page-spacer"></div>

    <div class="view-shell">
        <%- include('../../partials/breadcrumb', { pageTitle: 'Visualizar Sangria de Figurinhas' }) %>

        <section class="view-hero view-hero-blue">
            <div class="view-hero-content">
                <span class="form-kicker"><i class="bi bi-stickies"></i> Operacional</span>
                <h1><%= sangria ? sangria.estabelecimento : 'Sangria não encontrada' %></h1>
                <p>Veja o histórico da visita com foco em valor apurado, quantidade deixada e referência da última passagem pelo ponto.</p>
            </div>
            <div class="view-hero-side">
                <div class="list-stat">
                    <strong>ID</strong>
                    <span><%= sangria ? `#${sangria.id}` : 'N/A' %></span>
                </div>
                <div class="list-stat">
                    <strong>Produto</strong>
                    <span>Figurinhas</span>
                </div>
            </div>
        </section>

        <main class="view-stage">
            <section class="view-panel">
                <% if (sangria) { %>
                    <div class="view-panel-header">
                        <div>
                            <span class="form-section-tag">Visita</span>
                            <h2>Resumo da sangria</h2>
                            <p>As informações abaixo mostram a operação da visita atual e também o contexto da última visita registrada.</p>
                        </div>
                    </div>

                    <div class="view-grid">
                        <div class="view-card">
                            <strong>Data da sangria</strong>
                            <span><%= new Date(sangria.data_sangria).toLocaleDateString('pt-BR') %></span>
                        </div>
                        <div class="view-card">
                            <strong>Tipo de pagamento</strong>
                            <span><%= sangria.tipo_pagamento === 'pix' ? 'PIX' : 'Espécie' %></span>
                        </div>
                        <div class="view-card">
                            <strong>Valor apurado</strong>
                            <span><%= Number(sangria.valor_apurado).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' }) %></span>
                        </div>
                        <div class="view-card">
                            <strong>Última edição</strong>
                            <span><%= sangria.data_atualizacao ? new Date(sangria.data_atualizacao).toLocaleDateString('pt-BR') : 'Não informado' %></span>
                        </div>
                        <div class="view-card">
                            <strong>Última visita anterior</strong>
                            <span><%= sangria.data_sangria_anterior ? new Date(sangria.data_sangria_anterior).toLocaleDateString('pt-BR') : 'Não informado' %></span>
                        </div>
                        <div class="view-card">
                            <strong>Quantidade anterior</strong>
                            <span><%= sangria.qtde_anterior ?? 'Não informado' %></span>
                        </div>
                        <div class="view-card">
                            <strong>Nova quantidade deixada</strong>
                            <span><%= sangria.qtde_deixada ?? 'Não informado' %></span>
                        </div>
                        <div class="view-card">
                            <strong>Observações anteriores</strong>
                            <span><%= sangria.observacoes_anteriores || 'Sem observações anteriores.' %></span>
                        </div>
                        <div class="view-card is-wide">
                            <strong>Observações desta visita</strong>
                            <span><%= sangria.observacoes || 'Sem observações registradas.' %></span>
                        </div>
                    </div>
                <% } else { %>
                    <p class="mb-0">Sangria não encontrada.</p>
                <% } %>

                <div class="view-actions">
                    <div class="view-actions-copy">
                        <%= sangria
                            ? 'Use esta visualização para conferir o histórico do ponto antes de editar ou registrar a próxima visita.'
                            : 'Você pode voltar para a listagem geral de figurinhas e continuar a navegação normalmente.' %>
                    </div>
                    <div class="view-actions-buttons">
                        <a href="/figurinhas/sangrias" class="btn-modern-secondary">
                            <i class="bi bi-arrow-left"></i>
                            <span>Voltar</span>
                        </a>
                        <% if (sangria) { %>
                            <a href="/figurinhas/sangrias/edit/<%= sangria.id %>" class="btn-modern">
                                <i class="bi bi-pencil-square"></i>
                                <span>Editar registro</span>
                            </a>
                        <% } %>
                    </div>
                </div>
            </section>
        </main>
    </div>

    <script src="/vendor/bootstrap/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
</body>
</html>
