<!DOCTYPE html>
<html lang="pt-BR">
<%- include('../partials/head', { title }) %>

<body class="dashboard-body">
   <% const navProducts = navigationProducts || { bolinhas: false, figurinhas: false, pelucias: false, hasAny: false }; %>
   <% const adminShortcuts = [
      { href: '/estabelecimentos', title: 'Estabelecimentos', description: 'Consulte a base cadastrada e acompanhe os pontos ativos.', tone: 'blue' },
      { href: '/estabelecimentos/add', title: 'Novo estabelecimento', description: 'Cadastre uma nova máquina com todos os dados operacionais.', tone: 'gold' },
      { href: '/lancamentos', title: 'Lançamentos', description: 'Visualize entradas, saídas e movimentações registradas.', tone: 'slate' },
      { href: '/lancamentos/add', title: 'Novo lançamento', description: 'Registre uma movimentação financeira rapidamente.', tone: 'green' },
      { href: '/fluxo-de-caixa', title: 'Fluxo de caixa', description: 'Acompanhe o consolidado financeiro e o saldo do período.', tone: 'violet' },
      { href: '#', title: 'Financeiro consolidado', description: 'Espaço reservado para consolidar indicadores gerais do negócio.', tone: 'amber', disabled: true }
   ]; %>
   <% const revenueShortcuts = []; %>
   <% if (navProducts.bolinhas) revenueShortcuts.push({ href: '/bolinhas/receita-bolinha', title: 'Receita das bolinhas', badge: 'Bolinhas', tone: 'green' }); %>
   <% if (navProducts.figurinhas) revenueShortcuts.push({ href: '/figurinhas/receita-figurinha', title: 'Receita das figurinhas', badge: 'Figurinhas', tone: 'blue' }); %>
   <% if (navProducts.pelucias) revenueShortcuts.push({ href: '/pelucias/receita-pelucia', title: 'Receita das pelúcias', badge: 'Pelúcias', tone: 'violet' }); %>
   <% const operationGroups = []; %>
   <% if (navProducts.bolinhas) operationGroups.push({
      title: 'Bolinhas',
      subtitle: 'Operação diária, registros e visão consolidada.',
      accent: 'green',
      actions: [
         { href: '/bolinhas/sangrias/add', label: 'Novo formulário', meta: 'Registrar receita' },
         { href: '/bolinhas/sangrias', label: 'Registro financeiro', meta: 'Consultar lançamentos' },
         { href: '/bolinhas/sangrias/controle-geral', label: 'Controle geral', meta: 'Analisar desempenho' }
      ]
   }); %>
   <% if (navProducts.figurinhas) operationGroups.push({
      title: 'Figurinhas',
      subtitle: 'Acompanhe coletas, receitas e indicadores da operação.',
      accent: 'blue',
      actions: [
         { href: '/figurinhas/sangrias/add', label: 'Novo formulário', meta: 'Registrar receita' },
         { href: '/figurinhas/sangrias', label: 'Registro financeiro', meta: 'Consultar lançamentos' },
         { href: '/figurinhas/sangrias/controle-geral', label: 'Controle geral', meta: 'Analisar desempenho' }
      ]
   }); %>
   <% if (navProducts.pelucias) operationGroups.push({
      title: 'Pelúcias',
      subtitle: 'Gerencie a rotina operacional e o controle consolidado.',
      accent: 'violet',
      actions: [
         { href: '/pelucias/sangrias/add', label: 'Novo formulário', meta: 'Registrar receita' },
         { href: '/pelucias/sangrias', label: 'Registro financeiro', meta: 'Consultar lançamentos' },
         { href: '/pelucias/sangrias/controle-geral', label: 'Controle geral', meta: 'Analisar desempenho' }
      ]
   }); %>
   <% const overviewStats = [
      { value: adminShortcuts.length, label: 'atalhos administrativos' },
      { value: revenueShortcuts.length, label: 'consolidados de receita' },
      { value: operationGroups.length, label: 'frentes operacionais ativas' }
   ]; %>

   <main class="dashboard-shell">
      <section class="dashboard-hero">
         <div class="dashboard-hero-copy">
            <span class="dashboard-kicker">Painel central</span>
            <h1>Painel de Controle</h1>
            <p>Organize a operação, consulte os dados principais e avance rápido para as rotinas mais usadas do sistema.</p>

            <div class="dashboard-overview">
               <% overviewStats.forEach((item) => { %>
                  <div class="dashboard-overview-card">
                     <strong><%= item.value %></strong>
                     <span><%= item.label %></span>
                  </div>
               <% }) %>
            </div>
         </div>

         <div class="dashboard-user-card">
            <span class="dashboard-user-label">Usuário ativo</span>
            <strong><%= usuario.username %></strong>
            <small>Ambiente pronto para gestão administrativa e operacional.</small>
            <div class="dashboard-user-meta">
               <span>Visão centralizada</span>
               <span>Navegação rápida</span>
            </div>
         </div>
      </section>

      <section class="dashboard-grid">
         <article class="dashboard-panel dashboard-panel-primary">
            <div class="dashboard-panel-header">
               <div>
                  <span class="dashboard-section-tag">Administrativo</span>
                  <h2>Rotinas de gestão</h2>
               </div>
               <p>Atalhos para cadastros, lançamentos e visão financeira.</p>
            </div>

            <div class="dashboard-shortcuts">
               <% adminShortcuts.forEach((item) => { %>
                  <a href="<%= item.href %>" class="dashboard-shortcut dashboard-shortcut-<%= item.tone %><%= item.disabled ? ' is-disabled' : '' %>">
                     <div class="dashboard-shortcut-top">
                        <span class="dashboard-shortcut-pill"><%- item.disabled ? 'Em breve' : 'Acesso rápido' %></span>
                        <span class="dashboard-shortcut-arrow"><%- item.disabled ? '&bull;' : '&rarr;' %></span>
                     </div>
                     <h3><%- item.title %></h3>
                     <p><%- item.description %></p>
                  </a>
               <% }) %>
            </div>

            <% if (revenueShortcuts.length) { %>
               <div class="dashboard-revenue-strip">
                  <div class="dashboard-revenue-copy">
                     <span class="dashboard-section-tag">Receitas</span>
                     <h3>Consolidados por produto</h3>
                  </div>
                  <div class="dashboard-revenue-links">
                     <% revenueShortcuts.forEach((item) => { %>
                        <a href="<%= item.href %>" class="dashboard-mini-link dashboard-mini-link-<%= item.tone %>">
                           <span><%- item.badge %></span>
                           <strong><%- item.title %></strong>
                        </a>
                     <% }) %>
                  </div>
               </div>
            <% } %>
         </article>

         <aside class="dashboard-panel dashboard-panel-secondary">
            <div class="dashboard-panel-header">
               <div>
                  <span class="dashboard-section-tag">Operacional</span>
                  <h2>Fluxos do dia a dia</h2>
               </div>
               <p>Escolha o produto e siga para cadastro, histórico ou controle.</p>
            </div>

            <% if (operationGroups.length) { %>
               <div class="dashboard-operations">
                  <% operationGroups.forEach((group) => { %>
                     <section class="dashboard-operation-card dashboard-operation-card-<%= group.accent %>">
                        <div class="dashboard-operation-head">
                           <div>
                              <h3><%- group.title %></h3>
                              <p><%- group.subtitle %></p>
                           </div>
                        </div>

                        <div class="dashboard-operation-actions">
                           <% group.actions.forEach((action) => { %>
                              <a href="<%= action.href %>" class="dashboard-operation-link">
                                 <strong><%- action.label %></strong>
                                 <span><%- action.meta %></span>
                                 <em>Abrir</em>
                              </a>
                           <% }) %>
                        </div>
                     </section>
                  <% }) %>
               </div>
            <% } else { %>
               <div class="dashboard-empty-state">
                  <h3>Nenhum produto operacional disponível</h3>
                  <p>Assim que houver produtos habilitados, os atalhos operacionais aparecerão aqui.</p>
               </div>
            <% } %>
         </aside>
      </section>
   </main>

   <script>
      document.addEventListener('DOMContentLoaded', async () => {
         const totalAlertas = <%= financialNotifications?.total || 0 %>;
         const proximos = <%= financialNotifications?.proximos?.length || 0 %>;
         const atrasados = <%= financialNotifications?.atrasados?.length || 0 %>;

         if (!totalAlertas) return;

         const partes = [];
         if (proximos) partes.push(`${proximos} vencimento(s) nos próximos 5 dias`);
         if (atrasados) partes.push(`${atrasados} vencimento(s) atrasado(s)`);

         const confirmed = await window.AppAlerts?.confirm({
            title: 'Notificações financeiras',
            text: `Você tem ${partes.join(' e ')}.`,
            confirmButtonText: 'Ver alertas',
            cancelButtonText: 'Depois'
         });

         if (confirmed) {
            window.location.href = '/lancamentos/vencimentos';
         }
      });
   </script>
</body>

</html>
