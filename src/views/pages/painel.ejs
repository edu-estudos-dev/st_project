<!DOCTYPE html>
<html lang="pt-BR">
<%- include('../partials/head', { title }) %>

<body class="dashboard-body">
   <% const navProducts = navigationProducts || { bolinhas: false, consignados: false, figurinhas: false, pelucias: false, hasAny: false }; %>
   <% const isReadOnly = Boolean(typeof assinaturaSomenteLeitura !== 'undefined' && assinaturaSomenteLeitura); %>
   <% const financialData = financialNotifications || { proximos: [], atrasados: [], total: 0 }; %>
   <% const operationalData = operationalNotifications || { visitasAtrasadas: [], total: 0 }; %>
   <% const summary = dashboardSummary || { totalAtivos: 0, bolinhasAtivas: 0, consignadosAtivos: 0, figurinhasAtivas: 0, peluciasAtivas: 0 }; %>
   <% const consignadosAtivos = Number(summary.consignadosAtivos ?? summary.figurinhasAtivas ?? 0); %>
   <% const insights = dashboardInsights || {
      totals: { currentLabel: 'R$ 0,00', previousLabel: 'R$ 0,00', deltaLabel: '+R$ 0,00', deltaPercentLabel: 'Sem base anterior', averagePerVisitLabel: 'R$ 0,00', visits: 0, revenueDirection: 'neutral' },
      productBreakdown: [],
      topPoints: [],
      pointTrends: [],
      staleValue: { totalEstimatedLabel: 'R$ 0,00', items: [] },
      cashFlow: { saldoLabel: '+R$ 0,00', saldoTone: 'neutral', entradasLabel: 'R$ 0,00', saidasLabel: 'R$ 0,00', pendenteSaidasLabel: 'R$ 0,00', pendenteCount: 0, comprometimentoLabel: 'Sem base anterior' },
      recommendedAction: null
   }; %>
   <% const visitAlert = typeof dashboardVisitAlert !== 'undefined'
      ? dashboardVisitAlert
      : { tone: 'safe', title: 'Sem alertas', description: 'Nenhum ponto crítico encontrado.', items: [], actionHref: '/estabelecimentos', actionLabel: 'Ver estabelecimentos' }; %>
   <%
      const canAccessCommunityAdmin =
         typeof canModerateCommunity !== 'undefined' && Boolean(canModerateCommunity);

      const adminShortcutsBase = [
         { href: '/estabelecimentos', title: 'Estabelecimentos', description: 'Consulte a base cadastrada e acompanhe os pontos ativos.', tone: 'blue' },
         { href: '/estabelecimentos/add', title: 'Novo estabelecimento', description: 'Cadastre uma nova máquina com todos os dados operacionais.', tone: 'gold' },
         { href: '/rotas', title: 'Rotas dos pontos', description: 'Monte o trajeto por bairro e abra a navegação no Google Maps ou no Waze.', tone: 'amber' },
         { href: '/lancamentos', title: 'Lançamentos', description: 'Visualize entradas, saídas e movimentações registradas.', tone: 'slate' },
         { href: '/lancamentos/add', title: 'Novo lançamento', description: 'Registre uma movimentação financeira rapidamente.', tone: 'green' },
         { href: '/fluxo-de-caixa', title: 'Fluxo de caixa', description: 'Acompanhe o consolidado financeiro e o saldo do período.', tone: 'violet' }
      ];

      const communityAdminShortcuts = canAccessCommunityAdmin
         ? [
            {
               href: '/admin/comunidade',
               title: 'Moderação da Comunidade',
               description: 'Gerencie tópicos, respostas e destaques da Comunidade VendMaster.',
               tone: 'community'
            }
         ]
         : [];

      const adminShortcuts = [
         ...adminShortcutsBase,
         ...communityAdminShortcuts
      ];
   %>
   <% const operationalShortcuts = [
      { href: '/bolinhas/sangrias/add', title: 'Cadastro de bolinhas', description: 'Abrir o formulário operacional de bolinhas.', tone: 'green', productKey: 'bolinhas' },
      { href: '/consignados/sangrias/add', title: 'Cadastro de consignados', description: 'Abrir o formulário operacional de consignados.', tone: 'blue', productKey: 'consignados' },
      { href: '/pelucias/sangrias/add', title: 'Cadastro de pelúcias', description: 'Abrir o formulário operacional de pelúcias.', tone: 'violet', productKey: 'pelucias' }
   ]; %>
   <% const visibleOperationalShortcuts = operationalShortcuts.filter((item) => navProducts[item.productKey]); %>
   <% const visibleAdminShortcuts = adminShortcuts.filter((item) => !(isReadOnly && ['/estabelecimentos/add', '/lancamentos/add'].includes(item.href))); %>
   <% const mobilePrimaryShortcuts = [
      { href: '/estabelecimentos', title: 'Pontos', description: 'Base cadastrada', tone: 'blue', icon: 'bi-geo-alt' },
      { href: '/rotas', title: 'Rotas', description: 'Visitas por bairro', tone: 'amber', icon: 'bi-signpost-2' },
      { href: '/lancamentos', title: 'Financeiro', description: 'Entradas e saídas', tone: 'violet', icon: 'bi-cash-coin' },
      { href: '/relatorios', title: 'Relatórios', description: 'Indicadores da operação', tone: 'slate', icon: 'bi-graph-up-arrow' },
      { href: '/estabelecimentos/add', title: 'Novo ponto', description: 'Cadastrar máquina', tone: 'gold', icon: 'bi-plus-circle', writeOnly: true },
      { href: '/lancamentos/add', title: 'Lançar valor', description: 'Novo movimento', tone: 'green', icon: 'bi-receipt', writeOnly: true }
   ].filter((item) => !(isReadOnly && item.writeOnly)); %>
   <% const overviewStats = [
      { value: summary.totalAtivos, label: 'pontos ativos' },
      { value: summary.bolinhasAtivas, label: 'pontos com bolinhas' },
      { value: consignadosAtivos + summary.peluciasAtivas, label: 'outras frentes ativas' }
   ]; %>
   <% const financeTitle = financialData.atrasados.length
      ? `${financialData.atrasados.length} vencimento(s) atrasado(s)`
      : financialData.proximos.length
         ? `${financialData.proximos.length} vencimento(s) próximos`
         : 'Financeiro sem alerta urgente'; %>
   <% const financeDescription = financialData.atrasados.length
      ? `Há ${financialData.atrasados.length} item(ns) vencido(s) e ${financialData.proximos.length} a vencer nos próximos 5 dias.`
      : financialData.proximos.length
         ? `${financialData.proximos.length} vencimento(s) chegam nos próximos 5 dias.`
         : 'Nenhum vencimento urgente nos próximos 5 dias.'; %>
   <% const titlebarSummary = summary.totalAtivos
      ? `${summary.totalAtivos} ponto(s) ativo(s) agora, com receita, visitas e prioridades acompanhadas em tempo real.`
      : 'Sem pontos ativos cadastrados ainda. O primeiro cadastro libera a operação do sistema.'; %>
   <% const financeAlertTone = financialData.atrasados.length ? 'danger' : financialData.proximos.length ? 'warning' : 'safe'; %>
   <% const visitAlertHref = visitAlert.actionHref || '/rotas'; %>

   <main class="dashboard-shell">
      <div class="dashboard-layout">
         <aside class="dashboard-sidebar" aria-label="Navegação do painel">
            <div class="dashboard-sidebar-head">
               <a href="/painel" aria-label="VendMaster" class="brand-mark dashboard-sidebar-brand">
                  <span class="brand-mark-primary">Vend</span><span class="brand-mark-accent">Master</span>
               </a>
            </div>

            <div class="dashboard-sidebar-summary" aria-label="Resumo de pontos ativos">
               <% overviewStats.forEach((item) => { %>
                  <div class="dashboard-sidebar-stat">
                     <strong><%= item.value %></strong>
                     <span><%= item.label %></span>
                  </div>
               <% }) %>
            </div>

            <div class="dashboard-sidebar-section">
               <h2 class="dashboard-sidebar-title">Operação</h2>
               <nav class="dashboard-sidebar-nav" aria-label="Atalhos administrativos">
                  <% visibleAdminShortcuts.forEach((item) => { %>
                     <a href="<%= item.href %>" class="dashboard-sidebar-link dashboard-sidebar-link-<%= item.tone %>">
                        <span><%= item.title %></span>
                        <small>&rarr;</small>
                     </a>
                  <% }) %>
               </nav>
            </div>

            <% if (!isReadOnly && visibleOperationalShortcuts.length) { %>
               <div class="dashboard-sidebar-section">
                  <h2 class="dashboard-sidebar-title">Cadastros rápidos</h2>
                  <nav class="dashboard-sidebar-nav" aria-label="Cadastros operacionais">
                     <% visibleOperationalShortcuts.forEach((item) => { %>
                        <a href="<%= item.href %>" class="dashboard-sidebar-link dashboard-sidebar-link-<%= item.tone %>">
                           <span><%= item.title %></span>
                           <small>&rarr;</small>
                        </a>
                     <% }) %>
                  </nav>
               </div>
            <% } %>

            <div class="dashboard-sidebar-section">
               <h2 class="dashboard-sidebar-title">Atenção</h2>
               <div class="dashboard-sidebar-alerts">
                  <a href="/lancamentos/vencimentos" class="dashboard-sidebar-alert dashboard-sidebar-alert-<%= financeAlertTone %>">
                     <strong><%= financeTitle %></strong>
                     <p><%= financeDescription %></p>
                  </a>

                  <a href="<%= visitAlertHref %>" class="dashboard-sidebar-alert dashboard-sidebar-alert-<%= visitAlert.tone %>">
                     <strong><%= visitAlert.title %></strong>
                     <span><%= visitAlert.description %></span>
                  </a>
               </div>
            </div>

            <div class="dashboard-sidebar-footer">
               <form action="/logout" method="POST">
                  <button type="submit" class="dashboard-logout-btn">Sair</button>
               </form>
            </div>
         </aside>

         <div class="dashboard-main">
            <% if (isReadOnly) { %>
               <section class="dashboard-panel dashboard-panel-primary" aria-label="Aviso de assinatura vencida">
                  <div class="dashboard-panel-header">
                     <div>
                        <span class="dashboard-section-tag">Assinatura</span>
                        <h2>Assinatura vencida</h2>
                     </div>
                     <p>Por enquanto, o sistema permanece em modo de consulta até a regularização do pagamento.</p>
                  </div>

                  <div class="dashboard-shortcuts">
                     <a href="/assinatura/status" class="dashboard-shortcut dashboard-shortcut-amber">
                        <div class="dashboard-shortcut-top">
                           <span class="dashboard-shortcut-pill">Regularização</span>
                           <span class="dashboard-shortcut-arrow">&rarr;</span>
                        </div>
                        <h3>Regularizar assinatura</h3>
                        <p>Revise os dados de cobrança e prepare o pagamento para liberar novamente os cadastros e alterações.</p>
                     </a>

                     <a href="/assinatura/status" class="dashboard-shortcut dashboard-shortcut-violet">
                        <div class="dashboard-shortcut-top">
                           <span class="dashboard-shortcut-pill">Status</span>
                           <span class="dashboard-shortcut-arrow">&rarr;</span>
                        </div>
                        <h3>Ver status da assinatura</h3>
                        <p>Acompanhe o plano atual, dados de cobrança, vencimento e situação do pagamento.</p>
                     </a>
                  </div>
               </section>
            <% } %>

            <section class="dashboard-titlebar">
               <div class="dashboard-titlebar-copy dashboard-titlebar-copy--full">
                  <div class="dashboard-titlebar-main">
                     <div class="dashboard-titlebar-copy-block">
                        <span class="dashboard-kicker">Painel central</span>
                        <h1>Painel de Controle</h1>
                        <p><%= titlebarSummary %></p>
                     </div>

                     <div class="dashboard-overview">
                        <% overviewStats.forEach((item) => { %>
                           <div class="dashboard-overview-card">
                              <strong><%= item.value %></strong>
                              <span><%= item.label %></span>
                           </div>
                        <% }) %>
                     </div>
                  </div>
               </div>
            </section>

            <section class="dashboard-mobile-access" aria-labelledby="dashboard-mobile-access-title">
               <div class="dashboard-mobile-access-head">
                  <div>
                     <span class="dashboard-section-tag">Acessar sistema</span>
                     <h2 id="dashboard-mobile-access-title">O que você quer fazer agora?</h2>
                  </div>
                  <button
                     class="dashboard-mobile-menu-trigger"
                     type="button"
                     data-dashboard-menu-open
                     aria-controls="dashboard-mobile-menu"
                     aria-expanded="false">
                     <i class="bi bi-grid-3x3-gap" aria-hidden="true"></i>
                     <span>Menu</span>
                  </button>
               </div>

               <div class="dashboard-mobile-action-grid">
                  <% mobilePrimaryShortcuts.forEach((item) => { %>
                     <a href="<%= item.href %>" class="dashboard-mobile-action dashboard-mobile-action-<%= item.tone %>">
                        <i class="bi <%= item.icon %>" aria-hidden="true"></i>
                        <span>
                           <strong><%= item.title %></strong>
                           <small><%= item.description %></small>
                        </span>
                     </a>
                  <% }) %>
               </div>
            </section>

            <section class="dashboard-section-heading" aria-labelledby="dashboard-situacao-title">
               <div>
                  <span class="dashboard-section-tag">Situação agora</span>
                  <h2 id="dashboard-situacao-title">O que merece sua atenção</h2>
               </div>
               <p>Receita, caixa, compromissos e visitas críticas.</p>
            </section>

            <section class="dashboard-intelligence-grid">
               <article class="dashboard-revenue-hero dashboard-revenue-hero-<%= insights.totals.revenueDirection %>">
                  <div>
                     <span class="dashboard-section-tag">Consolidado operacional</span>
                     <h2><%= insights.totals.currentLabel %></h2>
                     <p>Receita do mês somando bolinhas, consignados e pelúcias.</p>
                  </div>
                  <div class="dashboard-revenue-hero-meta">
                     <strong><%= insights.totals.deltaPercentLabel %></strong>
                     <span><%= insights.totals.deltaLabel %> vs. mês anterior</span>
                  </div>
               </article>

               <article class="dashboard-kpi-card dashboard-kpi-card-<%= insights.cashFlow.saldoTone %>">
                  <span>Fluxo de caixa</span>
                  <strong><%= insights.cashFlow.saldoLabel %></strong>
                  <p>Entradas <%= insights.cashFlow.entradasLabel %> | saídas <%= insights.cashFlow.saidasLabel %>.</p>
               </article>

               <article class="dashboard-kpi-card dashboard-kpi-card-alert">
                  <span>Compromissos</span>
                  <strong><%= insights.cashFlow.pendenteSaidasLabel %></strong>
                  <p><%= insights.cashFlow.pendenteCount || 0 %> saída(s) pendente(s). Equivale a <%= insights.cashFlow.comprometimentoLabel %> das entradas.</p>
               </article>

               <article class="dashboard-kpi-card dashboard-kpi-card-<%= visitAlert.tone === 'danger' ? 'negative' : 'positive' %>">
                  <span>Visitas críticas</span>
                  <strong><%= operationalData.total || 0 %></strong>
                  <p><%= visitAlert.title %>. <%= visitAlert.description %></p>
               </article>
            </section>

            <section class="dashboard-titlebar-insights">
               <a href="/relatorios" class="dashboard-titlebar-card dashboard-titlebar-card-action">
                  <span class="dashboard-titlebar-card-tag">Média por visita</span>
                  <strong><%= insights.totals.averagePerVisitLabel %></strong>
                  <p><%= insights.totals.visits || 0 %> visita(s) com receita no mês.</p>
                  <em>Ver relatórios</em>
               </a>

               <a href="/rotas" class="dashboard-titlebar-card dashboard-titlebar-card-action">
                  <span class="dashboard-titlebar-card-tag">Ação recomendada</span>
                  <strong><%= insights.recommendedAction ? insights.recommendedAction.title : 'Operação sem ação crítica' %></strong>
                  <p><%= insights.recommendedAction ? insights.recommendedAction.description : 'Nenhum ponto com urgência forte foi identificado neste momento.' %></p>
                  <em>Abrir rotas</em>
               </a>
            </section>

            <section class="dashboard-section-heading" aria-labelledby="dashboard-operacao-title">
               <div>
                  <span class="dashboard-section-tag">Operação</span>
                  <h2 id="dashboard-operacao-title">Produtos e visitas</h2>
               </div>
               <p>Mostra de onde vem a receita e onde pode existir valor parado.</p>
            </section>

            <section class="dashboard-insight-layout">
               <article class="dashboard-panel dashboard-panel-primary">
                  <div class="dashboard-panel-header">
                     <div>
                        <span class="dashboard-section-tag">Receita por produto</span>
                        <h2>Onde o mês está acontecendo</h2>
                     </div>
                     <p>Participação de cada frente na receita consolidada.</p>
                  </div>

                  <% if (insights.productBreakdown.length) { %>
                     <div class="dashboard-product-bars">
                        <% insights.productBreakdown.forEach((item) => { %>
                           <div class="dashboard-product-row">
                              <div class="dashboard-product-row-head">
                                 <strong><%= item.produto %></strong>
                                 <span><%= item.totalLabel %></span>
                              </div>
                              <div class="dashboard-product-track">
                                 <span style="width: <%= Math.max(6, Math.min(100, Math.round(item.percent || 0))) %>%"></span>
                              </div>
                              <small><%= item.percentLabel %> do mês | média de <%= item.averageLabel %> por visita</small>
                           </div>
                        <% }) %>
                     </div>
                  <% } else { %>
                     <div class="dashboard-empty-state-light">
                        <h3>Sem receita no mês atual</h3>
                        <p>Quando as primeiras sangrias forem registradas, os produtos aparecem aqui.</p>
                     </div>
                  <% } %>
               </article>

               <article class="dashboard-panel dashboard-panel-primary">
                  <div class="dashboard-panel-header">
                     <div>
                        <span class="dashboard-section-tag">Valor parado</span>
                        <h2>Pontos com visita atrasada</h2>
                     </div>
                     <p>Estimativa baseada no histórico de arrecadação e dias sem visita.</p>
                  </div>

                  <% if (insights.staleValue.items.length) { %>
                     <div class="dashboard-stale-list">
                        <% insights.staleValue.items.forEach((item) => { %>
                           <a href="/estabelecimentos/<%= item.estabelecimentoId %>/view" class="dashboard-stale-item">
                              <div>
                                 <strong><%= item.estabelecimento %></strong>
                                 <small><%= item.produto %> | última visita: <%= item.lastMovementLabel %></small>
                              </div>
                              <span><%= item.daysWithoutVisit %> dia(s)</span>
                              <em><%= item.estimatedValueLabel %></em>
                           </a>
                        <% }) %>
                     </div>
                  <% } else { %>
                     <div class="dashboard-empty-state-light">
                        <h3>Sem valor parado relevante</h3>
                        <p>Não há pontos com atraso de visita suficiente para estimativa agora.</p>
                     </div>
                  <% } %>
               </article>
            </section>

            <section class="dashboard-section-heading" aria-labelledby="dashboard-desempenho-title">
               <div>
                  <span class="dashboard-section-tag">Desempenho</span>
                  <h2 id="dashboard-desempenho-title">Melhores pontos e variações</h2>
               </div>
               <p>Indicadores para entender crescimento, queda e concentração de receita.</p>
            </section>

            <section class="dashboard-insight-layout">
               <article class="dashboard-panel dashboard-panel-primary">
                  <div class="dashboard-panel-header">
                     <div>
                        <span class="dashboard-section-tag">Top pontos</span>
                        <h2>Melhores do mês</h2>
                     </div>
                     <p>Os pontos que mais contribuíram para o resultado atual.</p>
                  </div>

                  <% if (insights.topPoints.length) { %>
                     <div class="dashboard-ranking-list">
                        <% insights.topPoints.forEach((item) => { %>
                           <a href="/estabelecimentos/<%= item.estabelecimentoId %>/view" class="dashboard-ranking-item">
                              <span>#<%= item.position %></span>
                              <div>
                                 <strong><%= item.estabelecimento %></strong>
                                 <small><%= item.visits %> visita(s) | média <%= item.averageLabel %></small>
                              </div>
                              <em><%= item.totalLabel %></em>
                           </a>
                        <% }) %>
                     </div>
                  <% } else { %>
                     <div class="dashboard-empty-state-light">
                        <h3>Nenhum ranking ainda</h3>
                        <p>O ranking aparece assim que houver receita registrada neste mês.</p>
                     </div>
                  <% } %>
               </article>

               <article class="dashboard-panel dashboard-panel-primary">
                  <div class="dashboard-panel-header">
                     <div>
                        <span class="dashboard-section-tag">Alta e queda</span>
                        <h2>Variação por ponto</h2>
                     </div>
                     <p>Comparativo do mês atual contra o mês anterior.</p>
                  </div>

                  <% if (insights.pointTrends.length) { %>
                     <div class="dashboard-trend-list">
                        <% insights.pointTrends.forEach((item) => { %>
                           <a href="/estabelecimentos/<%= item.estabelecimentoId %>/view" class="dashboard-trend-item dashboard-trend-item-<%= item.tone %>">
                              <div>
                                 <strong><%= item.estabelecimento %></strong>
                                 <small>Atual <%= item.currentLabel %> | anterior <%= item.previousLabel %></small>
                              </div>
                              <span><%= item.deltaPercentLabel %></span>
                              <em><%= item.deltaLabel %></em>
                           </a>
                        <% }) %>
                     </div>
                  <% } else { %>
                     <div class="dashboard-empty-state-light">
                        <h3>Sem comparação suficiente</h3>
                        <p>Quando houver dados no mês atual e anterior, as variações aparecem aqui.</p>
                     </div>
                  <% } %>
               </article>
            </section>

            <section class="dashboard-grid">
               <aside class="dashboard-panel dashboard-panel-primary">
                  <div class="dashboard-panel-header">
                     <div>
                        <span class="dashboard-section-tag">Atenção</span>
                        <h2>Visitas críticas</h2>
                     </div>
                     <p>Um resumo direto para não deixar ponto parado por muito tempo.</p>
                  </div>

                  <div class="dashboard-visit-alert dashboard-visit-alert-<%= visitAlert.tone %>">
                     <span class="dashboard-visit-alert-tag">Mais de 30 dias sem visita</span>
                     <strong><%= visitAlert.title %></strong>
                     <p><%= visitAlert.description %></p>

                     <% if (visitAlert.items.length) { %>
                        <div class="dashboard-visit-alert-list">
                           <% visitAlert.items.forEach((item) => { %>
                              <div class="dashboard-visit-alert-item">
                                 <strong><%= item.estabelecimento %> <span>(<%= item.produto %>)</span></strong>
                                 <small><%= item.lastSeenLabel %> | <%= item.daysLabel %></small>
                              </div>
                           <% }) %>
                        </div>
                     <% } %>
                  </div>
               </aside>

               <article class="dashboard-panel dashboard-panel-primary">
                  <div class="dashboard-panel-header">
                     <div>
                        <span class="dashboard-section-tag">Atalhos</span>
                        <h2>Mais usados</h2>
                     </div>
                     <p>Acesse rapidamente as rotas, o financeiro e os cadastros da operação.</p>
                  </div>

                  <div class="dashboard-shortcuts">
                     <a href="/rotas" class="dashboard-shortcut dashboard-shortcut-amber">
                        <div class="dashboard-shortcut-top">
                           <span class="dashboard-shortcut-pill">Operação</span>
                           <span class="dashboard-shortcut-arrow">&rarr;</span>
                        </div>
                        <h3>Rotas dos pontos</h3>
                        <p>Monte o trajeto por bairro e abra a navegação no Google Maps ou no Waze.</p>
                     </a>

                     <a href="/lancamentos" class="dashboard-shortcut dashboard-shortcut-violet">
                        <div class="dashboard-shortcut-top">
                           <span class="dashboard-shortcut-pill">Financeiro</span>
                           <span class="dashboard-shortcut-arrow">&rarr;</span>
                        </div>
                        <h3>Fluxo financeiro</h3>
                        <p>Acompanhe lançamentos, entradas, saídas e saldo do período.</p>
                     </a>
                  </div>
               </article>
            </section>
         </div>
      </div>
   </main>

   <nav class="dashboard-mobile-bottom-nav" aria-label="Navegação rápida do painel">
      <a href="/painel" class="is-active">
         <i class="bi bi-house-door" aria-hidden="true"></i>
         <span>Painel</span>
      </a>
      <a href="/estabelecimentos">
         <i class="bi bi-geo-alt" aria-hidden="true"></i>
         <span>Pontos</span>
      </a>
      <a href="/rotas">
         <i class="bi bi-signpost-2" aria-hidden="true"></i>
         <span>Rotas</span>
      </a>
      <a href="/lancamentos">
         <i class="bi bi-cash-coin" aria-hidden="true"></i>
         <span>Caixa</span>
      </a>
      <button
         type="button"
         data-dashboard-menu-open
         aria-controls="dashboard-mobile-menu"
         aria-expanded="false">
         <i class="bi bi-grid-3x3-gap" aria-hidden="true"></i>
         <span>Menu</span>
      </button>
   </nav>

   <div class="dashboard-mobile-menu-overlay" data-dashboard-menu-overlay hidden></div>
   <aside
      class="dashboard-mobile-menu"
      id="dashboard-mobile-menu"
      aria-label="Menu completo do painel"
      aria-hidden="true"
      data-dashboard-mobile-menu>
      <div class="dashboard-mobile-menu-head">
         <div>
            <span class="dashboard-section-tag">Menu</span>
            <h2 class="dashboard-mobile-menu-brand">
               <span>Vend</span><strong>Master</strong>
            </h2>
         </div>
         <button type="button" data-dashboard-menu-close aria-label="Fechar menu">
            <i class="bi bi-x-lg" aria-hidden="true"></i>
         </button>
      </div>

      <div class="dashboard-mobile-menu-body">
         <section>
            <h3>Operação</h3>
            <% visibleAdminShortcuts.forEach((item) => { %>
               <a href="<%= item.href %>">
                  <span><%= item.title %></span>
                  <i class="bi bi-chevron-right" aria-hidden="true"></i>
               </a>
            <% }) %>
         </section>

         <% if (!isReadOnly && visibleOperationalShortcuts.length) { %>
            <section>
               <h3>Cadastros rápidos</h3>
               <% visibleOperationalShortcuts.forEach((item) => { %>
                  <a href="<%= item.href %>">
                     <span><%= item.title %></span>
                     <i class="bi bi-chevron-right" aria-hidden="true"></i>
                  </a>
               <% }) %>
            </section>
         <% } %>

         <section>
            <h3>Acompanhar</h3>
            <a href="/relatorios">
               <span>Relatórios</span>
               <i class="bi bi-chevron-right" aria-hidden="true"></i>
            </a>
            <a href="/lancamentos/vencimentos">
               <span>Alertas financeiros</span>
               <i class="bi bi-chevron-right" aria-hidden="true"></i>
            </a>
            <a href="<%= visitAlertHref %>">
               <span>Visitas críticas</span>
               <i class="bi bi-chevron-right" aria-hidden="true"></i>
            </a>
            <a href="/assinatura/produtos">
               <span>Ferramentas da assinatura</span>
               <i class="bi bi-chevron-right" aria-hidden="true"></i>
            </a>
         </section>

         <form action="/logout" method="POST">
            <button type="submit" class="dashboard-mobile-menu-logout">
               <i class="bi bi-box-arrow-right" aria-hidden="true"></i>
               <span>Sair</span>
            </button>
         </form>
      </div>
   </aside>

   <script>
      document.addEventListener('DOMContentLoaded', async () => {
         const mobileMenu = document.querySelector('[data-dashboard-mobile-menu]');
         const mobileMenuOverlay = document.querySelector('[data-dashboard-menu-overlay]');
         const mobileMenuOpenButtons = document.querySelectorAll('[data-dashboard-menu-open]');
         const mobileMenuCloseButton = document.querySelector('[data-dashboard-menu-close]');

         const setMobileMenuState = (isOpen) => {
            if (!mobileMenu || !mobileMenuOverlay) return;

            document.body.classList.toggle('dashboard-mobile-menu-open', isOpen);
            mobileMenu.classList.toggle('is-open', isOpen);
            mobileMenu.setAttribute('aria-hidden', String(!isOpen));
            mobileMenuOverlay.hidden = !isOpen;
            mobileMenuOpenButtons.forEach((button) => {
               button.setAttribute('aria-expanded', String(isOpen));
            });

            if (isOpen) {
               mobileMenuCloseButton?.focus();
            }
         };

         mobileMenuOpenButtons.forEach((button) => {
            button.addEventListener('click', () => setMobileMenuState(true));
         });
         mobileMenuCloseButton?.addEventListener('click', () => setMobileMenuState(false));
         mobileMenuOverlay?.addEventListener('click', () => setMobileMenuState(false));
         document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') setMobileMenuState(false);
         });

         const sleep = ms => new Promise(resolve => window.setTimeout(resolve, ms));
         const waitForSwalToClose = async () => {
            if (typeof Swal === 'undefined') return;

            let guard = 0;
            while (Swal.isVisible() && guard < 40) {
               await new Promise(resolve => window.setTimeout(resolve, 150));
               guard += 1;
            }
         };

         const assinaturaSomenteLeitura = <%= isReadOnly ? 'true' : 'false' %>;
         const assinaturaAlertStorageKey = 'vendmaster-subscription-readonly-dashboard-shown';

         if (assinaturaSomenteLeitura && window.sessionStorage.getItem(assinaturaAlertStorageKey) !== 'true') {
            window.sessionStorage.setItem(assinaturaAlertStorageKey, 'true');

            if (new URLSearchParams(window.location.search).has('success')) {
               await sleep(2800);
            }

            await sleep(700);
            await waitForSwalToClose();

            const regularizarAssinatura = await window.AppAlerts?.confirm({
               title: 'Assinatura vencida',
               text: 'Sua assinatura está vencida. Por enquanto, o sistema permanece em modo de consulta até a regularização do pagamento.',
               confirmButtonText: 'Regularizar agora',
               cancelButtonText: 'Continuar em modo de consulta'
            });

            if (regularizarAssinatura) {
               window.location.href = '/assinatura/status';
               return;
            }
         }

         const totalAlertas = <%= financialData.total || 0 %>;
         const proximos = <%= financialData.proximos?.length || 0 %>;
         const atrasados = <%= financialData.atrasados?.length || 0 %>;
         const visitasAtrasadas = <%= operationalData.total || 0 %>;
         const totalGeral = totalAlertas + visitasAtrasadas;
         const dismissedKey = 'vendmaster-alerts-dismissed-date';
         const todayKey = new Date().toISOString().slice(0, 10);

         const painelAlertStorageKey = 'vendmaster-alerts-dashboard-shown';

         if (!totalGeral) return;
         if (window.localStorage.getItem(dismissedKey) === todayKey) return;
         if (window.sessionStorage.getItem(painelAlertStorageKey) === 'true') return;

         const partes = [];
         if (proximos) partes.push(`${proximos} vencimento(s) nos próximos 5 dias`);
         if (atrasados) partes.push(`${atrasados} vencimento(s) atrasado(s)`);
         if (visitasAtrasadas) partes.push(`${visitasAtrasadas} ponto(s) sem visita há mais de 30 dias`);

         window.sessionStorage.setItem(painelAlertStorageKey, 'true');
         if (new URLSearchParams(window.location.search).has('success')) {
            await sleep(2800);
         }
         await sleep(900);
         await waitForSwalToClose();

         const confirmed = await window.AppAlerts?.confirm({
            title: 'Alertas da operação',
            text: `Você tem ${partes.join(' e ')}.`,
            confirmButtonText: visitasAtrasadas && !totalAlertas ? 'Ver rotas' : 'Ver alertas',
            cancelButtonText: 'Depois'
         });

         if (confirmed) {
            window.location.href = visitasAtrasadas && !totalAlertas ? '/rotas' : '/lancamentos/vencimentos';
         } else {
            window.localStorage.setItem(dismissedKey, todayKey);
         }
      });
   </script>
</body>
</html>