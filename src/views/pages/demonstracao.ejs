<!DOCTYPE html>
<html lang="pt-BR">
<%- include('../partials/head', { title, metaDescription, canonicalUrl, breadcrumbJsonLd, faqJsonLd, extraStyles,
    skipGlobalStyles, preloadExtraStyles, disableBootstrap: true, disableBootstrapIcons: true }) %>

    <body class="demo-page">
        <%- include('../partials/blogPublicHeader') %>

            <main class="demo-main">
                <section class="demo-hero">
                    <div class="demo-container">
                        <span class="demo-kicker">Demonstração gratuita</span>

                        <h1>Veja como organizar sua operação sem depender de planilhas soltas</h1>

                        <p>
                            Conheça o VendMaster na prática e entenda como controlar rotas,
                            sangrias, estoque, acertos e financeiro em um sistema feito para
                            operadores de bolinhas, pelúcias e consignados.
                        </p>

                        <div class="demo-hero-actions">
                            <a href="#solicitar-demonstracao" class="demo-btn demo-btn-primary">
                                Solicitar demonstração gratuita
                            </a>

                            <a href="/precos" class="demo-btn demo-btn-secondary">
                                Ver planos e preços
                            </a>
                        </div>
                    </div>
                </section>

                <section id="como-funciona" class="demo-section">
                    <div class="demo-container">
                        <div class="demo-section-heading">
                            <span class="demo-kicker">Como funciona</span>

                            <h2>Uma demonstração focada na realidade da sua operação</h2>

                            <p>
                                A demonstração mostra como o VendMaster pode ajudar no dia a dia
                                de quem precisa acompanhar pontos, máquinas, produtos, visitas,
                                coletas e acertos com mais segurança.
                            </p>
                        </div>

                        <div class="demo-grid">
                            <article class="demo-card">
                                <div class="demo-card-header">
                                    <span>1º passo</span>
                                    <h3>Você conta como sua operação funciona</h3>
                                </div>

                                <p>
                                    Antes de mostrar o sistema, entendemos quais frentes você
                                    trabalha e quais controles mais dão trabalho hoje.
                                </p>

                                <ul>
                                    <li>Bolinhas, pelúcias, consignados ou operação mista</li>
                                    <li>Quantidade aproximada de pontos e máquinas</li>
                                    <li>Dificuldades com rotas, sangrias, estoque ou acertos</li>
                                </ul>
                            </article>

                            <article class="demo-card demo-card-featured">
                                <div class="demo-badge">Mais importante</div>

                                <div class="demo-card-header">
                                    <span>2º passo</span>
                                    <h3>Você vê o VendMaster funcionando na prática</h3>
                                </div>

                                <p>
                                    A demonstração mostra o fluxo real de uso: cadastro de pontos,
                                    controle de visitas, registros de campo, movimentações e visão
                                    geral da operação.
                                </p>

                                <ul>
                                    <li>Rotas e prioridades de visita</li>
                                    <li>Sangrias, reposições e acertos</li>
                                    <li>Histórico por ponto e acompanhamento financeiro</li>
                                </ul>
                            </article>

                            <article class="demo-card">
                                <div class="demo-card-header">
                                    <span>3º passo</span>
                                    <h3>Você entende qual plano faz sentido</h3>
                                </div>

                                <p>
                                    Depois da demonstração, fica mais fácil escolher se você precisa
                                    de uma, duas ou três ferramentas do VendMaster.
                                </p>

                                <ul>
                                    <li>Plano para uma ferramenta</li>
                                    <li>Plano para duas ferramentas</li>
                                    <li>Plano completo para operação mais ampla</li>
                                </ul>
                            </article>
                        </div>
                    </div>
                </section>

                <section class="demo-section demo-tools-section">
                    <div class="demo-container">
                        <div class="demo-section-heading">
                            <span class="demo-kicker">O que será mostrado</span>

                            <h2>Controle operacional para parar de depender da memória</h2>

                            <p>
                                A demonstração pode ser direcionada para os módulos mais importantes
                                da sua rotina, sem mostrar telas que não fazem sentido para o seu momento.
                            </p>
                        </div>

                        <div class="demo-tools-grid">
                            <article>
                                <span>Rotas</span>
                                <h3>Saiba quais pontos precisam de visita</h3>
                                <p>
                                    Veja como organizar visitas, acompanhar pontos pendentes,
                                    consultar histórico e reduzir a chance de esquecer locais importantes.
                                </p>
                            </article>

                            <article>
                                <span>Sangrias</span>
                                <h3>Registre coletas, valores e responsáveis</h3>
                                <p>
                                    Entenda como controlar sangrias, quantidades, valores, observações
                                    e informações importantes de cada ponto visitado.
                                </p>
                            </article>

                            <article>
                                <span>Gestão</span>
                                <h3>Acompanhe estoque, financeiro e movimentações</h3>
                                <p>
                                    Veja como centralizar lançamentos, produtos, reposições e dados
                                    que ajudam a tomar decisões com mais clareza.
                                </p>
                            </article>
                        </div>
                    </div>
                </section>

                <section class="demo-section">
                    <div class="demo-container">
                        <div class="demo-section-heading">
                            <span class="demo-kicker">Para quem é</span>

                            <h2>Feito para operadores que querem sair do improviso</h2>

                            <p>
                                O VendMaster é indicado para quem precisa controlar pontos, máquinas,
                                produtos e dinheiro sem depender apenas de caderno, planilha ou memória.
                            </p>
                        </div>

                        <div class="demo-tools-grid">
                            <article>
                                <span>Bolinhas</span>
                                <h3>Máquinas de bolinhas</h3>
                                <p>
                                    Controle pontos visitados, sangrias, abastecimentos, prioridades,
                                    chaves, máquinas e histórico de cada estabelecimento.
                                </p>
                            </article>

                            <article>
                                <span>Consignados</span>
                                <h3>Produtos consignados</h3>
                                <p>
                                    Registre entradas, saídas, comissões, reposições, pagamentos e
                                    acertos com parceiros comerciais.
                                </p>
                            </article>

                            <article>
                                <span>Pelúcias</span>
                                <h3>Máquinas de pelúcias</h3>
                                <p>
                                    Organize estoque, reposição de prêmios, desempenho dos pontos,
                                    movimentações e rotina de acompanhamento em campo.
                                </p>
                            </article>
                        </div>
                    </div>
                </section>

                <section class="demo-section">
                    <div class="demo-container">
                        <div class="demo-section-heading">
                            <span class="demo-kicker">Quando pedir uma demonstração</span>

                            <h2>
                                Vale a pena conhecer o
                                <span class="brand-vend">Vend</span><span class="brand-master">Master</span>
                                se você sente falta de controle
                            </h2>

                            <p>
                                A demonstração ajuda principalmente quem já percebeu que a operação
                                cresceu e que os controles antigos começaram a atrapalhar.
                            </p>
                        </div>

                        <div class="demo-tools-grid">
                            <article>
                                <span>Planilhas</span>
                                <h3>Você usa planilhas que vivem desatualizadas</h3>
                                <p>
                                    Se os dados ficam espalhados ou dependem de atualização manual,
                                    a demonstração mostra uma forma mais organizada de acompanhar tudo.
                                </p>
                            </article>

                            <article>
                                <span>Campo</span>
                                <h3>Você precisa consultar informações durante a rota</h3>
                                <p>
                                    O VendMaster funciona pelo navegador e ajuda a consultar pontos,
                                    registrar movimentações e acompanhar informações importantes em campo.
                                </p>
                            </article>

                            <article>
                                <span>Crescimento</span>
                                <h3>Sua operação está ficando difícil de controlar sozinho</h3>
                                <p>
                                    Quando aumentam os pontos, produtos e acertos, ter histórico e
                                    organização evita perda de informação e decisões no escuro.
                                </p>
                            </article>
                        </div>
                    </div>
                </section>

                <section class="demo-section demo-faq-section">
                    <div class="demo-container">
                        <div class="demo-section-heading">
                            <span class="demo-kicker">Dúvidas comuns</span>

                            <h2>Antes de solicitar a demonstração</h2>

                            <p>
                                Veja algumas respostas rápidas para entender melhor como funciona
                                a demonstração gratuita do VendMaster.
                            </p>
                        </div>

                        <div class="demo-faq-list">
                            <details>
                                <summary>A demonstração do VendMaster é gratuita?</summary>
                                <p>
                                    Sim. A demonstração é gratuita e serve para você entender como
                                    o sistema funciona antes de contratar qualquer plano.
                                </p>
                            </details>

                            <details>
                                <summary>Depois da demonstração sou obrigado a contratar?</summary>
                                <p>
                                    Não. A demonstração é apenas para você avaliar se o VendMaster
                                    faz sentido para sua operação e para o seu momento atual.
                                </p>
                            </details>

                            <details>
                                <summary>Quanto tempo dura a demonstração?</summary>
                                <p>
                                    A demonstração é objetiva e focada nos controles mais importantes
                                    para sua rotina. O tempo pode variar conforme as dúvidas e os módulos
                                    que você deseja conhecer.
                                </p>
                            </details>

                            <details>
                                <summary>Preciso instalar aplicativo?</summary>
                                <p>
                                    Não. O VendMaster funciona pelo navegador, com acesso por login e senha.
                                    Você pode usar no computador, tablet ou celular.
                                </p>
                            </details>

                            <details>
                                <summary>O VendMaster funciona no celular?</summary>
                                <p>
                                    Sim. O sistema foi pensado para ser usado também em campo, pelo navegador
                                    do celular, facilitando consultas e registros durante a rotina.
                                </p>
                            </details>

                            <details>
                                <summary>Posso ver apenas uma ferramenta específica?</summary>
                                <p>
                                    Sim. A demonstração pode focar somente em bolinhas, consignados,
                                    pelúcias ou na operação completa, de acordo com o que você precisa.
                                </p>
                            </details>

                            <details>
                                <summary>Preciso cadastrar todos os meus pontos antes de usar?</summary>
                                <p>
                                    Não. Você pode começar com poucos pontos, entender o funcionamento
                                    e ir organizando sua operação aos poucos.
                                </p>
                            </details>

                            <details>
                                <summary>A demonstração serve para quem ainda usa caderno ou planilha?</summary>
                                <p>
                                    Sim. A demonstração é especialmente útil para quem ainda controla a operação
                                    de forma manual e quer entender como organizar melhor as informações.
                                </p>
                            </details>
                        </div>
                    </div>
                </section>

                <section id="solicitar-demonstracao" class="demo-section demo-contact-section">
                    <div class="demo-container">
                        <div class="demo-section-heading">
                            <span class="demo-kicker">Solicitar demonstração</span>

                            <h2>Receba uma demonstração direcionada para sua operação</h2>

                            <p>
                                Preencha seus dados e informe quais frentes deseja controlar.
                                O contato será feito preferencialmente pelo WhatsApp informado.
                            </p>
                        </div>

                        <div class="demo-contact-layout">
                            <form id="demoContactForm" class="demo-contact-form" action="/enviar-contato" method="POST"
                                novalidate>
                                <input type="hidden" name="preferenciaContato" value="WhatsApp">

                                <div class="demo-form-field">
                                    <label for="demoNome">Nome</label>
                                    <input type="text" id="demoNome" name="nome" autocomplete="name" required>
                                </div>

                                <div class="demo-form-field">
                                    <label for="demoTelefone">WhatsApp</label>
                                    <input type="tel" id="demoTelefone" name="telefone" autocomplete="tel"
                                        data-phone-mask required>
                                </div>

                                <div class="demo-form-field demo-form-field-full">
                                    <label for="demoEmail">E-mail</label>
                                    <input type="email" id="demoEmail" name="email" autocomplete="email">
                                </div>

                                <fieldset class="demo-form-products">
                                    <legend>Frentes da operação</legend>

                                    <label>
                                        <input type="checkbox" name="produtos[]" value="Bolinhas">
                                        <span>Máquinas de bolinhas</span>
                                    </label>

                                    <label>
                                        <input type="checkbox" name="produtos[]" value="Pelucias">
                                        <span>Máquinas de pelúcias</span>
                                    </label>

                                    <label>
                                        <input type="checkbox" name="produtos[]" value="Consignados">
                                        <span>Consignados e comissão</span>
                                    </label>
                                </fieldset>

                                <p id="demoContactStatus" class="demo-form-status" aria-live="polite"></p>

                                <button type="submit" class="demo-btn demo-btn-primary demo-submit-btn">
                                    Solicitar demonstração gratuita
                                </button>
                            </form>

                            <aside class="demo-contact-aside">
                                <span>Atendimento comercial</span>
                                <h3>Prefere falar direto pelo WhatsApp?</h3>
                                <p>
                                    Você também pode chamar diretamente para tirar dúvidas sobre planos,
                                    módulos e funcionamento antes de solicitar a demonstração.
                                </p>
                                <a href="https://wa.me/5585999992706" target="_blank" rel="noopener"
                                    class="demo-btn demo-btn-secondary">
                                    Falar no WhatsApp
                                </a>
                            </aside>
                        </div>
                    </div>
                </section>

                <section class="demo-final-cta">
                    <div class="demo-container">
                        <h2>
                            Quer saber se o
                            <span class="brand-vend">Vend</span><span class="brand-master">Master</span>
                            faz sentido para sua operação?
                        </h2>

                        <p>
                            Solicite uma demonstração gratuita e veja como organizar sua rotina
                            de campo, seus acertos, seu estoque e seus controles em um único sistema.
                        </p>

                        <a href="#solicitar-demonstracao" class="demo-btn demo-btn-primary">
                            Solicitar demonstração gratuita
                        </a>
                    </div>
                </section>
            </main>

            <%- include('../partials/footer') %>

                <script nonce="<%= cspNonce || '' %>">
                    document.addEventListener('DOMContentLoaded', () => {
                        const form = document.getElementById('demoContactForm');
                        const statusElement = document.getElementById('demoContactStatus');
                        const submitButton = form?.querySelector('button[type="submit"]');

                        if (!form || !statusElement || !submitButton) return;

                        form.addEventListener('submit', async (event) => {
                            event.preventDefault();

                            const formData = new FormData(form);
                            const nome = String(formData.get('nome') || '').trim();
                            const telefone = String(formData.get('telefone') || '').trim();

                            if (!nome || !telefone) {
                                statusElement.textContent = 'Preencha nome e WhatsApp para solicitar a demonstração.';
                                window.AppAlerts?.warning('Preencha nome e WhatsApp para solicitar a demonstração.');
                                return;
                            }

                            submitButton.disabled = true;
                            statusElement.textContent = 'Enviando suas informações...';

                            try {
                                const response = await fetch(form.action, {
                                    method: 'POST',
                                    body: new URLSearchParams(formData),
                                    headers: {
                                        Accept: 'application/json'
                                    }
                                });

                                const result = await response.json().catch(() => ({}));

                                if (!response.ok) {
                                    throw new Error(result.message || 'Não foi possível enviar sua solicitação agora.');
                                }

                                form.reset();
                                statusElement.textContent = result.message || 'Solicitação recebida. Em breve entraremos em contato.';
                                window.AppAlerts?.success(statusElement.textContent);
                            } catch (error) {
                                statusElement.textContent = error.message || 'Erro ao enviar as informações.';
                                window.AppAlerts?.error(statusElement.textContent);
                            } finally {
                                submitButton.disabled = false;
                            }
                        });
                    });
                </script>
    </body>

</html>